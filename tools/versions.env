# Pinned build/dev environment for Kirito — the single source of truth for tool versions.
# Read by tools/scripts/check_env.sh (and CI). Format: NAME_MIN="x.y" for a minimum, plus the
# exact REFERENCE version the project is developed and CI-validated against.
#
# Kirito is header-only C++20 with NO third-party runtime dependencies (OpenSSL is optional, only
# for the TLS/crypto features). So "recreate the environment" means: provide this toolchain. There
# is nothing to `pip install` / `npm install` / vendor — the reproducibility surface is the compiler,
# CMake, Ninja, and (optionally) OpenSSL below.

# --- required ---
CXX_STANDARD="20"                 # C++ standard the code requires
GXX_MIN="13"                      # g++ — the primary compiler (debug/release presets)
GXX_REF="13.3.0"
CMAKE_MIN="3.28"                  # matches cmake_minimum_required() in CMakeLists.txt
CMAKE_REF="3.28.3"
NINJA_MIN="1.10"
NINJA_REF="1.11.1"

# --- required for the sanitizer presets + the (opt-in) libFuzzer target ---
CLANGXX_MIN="18"                  # clang++ — asan/tsan presets and -DKIRITO_ENABLE_LIBFUZZER
CLANGXX_REF="18.1.3"

# --- required only for the doc/test helper scripts ---
PYTHON3_MIN="3.8"
PYTHON3_REF="3.12.3"

# --- optional ---
OPENSSL_REF="3.0.13"              # only for -DKIRITO_ENABLE_TLS (net HTTPS, socket TLS, crypto module)
# mold / lld — a faster linker is auto-selected when present (-DKIRITO_FAST_LINKER=OFF to disable); optional.
