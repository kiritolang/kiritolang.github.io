# Regression golden for the v1.14 audit — the observable fixes, driven from Kirito.
# (The HIGH heap-corruption fix A08-1 is pinned in spec_reentrant_clear.ki + test_audit_hardening;
# the C++/embedding item A19-1 is a C++ test. Here we pin the language/stdlib-visible ones.)
var io = import("io")
var math = import("math")
var time = import("time")
var json = import("json")

var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True

# --- A09-1: format(x) with NO spec must match String(x) — Floats no longer go 'g'-lossy ---
assert format(2.0) == "2.0", "A09-1: format(2.0) is '2.0', not the lossy '2'"
assert format(1234567.0) == "1234567.0", "A09-1: 7-digit float round-trips, not '1.23457e+06'"
assert format(0.1) == "0.1", "A09-1: format(0.1) is exact '0.1'"
assert format(2.0) == String(2.0), "A09-1: no-spec format equals String() for a Float"
assert format(42) == "42", "A09-1: Integer format unchanged"
assert format(2.0, ".2f") == "2.00", "A09-1: a real spec still applies the mini-format-spec"
assert format(255, "x") == "ff", "A09-1: base spec unaffected"

# --- A06-1: a _str_ that returns a deep chain of DISTINCT instances throws, never crashes ---
class N:
    var _init_ = Function(self, nxt): self.nxt = nxt
    var _str_ = Function(self): return self.nxt
var build = Function(depth):
    var head = None
    var i = 0
    while i < depth:
        head = N(head)
        i = i + 1
    return head
var deep = build(5000)
assert throws(Function(): String(deep)), "A06-1: deep _str_-returns-instance chain must throw, not segfault"
# a shallow chain still stringifies fine (the guard doesn't over-reject)
class W:
    var _init_ = Function(self, v): self.v = v
    var _str_ = Function(self): return self.v
assert String(W(W("deep"))) == "deep", "A06-1: a shallow _str_-returns-instance chain still works"

# --- A16-1: time.sleep() rejects non-finite / absurd values (was float-cast UB / effective hang) ---
assert throws(Function(): time.sleep(math.nan)), "A16-1: sleep(nan) must throw"
assert throws(Function(): time.sleep(math.inf)), "A16-1: sleep(inf) must throw"
assert throws(Function(): time.sleep(1e18)), "A16-1: sleep(1e18) must throw (would hang)"
time.sleep(0.0)                                   # <= 0 is a clean no-op
time.sleep(-3.0)
assert True, "A16-1: sleep(<=0) is a no-op"

# --- A14-2: json.stringify rejects a too-large indent (was signed-overflow UB / raw OOM message) ---
assert throws(Function(): json.stringify([1, 2], indent = 99999999)), "A14-2: huge indent must throw"
assert json.stringify([1, 2], indent = 2) == "[\n  1,\n  2\n]", "A14-2: a sane indent still pretty-prints"
assert json.stringify([1, 2]) == "[1, 2]", "A14-2: compact default unaffected"

# --- A11-1: an embedded NUL in a filesystem path is rejected (was a silent truncation bypass) ---
var path = import("path")
assert throws(Function(): io.open("safe" + chr(0) + ".sh", "w")), "A11-1: io.open rejects a NUL path"
assert throws(Function(): path.exists("a" + chr(0) + "b")), "A11-1: path.exists rejects a NUL path"
assert path.join("a", "b", "c") == "a/b/c", "A11-1: pure join() is unaffected"

# --- A11-19: BytesIO.truncate() honours the 256 MiB cap (was a write-guard bypass after seek) ---
var big = io.BytesIO()
big.seek(400000000)
assert throws(Function(): big.truncate()), "A11-19: truncate past the cap must throw"
var sm = io.BytesIO()
sm.write("hello world")
sm.seek(5)
assert sm.truncate() == 5, "A11-19: a normal truncate still works"

# --- A04-1: `not instance` via _not_ must return a Bool (like _bool_) ---
class NotBad:
    var _not_ = Function(self): return "nope"
assert throws(Function(): return not NotBad()), "A04-1: _not_ returning non-Bool must throw"
class NotGood:
    var _init_ = Function(self, v): self.v = v
    var _not_ = Function(self): return self.v == 0
assert (not NotGood(0)) == True, "A04-1: _not_ returning True works"
assert (not NotGood(9)) == False, "A04-1: _not_ returning False works"

# --- A04-2: the cyclic-structure guard message says "comparison" for </sort/min/max, not "equality" ---
var makeCycle = Function():
    var c = [1]
    c.append(c)
    return c
assert throws(Function(): return makeCycle() < makeCycle()), "A04-2: ordering a cyclic list throws (bounded)"

# --- A13-1: tensor max/min propagate NaN (position-independent); argmax/argmin return first-NaN index ---
var tensor = import("tensor")
assert math.isnan(tensor.Tensor([math.nan, 1.0, 3.0]).max()), "A13-1: max with NaN as seed -> NaN"
assert math.isnan(tensor.Tensor([1.0, math.nan, 3.0]).max()), "A13-1: max with NaN in middle -> NaN (was 3.0)"
assert math.isnan(tensor.Tensor([1.0, 3.0, math.nan]).min()), "A13-1: min with trailing NaN -> NaN"
var noNan = tensor.Tensor([1.0, 5.0, 3.0])
assert noNan.max() == 5.0 and noNan.min() == 1.0, "A13-1: no-NaN max/min unchanged"
assert noNan.argmax() == 1 and noNan.argmin() == 0, "A13-1: no-NaN argmax/argmin unchanged"
assert tensor.Tensor([1.0, math.nan, 3.0]).argmax() == 1, "A13-1: argmax returns the first-NaN index"
assert tensor.Tensor([1.0, 3.0, math.nan]).argmax() == 2, "A13-1: argmax first-NaN index (trailing)"

# --- A13-2: complex.atan(±i) throws a domain error (poles), like atanh(±1) ---
var complex = import("complex")
assert throws(Function(): return complex.atan(complex.i)), "A13-2: atan(i) must throw"
assert complex.atan(complex.real(0.5)).re > 0.4, "A13-2: atan of an in-domain value still works"

# --- A13-3: Matrix._setstate_ rejects a negative dimension (was a garbage rows()==-1 from untrusted state) ---
var matrix = import("matrix")
assert throws(Function(): return matrix.zeros(1, 1)._setstate_([-1, 0, []])), "A13-3: negative dim rejected"

# --- A17-1: a pathological many-group regex over a long input throws a budget error, not a 20s hang ---
var regex = import("regex")
var buildPat = Function():
    var p = ""
    var i = 0
    while i < 500:
        p = p + "(a?)"
        i = i + 1
    return p + "b"
assert throws(Function(): return regex.search(buildPat(), "a" * 10000)), "A17-1: capture-DoS pattern throws (bounded)"
# a normal regex with a few groups is unaffected
assert regex.search(r"(\d+)-(\d+)", "x 12-34 y").group(2) == "34", "A17-1: an ordinary regex still matches"
assert regex.findall(r"\w+", "a bb ccc") == ["a", "bb", "ccc"], "A17-1: findall unaffected"

io.print("OK audit-v114")
