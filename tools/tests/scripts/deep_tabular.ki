# Deep adversarial audit of the `tabular` module (Series + DataFrame + GroupBy). This goes BEYOND
# spec_tabular / audit_tabular / probe_tabular_full: it pins the surprising, undocumented, and
# crash-prone corners discovered by trying to break the library — Series binop length asymmetry,
# astype's silent String fallback, head/tail with negative/zero n, NaN in unique(), the
# duplicate-column data-loss + crash paths, missing-data arithmetic throwing (not propagating),
# resetindex dropping the old index, and which reductions exist at the frame level vs only on Series.
# Deterministic: floats compared with a tolerance helper, ties asserted as sets, no timing/randomness.
var io = import("io")
var pd = import("tabular")
var math = import("math")

var NAN = math.nan

var close = Function(a, b) -> Bool:
    return abs(a - b) < 0.0000001

var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch as e:
        return True

# A multiset-equality helper so tie-order-dependent results (valuecounts) can be checked
# deterministically without depending on Dict iteration order.
var bag = Function(xs):
    var d = {}
    for x in xs:
        d[x] = d.get(x, 0) + 1
    return d

# =================================================================== Series binop LENGTH ASYMMETRY
# A Series op now CONSISTENTLY throws on a length mismatch (no more silent asymmetric truncation):
# both `short OP long` and `long OP short` throw a clear "length mismatch" error, in both directions.
var shortS = pd.Series([1, 2])
var longS = pd.Series([10, 20, 30, 40])
assert throws(Function(): return shortS + longS), "short+long throws a length-mismatch error (no silent truncation)"
assert throws(Function(): return longS + shortS), "long+short throws a length-mismatch error too (now symmetric)"
# the multiply/divide/comparison paths share _binop, so they throw the same way
assert throws(Function(): return shortS * longS), "short*long throws (shared _binop)"
assert throws(Function(): return shortS > longS), "comparison throws the same way"
# equal-length Series-Series arithmetic still works
assert (pd.Series([1, 2]) + pd.Series([10, 20])).tolist() == [11, 22], "equal-length Series + Series aligns"

# =================================================================== Series MISSING-DATA arithmetic
# Aggregations skip missing, but element-wise arithmetic / comparison / sort do NOT propagate NaN
# like pandas — they THROW on a None operand (a None can't take a binary operator / be ordered).
assert throws(Function(): return pd.Series([1, None, 3]) + 1), "Series + scalar throws on a None element"
assert throws(Function(): return pd.Series([1, None, 3]) > 0), "Series comparison throws on a None element"
assert throws(Function(): return pd.Series([3, None, 1]).sortvalues()), "Series.sortvalues throws with None (cannot order None)"
# but the aggregations DO quietly skip the same None
var smix = pd.Series([1, None, 3])
assert smix.sum() == 4 and smix.count() == 2, "aggregations still skip the None"

# =================================================================== unique() vs Float NaN
# NaN != NaN, so `v not in seen` is always True for a NaN: every NaN is kept as a distinct "unique"
# value (pandas collapses NaN to one). valuecounts(), by contrast, drops NaN entirely.
var snan = pd.Series([1.0, NAN, 1.0, NAN])
assert snan.nunique() == 3, "unique() keeps EACH NaN (1.0 + NaN + NaN) since NaN != NaN"
assert snan.valuecounts().tolist() == [2], "valuecounts drops NaN (only 1.0 counted, x2)"

# =================================================================== astype: silent String fallback
# Only Integer/Float/Bool/String are documented; an unknown type name is silently treated as String
# (no error). astype("Integer") on Floats truncates toward zero (delegates to Integer()).
var castUnknown = pd.Series([1, 2, 3]).astype("Banana")
assert type(castUnknown.tolist()[0]) == "String", "astype(unknown) silently falls back to String (undocumented)"
assert pd.Series([1.7, 2.9, -1.7]).astype("Integer").tolist() == [1, 2, -1], "astype Integer truncates floats"
assert pd.Series([0, 1, 0]).astype("Bool").tolist() == [False, True, False], "astype Bool from Integer"

# =================================================================== head/tail with negative / zero n
# n is fed straight into a slice, so a NEGATIVE n is a from-the-end slice, not clamped.
var hs = pd.Series([1, 2, 3, 4, 5])
assert hs.head(-1).tolist() == [1, 2, 3, 4], "Series.head(-1) drops the LAST element (slice semantics, not clamp)"
assert hs.head(0).tolist() == [], "Series.head(0) is empty"
assert hs.tail(0).tolist() == [], "Series.tail(0) is empty"
assert hs.tail(-1).tolist() == [], "Series.tail(-1): start=len-(-1)=6, slice [6:] is empty (NOT clamped)"

# =================================================================== DUPLICATE COLUMNS: corruption + 2 crash paths
# (1) Direct construction with a duplicate column name does NOT throw: the backing Dict collapses the
#     two names to one key, so the FIRST column's data is lost and df["a"] returns the SECOND.
var dupc = pd.DataFrame([[1, 2], [3, 4]], columns=["a", "a"])
assert dupc.columns == ["a", "a"], "duplicate column names are accepted verbatim in .columns"
assert dupc["a"].tolist() == [2, 4], "BUG: duplicate column collapses in the backing Dict -> first column LOST"
assert dupc.nrows() == 2, "nrows still reports 2 (reads the first column slot)"
# (2) readcsv with a duplicated header column CRASHES (caught here): the column is appended to twice
#     per row, so the backing list is too long for the column count -> length-mismatch throw.
assert throws(Function(): return pd.readcsv("a,a,b\n1,2,3")), "readcsv with a duplicate header column throws (length mismatch)"
# (3) merge with a colliding NON-key column suffixes them _x / _y (pandas-style).
var mL = pd.DataFrame({"id": [1, 2], "v": [10, 20]}, columns=["id", "v"])
var mR = pd.DataFrame({"id": [1, 2], "v": [100, 200]}, columns=["id", "v"])
var mg = pd.merge(mL, mR, on="id")
assert "v_x" in mg.columns and "v_y" in mg.columns, "merge suffixes a colliding non-key column"

# =================================================================== setindex / resetindex round-trip LOSES the index
# Unlike pandas, resetindex() does NOT push the current index back into a column — the labels are
# simply replaced by 0..n and the old setindex column is gone for good.
var withidx = pd.DataFrame({"k": ["a", "b"], "v": [1, 2]}, columns=["k", "v"]).setindex("k")
assert withidx.index == ["a", "b"] and withidx.columns == ["v"], "setindex moves k into the index, drops the column"
var resetted = withidx.resetindex()
assert resetted.index == [0, 1], "resetindex relabels 0..n"
assert resetted.columns == ["v"], "resetindex does NOT restore 'k' as a column (the old index is dropped)"

# =================================================================== which reductions exist at the FRAME level
# Frame-level numeric reductions are exactly sum/mean/min/max/std/count (+ describe). median / variance
# / prod are Series-only and DO NOT exist on a DataFrame (pin this so a future change is noticed).
var fr = pd.DataFrame({"a": [1, 2, 3], "b": [4, 5, 6]}, columns=["a", "b"])
assert fr.sum().tolist() == [6, 15] and fr.count().tolist() == [3, 3], "frame sum/count exist"
assert throws(Function(): return fr.median()), "DataFrame.median() does NOT exist (Series-only)"
assert throws(Function(): return fr.variance()), "DataFrame.variance() does NOT exist (Series-only)"
assert throws(Function(): return fr.prod()), "DataFrame.prod() does NOT exist (Series-only)"
# DataFrame has NO element-wise arithmetic operators (only Series does) despite the prose 'element-wise'
assert throws(Function(): return fr + 1), "DataFrame + scalar throws (no frame-level _add_)"
assert throws(Function(): return fr + fr), "DataFrame + DataFrame throws (no frame-level _add_)"

# =================================================================== frame/group reductions: numeric filtering inconsistency
# sum/mean/min/max/std and apply only touch fully-numeric columns; count touches EVERY column. So the
# value-column set differs across reducers — pin both.
var mixed = pd.DataFrame({"n": [1, 2, 3], "s": ["x", "y", "z"]}, columns=["n", "s"])
assert mixed.sum().index == ["n"], "frame sum skips the non-numeric column"
assert mixed.count().index == ["n", "s"], "frame count includes the non-numeric column (inconsistent with sum)"
assert mixed.apply(Function(c): return c.sum()).index == ["n"], "frame apply == _aggcols: numeric only"
# Bool participates as 0/1 in a frame reduction
var bfr = pd.DataFrame({"flag": [True, False, True]}, columns=["flag"])
assert bfr.sum().tolist() == [2], "frame sum treats Bool as 0/1"
assert close(bfr.mean().tolist()[0], 2.0 / 3.0), "frame mean treats Bool as 0/1"

# GroupBy: sum/mean/min/max/std drop non-numeric value columns; count keeps them; size ignores columns.
var gmix = pd.DataFrame({"k": ["a", "a", "b"], "n": [1, 2, 3], "s": ["p", "q", "r"]}, columns=["k", "n", "s"])
assert gmix.groupby("k").sum().columns == ["n"], "group sum keeps only numeric value columns"
assert bag(gmix.groupby("k").count().columns) == bag(["n", "s"]), "group count keeps ALL value columns (incl. non-numeric)"
assert gmix.groupby("k").size().tolist() == [2, 1], "group size counts rows per group regardless of columns"
# a group of size 1 yields std == None inside the result frame (variance needs >= 2)
var gstd = pd.DataFrame({"k": ["a", "b", "b"], "v": [5, 10, 20]}, columns=["k", "v"]).groupby("k").std()
assert gstd["v"].tolist()[0] == None, "group std is None for a singleton group"
assert close(gstd["v"].tolist()[1], 7.0710678118654755), "group std is computed for a >=2 group"

# =================================================================== valuecounts ties: deterministic but order-fragile
# All-equal counts: pin the multiset so the test is order-independent, but assert determinism too.
var vcA = pd.Series(["a", "b", "c"]).valuecounts()
var vcB = pd.Series(["a", "b", "c"]).valuecounts()
assert vcA.index == vcB.index, "valuecounts tie-order is at least deterministic within a run"
assert bag(vcA.tolist()) == bag([1, 1, 1]), "valuecounts ties: every value counted once"
assert bag(vcA.index) == bag(["a", "b", "c"]), "valuecounts index covers every value"

# =================================================================== CSV: ragged rows, embedded newline, quoting
# Short row -> missing trailing cells become "" -> inferred as None (still padded, not an error).
var ragShort = pd.readcsv("a,b,c\n1,2\n3,4,5")
assert ragShort["c"].tolist() == [None, 5], "short CSV row: missing trailing cell -> None"
# Long row -> extra cells beyond the header now THROW (no silent data loss, like pandas' ParserError).
assert throws(Function(): return pd.readcsv("a,b\n1,2,3,4\n5,6")), "long CSV row (more fields than the header) throws"
# Quoted field with an embedded newline stays one cell / one row.
var emb = pd.readcsv("a,b\n\"x\ny\",z\np,q")
assert emb.nrows() == 2, "quoted embedded newline keeps the row intact"
assert emb["a"][0] == "x\ny", "quoted embedded newline preserved in the cell"
# unicode cells survive round-trip
var uni = pd.readcsv("name\ncafé\n日本")
assert uni["name"].tolist() == ["café", "日本"], "unicode CSV cells preserved"
# round-trip of an embedded comma + quote via tocsv -> readcsv
var rtDF = pd.DataFrame([["a, b", "he said \"hi\""]], columns=["x", "y"])
var rt = pd.readcsv(rtDF.tocsv())
assert rt["x"].tolist() == ["a, b"] and rt["y"].tolist() == ["he said \"hi\""], "tocsv->readcsv preserves comma + quote"

# =================================================================== duplicate INDEX labels: first-match resolution
var dupIdx = pd.DataFrame({"v": [10, 20, 30]}, columns=["v"], index=["x", "x", "y"])
assert dupIdx.at("x", "v") == 10, "at() with a duplicate index label returns the FIRST match"
assert dupIdx.loc["x"]["v"] == 10, "loc with a duplicate index label returns the first row"

# =================================================================== empty / single-row / single-column degenerates
assert pd.DataFrame().shape() == [0, 0], "bare DataFrame() is [0,0]"
assert pd.DataFrame().describe().shape() == [0, 0], "describe of an empty frame is [0,0]"
assert pd.DataFrame().tocsv() == "", "tocsv of an empty frame is empty"
assert pd.DataFrame([], columns=["a", "b"]).tocsv() == "a,b", "header-only frame tocsv is just the header"
assert throws(Function(): return pd.DataFrame().rowat(0)), "rowat on an empty frame throws"
# single-cell frame describe: std None, the rest equal to the value
var one = pd.DataFrame({"v": [5]}, columns=["v"]).describe()
assert one["v"].tolist()[2] == None, "describe std is None for a single-row frame"
assert one["v"].tolist()[0] == 1 and one["v"].tolist()[5] == 5, "describe count=1, max=value for a single row"
# all-numeric reductions on a frame of ONLY strings -> empty Series (no numeric columns)
var allstr = pd.DataFrame({"a": ["p", "q"], "b": ["r", "s"]}, columns=["a", "b"])
assert allstr.sum().index == [] and allstr.describe().columns == [], "all-string frame: numeric reductions/describe are empty"

# =================================================================== merge / concat result index is reset to 0..n
var mLeft = pd.DataFrame({"id": [1, 2], "x": [9, 8]}, columns=["id", "x"], index=["L0", "L1"])
var mRight = pd.DataFrame({"id": [1, 2], "y": [7, 6]}, columns=["id", "y"], index=["R0", "R1"])
assert pd.merge(mLeft, mRight, on="id").index == [0, 1], "merge result index is reset to 0..n (custom indices discarded)"
var cc = pd.concat([pd.DataFrame({"a": [1]}, columns=["a"], index=["z"]), pd.DataFrame({"a": [2]}, columns=["a"], index=["z"])])
assert cc.index == [0, 1], "concat result index is reset to 0..n"
# merge on a column missing from one side throws cleanly (not a crash)
assert throws(Function(): return pd.merge(mLeft, pd.DataFrame({"key": [1], "y": [1]}, columns=["key", "y"]), on="id")), "merge on a column absent from the right throws"
# outer/left/right fill the absent side with None
var oj = pd.merge(pd.DataFrame([[1, "a"], [3, "c"]], columns=["id", "x"]), pd.DataFrame([[1, "p"], [2, "q"]], columns=["id", "y"]), on="id", how="outer")
assert oj.nrows() == 3, "outer merge keeps unmatched rows from both sides"
assert None in oj["x"].tolist() and None in oj["y"].tolist(), "outer merge fills both unmatched sides with None"

# =================================================================== larger frame stress (a few hundred rows)
var bigKeys = []
var bigVals = []
var i = 0
while i < 600:
    bigKeys.append("g" + String(i % 7))
    bigVals.append(i)
    i = i + 1
var bigDF = pd.DataFrame({"k": bigKeys, "v": bigVals}, columns=["k", "v"])
var bigSum = bigDF.groupby("k").sum()
# oracle
var oracle = {}
i = 0
while i < 600:
    oracle[bigKeys[i]] = oracle.get(bigKeys[i], 0) + bigVals[i]
    i = i + 1
var gi = 0
var okBig = True
while gi < len(bigSum.index):
    if bigSum["v"][gi] != oracle[bigSum.index[gi]]:
        okBig = False
    gi = gi + 1
assert okBig, "groupby sum over 600 rows matches the oracle"
assert bigDF[bigDF["v"] >= 300].nrows() == 300, "boolean mask over 600 rows selects the right count"
var sortedDesc = bigDF.sortvalues("v", ascending=False)
assert sortedDesc.iat(0, 1) == 599, "sortvalues desc over 600 rows puts 599 first (by position)"
# FOOTGUN: the sorted column keeps the ORIGINAL index labels, so series[0] is label-first (the row
# whose original position was 0), NOT the first sorted element — use .iat(0) for positional access.
var sortedSmall = pd.DataFrame({"v": [5, 1, 9, 3]}, columns=["v"]).sortvalues("v", ascending=False)["v"]
assert sortedSmall[0] == 5, "series[0] after sort resolves by LABEL 0 (original row 0 = 5), a footgun"
assert sortedSmall.iat(0) == 9, "series.iat(0) is the true first sorted element (9)"

io.print("OK deep-tabular")
