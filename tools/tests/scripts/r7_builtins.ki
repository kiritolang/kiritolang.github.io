# r7_builtins.ki — round-7 audit of every built-in function against docs/pages/08-builtins.md.
# Complementary to r4_builtins / r6_builtins (DO NOT duplicate): this round probes the corners
# those leave open — negative-ndigits rounding ties, the full format-spec alignment matrix, the
# Bool-is-not-a-number boundary, uppercase/long-form numeric parsing, two's-complement bit edges,
# variadic-keyword binding, and inspect signatures.
# Self-checking: each ok(cond, msg) advances a counter; the final line prints the total.
# Run: build-release/ki tools/tests/scripts/r7_builtins.ki   (must print zero warnings to stderr)

var io = import("io")
var math = import("math")

var n = 0
var ok = Function(c, m):
  assert c, m
  n = n + 1

# throws(f) -> True iff calling f() throws a catchable error.
var throws = Function(f):
  try:
    discard f()
    return False
  catch String as e:
    discard e
    return True

# ============================================================ round: negative ndigits & ties ===
# Ties round HALF AWAY FROM ZERO at the chosen decimal place — also for negative ndigits.
ok(round(15, -1) == 20.0, "round 15 to tens (away: 1.5->2)")
ok(round(25, -1) == 30.0, "round 25 to tens (away: 2.5->3, not banker's 20)")
ok(round(-15, -1) == -20.0, "round -15 to tens (away from zero)")
ok(round(-25, -1) == -30.0, "round -25 to tens")
ok(round(1234.5, -2) == 1200.0, "round 1234.5 to hundreds (12.345->12)")
ok(round(1250.0, -2) == 1300.0, "round 1250 to hundreds (12.5->13 away)")
ok(round(1150.0, -2) == 1200.0, "round 1150 to hundreds (11.5->12 away)")
ok(round(0.125, 2) == 0.13, "round 0.125 (exactly representable, ties away -> 0.13)")
ok(round(0.375, 2) == 0.38, "round 0.375 ties away -> 0.38")
ok(round(2.5, 0) == 3.0, "round ndigits=0 yields Float 3.0")
ok(type(round(2.5, 0)) == "Float", "round with ndigits=0 yields Float")
ok(round(-2.5, 0) == -3.0, "round -2.5 ndigits=0 -> -3.0")
# An Integer input with no ndigits stays an Integer; with ndigits given it becomes a Float.
ok(round(5.0) == 5 and type(round(5.0)) == "Integer", "round float-with-no-ndigits -> Integer")
ok(round(7) == 7 and type(round(7)) == "Integer", "round Integer passthrough -> Integer")
ok(type(round(7, 2)) == "Float", "round Integer with ndigits -> Float")
ok(round(7, 2) == 7.0, "round Integer with ndigits value")
# Beyond a double's reach: huge +ndigits is a no-op, huge -ndigits gives a SIGNED zero.
ok(round(3.14159, 1000) == 3.14159, "round huge +ndigits is a no-op")
ok(round(3.14159, -1000) == 0.0, "round huge -ndigits -> 0.0")
ok(round(-3.0, -400) == 0.0, "round negative huge -ndigits -> signed zero (==0.0)")
ok(round(3.14, ndigits = 2) == 3.14, "round ndigits keyword (positive)")
ok(round(x = 12.7) == 13, "round x keyword")
ok(throws(Function(): return round(2.5, "2")), "round String ndigits throws")

# ===================================================== Bool is NOT a Number (the boundary) ===
# abs / round / sum REJECT Bool (a Number is Integer or Float); format coerces it. Pin both sides.
ok(throws(Function(): return abs(True)), "abs of Bool throws (Bool is not a Number)")
ok(throws(Function(): return round(True)), "round of Bool throws")
ok(throws(Function(): return sum([True, False, True])), "sum of Bools throws")
ok(format(True, "d") == "1", "format coerces True -> 1")
ok(format(False, "d") == "0", "format coerces False -> 0")
ok(format(True, "f") == "1.000000", "format True as float")
ok(format(False, "05.2f") == "00.00", "format False zero-padded float")
ok(format(True, "x") == "1", "format True as hex")
ok(format(True) == "True" and format(False) == "False", "format bare Bool stringifies")

# ====================================================== format: alignment & fill matrix ===
# '=' alignment pads BETWEEN sign and digits (numbers only); on a String it is meaningless and throws.
ok(format(-3.5, "=8.1f") == "-    3.5", "format = align pads between sign and float digits")
ok(format(3.5, "=+8.1f") == "+    3.5", "format = align with explicit + sign")
ok(throws(Function(): return format("hi", "=6")), "format = align on a String throws (sign-aware, meaningless)")
ok(throws(Function(): return format("hi", "*=6")), "format = align on a String with custom fill throws")
ok(format(7, "=6d") == "     7", "format = align Integer default space fill")
ok(format(-7, "=6d") == "-    7", "format = align negative Integer")
# The '0' flag forces '=' fill, but an EXPLICIT align overrides it (digits then 0-fill on '<').
ok(format(7, "<06d") == "700000", "format explicit < overrides 0's = (700000)")
ok(format(7, "^06d") == "007000", "format ^ center with 0 fill")
ok(format(-7, "<06d") == "-70000", "format < align negative with 0 fill")
ok(format(7, ">06d") == "000007", "format > align with 0 fill")
# Custom fill + align on numbers and strings.
ok(format(42, "*>10d") == "********42", "format custom fill right align number")
ok(format(42, "*<10d") == "42********", "format custom fill left align number")
ok(format("x", "->5") == "----x", "format dash fill right align string")
# Sign flags on zero / positive.
ok(format(0, "+d") == "+0", "format + sign on zero")
ok(format(0, " d") == " 0", "format space sign on zero")
ok(format(5, "+") == "+5", "format + sign no type")
ok(format(-0.0, "") == "-0.0", "format negative zero, empty spec == String(): '-0.0' (keeps the sign)")
# Strings: default left align; precision truncates by CODE POINTS; type 's' optional.
ok(format("hello", "10") == "hello     ", "format String default left align")
ok(format("hello", ".3") == "hel", "format String precision (no type) truncates")
ok(format("héllo", ".3") == "hél", "format String precision counts code points")
ok(format("hi", "^6") == "  hi  ", "format String center")

# ====================================================== format: numeric presentation types ===
ok(format(3.14159265, ".4g") == "3.142", "format .4g general precision")
ok(format(123456.789, ".3g") == "1.23e+05", "format .3g switches to scientific")
ok(format(0.0001234, ".2e") == "1.23e-04", "format .2e scientific")
ok(format(3.5, "+.1f") == "+3.5", "format float + sign")
ok(format(1234.5678, ",.2f") == "1,234.57", "format comma + float precision")
ok(format(255, "#X") == "0XFF", "format # uppercase hex prefix is 0X")
ok(format(255, "#08X") == "0X0000FF", "format #08X zero-pad after prefix")
ok(format(0, "#x") == "0x0", "format #x of zero")
ok(format(255, "#d") == "255", "format # is a no-op on decimal")
# Unsupported / contradictory specs throw (no silent drop).
ok(throws(Function(): return format(1000000, "_")), "format _ separator unsupported")
ok(throws(Function(): return format(255, "#,x")), "format comma with hex throws")
ok(throws(Function(): return format("x", "5.2f")), "format String with f type throws")
ok(throws(Function(): return format([1, 2], "d")), "format List with d type throws")
ok(throws(Function(): return format(42, "zz")), "format trailing junk in spec throws")

# ===================================================== Integer(): bases, signs, boundaries ===
ok(Integer("0XFF") == 255, "Integer uppercase 0X prefix")
ok(Integer("0B101") == 5, "Integer uppercase 0B prefix")
ok(Integer("0O17") == 15, "Integer uppercase 0O prefix")
ok(Integer("0xdeadBEEF") == 3735928559, "Integer mixed-case hex digits")
ok(Integer("  -0x10  ") == -16, "Integer signed hex with surrounding whitespace")
ok(Integer("+0b1111") == 15, "Integer + sign before binary prefix")
ok(Integer(hex(-1)) == -1, "Integer(hex(-1)) round-trips to -1")
ok(Integer(-9223372036854775808.0) == -9223372036854775808, "Integer of exact INT64_MIN float")
ok(Integer(9223372036854775807) == 9223372036854775807, "Integer INT64_MAX passthrough")
ok(Integer(-3.9) == -3, "Integer truncates toward zero (negative)")
ok(Integer(x = "0o777") == 511, "Integer x keyword with octal")
ok(throws(Function(): return Integer(9223372036854775808.0)), "Integer of 2^63 float overflows")
ok(throws(Function(): return Integer(math.inf)), "Integer of inf throws")
ok(throws(Function(): return Integer(math.nan)), "Integer of NaN throws")
ok(throws(Function(): return Integer("0x")), "Integer empty hex body throws")
ok(throws(Function(): return Integer("0b2")), "Integer non-binary digit throws")
ok(throws(Function(): return Integer("0o8")), "Integer non-octal digit throws")
ok(throws(Function(): return Integer("0x-5")), "Integer sign after prefix throws")

# ===================================================== Float(): forms beyond the docs' inf/nan ===
ok(Float("inf") == math.inf, "Float inf")
ok(Float("-inf") == 0.0 - math.inf, "Float -inf")
# Long form and capitalization parse too (broader than the docs' 'inf'/'nan').
ok(Float("infinity") == math.inf, "Float long-form 'infinity'")
ok(Float("Inf") == math.inf, "Float capitalized 'Inf'")
ok(math.isnan(Float("nan")), "Float nan is NaN")
ok(math.isnan(Float("NaN")), "Float capitalized 'NaN'")
ok(Float("1.5e-3") == 0.0015, "Float scientific notation")
ok(Float("  -2.5  ") == 0.0 - 2.5, "Float surrounding whitespace + sign")
ok(Float(True) == 1.0 and Float(False) == 0.0, "Float of Bool")
ok(throws(Function(): return Float("0x1p4")), "Float rejects C99 hex-float literal")
ok(throws(Function(): return Float("1.2.3")), "Float rejects double dot")

# ====================================================== String() of every value kind ===
ok(String(None) == "None", "String of None")
ok(String([1, "a"]) == "[1, 'a']", "String nests in repr form (quoted)")
ok(String({"k": "v"}) == "{'k': 'v'}", "String Dict in repr form")
ok(String([""]) == "['']", "String distinguishes [''] from []")
ok(String(min) == "<function min>", "String of a native function")
ok(String(io) == "<module io>", "String of a module")
ok(String(3.14) == "3.14", "String of Float")

# ====================================================== Bool() truthiness ===
ok(Bool([]) == False and Bool([0]) == True, "Bool of empty vs non-empty List")
ok(Bool("") == False and Bool(" ") == True, "Bool of empty vs non-empty String")
ok(Bool(0) == False and Bool(0.0) == False, "Bool of zero numbers")
ok(Bool(None) == False, "Bool of None")
ok(Bool({}) == False and Bool({1: 2}) == True, "Bool of Dict")

# ====================================================== List/Set/Dict converters ===
ok(List("abc") == ["a", "b", "c"], "List from a String")
ok(List(range(3)) == [0, 1, 2], "List from a range")
ok(List() == [], "List() empty")
ok(List(iterable = [1, 2]) == [1, 2], "List iterable keyword")
ok(len(Set([1, 1, 2, 3, 3])) == 3, "Set dedups")
ok(len(Set()) == 0 and type(Set()) == "Set", "Set() empty has length 0")
ok(Dict([["a", 1], ["b", 2]]) == {"a": 1, "b": 2}, "Dict from pair list")
ok(Dict() == {}, "Dict() empty")
ok(throws(Function(): return List(5)), "List of a non-iterable throws")
ok(throws(Function(): return Dict([[1]])), "Dict from a non-pair throws")
ok(throws(Function(): return Dict([1, 2])), "Dict from non-iterable items throws")

# ====================================================== Bytes() / fromhex() ===
ok(type(Bytes([72, 73])) == "Bytes", "Bytes from Integer list")
ok(Bytes([72, 73]) == fromhex("4849"), "Bytes list equals fromhex")
ok(len(Bytes(3)) == 3, "Bytes(n) gives n zero bytes")
ok(Bytes() == fromhex(""), "Bytes() empty equals fromhex empty")
ok(Bytes(None) == Bytes(), "Bytes(None) is empty")
ok(fromhex("48 65 6c 6c 6f").decode() == "Hello", "fromhex with spaces -> decode")
ok(Bytes("ab").decode() == "ab", "Bytes(String).decode round-trips")
ok(Bytes(x = [65], encoding = "ascii") == fromhex("41"), "Bytes keyword args")
ok(throws(Function(): return Bytes([256])), "Bytes byte > 255 throws")
ok(throws(Function(): return Bytes([0 - 1])), "Bytes negative byte throws")
ok(throws(Function(): return Bytes("x", "utf-32")), "Bytes unknown encoding throws")
ok(throws(Function(): return fromhex("xyz")), "fromhex bad hex throws")

# ====================================================== isinstance: every form ===
ok(isinstance(1, Integer) == True, "isinstance Integer constructor")
ok(isinstance(1, Float) == False, "isinstance Integer is not Float")
ok(isinstance(1.0, Float) == True, "isinstance Float")
ok(isinstance("x", String) == True, "isinstance String")
ok(isinstance([], List) and isinstance({1}, Set) and isinstance({}, Dict), "isinstance collections")
ok(isinstance(Bytes("x"), Bytes) == True, "isinstance Bytes")
ok(isinstance(1, "Integer") == True, "isinstance type-name String (builtin)")
# Bool is its OWN type, NOT a subtype of Integer.
ok(isinstance(True, Bool) == True, "isinstance Bool is Bool")
ok(isinstance(True, Integer) == False, "isinstance True is NOT Integer")
ok(isinstance(1, Bool) == False, "isinstance 1 is NOT Bool")
class Animal:
  var sound = Function(self) -> String:
    return "..."
class Dog(Animal):
  var sound = Function(self) -> String:
    return "woof"
var d = Dog()
ok(isinstance(d, Dog) == True, "isinstance own user class")
ok(isinstance(d, Animal) == True, "isinstance subclass satisfies base")
ok(isinstance(Animal(), Dog) == False, "isinstance base is not subclass")
ok(isinstance(d, "Animal") == True, "isinstance type-name String for a user class")
ok(isinstance(d, "Dog") == True, "isinstance type-name String own class")
ok(throws(Function(): return isinstance(1, 5)), "isinstance with a non-type throws")

# ====================================================== id() identity & interning ===
var aa = [1, 2, 3]
var bb = aa
var cc = [1, 2, 3]
ok(id(aa) == id(bb), "id equal for aliased object")
ok(id(aa) != id(cc), "id differs for equal-but-distinct objects")
ok(id(aa) == id(aa), "id stable across calls")
ok(id(5) == id(5), "id of a small Integer is interned (stable)")
ok(id(None) == id(None), "id of None is stable")

# ====================================================== type() names ===
ok(type(1) == "Integer" and type(1.0) == "Float", "type Integer/Float")
ok(type(True) == "Bool" and type(None) == "None", "type Bool/None")
ok(type([]) == "List" and type({}) == "Dict" and type({1}) == "Set", "type collections")
ok(type("x") == "String" and type(Bytes("x")) == "Bytes", "type String/Bytes")
ok(type(min) == "Function" and type(range) == "Function", "type of a native function is Function")
ok(type(io) == "Module", "type of a module")
# A class is a first-class value; type() of a class/instance is the class's OWN name.
ok(type(d) == "Dog", "type of an instance is its class name")
ok(type(Dog) == "Dog", "type of a class value is the class's own name")

# ====================================================== sum / min / max over collections ===
ok(sum({1, 2, 3}) == 6, "sum over a Set")
ok(sum([1.0, 2, 3]) == 6.0 and type(sum([1.0, 2, 3])) == "Float", "sum mixed -> Float")
ok(sum([], 5) == 5 and type(sum([])) == "Integer", "sum empty is start")
ok(sum(iterable = [10, 20], start = 100) == 130, "sum keyword args")
ok(min({3, 1, 2}) == 1 and max({3, 1, 2}) == 3, "min/max over a Set")
ok(max({"k1": 5, "k2": 3}) == "k2", "max over a Dict ranges its keys")
ok(min(["aa", "b", "ccc"], key = len) == "b", "min with key=len")
ok(max(["aa", "b", "ccc"], key = len) == "ccc", "max with key=len")
ok(min([], default = 99) == 99 and max([], default = 0 - 1) == 0 - 1, "min/max default on empty")
ok(min(3, 1, 2) == 1 and max(3, 1, 2) == 3, "min/max several positionals")
ok(throws(Function(): return min([])), "min empty no default throws")
ok(throws(Function(): return min([1], badkw = 1)), "min unknown keyword throws")

# ====================================================== sorted: stability & key ===
var pairs = [[1, "a"], [2, "b"], [1, "c"], [2, "d"], [1, "e"]]
ok(sorted(pairs, key = Function(p): return p[0]) == [[1, "a"], [1, "c"], [1, "e"], [2, "b"], [2, "d"]], "sorted stable by key")
# reverse is ALSO stable (equal keys keep their original order).
ok(sorted(pairs, key = Function(p): return p[0], reverse = True) == [[2, "b"], [2, "d"], [1, "a"], [1, "c"], [1, "e"]], "sorted reverse keeps stability")
ok(sorted("dcba") == ["a", "b", "c", "d"], "sorted a String -> List of chars")
ok(sorted({3, 1, 2}) == [1, 2, 3], "sorted a Set")
ok(sorted({"b": 1, "a": 2}) == ["a", "b"], "sorted a Dict -> its sorted keys")
ok(sorted([1, 2, 3], key = Function(x): return 0 - x) == [3, 2, 1], "sorted by negating key")
ok(sorted(iterable = [3, 1, 2], reverse = True) == [3, 2, 1], "sorted keyword args")

# ====================================================== enumerate / zip / map / filter ===
ok(enumerate(["a", "b", "c"]) == [[0, "a"], [1, "b"], [2, "c"]], "enumerate default start 0")
ok(enumerate(["a", "b"], start = 10) == [[10, "a"], [11, "b"]], "enumerate start keyword")
ok(enumerate("ab") == [[0, "a"], [1, "b"]], "enumerate over a String")
ok(zip([1, 2, 3], ["a", "b"]) == [[1, "a"], [2, "b"]], "zip truncates to the shortest")
ok(zip([1, 2], [3, 4], [5, 6]) == [[1, 3, 5], [2, 4, 6]], "zip three iterables")
ok(zip() == [], "zip of nothing is empty")
ok(zip("ab", "xy") == [["a", "x"], ["b", "y"]], "zip over Strings")
ok(map(Function(x): return x * 2, [1, 2, 3]) == [2, 4, 6], "map is eager")
ok(type(map(Function(x): return x, [1])) == "List", "map returns a List")
ok(filter(Function(x): return x > 1, [0, 1, 2, 3]) == [2, 3], "filter keeps truthy")
ok(map(function = Function(x): return x + 1, iterable = [1, 2]) == [2, 3], "map keyword args")
ok(throws(Function(): return map(Function(x, y): return x + y, [1, 2], [3, 4])), "map rejects a second iterable")

# ====================================================== all / any / reversed / len ===
ok(all([]) == True and any([]) == False, "all/any vacuous on empty")
ok(all([1, 2, 3]) == True and all([1, 0, 3]) == False, "all truthiness")
ok(any([0, 0, 1]) == True and any([0, 0, 0]) == False, "any truthiness")
ok(all({1, 2}) == True and any({0}) == False, "all/any over a Set")
ok(reversed([1, 2, 3]) == [3, 2, 1], "reversed a List")
ok(reversed("abc") == ["c", "b", "a"], "reversed a String -> List")
ok(reversed(range(3)) == [2, 1, 0], "reversed a range")
ok(len("héllo") == 5, "len counts code points, not bytes")
ok(len(Bytes([1, 2, 3])) == 3, "len of Bytes")
ok(len({1: 1, 2: 2}) == 2, "len of a Dict")
ok(throws(Function(): return len(5)), "len of a non-collection throws")

# ====================================================== range: kwargs, guards, directions ===
ok(range(5) == [0, 1, 2, 3, 4], "range(stop)")
ok(range(2, 5) == [2, 3, 4], "range(start, stop)")
ok(range(0, 10, 2) == [0, 2, 4, 6, 8], "range(start, stop, step)")
ok(range(5, 0, 0 - 1) == [5, 4, 3, 2, 1], "range descending negative step")
ok(range(0, 5, 0 - 1) == [], "range wrong-direction step is empty")
ok(range(5, 5) == [], "range empty when start == stop")
ok(range(stop = 3) == [0, 1, 2], "range stop keyword")
ok(range(end = 4) == [0, 1, 2, 3], "range end alias keyword")
ok(range(start = 1, stop = 5) == [1, 2, 3, 4], "range start+stop keywords")
ok(range(1, 10, step = 3) == [1, 4, 7], "range positional start/stop + step keyword")
ok(range(start = 0, end = 6, step = 2) == [0, 2, 4], "range all keywords with end alias")
ok(len(range(1000000)) == 1000000, "range a million entries is allowed")
ok(throws(Function(): return range(0, 100, 0)), "range step zero throws")
ok(throws(Function(): return range(10000000000000)), "range too large throws (guarded)")
ok(throws(Function(): return range(2, 5, start = 1)), "range positional/keyword clash throws")
ok(throws(Function(): return range()), "range with no stop throws")

# ====================================================== bin / oct / hex / bit ops edges ===
ok(bin(0) == "0b0" and oct(0) == "0o0" and hex(0) == "0x0", "radix of zero")
ok(bin(0 - 5) == "-0b101", "bin of a negative (sign-aware)")
ok(hex(0 - 255) == "-0xff", "hex of a negative")
ok(bitnot(0 - 1) == 0, "bitnot -1 -> 0")
ok(bitand(0 - 1, 255) == 255, "bitand -1 masks the low byte")
ok(bitor(0 - 2, 1) == 0 - 1, "bitor -2 | 1 -> -1")
ok(bitxor(0 - 1, 0 - 1) == 0, "bitxor of equal negatives -> 0")
ok(shl(1, 63) == 0 - 9223372036854775807 - 1, "shl 1<<63 wraps to INT64_MIN")
ok(shl(1, 64) == 0, "shl by 64 (>= width) -> 0")
ok(shl(255, 100) == 0, "shl by 100 -> 0")
ok(shr(0 - 1, 1) == 0 - 1, "shr -1 is arithmetic (stays -1)")
ok(shr(0 - 8, 2) == 0 - 2, "shr -8 >> 2 -> -2 (sign-preserving)")
ok(shr(0 - 1, 64) == 0 - 1, "shr negative by >= width fills the sign")
ok(shr(255, 100) == 0, "shr positive by >= width -> 0")
ok(bitand(a = 6, b = 3) == 2 and shl(a = 1, n = 3) == 8, "bit ops keyword args")
ok(throws(Function(): return shl(1, 0 - 1)), "shl negative count throws")
ok(throws(Function(): return bitnot(1.0)), "bitnot of a Float throws")

# ====================================================== pow: 2-arg, 3-arg, edges ===
ok(pow(2, 10) == 1024 and type(pow(2, 10)) == "Integer", "pow 2-arg Integer")
ok(pow(2, 0 - 1) == 0.5 and type(pow(2, 0 - 1)) == "Float", "pow negative exp -> Float")
ok(pow(2.0, 3) == 8.0, "pow Float base 2-arg")
ok(pow(2, 10, 1000) == 24, "pow 3-arg modular")
ok(pow(2, 10, mod = 1000) == 24, "pow mod keyword")
ok(pow(2, 0, 1) == 0, "pow x^0 mod 1 -> 0 (1 % 1)")
ok(pow(0, 0, 7) == 1, "pow 0^0 mod m -> 1")
ok(pow(0 - 3, 3, 7) == 1, "pow negative base modular ((-27) mod 7 == 1)")
ok(pow(base = 2, exp = 5) == 32, "pow base/exp keywords (2-arg)")
ok(throws(Function(): return pow(2, 0 - 1, 5)), "pow negative exp with modulus throws")
ok(throws(Function(): return pow(2, 3, 0)), "pow zero modulus throws")
ok(throws(Function(): return pow(2, 3, 0 - 5)), "pow negative modulus throws")
ok(throws(Function(): return pow(2.0, 3, 5)), "pow Float base with modulus throws")

# ====================================================== ord / chr round-trip & boundaries ===
ok(ord("A") == 65 and chr(65) == "A", "ord/chr ASCII")
ok(ord(chr(0x1F600)) == 0x1F600, "ord/chr astral round-trip")
ok(chr(ord("€")) == "€", "chr/ord euro round-trip")
ok(ord(char = "Z") == 90 and chr(codepoint = 66) == "B", "ord/chr keyword args")
ok(throws(Function(): return chr(0xD800)), "chr UTF-16 surrogate throws")
ok(throws(Function(): return chr(0x110000)), "chr above max code point throws")
ok(throws(Function(): return chr(0 - 1)), "chr negative throws")
ok(throws(Function(): return ord("ab")), "ord multi-char throws")

# ====================================================== abs ===
ok(abs(0 - 5) == 5 and abs(5) == 5, "abs of Integers")
ok(abs(0 - 5.5) == 5.5, "abs of a Float")
ok(abs(0 - 9223372036854775807 - 1) == 0 - 9223372036854775807 - 1, "abs(INT64_MIN) wraps to itself")
ok(abs(x = 0 - 7) == 7, "abs x keyword")

# ====================================================== inspect: signatures & shapes ===
# A signatured builtin shows name(params...) -> Ret; round/pow declare no fixed return type.
ok(inspect(len) == "len(x) -> Integer", "inspect len signature")
ok(inspect(abs) == "abs(x: Number) -> Number", "inspect abs signature")
ok(inspect(sorted) == "sorted(iterable, key = None, reverse: Bool = False) -> List", "inspect sorted signature")
ok(inspect(enumerate) == "enumerate(iterable, start = 0) -> List", "inspect enumerate signature")
ok(inspect(format) == "format(value, spec: String = \"\") -> String", "inspect format quotes its String default")
ok(inspect(isinstance) == "isinstance(value, type) -> Bool", "inspect isinstance signature")
ok(inspect(round) == "round(x: Number, ndigits = None)", "inspect round has no return type")
ok(inspect(pow) == "pow(base, exp, mod = None)", "inspect pow has no return type")
ok(inspect(Bytes) == "Bytes(x = None, encoding = None) -> Bytes", "inspect Bytes signature")
ok(inspect(Integer) == "Integer(x) -> Integer", "inspect Integer signature")
# Variadic builtins advertise themselves as name(...)  [native] and hide their keyword options.
ok(inspect(range) == "range(...)  [native]", "inspect variadic range")
ok(inspect(min) == "min(...)  [native]", "inspect variadic min (key/default hidden)")
ok(inspect(zip) == "zip(...)  [native]", "inspect variadic zip")

# inspect of a user class lists its methods with signatures.
class Vec:
  var _init_ = Function(self, x, y):
    self.x = x
    self.y = y
  var norm = Function(self) -> Float:
    return Float(self.x * self.x + self.y * self.y)
ok(inspect(Vec) == "class Vec:\n  _init_(self, x, y)\n  norm(self) -> Float", "inspect class lists methods")
var v = Vec(3, 4)
var vi = inspect(v)
ok(vi.startswith("Vec instance:"), "inspect instance header")
ok(vi.find("attr x: Integer") >= 0 and vi.find("norm(self) -> Float") >= 0, "inspect instance shows attrs + methods")
# inspect of a module lists its members; of a native object, its declared members.
var modi = inspect(io)
ok(modi.startswith("module io:"), "inspect module header")
ok(modi.find("open(") >= 0 and modi.find("[native]") >= 0, "inspect module shows native members")
var rndi = inspect(import("random").Random(1))
ok(rndi.startswith("Random object:"), "inspect native object header")
ok(rndi.find("random() -> Float") >= 0, "inspect native object shows declared methods")
# inspect of a user function (default value shown as ... since defaults are call-time).
ok(inspect(Function(a, b = 2) -> Integer: return a + b) == "function(a, b = ...) -> Integer", "inspect user function signature")

# ====================================================== import ===
ok(type(import("math")) == "Module", "import returns a Module")
ok(import(name = "io") == io, "import keyword arg, cached per VM")
ok(throws(Function(): return import("no_such_module_xyz")), "import of a missing module throws")
ok(throws(Function(): return import(5)), "import of a non-String throws")

# ====================================================== cross-cutting: arg-binding errors ===
ok(throws(Function(): return abs(y = 5)), "unknown keyword on a signatured builtin throws")
ok(throws(Function(): return len(1, 2)), "too many positionals throws")
ok(throws(Function(): return abs()), "missing required argument throws")
ok(throws(Function(): return round(2.5, ndigits = 1, ndigits = 2)), "duplicate keyword throws")
ok(throws(Function(): return sorted([1], 2, 3, 4)), "extra positional on sorted throws")

io.print("r7_builtins: " + String(n) + " checks passed")
