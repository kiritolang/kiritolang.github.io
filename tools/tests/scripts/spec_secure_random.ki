# OS-CSPRNG secure random: random.randombytes / randomhex / randomurlsafe / randombelow. The kernel
# entropy source is non-deterministic, so these assert PROPERTIES (lengths, alphabets, range,
# coverage, distinctness) rather than fixed values. Runs under every preset (no OpenSSL needed).
var random = import("random")
var io = import("io")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True

# --- hasentropy ---
assert type(random.hasentropy()) == "Bool", "hasentropy is a Bool"
assert random.hasentropy() == True, "OS CSPRNG is available on this system"

# --- randombytes ---
assert type(random.randombytes()) == "Bytes", "randombytes is Bytes"
assert len(random.randombytes()) == 32, "randombytes default 32"
assert len(random.randombytes(16)) == 16, "randombytes(16)"
assert len(random.randombytes(0)) == 0, "randombytes(0)"
assert len(random.randombytes(n = 48)) == 48, "randombytes kwarg"
# two draws differ (a stuck source would fail)
assert random.randombytes(32) != random.randombytes(32), "randombytes are random"
# every byte is a valid 0..255 Integer
for b in random.randombytes(64):
    assert b >= 0 and b <= 255, "token byte in range"

# --- randomhex: 2n lowercase hex chars ---
assert len(random.randomhex()) == 64, "randomhex default"
assert len(random.randomhex(20)) == 40, "randomhex(20)"
var hexchars = "0123456789abcdef"
for ch in random.randomhex(32):
    assert ch in hexchars, "randomhex is lowercase hex"

# --- randomurlsafe: base64url alphabet, no padding ---
var urlok = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
var u = random.randomurlsafe(48)
assert len(u) > 0, "randomurlsafe non-empty"
assert "=" not in u, "randomurlsafe unpadded"
assert "+" not in u and "/" not in u, "randomurlsafe is url-safe"
for ch in u:
    assert ch in urlok, "randomurlsafe alphabet"

# --- randombelow: range + coverage + edge ---
assert random.randombelow(1) == 0, "randombelow(1) is 0"
var counts = {}
for i in range(8):
    counts[i] = 0
for i in range(8000):
    var v = random.randombelow(8)
    assert v >= 0 and v < 8, "randombelow in range"
    counts[v] = counts[v] + 1
for i in range(8):
    assert counts[i] > 0, "randombelow covers every value"
# a large modulus stays in range (exercises the 64-bit rejection loop)
for i in range(500):
    var w = random.randombelow(1000000007)
    assert w >= 0 and w < 1000000007, "randombelow large modulus in range"

# --- distinctness over many tokens ---
var seen = {}
for i in range(2000):
    var t = random.randomhex(16)
    assert t not in seen, "randomhex tokens are distinct"
    seen[t] = True

# --- adversarial / bad input ---
assert raises(Function(): return random.randombytes(-1)), "randombytes(-1) throws"
assert raises(Function(): return random.randomhex(-5)), "randomhex(-5) throws"
assert raises(Function(): return random.randomurlsafe(-1)), "randomurlsafe(-1) throws"
assert raises(Function(): return random.randombytes(999999999999)), "randombytes huge throws"
assert raises(Function(): return random.randombelow(0)), "randombelow(0) throws"
assert raises(Function(): return random.randombelow(-10)), "randombelow negative throws"

io.print("OK secure_random")
