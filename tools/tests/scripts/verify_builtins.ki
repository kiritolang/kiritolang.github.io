# Doc-vs-impl verification for the built-in functions (docs/pages/08-builtins.md).
# Functioning cases (exact results), edge cases, and HARDENING (bad input must raise the right error,
# and anything that SHOULD raise but doesn't is a silent bug). Prints "OK builtins".
var io = import("io")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True
var raises_msg = Function(fn, needle) -> Bool:
    try:
        discard fn()
        return False
    catch String as e:
        return needle in e

# ============================================================ type() / conversions
assert type(1) == "Integer" and type(1.0) == "Float" and type("x") == "String", "type scalars"
assert type(True) == "Bool" and type(None) == "None", "type Bool/None"
assert type([1]) == "List" and type({1}) == "Set" and type({"a": 1}) == "Dict", "type containers"
assert type(Bytes([1])) == "Bytes", "type Bytes"
class Widget:
    var _init_ = Function(self): pass
assert type(Widget()) == "Widget", "type user class"

# --- Integer() ---
assert Integer(True) == 1 and Integer(False) == 0, "Integer(Bool)"
assert Integer(3.9) == 3 and Integer(-3.9) == -3, "Integer(Float) truncates toward zero"
assert Integer("42") == 42 and Integer("  -7  ") == -7 and Integer("+5") == 5, "Integer(String) signs/space"
assert Integer("0xFF") == 255 and Integer("0o17") == 15 and Integer("0b1010") == 10, "Integer bases"
assert Integer("0XfF") == 255 and Integer("0O17") == 15 and Integer("0B101") == 5, "Integer bases uppercase prefix"
assert raises_msg(Function(): return Integer("abc"), "Integer"), "Integer bad string raises"
assert raises(Function(): return Integer("--5")), "Integer doubled sign raises"
assert raises(Function(): return Integer("+ 5")), "Integer space after sign raises"
assert raises(Function(): return Integer("0x-5")), "Integer 0x-5 raises"
assert raises(Function(): return Integer(1.0 / 0.0 - 1.0 / 0.0)), "Integer(NaN) raises"
assert raises(Function(): return Integer([1])), "Integer(List) raises"

# --- Float() ---
assert Float(5) == 5.0 and Float(True) == 1.0, "Float(Integer/Bool)"
assert Float("2.5") == 2.5 and Float("1e3") == 1000.0 and Float("2e-3") == 0.002, "Float strings"
assert Float("inf") > 1e308 and Float("-INFINITY") < -1e308, "Float inf"
var fnan = Float("nan")
assert fnan != fnan, "Float(nan)"
assert raises(Function(): return Float("abc")), "Float bad string raises"
assert raises(Function(): return Float("0x1p4")), "Float rejects hex-float literal"
assert raises(Function(): return Float([1])), "Float(List) raises"

# --- String() / Bool() ---
assert String(42) == "42" and String(True) == "True" and String(None) == "None", "String scalars"
assert String([1, "a"]) == "[1, 'a']", "String nests strings in repr form"
assert Bool(0) == False and Bool("") == False and Bool([]) == False and Bool(None) == False, "Bool falsy"
assert Bool(1) == True and Bool("x") == True and Bool([0]) == True, "Bool truthy"

# --- List/Set/Dict constructors ---
assert List() == [] and List("ab") == ["a", "b"] and List(range(3)) == [0, 1, 2], "List()"
assert len(Set([1, 1, 2, 3, 3])) == 3, "Set() dedups"
assert Dict([["a", 1], ["b", 2]])["a"] == 1, "Dict() from pairs"
assert raises(Function(): return Dict([[1]])), "Dict() bad pair raises"

# --- Bytes()/fromhex() ---
assert Bytes([72, 73]).decode() == "HI", "Bytes(List)"
assert len(Bytes(3)) == 3 and Bytes(3) == Bytes([0, 0, 0]), "Bytes(n) zeros"
assert Bytes("Hi").hex() == "4869", "Bytes(String) utf-8"
assert Bytes() == Bytes([]) and Bytes(None) == Bytes([]), "Bytes() empty"
assert fromhex("48 69").decode() == "Hi", "fromhex spaces"
assert raises(Function(): return Bytes([256])), "Bytes out-of-range byte raises"
assert raises(Function(): return Bytes([-1])), "Bytes negative byte raises"
assert raises(Function(): return fromhex("xyz")), "fromhex bad raises"

# ============================================================ isinstance / hasattr / id
assert isinstance(1, Integer) and isinstance("x", String) and isinstance([1], List), "isinstance ctor"
assert isinstance(1, "Integer") and isinstance(1, "Number") and isinstance(1, "Any"), "isinstance name/pseudo"
assert not isinstance(True, Integer) and not isinstance(1, Bool), "isinstance Bool not Integer"
assert isinstance(Widget(), Widget) and isinstance(Widget(), "Any"), "isinstance user class"
class Base:
    var _init_ = Function(self): pass
class Derived(Base):
    var _init_ = Function(self): self._super_()
assert isinstance(Derived(), Base), "isinstance inheritance-aware"
assert isinstance(io, "Module") and isinstance(type, "Function"), "isinstance Module/Function"
assert raises(Function(): return isinstance(1, 5)), "isinstance bad type arg raises"

var inst = Widget()
inst.attr = None
assert hasattr(inst, "attr"), "hasattr present-but-None"
assert not hasattr(inst, "missing"), "hasattr missing"
assert hasattr("x", "upper") and hasattr([1], "append") and hasattr(5, "compare"), "hasattr builtin methods"
assert hasattr(io, "print"), "hasattr module member"
assert not hasattr(Widget, "attr"), "hasattr on a class value is False"
assert raises(Function(): return hasattr(inst, 5)), "hasattr non-String name raises"

var a = [1, 2]
var b = a
var c = [1, 2]
assert id(a) == id(b) and id(a) != id(c), "id shared vs equal"

# ============================================================ sequences / iteration
assert len("héllo") == 5 and len([1, 2, 3]) == 3 and len({"a": 1}) == 1, "len"
assert range(3) == [0, 1, 2] and range(2, 5) == [2, 3, 4] and range(5, 0, -2) == [5, 3, 1], "range"
assert range(0) == [] and range(5, 5) == [], "range empty"
assert range(end = 3) == [0, 1, 2], "range keyword end"
assert raises_msg(Function(): return range(0, 5, 0), "step"), "range step 0 raises"
assert enumerate(["a", "b"]) == [[0, "a"], [1, "b"]], "enumerate"
assert enumerate(["a"], start = 5) == [[5, "a"]], "enumerate start"
assert zip([1, 2, 3], ["a", "b"]) == [[1, "a"], [2, "b"]], "zip truncates to shortest"
assert zip([1], [2], [3]) == [[1, 2, 3]], "zip variadic"
assert map(Function(x): return x * x, [1, 2, 3]) == [1, 4, 9], "map"
assert filter(Function(x): return x % 2 == 0, range(6)) == [0, 2, 4], "filter"
assert reversed([1, 2, 3]) == [3, 2, 1] and reversed("abc") == ["c", "b", "a"], "reversed"
assert sorted([3, 1, 2]) == [1, 2, 3], "sorted"
assert sorted(["bb", "a", "ccc"], key = len) == ["a", "bb", "ccc"], "sorted key"
assert sorted([1, 2, 3], reverse = True) == [3, 2, 1], "sorted reverse"
assert sorted(["b", "a"], key = len, reverse = True) == ["b", "a"], "sorted stable key+reverse"
assert sum([1, 2, 3]) == 6 and sum([]) == 0 and sum([1, 2], 10) == 13, "sum"
assert sum([1.0, 2]) == 3.0 and type(sum([1.0, 2])) == "Float", "sum mixed -> Float"
assert min([3, 1, 2]) == 1 and max([3, 1, 2]) == 3, "min/max iterable"
assert min(3, 1, 2) == 1 and max(3, 1, 2) == 3, "min/max varargs"
assert min(["bb", "a"], key = len) == "a" and max(["bb", "a"], key = len) == "bb", "min/max key"
assert min([], default = 99) == 99 and max([], default = -1) == -1, "min/max default"
assert raises(Function(): return min([])), "min empty raises"
assert all([1, True, "x"]) and all([]) and not all([1, 0]), "all"
assert any([0, "", 1]) and not any([]) and not any([0, ""]), "any"
assert raises_msg(Function(): return len(5), "has no length"), "len non-iterable raises (clean message)"
assert raises_msg(Function(): return map(Function(x): return x, 5), "is not iterable"), "map non-iterable raises"
assert raises(Function(): return sum([1, "x"])), "sum non-number raises"

# ============================================================ numbers
assert abs(-5) == 5 and abs(5) == 5 and abs(-2.5) == 2.5, "abs"
assert round(0.5) == 1 and round(-1.5) == -2 and round(2.5) == 3, "round half away from zero"
assert round(3.14159, 2) == 3.14 and type(round(3.14159, 2)) == "Float", "round ndigits"
assert round(3.14159, ndigits = 2) == 3.14, "round keyword"
assert raises(Function(): return round(Float("nan"))), "round(nan)->Integer raises"
var rnan = round(Float("nan"), 2)
assert rnan != rnan, "round(nan, 2) passes through"
assert divmod(7, 3) == [2, 1] and divmod(-7, 3) == [-3, 2], "divmod floor"
assert pow(2, 10) == 1024 and pow(2, 10, 1000) == 24, "pow 2/3-arg"
assert pow(2, 10, mod = 1000) == 24, "pow keyword mod"
assert raises(Function(): return pow(2, 10, 0)), "pow mod<=0 raises"
assert raises(Function(): return pow(2, -1, 5)), "pow negative exp mod raises"
assert bin(10) == "0b1010" and oct(8) == "0o10" and hex(255) == "0xff", "bin/oct/hex"
assert bin(-2) == "-0b10" and hex(-255) == "-0xff", "bin/hex sign-aware"
assert bitand(12, 10) == 8 and bitor(12, 10) == 14 and bitxor(12, 10) == 6, "bitand/or/xor"
assert bitnot(5) == -6, "bitnot"
assert shl(1, 4) == 16 and shr(-16, 2) == -4, "shl/shr arithmetic"
assert ord("A") == 65 and ord("é") == 233 and chr(65) == "A" and chr(233) == "é", "ord/chr"
assert raises(Function(): return ord("ab")), "ord multi-char raises"

# ============================================================ format
assert format(42, "05d") == "00042", "format 05d"
assert format(255, "x") == "ff" and format(255, "#x") == "0xff", "format hex"
assert format(3.14159, ".2f") == "3.14", "format .2f"
assert format(1234567, ",") == "1,234,567", "format thousands"
assert format(0.25, ".1%") == "25.0%", "format percent"
assert format("hi", "^6") == "  hi  " and format("x", "*^7") == "***x***", "format align/fill"
assert format(-42, "+06d") == "-00042", "format sign+zero"
assert raises(Function(): return format("x", "+5")), "format sign on String raises"
assert raises(Function(): return format("x", "#6")), "format # on String raises"
assert raises(Function(): return format("x", ",")), "format , on String raises"

# ============================================================ introspection / import
assert type(import("io")) == "Module", "import returns Module"
assert import(name = "io") == io, "import keyword + cached"
assert "sqrt" in inspect(import("math")), "inspect module lists members"
assert "compare" in inspect(5), "inspect Integer lists methods"

io.print("OK builtins")
