# crypto module: AES-GCM, RSA/EC sign+verify+encrypt, X.509. OpenSSL-gated, so this branches on
# crypto.enabled: under a TLS build (debug/release) it exercises the real primitives; under a non-TLS
# build (asan/tsan) it asserts every function fails LOUDLY with a "requires KIRITO_ENABLE_TLS" error
# rather than silently doing nothing. Runs under every preset (mirrors spec_socket_tls.ki).
var crypto = import("crypto")
var random = import("random")
var io = import("io")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True
var raises_msg = Function(fn, needle) -> Bool:
    try:
        discard fn()
        return False
    catch String as e:
        return needle in e

# inspect / enabled surface exists in every build
assert type(crypto.enabled) == "Bool", "crypto.enabled is a Bool"

if not crypto.enabled:
    # --- non-TLS build: every operation must throw a clear, catchable "needs OpenSSL" error ---
    assert raises_msg(Function(): return crypto.aesencrypt(random.randombytes(32), "x", random.randombytes(12)), "KIRITO_ENABLE_TLS"), "aes needs TLS"
    assert raises_msg(Function(): return crypto.rsagenerate(2048), "KIRITO_ENABLE_TLS"), "rsa needs TLS"
    assert raises_msg(Function(): return crypto.ecgenerate(), "KIRITO_ENABLE_TLS"), "ec needs TLS"
    assert raises_msg(Function(): return crypto.x509parse("x"), "KIRITO_ENABLE_TLS"), "x509 needs TLS"
    io.print("OK crypto")   # same line in both branches so one .expected matches every preset
else:
    # --- AES-GCM known-answer (GCM spec test case 3: AES-128, 96-bit IV, no AAD) ---
    var key = fromhex("feffe9928665731c6d6a8f9467308308")
    var iv = fromhex("cafebabefacedbaddecaf888")
    var pt = fromhex("d9313225f88406e5a55909c5aff5269a86a7a9531534f7da2e4c303d8a318a721c3c0c95956809532fcf0e2449a6b525b16aedf5aa0de657ba637b391aafd255")
    var e = crypto.aesencrypt(key, pt, iv)
    assert e["ciphertext"].hex() == "42831ec2217774244b7221b784d0d49ce3aa212f2c02a4e035c17e2329aca12e21d514b25466931c7d8f6a5aac84aa051ba30b396a0aac973d58e091473f5985", "gcm KAT ciphertext"
    assert e["tag"].hex() == "4d5c2af327cd64a62cf35abd2ba6fab4", "gcm KAT tag"
    assert crypto.aesdecrypt(key, e["ciphertext"], iv, e["tag"]) == pt, "gcm KAT decrypt"

    # --- round-trip for every key size, with AAD ---
    for ks in [16, 24, 32]:
        var k = random.randombytes(ks)
        var n = random.randombytes(12)
        var enc = crypto.aesencrypt(k, "hello, kirito", n, "meta")
        assert crypto.aesdecrypt(k, enc["ciphertext"], n, enc["tag"], "meta").decode() == "hello, kirito", "gcm round-trip"
        # wrong AAD, wrong tag, wrong key all fail authentication
        assert raises_msg(Function(): return crypto.aesdecrypt(k, enc["ciphertext"], n, enc["tag"], "META"), "authentication"), "gcm wrong aad"
        var badtag = enc["tag"][0:1] + Bytes([bitxor(enc["tag"][1], 255)]) + enc["tag"][2:len(enc["tag"])]
        assert raises_msg(Function(): return crypto.aesdecrypt(k, enc["ciphertext"], n, badtag, "meta"), "authentication"), "gcm tampered tag"

    # --- AES-GCM fuzz: encrypt->decrypt is identity for random key/iv/msg ---
    for i in range(60):
        var k = random.randombytes([16, 24, 32][random.randombelow(3)])
        var n = random.randombytes(random.randombelow(16) + 1)
        var m = random.randombytes(random.randombelow(200))
        var enc = crypto.aesencrypt(k, m, n)
        assert crypto.aesdecrypt(k, enc["ciphertext"], n, enc["tag"]) == m, "gcm fuzz round-trip"

    # --- RSA sign/verify + OAEP ---
    var rk = crypto.rsagenerate(2048)
    assert type(rk["private"]) == "String" and "BEGIN" in rk["private"], "rsa private PEM"
    var sig = crypto.rsasign(rk["private"], "message to sign")
    assert crypto.rsaverify(rk["public"], "message to sign", sig) == True, "rsa verify ok"
    assert crypto.rsaverify(rk["public"], "message to sigX", sig) == False, "rsa verify tampered"
    var rk2 = crypto.rsagenerate(2048)
    assert crypto.rsaverify(rk2["public"], "message to sign", sig) == False, "rsa wrong key"
    var ct = crypto.rsaencrypt(rk["public"], "confidential")
    assert crypto.rsadecrypt(rk["private"], ct).decode() == "confidential", "rsa oaep round-trip"
    # different algos
    assert crypto.rsaverify(rk["public"], "m", crypto.rsasign(rk["private"], "m", "sha512"), "sha512") == True, "rsa sha512"
    # Bytes messages/payloads work byte-exact, not just Strings (binary with NUL / high bytes / CR-LF)
    var binmsg = Bytes([0, 255, 10, 13, 200, 1, 128])
    var bsig = crypto.rsasign(rk["private"], binmsg)
    assert crypto.rsaverify(rk["public"], binmsg, bsig) == True, "rsa verify Bytes message"
    assert crypto.rsaverify(rk["public"], Bytes([0, 255, 10, 13, 200, 1, 129]), bsig) == False, "rsa Bytes tampered"
    var bct = crypto.rsaencrypt(rk["public"], binmsg)
    assert crypto.rsadecrypt(rk["private"], bct) == binmsg, "rsa oaep Bytes round-trip"

    # --- EC sign/verify ---
    var ek = crypto.ecgenerate()
    var esig = crypto.ecsign(ek["private"], "ec message")
    assert crypto.ecverify(ek["public"], "ec message", esig) == True, "ec verify ok"
    assert crypto.ecverify(ek["public"], "ec messagE", esig) == False, "ec verify tampered"
    # a Bytes message signs/verifies byte-exact too
    var becsig = crypto.ecsign(ek["private"], binmsg)
    assert crypto.ecverify(ek["public"], binmsg, becsig) == True, "ec verify Bytes message"
    assert crypto.ecverify(ek["public"], Bytes([1, 255, 10, 13, 200, 1, 128]), becsig) == False, "ec Bytes tampered"

    # --- X.509 parse (self-signed cert, CN=kirito.test, SAN kirito.test + www.kirito.test) ---
    var pem = """-----BEGIN CERTIFICATE-----
MIIDXjCCAkagAwIBAgIUe2JbxlpFszPkf/V5/aDiv+5yiakwDQYJKoZIhvcNAQEL
BQAwKjEUMBIGA1UEAwwLa2lyaXRvLnRlc3QxEjAQBgNVBAoMCUtpcml0b09yZzAe
Fw0yNjA3MDkxNjQxMTFaFw0zNjA3MDYxNjQxMTFaMCoxFDASBgNVBAMMC2tpcml0
by50ZXN0MRIwEAYDVQQKDAlLaXJpdG9PcmcwggEiMA0GCSqGSIb3DQEBAQUAA4IB
DwAwggEKAoIBAQDTgrQbrW+MLTwQbXPhDzB82ln7gdxkQV3hpQ3wOe9dapb/5Ahs
MuocGXHZ1D7aIaatcu8SeH1GGvqMcr6GhiDy+jhFjkkD4RTETPY40fezzhDKtSqW
EUQhSbmZOsNlkGGh2zyRwJk4GJeT7fJlJ/ifu3zkTkaaMLN3Z0M7mf1DgG9g8/6S
Gwr9RAT2YNbf3Cv4CLjNybeISzoecnier93IxawPlsR1wU0QWOjyDakooJ+4xJcM
3Vt5anH9gK94AifBJo8CVFKckliC2S+40DDuI5U5MmRiJRcXesABq4rH7dJH4JnX
5sW2LRC7vHUc93n/XMS/WodmnHuJ0oRVRjmxAgMBAAGjfDB6MB0GA1UdDgQWBBTS
N9cxJIAITuBt1rKmXiSYG1aTvTAfBgNVHSMEGDAWgBTSN9cxJIAITuBt1rKmXiSY
G1aTvTAPBgNVHRMBAf8EBTADAQH/MCcGA1UdEQQgMB6CC2tpcml0by50ZXN0gg93
d3cua2lyaXRvLnRlc3QwDQYJKoZIhvcNAQELBQADggEBAF04jgiBOqe4gc+f1HkC
2pgijeBVV4fT8uQzNQtmrD2bugBwSQTGi9ZYZrQicrdIYH5c5j0o31f2f3BEqc1m
6vHtNzFxAd1GJHbBbxJaEB6sQMiWvAcxvHVQtYqtFHIE2zlsLjrEc3QlQxLPgUZm
SN1/Jmfde5Wzyh8YjpBi0g+sTJcjwzqRWlMxuRCTmngxnvQvFFrct81OsF6y8OyY
UGNqhx87/uKeMx3yXvphVH7whCaOOfMBlBV3VvPzLHNWH0CYsmW6qk+WXEJDaiVX
gkXEYar6uwu4qK0KOJWMTKgASTlKpXCmSJ9TvIs+ICqCrt1YWLpKcTUwlRysfuwU
NV0=
-----END CERTIFICATE-----
"""
    var info = crypto.x509parse(pem)
    assert "kirito.test" in info["subject"], "x509 subject"
    assert "KiritoOrg" in info["subject"], "x509 org"
    assert "kirito.test" in info["issuer"], "x509 issuer"
    assert len(info["sans"]) == 2, "x509 two SANs"
    assert "kirito.test" in info["sans"] and "www.kirito.test" in info["sans"], "x509 SAN values"
    assert len(info["serial"]) > 0, "x509 serial"

    # --- adversarial ---
    assert raises(Function(): return crypto.aesencrypt(fromhex("0011223344"), "x", iv)), "bad key length"
    assert raises_msg(Function(): return crypto.aesencrypt(random.randombytes(32), "x", Bytes(0)), "iv"), "empty iv"
    # a truncated (non-16-byte) GCM tag is rejected outright — accepting one would weaken forgery
    # resistance (A12-2). aesencrypt always emits a full 16-byte tag.
    var tge = crypto.aesencrypt(key, "data", iv)
    assert len(tge["tag"]) == 16, "gcm tag is 16 bytes"
    assert raises_msg(Function(): return crypto.aesdecrypt(key, tge["ciphertext"], iv, tge["tag"][0:15]), "16 bytes"), "truncated tag rejected"
    assert raises(Function(): return crypto.rsasign("not a pem", "x")), "bad private pem"
    assert raises(Function(): return crypto.rsagenerate(64)), "rsa too small"
    assert raises(Function(): return crypto.x509parse("garbage")), "bad cert"
    assert raises(Function(): return crypto.ecgenerate("not-a-curve")), "bad curve"

    io.print("OK crypto")
