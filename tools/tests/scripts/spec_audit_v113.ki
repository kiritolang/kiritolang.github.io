# Regression golden for the v1.13 audit — the observable core-engine fixes, driven from Kirito.
# (The memory-safety fixes A05-1 / A09-1 are gated as C++/ASan tests in test_audit_v113.cpp; here we
# pin their observable, no-crash behaviour too.)
var io = import("io")

var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True

# --- A03-1: a nested function's parameter default captures the ENCLOSING function's local ---
var z = 100
var make = Function():
    var z = 10
    var g = Function(x, y = z): return x + y   # y default must see F's z = 10, not module z = 100
    return g
assert make()(5) == 15, "A03-1: nested default captures enclosing local (15, not 105)"
# no outer shadow (the bug threw a spurious NameError)
var make2 = Function():
    var q = 7
    var g = Function(x, y = q): return x + y
    return g
assert make2()(3) == 10, "A03-1: nested default, no outer shadow (no NameError)"
# a default referencing an EARLIER nested param still binds to the param
var addparam = Function(a, b = a): return a + b
assert addparam(6) == 12, "A03-1: default referencing an earlier param binds to it"

# --- A04-1: `return` crossing a finally that break/continues must not corrupt an enclosing loop ---
var g1 = Function():
    var out = []
    for i in [1, 2]:
        for j in [10, 20, 30]:
            try:
                return 99
            finally:
                break        # abandons the return, breaks the inner loop
        out.append(i)
    return out
assert g1() == [1, 2], "A04-1: return in try + break in finally preserves the enclosing loop"
var g2 = Function():
    var n = 0
    for i in [1, 2, 3]:
        try:
            return 99
        finally:
            continue         # abandons each return; falls through to `return n`
    return n
assert g2() == 0, "A04-1: return in try + continue in finally"
var g3 = Function():
    for i in [1]:
        try:
            return 42
        finally:
            pass             # a normal finally must still let the return return its value
    return -1
assert g3() == 42, "A04-1: normal finally still returns the value"

# --- A05-1: iterating a String / Bytes materialises fresh handles — none lost under GC ---
var s = ""
for c in "hello":
    s = s + c
assert s == "hello", "A05-1: for over String round-trips"
var bs = []
for b in Bytes([65, 66, 67]):
    bs.append(b)
assert bs == [65, 66, 67], "A05-1: for over Bytes round-trips"

# --- A09-1: a hostile _eq_ mutating the list mid-search must not crash; result stays sane ---
var xs = [1, 2, 3, 4, 5]
class Evil:
    var _eq_ = Function(self, o):
        xs.append(0)         # realloc xs mid-search
        return False
assert not (Evil() in xs), "A09-1: reentrant _eq_ during `in` search — no crash"
assert throws(Function(): return xs.remove(Evil())), "A09-1: remove(no-match) throws cleanly"
assert [1, 2, 3, 2].index(2) == 1, "A09-1: index normal behaviour intact"
assert [1, 2, 3, 2].count(2) == 2, "A09-1: count normal behaviour intact"

# --- A15-1: a second backward() through a RETAINED intermediate must not double the leaf gradient ---
var T = import("tensor")
var x = T.Tensor([1.0, 2.0], requiresgrad = True)
var y = x * x                      # intermediate (non-leaf) — its .grad must not persist across passes
y.sum().backward()
x.zerograd()
y.sum().backward()
assert x.grad.tolist() == [2.0, 4.0], "A15-1: retained-intermediate double backward not doubled"

# --- A25-1 / A25-2: a Float NaN group/merge key must not crash (write-only NaN Dict); None keys kept ---
var pd = import("tabular")
var mm = import("math")
var gdf = pd.DataFrame({"k": [1.0, mm.nan, 2.0, 1.0], "v": [10, 20, 30, 40]})
assert len(gdf.groupby("k").agg({"v": "sum"})) == 2, "A25-1: NaN group key dropped, no crash"
var ndf = pd.DataFrame({"k": [None, 5.0, None], "v": [1, 2, 3]})
assert len(ndf.groupby("k").agg({"v": "sum"})) == 2, "A25-1: None kept as a group key"
var ml = pd.DataFrame({"k": [1.0, 2.0], "a": [10, 20]})
var mr = pd.DataFrame({"k": [1.0, mm.nan], "b": [100, 200]})
assert pd.merge(ml, mr, "k", "left").nrows() == 2, "A25-2: NaN merge key non-matching, no crash"

# --- A26-1: an XML surrogate numeric entity is kept verbatim, never crashes the lenient parser ---
var xml = import("xml")
assert xml.fromstring("<x>&#xD800;</x>").text == "&#xD800;", "A26-1: surrogate entity kept verbatim"

# --- A26-2: partial `>`/`<=` comparators round up per node-semver (>1 -> >=2.0.0, <=1 -> <2.0.0) ---
var sv = import("semver")
assert not sv.satisfies("1.5.0", ">1"), "A26-2: >1 excludes 1.5.0"
assert sv.satisfies("2.0.0", ">1"), "A26-2: >1 includes 2.0.0"
assert not sv.satisfies("1.2.5", ">1.2"), "A26-2: >1.2 excludes 1.2.5"
assert sv.satisfies("1.3.0", ">1.2"), "A26-2: >1.2 includes 1.3.0"
assert sv.satisfies("1.9.9", "<=1"), "A26-2: <=1 includes 1.9.9 (<2.0.0)"
assert not sv.satisfies("2.0.0", "<=1"), "A26-2: <=1 excludes 2.0.0"

io.print("OK audit_v113")
