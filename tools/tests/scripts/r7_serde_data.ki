# r7_serde_data.ki — ROUND-7 exhaustive re-audit of Kirito's data-serialization & compression stdlib:
#   time / json / serialize / dump / zlib / gzip / hash
# against docs/pages/10-stdlib.md and the implementations
#   (stdlib_time.hpp, stdlib_json.hpp, stdlib_serde.hpp [shared flatten/rebuild],
#    stdlib_serialize.hpp [text codec], stdlib_dump.hpp [binary codec], stdlib_zlib.hpp,
#    stdlib_gzip.hpp, stdlib_hash.hpp).
#
# Every function/method/argument is hammered from typical, edge, adversarial, malformed, fuzz and
# round-trip angles. Self-checking: each `ok(cond, msg)` increments a counter; the final line is the
# count. HARD: exit 0, exactly one stdout line, ZERO stderr (no warnings — every dropped value is
# `discard`-ed, no unused locals), DETERMINISTIC (the only RNG is a fixed seed; no clock/network is
# asserted by exact value — only invariants; scratch files are removed).

var io = import("io")
var path = import("path")
var json = import("json")
var serialize = import("serialize")
var dump = import("dump")
var zlib = import("zlib")
var gzip = import("gzip")
var hash = import("hash")
var time = import("time")
var math = import("math")
var sys = import("sys")
var random = import("random")
var matrix = import("matrix")
var complex = import("complex")
var tensor = import("tensor")
var net = import("net")
var regex = import("regex")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1
# True iff f() thrown a catchable error (a clean diagnostic, never a crash).
var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# =====================================================================================  hash
# Known standard digests/checksums (cross-checked against reference values).
ok(hash.md5("") == "d41d8cd98f00b204e9800998ecf8427e", "md5 empty")
ok(hash.md5("abc") == "900150983cd24fb0d6963f7d28e17f72", "md5 abc")
ok(hash.md5("The quick brown fox jumps over the lazy dog") == "9e107d9d372bb6826bd81d3542a419d6", "md5 fox")
ok(hash.sha1("") == "da39a3ee5e6b4b0d3255bfef95601890afd80709", "sha1 empty")
ok(hash.sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d", "sha1 abc")
ok(hash.sha256("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256 empty")
ok(hash.sha256("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad", "sha256 abc")
ok(hash.adler32("") == 1, "adler32 empty")
ok(hash.adler32("abc") == 38600999, "adler32 abc")
ok(hash.adler32("Wikipedia") == 300286872, "adler32 Wikipedia")
ok(hash.crc32("") == 0, "crc32 empty")
ok(hash.crc32("abc") == 891568578, "crc32 abc")
ok(hash.crc32("The quick brown fox jumps over the lazy dog") == 1095738169, "crc32 fox")
ok(hash.crc64("") == 0, "crc64 empty")
ok(hash.crc64("123456789") == -7395533204333446662, "crc64 XZ check-vector signed")
# crc64 top bit can make a value negative (documented: signed Integer)
ok(hash.crc64("123456789") < 0, "crc64 signed negative on top bit")
# String and Bytes give identical digests for equivalent bytes.
ok(hash.md5("abc") == hash.md5(Bytes([97, 98, 99])), "md5 str==bytes")
ok(hash.sha1("hello") == hash.sha1("hello".encode()), "sha1 str==bytes")
ok(hash.sha256("hello") == hash.sha256("hello".encode()), "sha256 str==bytes")
ok(hash.adler32("xyz") == hash.adler32(Bytes([120, 121, 122])), "adler32 str==bytes")
ok(hash.crc32("xyz") == hash.crc32(Bytes([120, 121, 122])), "crc32 str==bytes")
ok(hash.crc64("xyz") == hash.crc64(Bytes([120, 121, 122])), "crc64 str==bytes")
# Digests are 32/40/64 lowercase hex chars.
ok(len(hash.md5("q")) == 32, "md5 length 32")
ok(len(hash.sha1("q")) == 40, "sha1 length 40")
ok(len(hash.sha256("q")) == 64, "sha256 length 64")
# Empty Bytes hashes like empty String.
ok(hash.sha256(Bytes([])) == hash.sha256(""), "sha256 empty bytes")
# A NUL byte is hashed (not treated as a terminator).
ok(hash.md5(Bytes([0])) != hash.md5(""), "md5 NUL byte counted")
# kwargs (data=).
ok(hash.sha256(data = "abc") == hash.sha256("abc"), "hash kwarg data")
ok(hash.crc32(data = "abc") == hash.crc32("abc"), "crc32 kwarg data")
# Non-String/Bytes argument throws.
ok(throws(Function(): return hash.md5(123)), "hash rejects non-bytes arg")

# =====================================================================================  json
# Round-trips: nested dict/list, escapes, unicode, true/false/null, numbers.
var jdata = {"name": "héllo", "nums": [1, 2, 3], "nested": {"a": True, "b": None, "c": False}, "f": 0.5, "neg": -17}
var jback = json.loads(json.dumps(jdata))
ok(jback["name"] == "héllo", "json unicode value rt")
ok(jback["nums"][2] == 3, "json nested list rt")
ok(jback["nested"]["a"] == True, "json nested true")
ok(jback["nested"]["b"] == None, "json nested null")
ok(jback["nested"]["c"] == False, "json nested false")
ok(jback["neg"] == -17, "json negative int rt")
ok(jback["f"] == 0.5, "json float 0.5 rt")
# Float round-trips EXACTLY (shortest-roundtrip digits; Float == is exact).
var fx = 0.1 + 0.2
ok(json.loads(json.dumps(fx)) == fx, "json float exact rt (0.1+0.2)")
ok(json.dumps(0.1 + 0.2) == "0.30000000000000004", "json emits exact roundtrip digits")
# Integer vs Float distinction preserved.
ok(type(json.loads("5")) == "Integer", "json 5 is Integer")
ok(type(json.loads("5.0")) == "Float", "json 5.0 is Float")
ok(type(json.loads("5e2")) == "Float", "json 5e2 is Float")
# Non-finite float spellings round-trip (NaN/Infinity/-Infinity).
ok(json.loads("Infinity") == math.inf, "json bareword Infinity")
ok(json.loads("-Infinity") == -math.inf, "json bareword -Infinity")
ok(math.isnan(json.loads("NaN")), "json bareword NaN")
ok(json.dumps(math.inf) == "Infinity", "json dumps Infinity")
ok(json.dumps(-math.inf) == "-Infinity", "json dumps -Infinity")
ok(json.dumps(math.nan) == "NaN", "json dumps NaN")
# Surrogate pair (astral plane) decodes to one code point.
ok(len(json.loads("\"\\uD83D\\uDE00\"")) == 1, "json surrogate pair -> 1 code point")
# Lone surrogate substitutes U+FFFD (well-formed UTF-8 guaranteed).
ok(json.loads("\"\\uD800\"") == "�", "json lone high surrogate -> U+FFFD")
# Basic \u escape and named escapes.
ok(json.loads("\"\\u0041\"") == "A", "json \\u0041 -> A")
ok(json.loads("\"a\\nb\\tc\"") == "a\nb\tc", "json escaped \\n \\t")
# Control chars are \u-escaped on output (valid JSON).
ok(json.dumps("\n") == "\"\\n\"", "json dumps newline escaped")
ok("\\u0001" in json.dumps(Bytes([1]).decode("latin-1")), "json dumps control char \\u-escaped")
# Empty container shapes.
ok(json.dumps([]) == "[]", "json empty list")
ok(json.dumps({}) == "{}", "json empty dict")
ok(json.loads("[]") == [], "json parse empty list")
ok(len(json.loads("{}")) == 0, "json parse empty dict")
ok(json.dumps([], indent = 2) == "[]", "json indent empty list compact")
ok(json.dumps({}, indent = 2) == "{}", "json indent empty dict compact")
# Pretty-printing: indent>0 inserts newlines; indent<=0 stays compact.
ok("\n" in json.dumps({"a": 1}, indent = 2), "json indent inserts newline")
ok(json.dumps([1, 2]) == json.dumps([1, 2], indent = 0), "json indent 0 == compact")
ok(json.dumps([1, 2]) == json.dumps([1, 2], indent = -3), "json negative indent == compact")
ok(json.loads(json.dumps({"x": [1, {"y": 2}]}, indent = 4))["x"][1]["y"] == 2, "json pretty rt")
# Whitespace tolerance.
ok(json.loads("  [ 1 , 2 ]  ")[1] == 2, "json whitespace tolerated")
# loads/dumps are aliases of parse/stringify.
ok(json.parse("[7]")[0] == 7 and json.loads("[7]")[0] == 7, "json loads alias of parse")
ok(json.stringify([8]) == json.dumps([8]), "json dumps alias of stringify")
# Malformed input throws a clean error.
ok(throws(Function(): return json.parse("")), "json empty string throws")
ok(throws(Function(): return json.parse("{bad}")), "json {bad} throws")
ok(throws(Function(): return json.parse("[1,2")), "json unterminated array throws")
ok(throws(Function(): return json.parse("{\"k\":}")), "json missing value throws")
ok(throws(Function(): return json.parse("[1,2,]extra")), "json trailing chars throws")
ok(throws(Function(): return json.parse("nul")), "json bad literal throws")
ok(throws(Function(): return json.parse("\"unterminated")), "json unterminated string throws")
ok(throws(Function(): return json.parse("{1:2}")), "json non-string key throws")
ok(throws(Function(): return json.parse("0x10")), "json hex rejected")
ok(throws(Function(): return json.parse("+1")), "json leading + rejected")
ok(throws(Function(): return json.parse(".5")), "json leading dot rejected")
# Deeply-nested input throws (depth guard, not stack overflow).
ok(throws(Function(): return json.parse("[" * 2000 + "]" * 2000)), "json deep nesting throws")
# Cyclic / unsupported types throw on stringify.
var jcyc = [1]
discard jcyc.append(jcyc)
ok(throws(Function(): return json.dumps(jcyc)), "json cyclic throws")
ok(throws(Function(): return json.dumps(Bytes([1, 2]))), "json Bytes unsupported throws")
ok(throws(Function(): return json.dumps(Set([1]))), "json Set unsupported throws")
# kwargs.
ok(json.dumps(value = [1], indent = 0) == "[1]", "json dumps kwargs")
ok(json.parse(text = "[2]")[0] == 2, "json parse kwarg text")

# =====================================================================================  serialize + dump
# Helper: a value round-trips identically through BOTH the text (serialize) and binary (dump) codecs.
var bothEq = Function(v):
    return serialize.loads(serialize.dumps(v)) == v and dump.loads(dump.dumps(v)) == v

# Every built-in scalar.
ok(bothEq(None), "serde None")
ok(bothEq(True) and bothEq(False), "serde Bool")
ok(bothEq(0) and bothEq(-1) and bothEq(9223372036854775807), "serde Integer extremes")
ok(bothEq(-9223372036854775808), "serde Integer INT64_MIN")
ok(dump.loads(dump.dumps(0.1 + 0.2)) == 0.1 + 0.2, "serde Float exact (dump)")
ok(serialize.loads(serialize.dumps(0.1 + 0.2)) == 0.1 + 0.2, "serde Float exact (serialize)")
ok(bothEq(""), "serde empty String")
ok(bothEq("héllo\n\t\\\"world"), "serde String with escapes/unicode")
ok(serialize.loads(serialize.dumps("a b  c\nd")) == "a b  c\nd", "serde String w/ spaces+nl (text len-prefix)")
# Float non-finite values survive (binary preserves bits; text uses %.17g).
ok(math.isnan(dump.loads(dump.dumps(math.nan))), "serde NaN (dump)")
ok(dump.loads(dump.dumps(math.inf)) == math.inf, "serde inf (dump)")
ok(serialize.loads(serialize.dumps(math.inf)) == math.inf, "serde inf (serialize)")
ok(math.isnan(serialize.loads(serialize.dumps(math.nan))), "serde NaN (serialize)")
# Collections.
ok(bothEq([1, "two", 3.0, None, True]), "serde mixed List")
ok(bothEq({"k": [1, 2], "n": None, "b": False}), "serde nested Dict")
ok(bothEq(Set([1, 2, 3])), "serde Set")
ok(dump.loads(dump.dumps([])) == [], "serde empty List")
ok(len(dump.loads(dump.dumps({}))) == 0, "serde empty Dict")
ok(len(dump.loads(dump.dumps(Set([])))) == 0, "serde empty Set")
# Type is preserved.
ok(type(dump.loads(dump.dumps(Set([1])))) == "Set", "serde Set stays Set")
ok(type(dump.loads(dump.dumps([1]))) == "List", "serde List stays List")
# Bytes round-trips (documented; via the registered Stateful path) — even with separator bytes.
var rawb = Bytes([0, 32, 10, 255, 32, 13, 32])
ok(dump.loads(dump.dumps(rawb)) == rawb, "serde Bytes (dump)")
ok(serialize.loads(serialize.dumps(rawb)) == rawb, "serde Bytes w/ space+nl bytes (serialize text)")
ok(type(dump.loads(dump.dumps(rawb))) == "Bytes", "serde Bytes stays Bytes")

# dump.dumps returns Bytes; serialize.dumps returns String.
ok(type(dump.dumps([1])) == "Bytes", "dump.dumps -> Bytes")
ok(type(serialize.dumps([1])) == "String", "serialize.dumps -> String")
# dump.loads accepts the Bytes from dumps directly; wrapping in String(...) corrupts -> throws.
ok(dump.loads(dump.dumps([1, 2, 3]))[1] == 2, "dump.loads on Bytes blob")
ok(throws(Function(): return dump.loads(String(dump.dumps([1, 2, 3])))), "dump.loads(String(blob)) corrupts -> throws")
# dump.loads also accepts a String of the same bytes (per impl note) for an ASCII-clean blob path.
ok(dump.loads(dump.dumps(7)) == 7, "dump scalar rt")

# Shared references: a value reachable by two paths stays ONE object after load.
var sharedInner = [1, 2, 3]
var sharedOuter = [sharedInner, sharedInner]
var dShared = dump.loads(dump.dumps(sharedOuter))
ok(id(dShared[0]) == id(dShared[1]), "dump preserves shared identity")
discard dShared[0].append(99)
ok(dShared[1][3] == 99, "dump shared mutation visible via both paths")
var sShared = serialize.loads(serialize.dumps(sharedOuter))
discard sShared[0].append(99)
ok(id(sShared[0]) == id(sShared[1]) and sShared[1][3] == 99, "serialize preserves shared identity")
# A shared Dict value.
var sd = {"v": 1}
var dsd = dump.loads(dump.dumps({"a": sd, "b": sd}))
ok(id(dsd["a"]) == id(dsd["b"]), "dump shared dict identity")

# Cycles: a list containing itself, and a dict referencing itself.
var cyc = [1]
discard cyc.append(cyc)
var dcyc = dump.loads(dump.dumps(cyc))
ok(len(dcyc) == 2 and id(dcyc[1]) == id(dcyc), "dump self-cycle terminates+links")
var scyc = serialize.loads(serialize.dumps(cyc))
ok(id(scyc[1]) == id(scyc), "serialize self-cycle links")
var dcyc2 = {"self": None}
dcyc2["self"] = dcyc2
var rdcyc2 = dump.loads(dump.dumps(dcyc2))
ok(id(rdcyc2["self"]) == id(rdcyc2), "dump dict self-cycle")

# User class: plain attributes (reconstructed by class name; _init_ not re-run).
class Point:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
var pt = Point(3, 4)
var dpt = dump.loads(dump.dumps(pt))
ok(type(dpt) == "Point" and dpt.x == 3 and dpt.y == 4, "dump user-class by attributes")
var spt = serialize.loads(serialize.dumps(pt))
ok(spt.x == 3 and spt.y == 4, "serialize user-class by attributes")
# Nested + shared user instance.
var pair = [pt, pt]
var dpair = dump.loads(dump.dumps(pair))
ok(id(dpair[0]) == id(dpair[1]), "dump shared instance identity")

# User class with _getstate_/_setstate_ (drop a transient field, recompute on load).
class Temp:
    var _init_ = Function(self, c):
        self.celsius = c
        self.cached = c * 9 / 5 + 32
    var _getstate_ = Function(self):
        return self.celsius
    var _setstate_ = Function(self, state):
        self.celsius = state
        self.cached = state * 9 / 5 + 32
var tmp = Temp(100)
var dtmp = dump.loads(dump.dumps(tmp))
ok(dtmp.celsius == 100 and dtmp.cached.compare(212.0), "dump _getstate_/_setstate_ rt")
var stmp = serialize.loads(serialize.dumps(tmp))
ok(stmp.celsius == 100 and stmp.cached.compare(212.0), "serialize _getstate_/_setstate_ rt")

# Native value types round-trip (standalone and nested).
var mx = matrix.Matrix([[1.0, 2.0], [3.0, 4.0]])
ok(dump.loads(dump.dumps(mx)) == mx, "dump Matrix")
ok(serialize.loads(serialize.dumps(mx)) == mx, "serialize Matrix")
var vec = matrix.vector([1.0, 2.0, 3.0])
ok(dump.loads(dump.dumps(vec)) == vec, "dump Vector")
var cx = complex.Complex(3, 4)
ok(dump.loads(dump.dumps(cx)) == cx, "dump Complex")
ok(serialize.loads(serialize.dumps(cx)) == cx, "serialize Complex")
var cm = complex.Matrix([[complex.Complex(1, 1), complex.Complex(2, -2)]])
ok(dump.loads(dump.dumps(cm)) == cm, "dump ComplexMatrix")
var tn = tensor.Tensor([[1.0, 2.0], [3.0, 4.0]])
ok(dump.loads(dump.dumps(tn)) == tn, "dump grad-free Tensor")
ok(serialize.loads(serialize.dumps(tn)) == tn, "serialize grad-free Tensor")
# A DateTime nested inside a Dict.
var ndt = time.make(2024, 1, 15, 12, 0, 0)
ok(dump.loads(dump.dumps({"when": ndt}))["when"] == ndt, "dump nested DateTime")

# Random round-trip restores the EXACT stream (a reproducible checkpoint).
var rng = random.Random(12345)
discard rng.random()
discard rng.random()
var rng2 = dump.loads(dump.dumps(rng))
ok(rng.random() == rng2.random(), "dump Random stream continues identically")
var rng3 = serialize.loads(serialize.dumps(rng))
ok(rng.random() == rng3.random(), "serialize Random stream continues identically")

# A grad-tracking Tensor must NOT serialize (detach first); a detached one does.
var tg = tensor.zeros([2, 2], requiresgrad = True)
ok(throws(Function(): return dump.dumps(tg)), "dump grad Tensor throws")
ok(dump.loads(dump.dumps(tg.detach())) == tg.detach(), "dump detached Tensor rt")

# Resource-like natives throw a clean error (never crash).
ok(throws(Function(): return dump.dumps(net.Socket())), "dump Socket throws")
ok(throws(Function(): return serialize.dumps(net.Socket())), "serialize Socket throws")
ok(throws(Function(): return dump.dumps(io.BytesIO())), "dump BytesIO throws")
ok(throws(Function(): return dump.dumps(regex.compile("a+"))), "dump regex Pattern throws")
ok(throws(Function(): return serialize.dumps(regex.compile("a+"))), "serialize regex Pattern throws")
ok(throws(Function(): return dump.dumps(net.Session())), "dump Session throws")
# An open file throws (and clean up).
var tmpFile = path.join(path.gettempdir(), "r7_serde_openfile.txt")
var ofh = io.open(tmpFile, "w")
ok(throws(Function(): return dump.dumps(ofh)), "dump open file throws")
ofh.close()
discard path.remove(tmpFile, missing_ok = True)
# A Function (bare callable) is not serializable.
ok(throws(Function(): return dump.dumps(Function(): return 1)), "dump Function throws")

# Corrupt / truncated / malformed blobs throw a CLEAN diagnostic (bounds-checked).
ok(throws(Function(): return dump.loads(Bytes([1, 2, 3, 4, 5]))), "dump bad magic throws")
ok(throws(Function(): return dump.loads(Bytes([]))), "dump empty blob throws")
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1]))), "dump truncated (header only) throws")
# KDMP + version 1 + claimed count far exceeding data -> rejected before allocating.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 255, 255, 255, 255]))), "dump huge count rejected")
ok(throws(Function(): return serialize.loads("GARBAGE 5 stuff")), "serialize bad header throws")
ok(throws(Function(): return serialize.loads("")), "serialize empty throws")
ok(throws(Function(): return serialize.loads("KSER1 999999999999 X")), "serialize bad count throws")
ok(throws(Function(): return serialize.loads("KSER1 1 I notanumber 0")), "serialize malformed number throws")
# A dump blob truncated mid-stream throws (not a crash).
var goodBlob = dump.dumps([1, 2, 3, 4, 5])
ok(throws(Function(): return dump.loads(goodBlob[0:8])), "dump truncated-good-blob throws")

# File save/load round-trip (scratch dir; cleaned up).
var serPath = path.join(path.gettempdir(), "r7_serde_text.kser")
var dmpPath = path.join(path.gettempdir(), "r7_serde_bin.kdmp")
discard serialize.save([1, "two", 3.0, {"k": True}], serPath)
ok(serialize.load(serPath)[1] == "two", "serialize.save/load file rt")
ok(serialize.load(serPath)[3]["k"] == True, "serialize.save/load nested")
discard dump.save({"a": [None, False], "b": Set([1, 2])}, dmpPath)
ok(dump.load(dmpPath)["a"][1] == False, "dump.save/load file rt")
ok(2 in dump.load(dmpPath)["b"], "dump.save/load Set member")
discard path.remove(serPath, missing_ok = True)
discard path.remove(dmpPath, missing_ok = True)
# Loading a missing file throws.
ok(throws(Function(): return serialize.load(path.join(path.gettempdir(), "r7_does_not_exist.kser"))), "serialize.load missing throws")
ok(throws(Function(): return dump.load(path.join(path.gettempdir(), "r7_does_not_exist.kdmp"))), "dump.load missing throws")

# kwargs across the serde signatured functions.
ok(serialize.loads(text = serialize.dumps(value = [5, 6]))[0] == 5, "serialize kwargs")
ok(dump.loads(data = dump.dumps(value = [9, 8, 7]))[0] == 9, "dump kwargs")

# serialize(text) and dump(binary) AGREE on the same nontrivial input.
var agree = {"list": [1, 2, 3], "set": Set(["a", "b"]), "inst": Point(7, 8), "by": Bytes([1, 2, 3])}
var sA = serialize.loads(serialize.dumps(agree))
var dA = dump.loads(dump.dumps(agree))
ok(sA["list"] == dA["list"] and sA["inst"].x == dA["inst"].x and sA["by"] == dA["by"], "serialize/dump agree")

# =====================================================================================  zlib
# Round-trip: String and Bytes, same TYPE out.
var zmsg = "The quick brown fox jumps over the lazy dog. " * 40
ok(zlib.decompress(zlib.compress(zmsg)) == zmsg, "zlib String rt")
ok(type(zlib.compress(zmsg)) == "String", "zlib String -> String")
var zb = zmsg.encode()
ok(zlib.decompress(zlib.compress(zb)) == zb, "zlib Bytes rt")
ok(type(zlib.compress(zb)) == "Bytes", "zlib Bytes -> Bytes")
ok(type(zlib.decompress(zlib.compress(zb))) == "Bytes", "zlib Bytes decompress -> Bytes")
# Empty input.
ok(zlib.decompress(zlib.compress("")) == "", "zlib empty String rt")
ok(zlib.decompress(zlib.compress(Bytes([]))) == Bytes([]), "zlib empty Bytes rt")
# High compression ratio on repetitive input.
ok(len(zlib.compress("x" * 100000)) < 1000, "zlib high ratio on repetitive")
# Raw DEFLATE round-trip (no zlib header).
ok(zlib.inflate(zlib.deflate(zmsg)) == zmsg, "zlib raw deflate/inflate rt")
ok(zlib.inflate(zlib.deflate(zb)) == zb, "zlib raw deflate Bytes rt")
ok(type(zlib.deflate(zb)) == "Bytes", "zlib deflate Bytes -> Bytes")
# A zlib stream has a header that raw deflate does not, so they are distinct formats.
ok(zlib.compress(zmsg) != zlib.deflate(zmsg), "zlib stream != raw deflate")
ok(throws(Function(): return zlib.inflate(zlib.compress(zmsg))), "inflate on zlib stream throws (header in the way)")
ok(throws(Function(): return zlib.decompress(zlib.deflate(zmsg))), "decompress on raw deflate throws (no header)")
# Corrupt data throws.
ok(throws(Function(): return zlib.decompress("not a zlib stream at all")), "zlib corrupt throws")
ok(throws(Function(): return zlib.inflate(Bytes([255, 255, 255, 255]))), "zlib inflate garbage throws")
ok(throws(Function(): return zlib.decompress(Bytes([]))), "zlib decompress empty throws")
# A valid stream with a flipped tail byte (corrupted) throws (Adler-32 / data check).
var zc = zlib.compress(zb)
var zcorrupt = zc[0:len(zc) - 1] + Bytes([(zc[len(zc) - 1] + 1) % 256])
ok(throws(Function(): return zlib.decompress(zcorrupt)), "zlib corrupted tail throws")
# Non-bytes argument throws.
ok(throws(Function(): return zlib.compress(123)), "zlib rejects non-bytes")
# kwargs.
ok(zlib.decompress(data = zlib.compress(data = "hi")) == "hi", "zlib kwargs data")

# =====================================================================================  gzip
# Round-trip: String and Bytes, same TYPE out.
ok(gzip.decompress(gzip.compress(zmsg)) == zmsg, "gzip String rt")
ok(type(gzip.compress(zmsg)) == "String", "gzip String -> String")
ok(gzip.decompress(gzip.compress(zb)) == zb, "gzip Bytes rt")
ok(type(gzip.compress(zb)) == "Bytes", "gzip Bytes -> Bytes")
# Aliases gzip/gunzip.
ok(gzip.gunzip(gzip.gzip(zb)) == zb, "gzip/gunzip aliases rt")
ok(gzip.gzip(zb) == gzip.compress(zb), "gzip alias == compress")
# Empty input.
ok(gzip.decompress(gzip.compress("")) == "", "gzip empty rt")
ok(gzip.decompress(gzip.compress(Bytes([]))) == Bytes([]), "gzip empty Bytes rt")
# Valid gzip magic header (0x1f 0x8b 0x08).
var gz = gzip.compress(zb)
ok(gz[0] == 31 and gz[1] == 139 and gz[2] == 8, "gzip header magic+CM")
# Multi-member: concatenated gzip members decompress to the concatenation (gunzip semantics).
ok(gzip.decompress(gzip.compress("AAA".encode()) + gzip.compress("BBB".encode())).decode() == "AAABBB", "gzip multi-member")
# Truncated / corrupt streams throw.
ok(throws(Function(): return gzip.decompress("not gzip")), "gzip corrupt throws")
ok(throws(Function(): return gzip.decompress(gz[0:10])), "gzip truncated throws")
ok(throws(Function(): return gzip.decompress(Bytes([31, 139, 8]))), "gzip header-only throws")
# A flipped CRC/ISIZE trailer byte throws.
var gzc = gz[0:len(gz) - 1] + Bytes([(gz[len(gz) - 1] + 1) % 256])
ok(throws(Function(): return gzip.decompress(gzc)), "gzip corrupted trailer throws")
# Cross-container rejection: gzip != zlib, neither decodes the other.
ok(throws(Function(): return gzip.decompress(zlib.compress(zb))), "gzip on zlib stream throws")
ok(throws(Function(): return zlib.decompress(gzip.compress(zb))), "zlib on gzip stream throws")
# kwargs.
ok(gzip.decompress(data = gzip.compress(data = "hi")) == "hi", "gzip kwargs data")

# =====================================================================================  time (determinism-safe)
# Fixed instant 2024-01-15 12:30:45 UTC.
var dt = time.make(2024, 1, 15, 12, 30, 45)
ok(dt.iso() == "2024-01-15T12:30:45", "DateTime iso fixed instant")
ok(dt.isoformat() == dt.iso(), "isoformat alias of iso")
ok(dt.year == 2024 and dt.month == 1 and dt.day == 15, "DateTime y/m/d fields")
ok(dt.hour == 12 and dt.minute == 30 and dt.second == 45, "DateTime h/m/s fields")
ok(dt.timestamp == 1705321845, "DateTime epoch seconds")
ok(dt.weekday == 1, "DateTime weekday (Mon=1, Sun=0 convention)")
ok(dt.yearday == 15, "DateTime yearday")
ok(dt.format("%Y/%m/%d %H:%M:%S") == "2024/01/15 12:30:45", "DateTime format codes")
ok(dt.format("%Y") == "2024", "DateTime format %Y")
# datetime(epoch) reconstructs the same instant; equality by instant.
ok(time.datetime(dt.timestamp) == dt, "datetime(epoch) == make")
# make normalizes out-of-range components (mktime-style rollover), no throw.
ok(time.make(2024, 13, 1).iso() == "2025-01-01T00:00:00", "make month 13 -> next year Jan")
ok(time.make(2024, 1, 32).iso() == "2024-02-01T00:00:00", "make day 32 -> Feb 1")
ok(time.make(2024, 1, 1, 25).hour == 1, "make hour 25 -> rolls a day")
# make defaults (hour/minute/second = 0).
ok(time.make(2024, 6, 1).iso() == "2024-06-01T00:00:00", "make default time fields")
# Pre-1970 (negative epoch) handled identically.
var old = time.make(1960, 1, 1, 0, 0, 0)
ok(old.timestamp < 0, "pre-1970 epoch negative")
ok(old.iso() == "1960-01-01T00:00:00", "pre-1970 iso")
# strptime parses fixed text; STRICT on mismatch / out-of-range / trailing input.
ok(time.strptime("2024-01-15 12:30:45", "%Y-%m-%d %H:%M:%S") == dt, "strptime round-trips make")
ok(time.strptime("2024-06-01", "%Y-%m-%d").iso() == "2024-06-01T00:00:00", "strptime date-only")
ok(throws(Function(): return time.strptime("2024-99-99", "%Y-%m-%d")), "strptime out-of-range month/day throws")
ok(throws(Function(): return time.strptime("2024-01-01", "%Y/%m/%d")), "strptime literal mismatch throws")
ok(throws(Function(): return time.strptime("2024-01-01XYZ", "%Y-%m-%d")), "strptime trailing input throws")
ok(throws(Function(): return time.strptime("2024-01-32", "%Y-%m-%d")), "strptime day 32 throws")
ok(throws(Function(): return time.strptime("2024-01-01 25:00:00", "%Y-%m-%d %H:%M:%S")), "strptime hour 25 throws")
# DateTime arithmetic.
ok(dt.add(3600).hour == 13, "DateTime add 1h")
ok(dt.sub(3600).hour == 11, "DateTime sub 1h")
ok(dt.add(86400).day == 16, "DateTime add 1 day")
ok(dt.add(100).diff(dt) == 100, "DateTime diff forward")
ok(dt.diff(dt.add(100)) == -100, "DateTime diff backward (signed)")
ok(dt.add(3600).timestamp == dt.timestamp + 3600, "DateTime add shifts epoch")
# add accepts a Float number of seconds.
ok(dt.add(60.0).minute == 31, "DateTime add Float seconds")
# diff requires a DateTime; add/sub require a number.
ok(throws(Function(): return dt.diff(5)), "DateTime diff non-DateTime throws")
ok(throws(Function(): return dt.add("x")), "DateTime add non-number throws")
# Value equality + hashing by instant: two DateTimes for the same instant are equal and hash alike.
var dtA = time.make(2000, 6, 1, 0, 0, 0)
var dtB = time.datetime(dtA.timestamp)
ok(dtA == dtB, "DateTime equality by instant")
ok(dtA != dt, "DateTime inequality different instant")
var dthash = {}
dthash[dtA] = "x"
ok(dthash[dtB] == "x", "DateTime usable as Dict key (hash by instant)")
var dtset = Set([dtA, dtB])
ok(len(dtset) == 1, "DateTime equal instants collapse in a Set")
# DateTime is serializable through both formats (by epoch).
ok(dump.loads(dump.dumps(dt)) == dt, "DateTime dump rt")
ok(serialize.loads(serialize.dumps(dt)) == dt, "DateTime serialize rt")
# Clock invariants (NO exact wall-clock asserts — only monotonicity / positivity / type).
ok(time.monotonic() >= 0.0, "monotonic non-negative")
var m1 = time.monotonic()
var m2 = time.monotonic()
ok(m2 >= m1, "monotonic non-decreasing")
var pc1 = time.perfcounterns()
var pc2 = time.perfcounterns()
ok(pc2 >= pc1, "perfcounterns non-decreasing")
ok(type(time.monotonic()) == "Float", "monotonic -> Float")
ok(type(time.perfcounterns()) == "Integer", "perfcounterns -> Integer")
ok(time.time() > 0.0, "time() positive")
ok(type(time.time()) == "Float", "time() -> Float")
ok(time.timens() > 0, "timens() positive")
ok(type(time.timens()) == "Integer", "timens() -> Integer")
# sleep(0) is a no-op that returns None (do not sleep a real interval).
ok(time.sleep(0) == None, "sleep(0) returns None")
ok(time.sleep(-1) == None, "sleep negative no-op")
# now()/datetime()/datetime(None) all yield a DateTime.
ok(type(time.now()) == "DateTime", "now() -> DateTime")
ok(type(time.datetime()) == "DateTime", "datetime() -> DateTime")
ok(type(time.datetime(None)) == "DateTime", "datetime(None) -> DateTime")
# datetime rejects NaN / infinity timestamps.
ok(throws(Function(): return time.datetime(math.nan)), "datetime(NaN) throws")
ok(throws(Function(): return time.datetime(math.inf)), "datetime(inf) throws")
# time.make kwargs (any order).
ok(time.make(day = 15, month = 1, year = 2024, second = 45, hour = 12, minute = 30) == dt, "time.make kwargs out of order")
ok(time.strptime(format = "%Y-%m-%d", text = "2024-06-01").iso() == "2024-06-01T00:00:00", "strptime kwargs")

# =====================================================================================  fuzz (deterministic)
# Random byte payloads through zlib / gzip / dump round-trips — fixed seed, no clock/network.
var fr = random.Random(98765)
var fuzzZlib = True
var fuzzGzip = True
var fuzzDump = True
var fi = 0
while fi < 40:
    var sz = fr.randint(0, 300)
    var arr = []
    var fj = 0
    while fj < sz:
        discard arr.append(fr.randint(0, 255))
        fj = fj + 1
    var payload = Bytes(arr)
    if zlib.decompress(zlib.compress(payload)) != payload:
        fuzzZlib = False
    if gzip.decompress(gzip.compress(payload)) != payload:
        fuzzGzip = False
    if dump.loads(dump.dumps(payload)) != payload:
        fuzzDump = False
    fi = fi + 1
ok(fuzzZlib, "fuzz: zlib round-trip on 40 random byte payloads")
ok(fuzzGzip, "fuzz: gzip round-trip on 40 random byte payloads")
ok(fuzzDump, "fuzz: dump round-trip on 40 random byte payloads")
# Fuzz raw deflate/inflate as well.
var fuzzRaw = True
var ri = 0
while ri < 20:
    var rs = fr.randint(0, 200)
    var ra = []
    var rj = 0
    while rj < rs:
        discard ra.append(fr.randint(0, 255))
        rj = rj + 1
    var rp = Bytes(ra)
    if zlib.inflate(zlib.deflate(rp)) != rp:
        fuzzRaw = False
    ri = ri + 1
ok(fuzzRaw, "fuzz: raw deflate/inflate round-trip")
# Fuzz a nested structure of random scalars through both serde formats.
var fuzzStruct = True
var si = 0
while si < 20:
    var d = {}
    var sj = 0
    while sj < fr.randint(1, 6):
        d[String(sj)] = [fr.randint(-1000000, 1000000), fr.random(), sj % 2 == 0]
        sj = sj + 1
    if serialize.loads(serialize.dumps(d)) != d or dump.loads(dump.dumps(d)) != d:
        fuzzStruct = False
    si = si + 1
ok(fuzzStruct, "fuzz: nested struct round-trip (both formats)")

io.print("r7_serde_data: " + String(n) + " checks passed")
