# Adversarial audit of the `time` module: clocks, DateTime fields/methods, normalization, arithmetic,
# strptime parsing, equality+hashing, and serialization round-trip.
var io = import("io")
var time = import("time")

# --- clocks: types + ordering + relation between time/timens and monotonic/perfcounterns ---
assert type(time.time()) == "Float", "time() Float"
assert type(time.timens()) == "Integer", "timens() Integer"
assert type(time.monotonic()) == "Float", "monotonic() Float"
assert type(time.perfcounterns()) == "Integer", "perfcounterns() Integer"
assert time.time() > 1000000000.0, "time() is a recent epoch"
assert time.timens() > 1000000000 * 1000000000, "timens() is a recent epoch in nanoseconds"

# monotonic never goes backwards across short bursts
var prev = time.monotonic()
var i = 0
while i < 200:
    var cur = time.monotonic()
    assert cur >= prev, "monotonic never decreases"
    prev = cur
    i = i + 1

# Same for perfcounterns
var pprev = time.perfcounterns()
var k = 0
while k < 200:
    var cur = time.perfcounterns()
    assert cur >= pprev, "perfcounterns never decreases"
    pprev = cur
    k = k + 1

# sleep advances the clock by approximately the right amount (loose to avoid flakiness)
var s0 = time.monotonic()
time.sleep(0.02)
var s1 = time.monotonic()
assert s1 - s0 >= 0.01, "sleep advances monotonic by at least ~10ms"
# sleep(0) is a no-op
time.sleep(0)
time.sleep(0.0)
# negative durations are silently ignored (no error per impl)
time.sleep(-1)

# --- DateTime construction + every documented attribute ---
var dt = time.make(2024, 1, 15, 10, 30, 45)
assert dt.year == 2024, "year"
assert dt.month == 1, "month"
assert dt.day == 15, "day"
assert dt.hour == 10, "hour"
assert dt.minute == 30, "minute"
assert dt.second == 45, "second"
# weekday is 0=Sunday..6=Saturday (tm_wday convention); 2024-01-15 is a Monday -> 1
assert type(dt.weekday) == "Integer", "weekday is Integer"
assert dt.weekday >= 0 and dt.weekday <= 6, "weekday in 0..6"
# yearday: 1-based day-of-year; Jan 15 -> 15
assert dt.yearday == 15, "yearday Jan 15 -> 15"
assert type(dt.timestamp) == "Integer", "timestamp Integer attribute"
# Unix epoch matches a known constant
assert time.make(2020, 1, 1, 0, 0, 0).timestamp == 1577836800, "epoch of 2020-01-01"
assert time.make(1970, 1, 1, 0, 0, 0).timestamp == 0, "epoch of 1970-01-01"

# defaults: make(y, m, d) with no hour/minute/second
var d3 = time.make(2024, 3, 4)
assert d3.hour == 0 and d3.minute == 0 and d3.second == 0, "make defaults H=M=S=0"

# --- C mktime-style normalization (doc'd promise) ---
var nm = time.make(2024, 13, 1)            # month 13 -> Jan of next year
assert nm.year == 2025 and nm.month == 1, "month 13 -> Jan next year"
var nm2 = time.make(2024, 1, 32)            # day 32 -> 1st of next month
assert nm2.month == 2 and nm2.day == 1, "day 32 -> Feb 1"
var nm3 = time.make(2024, 1, 1, 25, 0, 0)   # hour 25 -> +1 day, hour 1
assert nm3.day == 2 and nm3.hour == 1, "hour 25 wraps to next day"

# --- ISO / format ---
assert dt.iso() == "2024-01-15T10:30:45", "iso shape"
assert dt.isoformat() == dt.iso(), "isoformat is an alias"
assert dt.format("%Y-%m-%d") == "2024-01-15", "format %Y-%m-%d"
assert dt.format("%H:%M:%S") == "10:30:45", "format %H:%M:%S"
assert dt.format("plain text") == "plain text", "literal text passes through"

# --- arithmetic: add/sub/diff (in seconds) ---
var a = time.make(2024, 1, 1)
var b = a.add(86400)
assert b.day == 2, "add(86400) advances one day"
assert b.diff(a) == 86400, "diff is +86400"
var c = a.sub(60)
assert c.diff(a) == -60, "sub(60) leaves -60 second diff"
# Float seconds also accepted
var f = a.add(3600.5)
assert f.hour == 1, "add float seconds truncates to int"

# --- strptime ---
var p = time.strptime("2024-06-01 13:30:45", "%Y-%m-%d %H:%M:%S")
assert p.year == 2024 and p.month == 6 and p.day == 1 and p.hour == 13, "strptime fields"
# round-trip iso() -> strptime() -> same epoch
var rt = time.strptime(dt.iso(), "%Y-%m-%dT%H:%M:%S")
assert rt.timestamp == dt.timestamp, "iso() -> strptime round-trip"
# bad text/format throws
var thrown = False
try:
    discard time.strptime("not-a-date", "%Y-%m-%d")
catch as e:
    thrown = True
assert thrown, "strptime rejects bad text"
thrown = False
try:
    discard time.strptime("2024", "%Z")    # unsupported directive
catch as e:
    thrown = True
assert thrown, "strptime rejects unsupported directive"

# --- equality + hashability by instant ---
var d1 = time.make(2024, 1, 1, 0, 0, 0)
var d2 = time.make(2024, 1, 1, 0, 0, 0)
assert d1 == d2, "DateTimes equal when epoch equal"
assert d1 != time.make(2024, 1, 1, 0, 0, 1), "DateTimes unequal when epoch differs"
# usable as a Dict / Set key
var ss = {d1, d2, time.make(2024, 1, 1, 0, 0, 1)}
assert len(ss) == 2, "DateTime hashable in a Set (two distinct instants)"
var dd = {}
dd[d1] = "a"
assert dd[d2] == "a", "DateTime usable as a Dict key"

# --- datetime(0) -> 1970-01-01 epoch start ---
var epoch = time.datetime(0)
assert epoch.year == 1970 and epoch.month == 1 and epoch.day == 1, "datetime(0) = epoch"
# datetime() (no arg) is now() equivalent
var now1 = time.datetime()
assert now1.year >= 2024, "datetime() defaults to now"
# datetime(None) also works
var now2 = time.datetime(None)
assert now2.year >= 2024, "datetime(None) defaults to now"

# --- serialization (a documented promise: DateTime is serialize/dump-safe) ---
var dump = import("dump")
var blob = dump.dumps(dt)
var dt2 = dump.loads(blob)
assert dt2 == dt, "DateTime round-trips through dump"
assert dt2.iso() == dt.iso(), "DateTime fields survive dump round-trip"

io.print("OK audit-time")
