# Socket-foundation primitives (UDP, socketpair, options, address introspection, name resolution)
# exercised end-to-end through the Kirito `net` surface — all in-process on 127.0.0.1, fully
# deterministic (no external network, no ports printed). Any failed assert aborts with a diagnostic;
# the success path prints exactly one line.
var net = import("net")
var io = import("io")

var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True

# --- UDP loopback: sendto / recvfrom carry the datagram + the sender address ---
var rx = net.udpsocket()
rx.bind("127.0.0.1", 0)
rx.settimeout(5)
var port = rx.getsockname()[1]
assert port > 0, "ephemeral UDP port assigned"
var tx = net.udpsocket()
assert tx.sendto("ping", "127.0.0.1", port) == 4, "sendto returns the byte count"
var got = rx.recvfrom(64)
assert got[0].decode() == "ping", "recvfrom payload"
assert got[1][0] == "127.0.0.1", "recvfrom reports the sender host"
rx.close()
tx.close()

# --- datagrams are binary-safe (NUL / 0xFF / CR-LF round-trip byte-exact) ---
var r2 = net.udpsocket()
r2.bind("127.0.0.1", 0)
r2.settimeout(5)
var p2 = r2.getsockname()[1]
var t2 = net.udpsocket()
var blob = Bytes([0, 255, 128, 10, 13, 0, 7])
discard t2.sendto(blob, "127.0.0.1", p2)
assert r2.recvfrom(64)[0] == blob, "binary datagram round-trips exactly"
r2.close()
t2.close()

# --- socketpair: a connected, share-nothing stream pair, bytes both directions ---
var pair = net.socketpair()
discard pair[0].send("ab")
assert pair[1].recv(2).decode() == "ab", "socketpair a -> b"
discard pair[1].send("ba")
assert pair[0].recv(2).decode() == "ba", "socketpair b -> a"
pair[0].close()
pair[1].close()

# --- introspection attributes ---
assert net.udpsocket().type == "dgram", "udp socket type"
assert net.tcpsocket().type == "stream", "tcp socket type"
assert net.Socket().family == "inet", "default family is inet"

# --- TCP connect + getpeername/getsockname agree on the peer's local address ---
var srv = net.tcpsocket()
srv.bind("127.0.0.1", 0)
srv.listen(1)
var sport = srv.getsockname()[1]
var cli = net.tcpsocket()
cli.connect("127.0.0.1", sport)
var conn = srv.accept()
assert conn.getpeername()[1] == cli.getsockname()[1], "peer port == client's local port"
# half-close the client's write side; the server then reads EOF
discard cli.send("hi")
cli.shutdown("write")
assert conn.recv(8).decode() == "hi", "data before shutdown arrives"
assert len(conn.recv(8)) == 0, "shutdown(write) surfaces as EOF at the peer"
srv.close()
cli.close()
conn.close()

# --- string-keyed socket options round-trip ---
var s = net.tcpsocket()
s.setsockopt("reuseaddr", 1)
assert s.getsockopt("reuseaddr") != 0, "reuseaddr set via setsockopt"
s.setnodelay(True)
assert s.getsockopt("nodelay") != 0, "nodelay set via named helper"
assert s.getsockopt("type") == 1, "SO_TYPE reports SOCK_STREAM"
assert s.getsockopt("error") == 0, "SO_ERROR is 0 on a fresh socket"
s.close()

# --- name resolution (numeric, no DNS) ---
assert len(net.gethostname()) > 0, "gethostname is non-empty"
assert net.gethostbyname("127.0.0.1") == "127.0.0.1", "gethostbyname of a literal is identity"
var ai = net.getaddrinfo("127.0.0.1", 80)
assert ai[0]["host"] == "127.0.0.1", "getaddrinfo host"
assert ai[0]["port"] == 80, "getaddrinfo port"

# --- adversarial: bad inputs throw cleanly (never crash / hang) ---
assert throws(Function(): return net.socket("bogus", "stream")), "unknown family throws"
assert throws(Function(): return net.socket("inet", "raw")), "unknown type throws"
assert throws(Function(): return net.tcpsocket().setsockopt("nope", 1)), "unknown option throws"
assert throws(Function(): return net.udpsocket().sendto("x", "127.0.0.1", 99999)), "port out of range throws"
assert throws(Function(): return net.udpsocket().recvfrom(-1)), "negative recvfrom size throws"
assert throws(Function(): return net.tcpsocket().shutdown("sideways")), "bad shutdown how throws"
assert throws(Function(): return net.tcpsocket().getpeername()), "getpeername on an unconnected socket throws"
var dead = net.tcpsocket()
dead.close()
assert throws(Function(): return dead.recv(4)), "recv on a closed socket throws"
assert throws(Function(): return dead.getsockname()), "getsockname on a closed socket throws"

io.print("OK net_primitives")
