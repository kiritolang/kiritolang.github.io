var io = import("io")
var C = import("complex")
io.print(String(C.of(1, 2) + C.of(3, 4)))
io.print(String(C.of(1, 2) * C.of(3, 4)))
io.print(String(C.of(5, 0) - C.of(2, 3)))
io.print(String(C.of(1, 1) / C.of(1, 1)))
io.print(String(C.of(2, 3).conjugate()))
io.print(String(C.of(3, 4).norm2()))
io.print(String(C.of(1, 2) == C.of(1, 2)))
