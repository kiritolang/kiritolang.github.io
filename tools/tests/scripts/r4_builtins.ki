# Exhaustive + adversarial spec for the non-numeric builtin functions:
#   range, sum, min, max, sorted, enumerate, zip, map, filter, len, type, inspect,
#   all, any, reversed, isinstance, import.
# Typical use, edges (empty/single/huge/negative/kwargs/nested), and malformed/wrong-type input
# (asserted to RAISE via `throws`). Output: a deterministic "OK" plus an assertion count.
var io = import("io")

var throws = Function(f):
    try:
        discard f()
        return False
    catch as e:
        return True

# Named helpers (an inline Function as a non-final call arg would swallow the closing paren).
var neg = Function(x): return -x
var lenf = Function(x): return len(x)
var firstf = Function(p): return p[0]
var upperf = Function(c): return c.upper()
var inc = Function(x): return x + 1
var gt2 = Function(x): return x > 2
var n = 0
var check = Function(cond, msg):
    n = n + 1
    assert cond, msg

# =====================================================================
# len
# =====================================================================
check(len("abc") == 3, "len String")
check(len("") == 0, "len empty String")
check(len("café") == 4, "len counts code points not bytes")
check(len([1, 2, 3]) == 3 and len([]) == 0, "len List")
check(len({1, 2, 3}) == 3 and len(Set([])) == 0, "len Set")
check(len({"a": 1, "b": 2}) == 2 and len({}) == 0, "len Dict")
check(len(Bytes([1, 2, 3])) == 3, "len Bytes")
check(len(range(10)) == 10, "len of materialized range")
check(len(x = [1, 2]) == 2, "len keyword form")
check(throws(Function(): return len(5)), "len Integer throws")
check(throws(Function(): return len(None)), "len None throws")
check(throws(Function(): return len(True)), "len Bool throws")
check(throws(Function(): return len(io.print)), "len function throws")
check(throws(Function(): return len()), "len no-arg throws")
check(throws(Function(): return len([1], x = [2])), "len duplicate arg throws")

# =====================================================================
# range  (variadic by position; also names start/stop/step)
# =====================================================================
check(range(3) == [0, 1, 2], "range(stop)")
check(range(0) == [] and range(-3) == [], "range non-positive stop is empty")
check(range(2, 5) == [2, 3, 4], "range(start, stop)")
check(range(0, 10, 2) == [0, 2, 4, 6, 8], "range positive step")
check(range(10, 0, -2) == [10, 8, 6, 4, 2], "range negative step")
check(range(0, -5, -1) == [0, -1, -2, -3, -4], "range descending")
check(range(5, 5) == [] and range(3, 0) == [], "range empty spans")
check(range(1, 10, 3) == [1, 4, 7], "range non-even step")
check(range(stop = 3) == [0, 1, 2], "range stop keyword")
check(range(1, stop = 5) == [1, 2, 3, 4], "range positional start + keyword stop")
check(range(start = 2, stop = 8, step = 2) == [2, 4, 6], "range all keywords")
check(range(0, 5, step = 2) == [0, 2, 4], "range positional + keyword step")
check(throws(Function(): return range()), "range no args throws (missing stop)")
check(throws(Function(): return range(start = 1)), "range only start throws (missing stop)")
check(throws(Function(): return range(0, 10, 0)), "range zero step throws")
check(throws(Function(): return range(2, 5, start = 1)), "range positional/keyword clash throws")
check(throws(Function(): return range(1, 2, 3, 4)), "range too many positionals throws")
check(throws(Function(): return range(2.5)), "range Float arg throws")
check(throws(Function(): return range(0, 10, 2.0)), "range Float step throws")
check(throws(Function(): return range(0, 100000000000)), "range over-large result throws (memory guard)")

# =====================================================================
# sum  (iterable, start = 0)  -> Integer if all-Integer, else Float
# =====================================================================
check(sum([1, 2, 3]) == 6, "sum Integers")
check(sum([]) == 0, "sum empty is 0")
check(sum([], 5) == 5, "sum empty returns start")
check(sum([1, 2, 3], 10) == 16, "sum with start")
check(sum(iterable = [1, 2, 3], start = 100) == 106, "sum keyword form")
check(type(sum([1, 2], 0)) == "Integer", "sum stays Integer")
check(type(sum([1, 2], 0.0)) == "Float", "sum Float start promotes")
check(type(sum([1.0, 2])) == "Float", "sum with a Float element promotes")
check(sum([1.5, 2.5]) == 4.0, "sum Floats")
check(sum({1, 2, 3}) == 6, "sum over a Set")
check(sum({10: 0, 20: 0}) == 30, "sum over a Dict sums its keys")
check(sum(range(5)) == 10, "sum over a range")
check(throws(Function(): return sum(["a", "b"])), "sum of Strings throws")
check(throws(Function(): return sum([1, 2], "x")), "sum non-numeric start throws")
check(throws(Function(): return sum(5)), "sum non-iterable throws")
check(throws(Function(): return sum([[1], [2]], [])), "sum of Lists throws (no list start concat)")
# NOTE: sum rejects Bool elements (Kirito sum accepts only Integer/Float) -> see FINDINGS.
check(throws(Function(): return sum([True, False])), "sum rejects Bool elements")

# =====================================================================
# min / max  (variadic: a single iterable OR several positionals; key=, default=)
# =====================================================================
check(min(5, 2, 8) == 2 and max(5, 2, 8) == 8, "min/max variadic positionals")
check(min([3, 1, 2]) == 1 and max([3, 1, 2]) == 3, "min/max over an iterable")
check(min("banana") == "a" and max("banana") == "n", "min/max over a String")
check(min(3, 2.5, 4) == 2.5, "min over mixed Integer/Float")
check(type(min(3, 2.5)) == "Float", "min keeps the winning element's type")
check(min([], default = 99) == 99, "min default on empty")
check(max([], default = -1) == -1, "max default on empty")
check(min([], key = lenf, default = "D") == "D", "min default short-circuits before key")
check(min([3, 1, 2], key = neg) == 3, "min with key returns the original element")
check(max(["aa", "b", "ccc"], key = lenf) == "ccc", "max key over Strings")
check(min(["aa", "bb", "c"], key = lenf) == "c", "min key over Strings")
check(max("aa", "b", "ccc", key = lenf) == "ccc", "max positionals + key")
# Ties: the FIRST candidate wins (stable).
check(max(["aa", "bb", "cc"], key = lenf) == "aa", "max key tie keeps first")
check(min(["x", "y", "z"], key = lenf) == "x", "min key tie keeps first")
# Exact int64 ordering beyond 2^53 (no double collapse).
check(min([9007199254740993, 9007199254740992]) == 9007199254740992, "min exact int64")
check(max([9007199254740993, 9007199254740992]) == 9007199254740993, "max exact int64")
check(min({3: 0, 1: 0, 2: 0}) == 1 and max({3: 0, 1: 0, 2: 0}) == 3, "min/max over Dict keys")
check(min("z") == "z", "min single-char String")
check(min("", default = "e") == "e", "min default on empty String")
check(throws(Function(): return min()), "min no args throws")
check(throws(Function(): return max([])), "max empty without default throws")
check(throws(Function(): return min("")), "min empty String without default throws")
check(throws(Function(): return min([1, "a"])), "min unorderable mixed types throws")
check(throws(Function(): return min(True, False)), "min over Bool throws (unorderable)")
check(throws(Function(): return min([1, 2], key = 5)), "min non-callable key throws")
check(throws(Function(): return min([1], bogus = True)), "min unexpected keyword throws")

# =====================================================================
# sorted  (iterable, key = None, reverse = False)  -> a new stable List
# =====================================================================
check(sorted([3, 1, 2]) == [1, 2, 3], "sorted ascending")
check(sorted([]) == [], "sorted empty")
check(sorted([3, 1, 2], reverse = True) == [3, 2, 1], "sorted reverse")
check(sorted("dcba") == ["a", "b", "c", "d"], "sorted over a String yields chars")
check(sorted([3, 1, 2], key = neg) == [3, 2, 1], "sorted by key")
check(sorted([3, 1, 2], key = neg, reverse = True) == [1, 2, 3], "sorted key + reverse")
check(sorted(iterable = [3, 1, 2]) == [1, 2, 3], "sorted keyword iterable")
check(type(sorted([1])) == "List", "sorted returns a List")
# Stability: equal keys keep input order, forward and reversed.
var pairs = [[1, "a"], [0, "b"], [1, "c"], [0, "d"]]
check(sorted(pairs, key = firstf) == [[0, "b"], [0, "d"], [1, "a"], [1, "c"]], "sorted stable")
check(sorted(pairs, key = firstf, reverse = True) == [[1, "a"], [1, "c"], [0, "b"], [0, "d"]], "sorted stable reverse")
check(sorted([9007199254740993, 9007199254740992]) == [9007199254740992, 9007199254740993], "sorted exact int64")
check(throws(Function(): return sorted(5)), "sorted non-iterable throws")
check(throws(Function(): return sorted([1, "a"])), "sorted unorderable throws")
check(throws(Function(): return sorted([1, 2], key = 5)), "sorted non-callable key throws")
check(throws(Function(): return sorted([1], bogus = True)), "sorted unexpected keyword throws")

# =====================================================================
# enumerate  (iterable, start = 0)  -> List of [index, value]
# =====================================================================
check(List(enumerate(["a", "b"])) == [[0, "a"], [1, "b"]], "enumerate default start")
check(List(enumerate([])) == [], "enumerate empty")
check(List(enumerate(["a", "b"], 5)) == [[5, "a"], [6, "b"]], "enumerate positional start")
check(List(enumerate(["a", "b"], start = 10)) == [[10, "a"], [11, "b"]], "enumerate keyword start")
check(List(enumerate(["x", "y"], -2)) == [[-2, "x"], [-1, "y"]], "enumerate negative start")
check(List(enumerate("ab")) == [[0, "a"], [1, "b"]], "enumerate over a String")
check(type(enumerate([1])) == "List", "enumerate returns a List (eager)")
check(enumerate(["a", "b"])[1] == [1, "b"], "enumerate result is indexable")
check(throws(Function(): return enumerate(5)), "enumerate non-iterable throws")
check(throws(Function(): return enumerate([1, 2], 1.5)), "enumerate Float start throws")

# =====================================================================
# zip  (*iterables)  -> List of tuples, truncated to the shortest
# =====================================================================
check(List(zip([1, 2], ["a", "b"])) == [[1, "a"], [2, "b"]], "zip two-way")
check(List(zip([1, 2], ["a", "b"], [True, False])) == [[1, "a", True], [2, "b", False]], "zip three-way")
check(List(zip([1, 2, 3], [1])) == [[1, 1]], "zip truncates to shortest")
check(zip() == [], "zip no args is empty")
check(List(zip([1, 2, 3])) == [[1], [2], [3]], "zip single iterable")
check(List(zip([], [1, 2])) == [], "zip with an empty input is empty")
check(List(zip("ab", [1, 2])) == [["a", 1], ["b", 2]], "zip over a String")
check(type(zip([1], [2])) == "List", "zip returns a List (eager)")
check(zip([1, 2], [3, 4])[1] == [2, 4], "zip result is indexable")
check(throws(Function(): return zip(5)), "zip non-iterable throws")
check(throws(Function(): return zip([1, 2], 5)), "zip a non-iterable among iterables throws")

# =====================================================================
# map  (function, iterable)  -> List of results
# =====================================================================
check(List(map(inc, [1, 2, 3])) == [2, 3, 4], "map increments")
check(List(map(inc, [])) == [], "map empty")
check(List(map(upperf, "abc")) == ["A", "B", "C"], "map over a String")
check(List(map(function = neg, iterable = [1, 2])) == [-1, -2], "map keyword form")
check(type(map(neg, [1])) == "List", "map returns a List (eager)")
check(throws(Function(): return map(5, [1, 2])), "map non-callable throws")
check(throws(Function(): return map(inc, 5)), "map non-iterable throws")
check(throws(Function(): return map(inc, [1], [2])), "map a third arg throws")

# =====================================================================
# filter  (function, iterable)  -> kept elements
# =====================================================================
check(List(filter(gt2, [1, 2, 3, 4])) == [3, 4], "filter keeps truthy(fn)")
check(List(filter(gt2, [])) == [], "filter empty")
check(List(filter(neg, [0, 1, 2])) == [1, 2], "filter drops falsy results (0 of neg(0)==0)")
check(List(filter(function = gt2, iterable = [1, 2, 3])) == [3], "filter keyword form")
check(type(filter(gt2, [1])) == "List", "filter returns a List (eager)")
check(throws(Function(): return filter(5, [1, 2])), "filter non-callable throws")
check(throws(Function(): return filter(gt2, 5)), "filter non-iterable throws")

# =====================================================================
# reversed  (iterable)  -> List in reverse
# =====================================================================
check(List(reversed([1, 2, 3])) == [3, 2, 1], "reversed List")
check(List(reversed([])) == [], "reversed empty")
check(List(reversed("abc")) == ["c", "b", "a"], "reversed String")
check(reversed([1, 2, 3]) == [3, 2, 1], "reversed already a List")
check(type(reversed([1])) == "List", "reversed returns a List")
check(type(reversed({1, 2, 3})) == "List", "reversed over a Set yields a List")
check(reversed([1, 2, 3])[0] == 3, "reversed result is indexable")
check(throws(Function(): return reversed(5)), "reversed non-iterable throws")
check(throws(Function(): return reversed()), "reversed no-arg throws")

# =====================================================================
# all / any  (iterable)  -> Bool
# =====================================================================
check(all([True, True, True]) and not all([True, False]), "all")
check(any([False, True]) and not any([False, False]), "any")
check(all([]) and not any([]), "all([]) True, any([]) False")
check(all([1, 2, 3]) and not all([1, 0, 3]), "all over truthy Integers")
check(any([0, 0, 1]) and not any([0, 0, 0]), "any over Integers")
check(all("abc") and not all([""]), "all over a String / empty-String element")
check(any([""]) == False, "any of an empty String element is False")
check(all({1, 2, 3}) and any({0, 1}), "all/any over a Set")
check(all({1: 0, 2: 0}), "all over Dict keys")
check(throws(Function(): return all(5)), "all non-iterable throws")
check(throws(Function(): return any(5)), "any non-iterable throws")

# =====================================================================
# type
# =====================================================================
check(type(1) == "Integer" and type(1.0) == "Float", "type numeric")
check(type("s") == "String" and type(True) == "Bool" and type(None) == "None", "type scalars")
check(type([1]) == "List" and type({1}) == "Set" and type({"a": 1}) == "Dict", "type collections")
check(type(Bytes([1])) == "Bytes", "type Bytes")
check(type(range) == "Function" and type(len) == "Function", "type of a native function")
check(type(neg) == "Function", "type of a user function")
check(type(io) == "Module", "type of a module")
check(type(x = 5) == "Integer", "type keyword form")
class TypeProbe:
    var z = 1
check(type(TypeProbe) == "TypeProbe", "type of a class is the class name")
check(type(TypeProbe()) == "TypeProbe", "type of an instance is the class name")
check(throws(Function(): return type()), "type no-arg throws")

# =====================================================================
# isinstance  (value, type)   type: constructor | class | type-name String
# =====================================================================
check(isinstance(1, Integer) and isinstance(1, "Integer"), "isinstance Integer (ctor + name)")
check(isinstance(1.5, Float) and isinstance("x", String), "isinstance Float/String ctor")
check(isinstance([], List) and isinstance(Set([]), Set) and isinstance({}, Dict), "isinstance collection ctors")
check(isinstance(True, Bool) and isinstance(None, "None"), "isinstance Bool/None")
check(isinstance(Bytes([1]), Bytes), "isinstance Bytes ctor")
check(not isinstance([1], "Dict") and not isinstance(1, "String"), "isinstance negative")
check(not isinstance(1, "Frobnicate"), "isinstance unknown type-name is False (no throw)")
# Inheritance-aware.
class Base:
    var a = 1
class Derived(Base):
    var b = 2
var dv = Derived()
check(isinstance(dv, Base) and isinstance(dv, Derived), "isinstance up the chain")
check(isinstance(dv, "Base"), "isinstance base by name")
check(not isinstance(Base(), Derived), "isinstance not down the chain")
# Boundary behaviors confirmed (diverge from Python; see FINDINGS):
check(not isinstance(True, Integer), "Bool is NOT an Integer subtype")
check(isinstance(1, "Number") and isinstance(1.5, "Number") and not isinstance("x", "Number"), "'Number' matches Integer/Float in isinstance (consistent with the annotation)")
check(throws(Function(): return isinstance(1, 5)), "isinstance non-type 2nd arg throws")
check(throws(Function(): return isinstance(1, [1, 2])), "isinstance List 2nd arg throws")
check(throws(Function(): return isinstance(1, None)), "isinstance None 2nd arg throws")
check(throws(Function(): return isinstance(1)), "isinstance one arg throws")

# =====================================================================
# import
# =====================================================================
check(type(import("io")) == "Module", "import returns a Module")
check(type(import(name = "math")) == "Module", "import keyword form")
check(id(import("math")) == id(import("math")), "import is cached (same object)")
check(throws(Function(): return import("nonexistent_module_xyz")), "import unknown module throws")
check(throws(Function(): return import(5)), "import non-String name throws")
check(throws(Function(): return import()), "import no-arg throws")

# =====================================================================
# inspect  (x)  -> a describing String
# =====================================================================
# Native builtins with a signature print name(params) -> Ret.
check(inspect(len) == "len(x) -> Integer", "inspect len signature")
check(inspect(type) == "type(x) -> String", "inspect type signature")
check(inspect(map) == "map(function, iterable) -> List", "inspect map signature")
check(inspect(sum) == "sum(iterable, start = 0) -> Number", "inspect sum signature + default")
check(inspect(enumerate) == "enumerate(iterable, start = 0) -> List", "inspect enumerate signature")
check(inspect(isinstance) == "isinstance(value, type) -> Bool", "inspect isinstance signature")
check("reverse: Bool = False" in inspect(sorted), "inspect sorted shows the reverse default + annotation")
# Variadic builtins advertise themselves as name(...).
check(inspect(range) == "range(...)  [native]", "inspect range is variadic")
check(inspect(zip) == "zip(...)  [native]", "inspect zip is variadic")
check(inspect(min) == "min(...)  [native]", "inspect min is variadic")
check(inspect(max) == "max(...)  [native]", "inspect max is variadic")
# A user function.
var annotated = Function(a, b = 2) -> Integer:
    return a + b
check(inspect(annotated) == "function(a, b = ...) -> Integer", "inspect a user function (default shown as ...)")
# A module.
var minfo = inspect(import("math"))
check("module math" in minfo and "sqrt" in minfo and "-> Float" in minfo, "inspect a module lists members + signatures")
# A class and an instance.
class Widget:
    var size = 1
    var hidden = 2
    var _private = 3
    var draw = Function(self): return None
var wi = inspect(Widget)
check("class Widget" in wi and "draw(self)" in wi and "size: Integer" in wi, "inspect a class")
check(not ("_private" in wi), "inspect hides private members")
var ii = inspect(Widget())
check("Widget instance" in ii and "draw(self)" in ii, "inspect an instance")
# A native object declares its members.
var rinfo = inspect(import("random").Random(1))
check("Random object" in rinfo and "random()" in rinfo, "inspect a native object")
# A built-in container value lists its methods.
var linfo = inspect([1, 2, 3])
check("List value" in linfo and "append(item)" in linfo, "inspect a List value")
check(throws(Function(): return inspect()), "inspect no-arg throws")

# =====================================================================
# cross-cutting: an unknown keyword on a signatured builtin throws
# =====================================================================
check(throws(Function(): return sorted([1], nope = 1)), "unexpected keyword throws (sorted)")
check(throws(Function(): return enumerate([1], nope = 1)), "unexpected keyword throws (enumerate)")

io.print("OK")
io.print(String(n) + " assertions passed")
