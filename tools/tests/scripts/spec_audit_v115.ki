# Regression golden for the v1.15 audit — the observable memory-safety fixes, driven from Kirito.
# (The HIGH heap-UAF fixes are also pinned under ASan by running this script under the asan ki.)
var io = import("io")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True
var raises_msg = Function(fn, needle) -> Bool:
    try:
        discard fn()
        return False
    catch String as e:
        return needle in e

# --- collections UAF: a contained value's _str_ mutating the SAME Dict/Set mid-stringify must throw
#     a catchable "changed size" error, never corrupt the heap (was a heap-use-after-free). ---
var d = {}
class Key:
    var _init_ = Function(self, n): self._n = n
    var _hash_ = Function(self): return 5              # collide into one bucket
    var _eq_ = Function(self, o): return self._n == o._n
    var _str_ = Function(self): return "K" + String(self._n)
class DBomb:
    var _str_ = Function(self):
        var i = 100
        while i < 400:
            d[Key(i)] = i                              # grow the hash-5 bucket mid-stringify
            i = i + 1
        return "boom"
d[Key(0)] = DBomb()
d[Key(1)] = 1
assert raises_msg(Function(): return String(d), "changed size"), "Dict str reentrant-mutation throws (no UAF)"
assert len(d) == 2, "the rejected mutation left the dict intact"

var g = Set()
class Elem:
    var _init_ = Function(self, n): self._n = n
    var _hash_ = Function(self): return 7
    var _eq_ = Function(self, o): return self._n == o._n
    var _str_ = Function(self):
        var i = 100
        while i < 400:
            g.add(Elem(i))
            i = i + 1
        return "E"
g.add(Elem(0))
g.add(Elem(1))
assert raises_msg(Function(): return String(g), "changed size"), "Set str reentrant-mutation throws (no UAF)"

# a NON-mutating _str_ inside a container still stringifies fine (the guard doesn't over-reject)
class Nice:
    var _init_ = Function(self, v): self._v = v
    var _str_ = Function(self): return "<" + self._v + ">"
assert String([Nice("a"), Nice("b")]) == "[<a>, <b>]", "non-mutating contained _str_ still works"
assert "3" in String({1: Nice("x"), 2: 3}), "ordinary dict stringify unaffected"

# --- tensor.split with a negative section size: a size_t wrap must NOT bypass the sum check and
#     read out of bounds — it must be rejected up front. ---
var T = import("tensor")
assert raises_msg(Function(): return T.split(T.Tensor([1.0, 2.0, 3.0, 4.0]), [-1, 5]),
    "non-negative"), "tensor.split rejects a negative section size (was an OOB heap read)"
assert raises_msg(Function(): return T.split(T.Tensor([1.0, 2.0, 3.0, 4.0]), [-1, -1, 6]),
    "non-negative"), "tensor.split rejects negative sections (multiple)"
# a valid split still works
var parts = T.split(T.Tensor([1.0, 2.0, 3.0, 4.0]), [1, 3])
assert parts[0].tolist() == [1.0] and parts[1].tolist() == [2.0, 3.0, 4.0], "valid explicit split unchanged"
var eq = T.split(T.Tensor([1.0, 2.0, 3.0, 4.0]), 2)
assert eq[0].tolist() == [1.0, 2.0] and eq[1].tolist() == [3.0, 4.0], "equal-parts split unchanged"

# --- dunder ownerClass: method ownership is per-(class,method) BINDING, not stamped on a shared
#     function object (was: last class to reference a shared fn won -> _super_ climbs wrong base, and
#     privacy was both falsely-denied AND bypassable from external scope). ---
class Base1:
    var who = Function(self): return "Base1"
class Base2:
    var who = Function(self): return "Base2"
var callsuper = Function(self): return self._super_().who()
class D1(Base1):
    var m = callsuper
class D2(Base2):
    var m = callsuper
assert D1().m() == "Base1" and D2().m() == "Base2", "shared method resolves _super_ against its OWN class"
# a module-level function adopted as a method must NOT let external code bypass privacy
var readpriv = Function(obj): return obj._secret
class Secret:
    var _init_ = Function(self): self._secret = "s"
    var use = readpriv
assert Secret().use() == "s", "the class's own method can read its private"
assert raises_msg(Function(): return readpriv(Secret()), "private"), "external call to the raw fn is denied (no bypass)"
# a method calling a sibling as a free variable (through the class scope) still reaches privates
class FV:
    var _init_ = Function(self): self._x = 7
    var helper = Function(self): return self._x
    var use = Function(self): return helper(self)
assert FV().use() == 7, "free-var sibling call still accesses privates"
# a shared method resolves each instance's own class
var tagof = Function(self): return self._tag
class P:
    var _init_ = Function(self): self._tag = "P"
    var m = tagof
class Q:
    var _init_ = Function(self): self._tag = "Q"
    var m = tagof
assert P().m() == "P" and Q().m() == "Q", "shared method reads each class's own private"

io.print("OK audit-v115")
