# Lazy builtins: range/map/filter/zip/enumerate are lazy iterators (Python semantics). range keeps
# full backward compatibility (list-style str, == a List, O(1) index/len/contains); map/filter/zip/
# enumerate are opaque one-pass-per-iteration iterators (type() is their name, not List; not indexable).
var io = import("io")

var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# --- range: lazy but backward-compatible ---
assert range(3) == [0, 1, 2] and [0, 1, 2] == range(3), "range == List (both directions)"
assert range(2, 5) == [2, 3, 4], "range(start, stop)"
assert range(0, 10, 2) == [0, 2, 4, 6, 8], "range step"
assert range(10, 0, -3) == [10, 7, 4, 1], "range negative step"
assert range(5, 5) == [] and range(3, 0) == [], "empty range"
assert range(1, 100, 999999999999) == [1], "range huge step -> single element"
assert String(range(3)) == "[0, 1, 2]", "range str() is list-style"
assert type(range(3)) == "range", "range type is 'range'"
assert len(range(1000)) == 1000, "range len is O(1)"
assert range(1000)[999] == 999 and range(1000)[-1] == 999, "range index (incl. negative)"
assert 5 in range(10) and not (10 in range(10)) and not (5 in range(0, 10, 2)), "range membership"
assert throws(Function(): return range(100000000000)), "range beyond the 32M cap still throws"
# lazy: a large (within-cap) range is constructed instantly and iterated with O(1) memory — a break
# after a few steps never materializes the 30M elements.
var seen = 0
for x in range(30000000):
    seen = seen + 1
    if seen >= 4:
        break
assert seen == 4, "range iterates lazily (large range + early break, no materialization)"

# --- map / filter / zip / enumerate: lazy, one pass ---
var dbl = Function(x): return x * 2
assert List(map(dbl, [1, 2, 3])) == [2, 4, 6], "map materialized"
assert List(map(dbl, range(3))) == [0, 2, 4], "map over range"
assert type(map(dbl, [1])) == "map", "map type"
assert not isinstance(map(dbl, [1]), List), "a map is not a List"
assert throws(Function(): return map(dbl, [1])[0]), "a map is not indexable"

var isodd = Function(x): return x % 2 == 1
assert List(filter(isodd, range(10))) == [1, 3, 5, 7, 9], "filter materialized"
assert type(filter(isodd, [1])) == "filter", "filter type"

assert List(zip([1, 2, 3], ["a", "b"])) == [[1, "a"], [2, "b"]], "zip truncates to shortest"
assert List(zip()) == [], "zip() empty"
assert type(zip([1], [2])) == "zip", "zip type"

assert List(enumerate(["a", "b", "c"])) == [[0, "a"], [1, "b"], [2, "c"]], "enumerate"
assert List(enumerate(["a", "b"], 10)) == [[10, "a"], [11, "b"]], "enumerate start"
assert type(enumerate([1])) == "enumerate", "enumerate type"

# --- eager consumers drain a lazy source (streaming, never materialized as a List first) ---
assert sum(range(5)) == 10 and sum(map(dbl, [1, 2, 3])) == 12, "sum over lazy"
assert sorted(filter(isodd, [5, 2, 9, 1])) == [1, 5, 9], "sorted over lazy"
assert max(map(dbl, [1, 5, 3])) == 10 and min(range(3, 9)) == 3, "min/max over lazy"
assert Set(map(dbl, [1, 1, 2])) == {2, 4}, "Set over lazy"

# --- for-loop + unpacking over lazy ---
var p, q = zip([1, 2], [3, 4])
assert p == [1, 3] and q == [2, 4], "unpack zip"
var collected = []
for i, ch in enumerate("xyz"):
    collected.append(String(i) + ch)
assert collected == ["0x", "1y", "2z"], "for-unpack enumerate over a String"

# --- chained lazily ---
assert List(map(Function(n): return n + 1, filter(Function(n): return n > 2, range(6)))) == [4, 5, 6], "chained map/filter/range"

# --- inspect shows the lazy return type ---
assert inspect(map) == "map(function, iterable) -> Iterator", "inspect map"
assert inspect(enumerate) == "enumerate(iterable, start = 0) -> Iterator", "inspect enumerate"

io.print("lazy: all passed")
