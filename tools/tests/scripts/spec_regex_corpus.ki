]
var correct=0
var falseNeg=0
var falsePos=0
var groupMismatch=0
var correctReject=0
var gracefulReject=0
var acceptedInvalid=0
for cse in cases:
    var pat = fromCps(cse[0])
    var subj = fromCps(cse[1])
    var outcome = cse[2]
    var threw = False
    var m = None
    try:
        m = re.search(pat, subj)
    catch as e:
        threw = True
    if threw:
        if outcome == 2:
            correctReject = correctReject + 1
        else:
            gracefulReject = gracefulReject + 1
    else:
        if outcome == 2:
            acceptedInvalid = acceptedInvalid + 1
        elif outcome == 0:
            if m == None:
                falseNeg = falseNeg + 1
            else:
                var ops = cse[3]
                if len(ops) == 0:
                    correct = correct + 1
                else:
                    var got = ""
                    for op in ops:
                        if op[0] == 0:
                            got = got + fromCps(op[1])
                        else:
                            var gv = "None"
                            try:
                                var raw = m.group(op[1])
                                if raw != None:
                                    gv = raw
                            catch as ge:
                                gv = "Error"
                            got = got + gv
                    if got == fromCps(cse[4]):
                        correct = correct + 1
                    else:
                        groupMismatch = groupMismatch + 1
        else:
            if m != None:
                falsePos = falsePos + 1
            else:
                correct = correct + 1

# Hard correctness: no false negatives/positives, no group mismatches, no syntactically-invalid pattern accepted.
assert falseNeg == 0, "regex corpus false negatives: " + String(falseNeg)
assert falsePos == 0, "regex corpus false positives: " + String(falsePos)
assert groupMismatch == 0, "regex corpus group mismatches: " + String(groupMismatch)
assert acceptedInvalid == 0, "regex corpus accepted-invalid: " + String(acceptedInvalid)
# Behavioural pins (the corpus is frozen, so these change only if the engine's behaviour changes):
assert correct == 325, "regex corpus correct count changed: " + String(correct)
assert correctReject == 40, "regex corpus syntax-error rejects changed: " + String(correctReject)
assert gracefulReject == 38, "regex corpus unsupported-feature rejects changed: " + String(gracefulReject)
io.print("OK")
