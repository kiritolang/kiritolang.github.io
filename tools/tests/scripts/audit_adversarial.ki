# Deep adversarial audit: probes builtins, type methods, and stdlib for boundary/edge-case bugs.
# Tests every claim in the docs that says "throws X" or "returns Y on edge Z", plus stress patterns
# (overflow, Unicode, negative indices, empty collections, mixed types, malformed inputs).
# Prints "OK adversarial-audit" if every probe passes; the assert prints the failed claim.

var io = import("io")

# True iff calling `thunk` throws — for asserting domain/edge errors now throw instead of NaN/inf.
var throws = Function(thunk) -> Bool:
    try:
        discard thunk()
    catch as e:
        return True
    return False

# --- INTEGER + arithmetic edges -----------------------------------------------------------------
assert (9223372036854775807 + 1) == -9223372036854775808, "int64 overflow wraps to MIN"
assert (-9223372036854775808 - 1) == 9223372036854775807, "int64 underflow wraps to MAX"
assert (-9223372036854775808 // 1) == -9223372036854775808, "abs(MIN)/1 stays MIN (overflow-aware)"
assert 0 ** 0 == 1, "0**0 = 1 (math convention)"
assert 2 ** 63 == -9223372036854775808, "2**63 wraps to MIN"
assert 0xFFFFFFFFFFFFFFFF == -1, "all-ones int64 == -1 (two's complement literal)"
assert -7 // 2 == -4 and 7 // -2 == -4, "floor division rounds toward negative infinity"
assert -7 % 2 == 1 and 7 % -2 == -1, "mod sign follows divisor"
assert 1 / 2 == 0.5, "/ always yields Float"
assert type(1 / 1) == "Float", "/ returns Float even when divisible"
assert type(4 // 2) == "Integer", "// of two ints is Integer"
# division by zero
var threw = False
try:
    discard 1 / 0
catch as e:
    threw = "division" in e or "zero" in e
assert threw, "1/0 throws with a clear message"
threw = False
try:
    discard 1 // 0
catch as e:
    threw = True
assert threw, "1//0 throws"
threw = False
try:
    discard 5 % 0
catch as e:
    threw = True
assert threw, "5%0 throws"

# --- FLOAT edges --------------------------------------------------------------------------------
var inf = 1e308 * 10           # overflow -> inf
assert inf > 1e300, "Float overflow -> inf"
assert -inf < -1e300, "negative Float overflow -> -inf"
var math = import("math")
assert math.isinf(inf) and math.isnan(inf - inf), "isinf/isnan classify edges"
assert 0.0 == -0.0, "+0 == -0"
assert 1.5e3 == 1500.0 and 2e-3 == 0.002, "scientific notation"
threw = False
try:
    discard Integer(1e100)
catch as e:
    threw = "Float" in e or "range" in e or "convert" in e
assert threw, "Integer(huge Float) throws"
threw = False
try:
    discard Integer(0.0/0.0)
catch as e:
    threw = True
assert threw, "Integer(NaN) throws"

# --- LIST: negative indices, slicing, mutation during iteration -------------------------------
var xs = [10, 20, 30, 40, 50]
assert xs[-1] == 50 and xs[-5] == 10, "negative indices"
threw = False
try:
    discard xs[-6]
catch as e:
    threw = True
assert threw, "out-of-range negative index"
threw = False
try:
    discard xs[100]
catch as e:
    threw = True
assert threw, "out-of-range positive index"
assert xs[1:4] == [20, 30, 40], "slice"
assert xs[::-1] == [50, 40, 30, 20, 10], "reverse slice"
assert xs[10:20] == [], "out-of-range slice is empty"
threw = False
try:
    var bad = xs[::0]
catch as e:
    threw = "step" in e or "zero" in e
assert threw, "slice step 0 throws"

# list methods edge cases
assert [].count(5) == 0, "count empty returns 0"
threw = False
try:
    discard [].index(5)
catch as e:
    threw = True
assert threw, "index on empty throws"
var ys = [1, 2, 3]
ys.insert(100, 99)            # past end -> append
assert ys == [1, 2, 3, 99], "insert past end -> append"
var zs = [1, 2, 3]
zs.insert(-100, 99)           # before start -> prepend
assert zs == [99, 1, 2, 3], "insert before start -> prepend"
var w = [1, 2, 3]
w.pop(-1)
assert w == [1, 2], "pop(-1) removes last"
var v = [1, 2, 3]
v.pop(0)
assert v == [2, 3], "pop(0) removes first"

# huge repetition is guarded
threw = False
try:
    discard [1] * 100000000000
catch as e:
    threw = "large" in e or "huge" in e or "Memory" in e or "too" in e or "size" in e
assert threw, "huge list repeat throws (not OOM)"

# stable sort preserves equal-element order
var pairs = [[3, "a"], [1, "b"], [3, "c"], [2, "d"]]
pairs.sort(key = Function(p): return p[0])
assert pairs == [[1, "b"], [2, "d"], [3, "a"], [3, "c"]], "stable sort"
# sort with multi-key (list key)
var items = [[1, 2], [1, 1], [2, 0]]
items.sort()
assert items == [[1, 1], [1, 2], [2, 0]], "list lexicographic sort"

# --- STRING: Unicode, slicing, methods --------------------------------------------------------
var s = "héllo"
assert len(s) == 5, "code-point length (é is 1 codepoint)"
assert s[1] == "é", "indexing yields a code-point character"
assert s.encode("utf-8") == Bytes([104, 195, 169, 108, 108, 111]), "utf-8 encodes é as 2 bytes"
assert len(s.encode("utf-8")) == 6, "encoded byte length"
assert "ABC".lower() == "abc" and "abc".upper() == "ABC", "ASCII case"
# Latin-1 case-folding
assert "É".lower() == "é" and "é".upper() == "É", "Latin-1 case (U+00E9 / U+00C9)"
# strip variants
assert "  hi  ".strip() == "hi", "strip"
assert "**hi**".strip("*") == "hi", "strip(chars)"
assert "  hi  ".lstrip() == "hi  " and "  hi  ".rstrip() == "  hi", "lstrip/rstrip"
# split/join
assert ",,,".split(",") == ["", "", "", ""], "split preserves empty fields"
threw = False
try:
    var bad = "abc".split("")
catch as e:
    threw = "empty" in e or "separator" in e
assert threw, "split empty sep throws"
# replace count
assert "aaaa".replace("a", "b") == "bbbb", "replace all"
assert "aaaa".replace("a", "b", 2) == "bbaa", "replace count"
# find/rfind
assert "abcabc".find("bc") == 1, "find first"
assert "abcabc".rfind("bc") == 4, "rfind last"
assert "abc".find("xyz") == -1, "find absent -> -1"
threw = False
try:
    discard "abc".index("xyz")
catch as e:
    threw = True
assert threw, "index absent throws"
# format spec edges
assert format(3.14159, ".2f") == "3.14", "float format"
assert format(255, "08b") == "11111111", "binary format"
assert format(255, "#x") == "0xff", "alternate hex"
assert format(-42, "+05d") == "-0042", "signed width"
assert format(1234, ",") == "1,234", "thousands separator"
# string repetition guard
threw = False
try:
    discard "x" * 100000000000
catch as e:
    threw = True
assert threw, "huge string repeat throws"

# --- DICT: ordering preservation, key types, iteration --------------------------------------
var d = {"a": 1, "b": 2, "c": 3}
# Dict is documented as UNORDERED (iteration order is unspecified). We assert membership only.
assert Set(d.keys()) == Set(["a", "b", "c"]), "Dict contains all keys"
d["d"] = 4
assert Set(d.keys()) == Set(["a", "b", "c", "d"]), "new key added"
d["a"] = 99
assert d["a"] == 99, "rebinding updates value"
# mixed key types
var dm = {1: "int", "1": "str", 1.0: "float"}
assert len(dm) == 2, "Integer 1 and Float 1.0 hash equal (one key)"
# get with default
assert {"k": 5}.get("k") == 5, "get existing"
assert {"k": 5}.get("missing", 99) == 99, "get default"
assert {"k": 5}.get("missing") == None, "get None default"
# pop default
threw = False
try:
    discard {"k": 5}.pop("missing")
catch as e:
    threw = True
assert threw, "pop missing without default throws"
assert {"k": 5}.pop("missing", "fallback") == "fallback", "pop with default"
# unhashable key
threw = False
try:
    var bad = {[1, 2]: "x"}
catch as e:
    threw = "hashable" in e or "unhashable" in e or "key" in e
assert threw, "List as Dict key throws"

# --- SET: math operations + edge cases ----------------------------------------------------
var a = Set([1, 2, 3])
var b = Set([2, 3, 4])
assert a.union(b) == Set([1, 2, 3, 4]), "union"
assert a.intersection(b) == Set([2, 3]), "intersection"
assert a.difference(b) == Set([1]), "difference"
assert a.symmetricdifference(b) == Set([1, 4]), "symmetric diff"
assert Set([1, 2]).issubset(Set([1, 2, 3])), "issubset"
assert Set([1, 2, 3]).issuperset(Set([1])), "issuperset"
assert Set([1]).isdisjoint(Set([2, 3])), "isdisjoint"
# discard vs remove
var s2 = Set([1, 2, 3])
s2.discard(99)              # no-op
assert s2 == Set([1, 2, 3]), "discard missing is no-op"
threw = False
try:
    Set([1]).remove(99)
catch as e:
    threw = True
assert threw, "remove missing throws"

# --- BYTES adversarial -----------------------------------------------------------------------
assert Bytes(0) == Bytes(), "0 zero bytes is empty"
threw = False
try:
    discard Bytes([256])
catch as e:
    threw = True
assert threw, "Bytes([256]) throws"
threw = False
try:
    discard Bytes([-1])
catch as e:
    threw = True
assert threw, "Bytes([-1]) throws"
threw = False
try:
    discard Bytes([0.5])
catch as e:
    threw = True
assert threw, "Bytes([Float]) throws"
threw = False
try:
    discard Bytes("héllo".encode("latin-1"))
catch as e:
    threw = True or threw          # this might actually succeed; latin-1 ok
assert "héllo".encode("latin-1") == Bytes([104, 233, 108, 108, 111]), "latin-1 of é"
threw = False
try:
    discard "€".encode("latin-1")
catch as e:
    threw = True
assert threw, "code-point > 255 in latin-1 throws"
threw = False
try:
    discard Bytes([200]).decode("ascii")
catch as e:
    threw = True
assert threw, "byte > 127 in ascii decode throws"
# hex round-trip
assert fromhex(Bytes([0, 1, 254, 255]).hex()) == Bytes([0, 1, 254, 255]), "hex roundtrip"
threw = False
try:
    discard fromhex("abc")
catch as e:
    threw = "odd" in e or "length" in e
assert threw, "fromhex odd-length throws"
threw = False
try:
    discard fromhex("xy")
catch as e:
    threw = True
assert threw, "fromhex non-hex throws"
# Bytes immutability
var bm = Bytes([1, 2, 3])
threw = False
try:
    bm[0] = 99
catch as e:
    threw = True
assert threw, "Bytes is immutable (no item assignment)"

# --- MATH module ----------------------------------------------------------------------------
assert math.sqrt(0) == 0.0, "sqrt(0)"
assert math.sqrt(4) == 2.0, "sqrt(4)"
# sqrt of a negative THROWS a math domain error (use complex.sqrt for the principal root)
assert throws(Function(): return math.sqrt(-1)), "sqrt(-1) throws"
# transcendental edges
assert math.exp(0) == 1.0, "exp(0)"
assert math.log(1) == 0.0, "log(1)"
assert math.log(math.e) == 1.0, "log(e)"
# domain errors throw (no silent -inf/NaN): log of a non-positive argument
assert throws(Function(): return math.log(0)), "log(0) throws"
assert throws(Function(): return math.log(-1)), "log(-1) throws"
# trig
assert math.sin(0) == 0.0 and math.cos(0) == 1.0, "sin(0)=0, cos(0)=1"
# floor / ceil / trunc
assert math.floor(-0.5) == -1, "floor toward -inf"
assert math.ceil(-0.5) == 0, "ceil toward +inf"
assert math.trunc(-0.5) == 0 and math.trunc(0.5) == 0, "trunc toward 0"
# gcd / lcm
assert math.gcd(12, 18) == 6 and math.lcm(4, 6) == 12, "gcd/lcm"
assert math.gcd(0, 5) == 5, "gcd(0, x) = x"
# factorial
assert math.factorial(0) == 1 and math.factorial(5) == 120, "factorial"
threw = False
try:
    discard math.factorial(-1)
catch as e:
    threw = True
assert threw, "factorial(-1) throws"

# --- JSON --------------------------------------------------------------------------------
var json = import("json")
assert json.loads("null") == None, "json null"
assert json.loads("true") == True, "json true"
assert json.loads("[1, 2, 3]") == [1, 2, 3], "json array"
assert json.loads('{"k": [1, 2]}') == {"k": [1, 2]}, "json nested"
# unicode escapes
assert json.loads('"\\u00e9"') == "é", "json \\u escape"
assert json.loads('"\\uD83D\\uDE00"') == "😀", "json surrogate-pair escape"
# numeric edges
assert json.loads("1.5e3") == 1500.0, "scientific notation in json"
assert json.loads("-0") == -0, "negative zero"
# malformed
for bad in ["{", "[1, 2,", '"unterminated', "{\"k\":}", "tru"]:
    threw = False
    try:
        discard json.loads(bad)
    catch as e:
        threw = "JSON" in e or "parse" in e or "expected" in e
    assert threw, "malformed JSON throws: " + bad
# round-trip
var doc = {"a": [1, 2, 3], "b": {"nested": True}, "c": None}
assert json.loads(json.dumps(doc)) == doc, "json round-trip"
# indent
var indented = json.dumps([1, 2], 2)
assert "\n" in indented, "json indent produces newlines"

# --- HASH ---------------------------------------------------------------------------------
var hash = import("hash")
# known vectors
assert hash.md5("") == "d41d8cd98f00b204e9800998ecf8427e", "md5 empty vector"
assert hash.sha256("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256 empty"
assert hash.sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d", "sha1 abc vector"
assert hash.crc32("123456789") == 3421780262, "crc32 123456789 vector"
assert hash.adler32("Wikipedia") == 300286872, "adler32 Wikipedia vector"
assert hash.crc64("123456789") == -7395533204333446662, "crc64-XZ 123456789 vector"
# Bytes input
assert hash.sha256(Bytes([97, 98, 99])) == hash.sha256("abc"), "sha256 String == Bytes equiv"
# determinism + length
assert len(hash.md5("x")) == 32 and len(hash.sha256("x")) == 64, "digest lengths"

# --- ZLIB / GZIP ----------------------------------------------------------------------
var zlib = import("zlib")
var gzip = import("gzip")
var bin = Bytes([0, 1, 2, 254, 255]) * 10
assert zlib.decompress(zlib.compress(bin)) == bin, "zlib bytes round-trip"
assert gzip.decompress(gzip.compress(bin)) == bin, "gzip bytes round-trip"
assert type(gzip.compress("x")) == "String", "gzip String -> String"
assert type(gzip.compress(Bytes([1]))) == "Bytes", "gzip Bytes -> Bytes"
threw = False
try:
    discard gzip.decompress(Bytes([0, 1, 2, 3]))
catch as e:
    threw = True
assert threw, "gzip bad magic throws"
threw = False
try:
    discard zlib.decompress("not zlib")
catch as e:
    threw = True
assert threw, "zlib garbage throws"

# --- REGEX --------------------------------------------------------------------------
var regex = import("regex")
# basic
assert regex.search("\\d+", "abc123def").group() == "123", "regex digit run"
assert regex.match("\\d+", "abc123") == None, "regex match at start"
assert regex.fullmatch("\\d+", "123") != None, "regex fullmatch"
assert regex.fullmatch("\\d+", "123x") == None, "fullmatch must cover whole"
# groups
var m = regex.search("(\\w+)@(\\w+)", "user@host")
assert m.group(1) == "user" and m.group(2) == "host", "groups"
assert m.groups() == ["user", "host"], "groups() list"
# repetition + alternation
assert regex.findall("\\b\\w+\\b", "hi there") == ["hi", "there"], "findall words"
# replace with callable
assert regex.sub("\\d", Function(m): return "*", "ab1c2d3") == "ab*c*d*", "sub with callable"
# named groups
var mn = regex.search("(?P<name>\\w+)", "abc")
assert mn.group("name") == "abc", "named group"
# rejection: backreferences and lookarounds not allowed
threw = False
try:
    discard regex.compile("(a)\\1")
catch as e:
    threw = "backref" in e or "support" in e
assert threw, "backreference rejected"
threw = False
try:
    discard regex.compile("(?=a)b")
catch as e:
    threw = "lookahead" in e or "lookaround" in e or "support" in e
assert threw, "lookahead rejected"

# --- BUILTINS ---------------------------------------------------------------------------
assert sum([1, 2, 3]) == 6, "sum"
assert sum([], 10) == 10, "sum with start"
assert min([3, 1, 2]) == 1 and max([3, 1, 2]) == 3, "min/max"
assert min([3, 1, 2], key = Function(x): return -x) == 3, "min with key"
assert max(default = "fallback") == "fallback" if False else max([], default = "fallback") == "fallback", "max empty with default"
assert abs(-5) == 5 and abs(-5.5) == 5.5, "abs"
assert round(3.14159, 2) == 3.14, "round"
# Kirito uses half-away-from-zero (doc'd), not half-to-even
assert round(0.5) == 1 and round(-0.5) == -1, "round half away from zero"
assert round(2.5) == 3 and round(-2.5) == -3, "round half away from zero (2.5)"
assert sorted([3, 1, 2]) == [1, 2, 3], "sorted"
assert sorted([1, 2, 3], reverse = True) == [3, 2, 1], "sorted reverse"
assert List(enumerate([10, 20])) == [[0, 10], [1, 20]], "enumerate"
assert List(enumerate([10, 20], 5)) == [[5, 10], [6, 20]], "enumerate start"
assert List(zip([1, 2], [3, 4])) == [[1, 3], [2, 4]], "zip"
assert List(zip([1, 2, 3], [4, 5])) == [[1, 4], [2, 5]], "zip stops at shortest"
assert range(0) == [] and range(5) == [0, 1, 2, 3, 4], "range"
assert range(1, 10, 2) == [1, 3, 5, 7, 9], "range step"
assert range(10, 0, -2) == [10, 8, 6, 4, 2], "range negative step"
threw = False
try:
    discard range(0, 10, 0)
catch as e:
    threw = True
assert threw, "range step 0 throws"
# huge range guarded
threw = False
try:
    discard range(0, 100000000000)
catch as e:
    threw = True
assert threw, "huge range throws"
# divmod
assert divmod(7, 2) == [3, 1] and divmod(-7, 2) == [-4, 1], "divmod with floor semantics"
# pow with mod
assert pow(2, 10) == 1024 and pow(2, 10, 100) == 24, "pow 2-arg / 3-arg modular"
# bitwise + shifts
assert bitand(0b1100, 0b1010) == 0b1000, "bitand"
assert bitor(0b1100, 0b1010) == 0b1110, "bitor"
assert bitxor(0b1100, 0b1010) == 0b0110, "bitxor"
assert bitnot(0) == -1 and bitnot(-1) == 0, "bitnot two's-complement"
assert shl(1, 3) == 8 and shr(16, 2) == 4, "shl/shr"
assert shr(-1, 1) == -1, "shr of -1 stays -1 (arithmetic shift)"
# ord/chr
assert ord("A") == 65 and chr(65) == "A", "ord/chr ASCII"
assert ord("€") == 8364 and chr(8364) == "€", "ord/chr non-ASCII"
threw = False
try:
    discard ord("ab")
catch as e:
    threw = True
assert threw, "ord of multi-char throws"
# type
assert type(1) == "Integer" and type(1.0) == "Float" and type("x") == "String", "type names"
assert type(None) == "None" and type(True) == "Bool", "None/Bool types"
assert type([]) == "List" and type({}) == "Dict" and type(Set()) == "Set", "container types"
# isinstance with type name
assert isinstance(1, "Integer") and isinstance("x", "String"), "isinstance with name"
assert not isinstance(1, "Float"), "isinstance strict"
# format converters
assert Integer("42") == 42 and Integer("0xFF") == 255, "Integer parses hex"
assert Integer("0o17") == 15 and Integer("0b1010") == 10, "Integer parses oct/bin"
assert Float("1.5e3") == 1500.0, "Float parses scientific"
assert Float("inf") > 1e300 and Float("-inf") < -1e300, "Float parses inf"
threw = False
try:
    discard Integer("not a number")
catch as e:
    threw = "convert" in e or "Integer" in e
assert threw, "Integer parse fail throws"
assert Bool("") == False and Bool("x") == True, "Bool truthiness"
assert Bool(0) == False and Bool(1) == True, "Bool Integer truthiness"
assert Bool([]) == False and Bool([0]) == True, "Bool collection truthiness"

# --- RANDOM determinism + range -------------------------------------------------------
var random = import("random")
var r1 = random.Random(42)
var r2 = random.Random(42)
var seq1 = []
var seq2 = []
var i = 0
while i < 20:
    seq1.append(r1.randint(0, 1000))
    seq2.append(r2.randint(0, 1000))
    i = i + 1
assert seq1 == seq2, "Random with same seed gives same stream"
var r3 = random.Random(99)
var allinrange = True
i = 0
while i < 1000:
    var v = r3.randint(-10, 10)
    if v < -10 or v > 10:
        allinrange = False
    i = i + 1
assert allinrange, "randint stays in range"
# choice on empty
threw = False
try:
    discard random.Random().choice([])
catch as e:
    threw = "empty" in e or "choice" in e
assert threw, "choice on empty throws"

# --- TIME determinism + DateTime equality ---------------------------------------------
var time = import("time")
var t1 = time.make(2024, 1, 1, 12, 0, 0)
var t2 = time.make(2024, 1, 1, 12, 0, 0)
assert t1 == t2, "DateTime value equality"
assert t1 != time.make(2024, 1, 1, 12, 0, 1), "DateTime inequality"
assert t1.iso() == "2024-01-01T12:00:00", "DateTime iso"
assert t1.year == 2024 and t1.month == 1 and t1.day == 1, "DateTime fields"
# arithmetic
var t3 = t1.add(86400)        # one day
assert t3.day == 2, "DateTime add(86400) advances one day"
assert t3.diff(t1) == 86400, "DateTime diff"

io.print("OK adversarial-audit")
