# Showcase of the standard library: math, random (seeded), matrix, json, serialize, builtins.
var io = import("io")
var math = import("math")
var random = import("random")
var matrix = import("matrix")
var json = import("json")
var serialize = import("serialize")

# math + builtins
io.print(math.gcd(48, 36))
io.print(round(math.pi, 4))
io.print(sum(range(1, 11)))
io.print(sorted([3, 1, 4, 1, 5, 9, 2, 6]))
io.print(List(map(Function(x): return x * x, range(5))))

# seeded random is reproducible; pin the historical Mersenne-Twister stream so the
# expected value stays stable across engine-default changes.
var rng = random.Random(42, generator = "mersenne_twister")
io.print(rng.randint(1, 100))

# matrix
var M = matrix.Matrix([[2, 1], [1, 3]])
io.print(M.determinant())
io.print((M * matrix.identity(2)) == M)

# json: objects are Dicts
var data = json.parse("{\"name\": \"test\", \"items\": [1, 2, 3]}")
io.print(data["name"])
io.print(sum(data["items"]))
io.print(json.stringify([1, 2, 3]))

# serialization preserves shared references
var A = [1, 2]
var shared = [A, A]
var restored = serialize.loads(serialize.dumps(shared))
restored[0].append(3)
io.print(restored[1])
