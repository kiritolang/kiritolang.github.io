# Doc-vs-impl verification for the `tabular` stdlib module (pandas-like Series/DataFrame).
# Impl: src/kirito/stdlib_kimodules.hpp (`tabular`). Docs: docs/pages/10-stdlib.md `## tabular`
# and docs/pages/28-bonus-03-data.md. Functioning + edge + HARDENING. Prints "OK tabular".
var io = import("io")
var tb = import("tabular")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True
var raises_msg = Function(fn, needle) -> Bool:
    try:
        discard fn()
        return False
    catch String as e:
        return needle in e

var nan = Float("nan")

# ============================================================ Series construction
var s = tb.Series([10, 20, 30, 40])
assert s.tolist() == [10, 20, 30, 40], "Series values"
assert s.index == [0, 1, 2, 3], "Series default index is range"
assert len(s) == 4, "len(Series)"
assert s.name == None, "Series default name None"
var sn = tb.Series([1, 2], ["a", "b"], "col")
assert sn.index == ["a", "b"] and sn.name == "col", "Series index+name"
assert raises_msg(Function(): return tb.Series([1, 2], ["a"]), "index length"), "Series index length mismatch throws"

# --- indexing: by label first, else by position ---
assert s[0] == 10 and s[3] == 40, "Series positional getitem (default index)"
assert sn["a"] == 1 and sn["b"] == 2, "Series label getitem"
assert sn[0] == 1 and sn[1] == 2, "Series position fallback when label absent"
assert s.iat(2) == 30, "Series.iat"
var scopy = s.copy()
scopy[0] = 99
assert s[0] == 10 and scopy[0] == 99, "Series.copy is independent"

# ============================================================ Series arithmetic (scalar broadcast)
assert (s * 2).tolist() == [20, 40, 60, 80], "Series * scalar"
assert (s + 1).tolist() == [11, 21, 31, 41], "Series + scalar"
assert (s - 5).tolist() == [5, 15, 25, 35], "Series - scalar"
assert (s / 10).tolist() == [1.0, 2.0, 3.0, 4.0], "Series / scalar (true division)"
assert (s // 3).tolist() == [3, 6, 10, 13], "Series // scalar"
assert (s % 7).tolist() == [3, 6, 2, 5], "Series % scalar"
# Series-Series aligned by position
var t2 = tb.Series([1, 2, 3, 4])
assert (s + t2).tolist() == [11, 22, 33, 44], "Series + Series"
assert (s * t2).tolist() == [10, 40, 90, 160], "Series * Series"
assert raises_msg(Function(): return s + tb.Series([1, 2]), "length mismatch"), "Series+Series length mismatch throws"
assert raises_msg(Function(): return tb.Series([1, 2]) + s, "length mismatch"), "mismatch throws in either order"

# ============================================================ Series comparisons -> boolean Series
assert (s > 20).tolist() == [False, False, True, True], "Series > scalar -> bool Series"
assert (s >= 20).tolist() == [False, True, True, True], "Series >="
assert (s < 20).tolist() == [True, False, False, False], "Series <"
assert (s <= 20).tolist() == [True, True, False, False], "Series <="
assert (s == 20).tolist() == [False, True, False, False], "Series == is element-wise"
assert (s != 20).tolist() == [True, False, True, True], "Series != is element-wise"
assert s.eq(30).tolist() == [False, False, True, False], "Series.eq"
assert s.ne(30).tolist() == [True, True, False, True], "Series.ne"
assert s.isin([10, 40]).tolist() == [True, False, False, True], "Series.isin"

# ============================================================ Series aggregations (skip missing; Bool as 0/1)
assert s.sum() == 100, "Series.sum"
assert s.mean() == 25.0 and type(s.mean()) == "Float", "Series.mean -> Float"
assert s.min() == 10 and s.max() == 40, "Series.min/max"
assert s.median() == 25.0, "Series.median even count"
assert tb.Series([3, 1, 2]).median() == 2, "Series.median odd count"
assert s.prod() == 240000, "Series.prod"
assert s.count() == 4, "Series.count"
assert tb.Series([10, 20, 30, 40]).variance().compare(166.66666666666666), "Series.variance sample"
assert tb.Series([10, 20, 30, 40]).std().compare(12.909944487358056), "Series.std"
# Bool counts as 0/1 in numeric reductions; count is a non-null tally of ANY type
var sb = tb.Series([True, False, True])
assert sb.sum() == 2 and sb.mean().compare(0.6666666666666666), "Series Bool sum/mean as 0/1"
assert sb.min() == 0 and sb.max() == 1, "Series Bool min/max as 0/1"
assert sb.count() == 3, "Series.count Bool"
# missing (None / NaN) skipped by numeric reductions
var sm = tb.Series([10, None, 30, nan])
assert sm.sum() == 40 and sm.mean() == 20.0, "Series numeric reductions skip None/NaN"
assert sm.count() == 2, "Series.count skips None/NaN"
assert sm.min() == 10 and sm.max() == 30, "Series min/max skip missing"
# all-missing -> None for mean/min/max/median; sum is 0, prod is 1
var sall = tb.Series([None, nan])
assert sall.mean() == None and sall.min() == None and sall.max() == None and sall.median() == None, "all-missing reductions -> None"
assert sall.sum() == 0 and sall.prod() == 1, "all-missing sum=0 prod=1"
assert tb.Series([5]).variance() == None and tb.Series([5]).std() == None, "variance/std None for n<2"

# ============================================================ unique / nunique / valuecounts
var sv = tb.Series([1, 2, 2, 3, 3, 3, None])
assert sv.unique() == [1, 2, 3, None], "Series.unique keeps None as a value"
assert sv.nunique() == 4, "Series.nunique counts None"
var vc = sv.valuecounts()
assert vc.tolist() == [3, 2, 1], "valuecounts descending by count, skips None"
assert vc.index == [3, 2, 1], "valuecounts indexed by value"
assert vc.name == "count", "valuecounts name"

# ============================================================ apply / map / astype / fillna / dropna
assert s.apply(Function(x): return x + 1).tolist() == [11, 21, 31, 41], "Series.apply"
assert s.map(Function(x): return x * 10).tolist() == [100, 200, 300, 400], "Series.map"
assert tb.Series(["1", "2", "3"]).astype("Integer").tolist() == [1, 2, 3], "Series.astype Integer"
assert tb.Series([1, 2]).astype("Float").tolist() == [1.0, 2.0], "Series.astype Float"
assert tb.Series([1, 2]).astype("String").tolist() == ["1", "2"], "Series.astype String"
assert tb.Series([0, 1, 2]).astype("Bool").tolist() == [False, True, True], "Series.astype Bool"
assert sm.fillna(0).tolist() == [10, 0, 30, 0], "Series.fillna"
assert sm.dropna().tolist() == [10, 30], "Series.dropna drops None and NaN"
assert sm.dropna().index == [0, 2], "Series.dropna preserves index"

# ============================================================ head / tail / sortvalues / resetindex
assert tb.Series([1, 2, 3, 4, 5, 6]).head(2).tolist() == [1, 2], "Series.head"
assert tb.Series([1, 2, 3, 4, 5, 6]).tail(2).tolist() == [5, 6], "Series.tail"
assert tb.Series([1, 2, 3]).head().tolist() == [1, 2, 3], "Series.head default n=5"
# negative n (PINNED behaviour): head uses [0:n] slice, tail computes start=len-n
assert tb.Series([1, 2, 3, 4]).head(-1).tolist() == [1, 2, 3], "Series.head(-1) == [0:-1]"
assert tb.Series([1, 2, 3, 4]).tail(-1).tolist() == [], "Series.tail(-1) -> empty (start>len)"
var ss = tb.Series([30, 10, 20, None], ["a", "b", "c", "d"])
assert ss.sortvalues().tolist() == [10, 20, 30, None], "sortvalues asc, missing last"
assert ss.sortvalues(ascending = False).tolist() == [30, 20, 10, None], "sortvalues desc, missing STILL last"
assert ss.sortvalues().index == ["b", "c", "a", "d"], "sortvalues carries index"
var ri = tb.Series([1, 2], ["x", "y"]).resetindex()
assert ri.index == [0, 1], "Series.resetindex -> range"

# ============================================================ DataFrame construction
# from Dict of columns (+columns order)
var d1 = tb.DataFrame({"a": [1, 2], "b": [3, 4]}, columns = ["a", "b"])
assert d1.shape() == [2, 2] and d1.columns == ["a", "b"], "DataFrame from dict-of-columns"
assert d1.nrows() == 2 and len(d1) == 2, "DataFrame nrows/len"
assert d1["a"].tolist() == [1, 2], "DataFrame column access"
# from list of rows (list-of-lists) with columns
var d2 = tb.DataFrame([["Ada", 120], ["Alan", 110]], columns = ["name", "salary"])
assert d2["name"].tolist() == ["Ada", "Alan"] and d2["salary"].tolist() == [120, 110], "DataFrame from list-of-lists"
# list-of-lists without columns -> default col0,col1
var d3 = tb.DataFrame([[1, 2], [3, 4]])
assert d3.columns == ["col0", "col1"], "DataFrame default column names"
# from list of row-Dicts (union of keys)
var d4 = tb.DataFrame([{"a": 1, "b": 2}, {"a": 3, "c": 4}])
assert d4.columns == ["a", "b", "c"], "DataFrame from row-dicts, key union"
assert d4["b"].tolist() == [2, None], "DataFrame row-dicts fill missing with None"
assert raises_msg(Function(): return tb.DataFrame({"a": [1, 2], "b": [3]}), "same length"), "ragged dict columns throw"
assert raises_msg(Function(): return tb.DataFrame(42), "must be a Dict"), "bad DataFrame data throws"
# empty frame
var de = tb.DataFrame()
assert de.shape() == [0, 0] and de.columns == [] and len(de) == 0, "empty DataFrame"
# single row / single col
assert tb.DataFrame({"a": [1]}).shape() == [1, 1], "single-cell DataFrame"

# ============================================================ readcsv (type inference)
var csv = "name,dept,salary\nAda,eng,120\nAlan,eng,110\nGrace,ops,95\nEdsger,ops,130"
var df = tb.readcsv(csv)
assert df.columns == ["name", "dept", "salary"], "readcsv header order preserved"
assert df.shape() == [4, 3], "readcsv shape"
assert type(df["salary"][0]) == "Integer", "readcsv infers Integer"
assert df["dept"].tolist() == ["eng", "eng", "ops", "ops"], "readcsv String column"
assert type(tb.readcsv("x\n1.5")["x"][0]) == "Float", "readcsv infers Float"
assert tb.readcsv("x\nTrue\nfalse")["x"].tolist() == [True, False], "readcsv infers Bool"
assert tb.readcsv("x\n1\n")["x"].tolist() == [1], "readcsv skips blank trailing line"
# short row -> trailing None; hex-looking / whitespace stays String (PINNED gating)
assert tb.readcsv("a,b\n1")["b"].tolist() == [None], "readcsv short row -> None"
assert type(tb.readcsv("id\n0x1F")["id"][0]) == "String", "readcsv leaves hex-looking cell as String"
assert tb.readcsv("x\n5", header = False).columns == ["col0"], "readcsv header=False default cols"
assert tb.readcsv("x\n5", infer = False)["x"].tolist() == ["5"], "readcsv infer=False keeps text"
assert raises_msg(Function(): return tb.readcsv("a,b\n1,2,3"), "expected"), "readcsv over-wide row throws"

# ============================================================ selection / loc / iloc / mask
assert df[["name", "salary"]].columns == ["name", "salary"], "column subset"
assert df["salary"].mean() == 113.75, "column aggregate"
# boolean-Series mask
assert df[df["salary"] > 100]["name"].tolist() == ["Ada", "Alan", "Edsger"], "boolean-Series mask"
# boolean-List mask
assert df[[True, False, True, False]]["name"].tolist() == ["Ada", "Grace"], "boolean-List mask"
assert raises_msg(Function(): return df[[True, False]], "mask length"), "wrong-length mask throws"
# iloc / loc
assert df.iloc[0]["name"] == "Ada", "iloc row"
assert df.iloc[[0, 2]]["name"].tolist() == ["Ada", "Grace"], "iloc list -> DataFrame"
assert df.loc[0]["name"] == "Ada", "loc by label"
assert df.loc[[1, 3]]["name"].tolist() == ["Alan", "Edsger"], "loc list -> DataFrame"
assert df.column("dept").tolist() == ["eng", "eng", "ops", "ops"], "df.column"
assert df.at(2, "name") == "Grace", "df.at(label, col)"
assert df.iat(3, 0) == "Edsger", "df.iat(pos, col)"
# rowat(pos) -> one row as a Series (indexed by column name); docs corrected from "a Dict".
assert type(df.rowat(0)) == "Series", "rowat returns a Series"
assert df.rowat(0)["dept"] == "eng", "rowat row access by column name"
# rowsat(positions) -> a sub-DataFrame of the selected row positions.
var sub = df.rowsat([0, 2])
assert type(sub) == "DataFrame" and sub.nrows() == 2, "rowsat -> sub-DataFrame of the given rows"
assert sub.rowat(0)["dept"] == df.rowat(0)["dept"], "rowsat preserves the selected rows"

# ============================================================ mutation / assign / rename / drop
var dm = df.copy()
dm["bonus"] = dm["salary"] * 0.1
assert dm["bonus"].tolist() == [12.0, 11.0, 9.5, 13.0], "assign Series column"
dm["flat"] = 1
assert dm["flat"].tolist() == [1, 1, 1, 1], "assign scalar column (broadcast)"
dm["lst"] = [9, 8, 7, 6]
assert dm["lst"].tolist() == [9, 8, 7, 6], "assign List column"
assert raises_msg(Function(): dm["bad"] = [1, 2], "match row count"), "wrong-length column throws"
var da = df.assign("x", 5)
assert da["x"].tolist() == [5, 5, 5, 5] and "x" not in df.columns, "assign returns a copy"
assert df.rename({"dept": "team"}).columns == ["name", "team", "salary"], "rename"
assert df.drop(["dept"]).columns == ["name", "salary"], "drop"
assert df.copy().columns == df.columns, "copy columns"

# ============================================================ frame aggregations (numeric cols only)
var summ = df.sum()
assert summ.tolist() == [455] and summ.index == ["salary"], "DataFrame.sum only numeric cols"
assert df.mean().tolist() == [113.75], "DataFrame.mean numeric"
assert df.min().tolist() == [95] and df.max().tolist() == [130], "DataFrame.min/max"
# count spans EVERY column (any dtype)
var cnt = df.count()
assert cnt.index == ["name", "dept", "salary"] and cnt.tolist() == [4, 4, 4], "DataFrame.count all columns"
# apply over each numeric column's Series
assert df.apply(Function(col): return col.max()).tolist() == [130], "DataFrame.apply numeric columns"
# describe
var desc = df.describe()
assert desc.columns == ["salary"], "describe numeric columns"
assert desc.index == ["count", "mean", "std", "min", "median", "max"], "describe stat rows"
assert desc["salary"]["count"] == 4 and desc["salary"]["mean"] == 113.75, "describe values"
assert desc["salary"]["min"] == 95 and desc["salary"]["max"] == 130 and desc["salary"]["median"] == 115.0, "describe min/max/median"

# ============================================================ sortvalues on DataFrame
assert df.sortvalues("salary")["name"].tolist() == ["Grace", "Alan", "Ada", "Edsger"], "df.sortvalues asc"
assert df.sortvalues("salary", ascending = False)["name"].tolist() == ["Edsger", "Ada", "Alan", "Grace"], "df.sortvalues desc"

# ============================================================ views: todict / torows / iterrows / tocsv / slice
assert df.todict()["salary"] == [120, 110, 95, 130], "todict"
assert df.torows()[0] == {"name": "Ada", "dept": "eng", "salary": 120}, "torows -> list of Dicts"
var itr = df.iterrows()
assert itr[0][0] == 0 and type(itr[0][1]) == "Series", "iterrows -> [index, Series]"
assert df.slice(1, 3)["name"].tolist() == ["Alan", "Grace"], "df.slice"
assert df.head(2)["name"].tolist() == ["Ada", "Alan"], "df.head"
assert df.tail(2)["name"].tolist() == ["Grace", "Edsger"], "df.tail"
assert df.head(-1).nrows() == 0, "df.head(-1) -> empty (PINNED)"
assert df.tail(-1).nrows() == 0, "df.tail(-1) -> empty (PINNED)"
# tocsv round-trips through readcsv
var rt = tb.readcsv(df.tocsv())
assert rt["salary"].tolist() == [120, 110, 95, 130] and rt.columns == df.columns, "tocsv/readcsv round-trip"

# ============================================================ setindex / resetindex on DataFrame
var si = df.setindex("name")
assert si.index == ["Ada", "Alan", "Grace", "Edsger"] and "name" not in si.columns, "setindex"
assert si.loc["Grace"]["salary"] == 95, "loc after setindex"
assert si.resetindex().index == [0, 1, 2, 3], "df.resetindex -> range"

# ============================================================ groupby + agg
var gdf = tb.readcsv("name,dept,salary\nAda,eng,120\nAlan,eng,110\nGrace,ops,95\nEdsger,ops,130")
var g = gdf.groupby("dept")
assert g.mean()["salary"].tolist() == [115.0, 112.5], "groupby.mean"
assert g.sum()["salary"].tolist() == [230, 225], "groupby.sum"
assert g.min()["salary"].tolist() == [110, 95], "groupby.min"
assert g.max()["salary"].tolist() == [120, 130], "groupby.max"
assert g.size().tolist() == [2, 2] and g.size().index == ["eng", "ops"], "groupby.size"
# count spans every value column, reports row count per group
assert g.count().columns == ["name", "salary"] and g.count()["salary"].tolist() == [2, 2], "groupby.count row counts"
assert g.agg({"salary": "max"})["salary"].tolist() == [120, 130], "groupby.agg max"
assert g.agg({"salary": "median"})["salary"].tolist() == [115.0, 112.5], "groupby.agg median"
# groupby.apply gets each sub-DataFrame
assert g.apply(Function(sub): return sub.nrows()).tolist() == [2, 2], "groupby.apply sub-DataFrame"

# ============================================================ merge (inner/left/right/outer)
var orders = tb.DataFrame([[1, 2], [2, 3], [3, 9]], columns = ["id", "product_id"])
var products = tb.DataFrame([[2, "Mouse"], [3, "Monitor"]], columns = ["product_id", "name"])
var jin = tb.merge(orders, products, on = "product_id", how = "inner")
assert jin["name"].tolist() == ["Mouse", "Monitor"], "merge inner"
assert jin.nrows() == 2, "merge inner drops unmatched"
var jle = tb.merge(orders, products, on = "product_id", how = "left")
assert jle.nrows() == 3 and jle["name"].tolist() == ["Mouse", "Monitor", None], "merge left keeps all left"
var jri = tb.merge(products, orders, on = "product_id", how = "right")
assert jri.nrows() == 3, "merge right keeps all right"
var jou = tb.merge(orders, products, on = "product_id", how = "outer")
assert jou.nrows() == 3, "merge outer"
# _x/_y suffix disambiguation for a shared non-key column
var L = tb.DataFrame([[1, "a"], [2, "b"]], columns = ["k", "v"])
var R = tb.DataFrame([[1, "c"], [2, "d"]], columns = ["k", "v"])
var jsuf = tb.merge(L, R, on = "k")
assert "v_x" in jsuf.columns and "v_y" in jsuf.columns, "merge suffixes shared column _x/_y"
assert jsuf["v_x"].tolist() == ["a", "b"] and jsuf["v_y"].tolist() == ["c", "d"], "merge suffix values"
# DataFrame.merge method form is equivalent
assert orders.merge(products, "product_id", "inner")["name"].tolist() == ["Mouse", "Monitor"], "DataFrame.merge method"

# ============================================================ concat
var c1 = tb.DataFrame({"a": [1, 2], "b": [3, 4]}, columns = ["a", "b"])
var c2 = tb.DataFrame({"a": [5], "c": [6]}, columns = ["a", "c"])
var cc = tb.concat([c1, c2])
assert cc.columns == ["a", "b", "c"], "concat column union"
assert cc["a"].tolist() == [1, 2, 5], "concat stacks values"
assert cc["b"].tolist() == [3, 4, None] and cc["c"].tolist() == [None, None, 6], "concat fills missing with None"
assert cc.nrows() == 3, "concat row count"

# ============================================================ missing data on DataFrame
var mdf = tb.readcsv("name,age\nAda,36\nBjarne,\nGrace,85")
assert mdf["age"].count() == 2, "count skips blank cell"
assert mdf["age"].mean() == 60.5, "mean skips missing"
assert mdf.dropna()["name"].tolist() == ["Ada", "Grace"], "df.dropna"
assert mdf.fillna(0)["age"].tolist() == [36, 0, 85], "df.fillna"

# ============================================================ NaN key handling (the recent fix)
# groupby DROPS a Float NaN key (write-only in a Dict); None keys are KEPT.
var gk = tb.DataFrame({"k": [1.0, nan, 1.0, 2.0], "v": [10, 20, 30, 40]}, columns = ["k", "v"])
var gg = gk.groupby("k")
assert gg.size().index == [1.0, 2.0], "groupby drops NaN key rows"
assert gg.sum()["v"].tolist() == [40, 40], "groupby NaN-key rows excluded from reduction"
var gnone = tb.DataFrame({"k": [None, 1, None], "v": [5, 6, 7]}, columns = ["k", "v"])
var ggn = gnone.groupby("k")
assert None in ggn.size().index, "groupby KEEPS a None key"
assert ggn.sum()["v"].tolist() == [12, 6], "groupby None-key group sums non-NaN rows"
# merge with a NaN join key must NOT crash (a NaN key is simply non-matching)
var no = tb.DataFrame({"pid": [nan, 2.0], "q": [1, 2]}, columns = ["pid", "q"])
var np = tb.DataFrame({"pid": [2.0, 3.0], "nm": ["M", "N"]}, columns = ["pid", "nm"])
assert not raises(Function(): return tb.merge(no, np, on = "pid", how = "inner")), "merge NaN key inner does not crash"
assert tb.merge(no, np, on = "pid", how = "inner")["nm"].tolist() == ["M"], "merge NaN key inner drops NaN row"
assert not raises(Function(): return tb.merge(no, np, on = "pid", how = "outer")), "merge NaN key outer does not crash"
assert tb.merge(no, np, on = "pid", how = "outer").nrows() == 3, "merge NaN key outer row count"

# ============================================================ duplicate columns / ragged rows (PINNED)
# duplicate column name via columns=: self.columns keeps both, self.data keeps ONE (last wins)
var dup = tb.DataFrame([[1, 2], [3, 4]], columns = ["a", "a"])
assert dup.columns == ["a", "a"], "duplicate column name kept in columns list"
assert dup["a"].tolist() == [2, 4], "duplicate column: last column wins in data (PINNED)"
# ragged list-of-lists: a SHORT later row throws (index out of range); a LONG later row silently truncates
assert raises(Function(): return tb.DataFrame([[1, 2], [3]])), "ragged short row throws (PINNED)"
var rlong = tb.DataFrame([[1, 2], [3, 4, 5]])
assert rlong.columns == ["col0", "col1"] and rlong.nrows() == 2, "ragged long row silently truncated (PINNED)"

# ============================================================ HARDENING
assert raises(Function(): return df["nonexistent"]), "missing column raises"
assert raises_msg(Function(): return tb.merge(orders, products, on = "product_id", how = "bogus"), "how must be one of"), "bad merge how throws"
assert raises_msg(Function(): return orders.merge(products, "product_id", "bogus"), "how must be one of"), "bad how via DataFrame.merge throws"
assert raises(Function(): return gdf.groupby("dept").agg({"salary": "bogus"})), "unknown reducer in agg raises"

# ============================================================ Series.all()/any() (now implemented)
# docs (10-stdlib.md) present s.all()/s.any() as the way to reduce a boolean Series to a scalar.
var bmask = tb.Series([True, True, False])
assert bmask.all() == False and bmask.any() == True, "Series all/any on a mixed mask"
assert tb.Series([True, True]).all() == True, "Series.all() all-true"
assert tb.Series([False, False]).any() == False, "Series.any() all-false"
assert tb.Series([]).all() == True and tb.Series([]).any() == False, "Series all/any empty (vacuous)"
assert (tb.Series([10, 30, 20]) > 25).any() == True and (tb.Series([10, 30, 20]) > 25).all() == False, "all/any on a comparison mask"
# a DataFrame has no arithmetic operators (docs: 'operated on per-column'); df + 1 raises.
assert raises(Function(): return df + 1), "DataFrame arithmetic operator not implemented"

io.print("OK tabular")
