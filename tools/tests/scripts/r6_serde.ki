# r6_serde.ki — ROUND-6 audit of the `serialize` (text) AND `dump` (binary) stdlib modules, the two
# formats of the same object-graph serialization core (serde::flatten/rebuild). Verifies every
# documented behavior of docs/pages/10-stdlib.md "## serialize" / "## dump" against the implementation
# (stdlib_serde.hpp shared core, stdlib_serialize.hpp text codec, stdlib_dump.hpp binary codec).
# Non-overlapping companion to r5_serde.ki / deep_serialization.ki (those cover throwing _getstate_,
# huge >2^16 containers, and the compression stack; this covers the base contract + cross-format
# agreement + corrupt-blob handling + keyword args).
# Focus areas:
#   - every built-in value type round-trips through BOTH formats
#   - shared references stay one object (id()), self-cycles + mutual-instance cycles terminate
#   - user classes by-attribute AND via the _getstate_/_setstate_ protocol (dropping a transient field)
#   - native value types that opt in: DateTime, Random (exact-stream checkpoint), Set/Bytes/Dict nested
#   - serialize(text) and dump(binary) AGREE on the same input
#   - live resources that must NOT serialize (open file, BytesIO) throw cleanly (a Function DOES)
#   - corrupt/truncated blobs throw a clean diagnostic (never a crash), with bounds-checked ids
#   - file save/load round-trip (scratch dir, cleaned up); keyword-argument support per inspect
#
# DETERMINISTIC: the only RNG is a fixed-seed generator whose RESTORED stream is compared to the
# original (a checkpoint test), never to a literal. No clock/network. Scratch files are removed.

var io = import("io")
var path = import("path")
var sys = import("sys")
var serialize = import("serialize")
var dump = import("dump")
var time = import("time")
var random = import("random")
var math = import("math")

var n = 0
var ok = Function(cond, msg):
    n = n + 1
    assert cond, msg

var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch as e:
        return True

# A round-trip through a given format (loadfn . dumpfn). Used to run every check against both formats.
var roundtrip = Function(loadfn, dumpfn, v):
    return loadfn(dumpfn(v))

# ============================================================ OUTPUT TYPES (documented)
ok(type(serialize.dumps([1, 2])) == "String", "serialize.dumps returns a String")
ok(type(dump.dumps([1, 2])) == "Bytes", "dump.dumps returns Bytes")

# ============================================================ EVERY BUILT-IN VALUE TYPE, BOTH FORMATS
var scalars = [None, True, False, 0, 42, -9223372036854775808, 9223372036854775807, 3.14, -0.0, "hi", "", "uniécode"]
for v in scalars:
    ok(roundtrip(dump.loads, dump.dumps, v) == v, "dump scalar round-trip: " + String(v))
    ok(roundtrip(serialize.loads, serialize.dumps, v) == v, "serialize scalar round-trip: " + String(v))

# Non-finite floats are raw f64 bits in both codecs (not JSON tokens), so they survive a cycle. NaN !=
# NaN, so verify via math.isnan; inf compares == exactly.
ok(math.isnan(dump.loads(dump.dumps(math.nan))), "dump: NaN round-trips (isnan)")
ok(math.isnan(serialize.loads(serialize.dumps(math.nan))), "serialize: NaN round-trips (isnan)")
ok(dump.loads(dump.dumps(math.inf)) == math.inf, "dump: +inf round-trips")
ok(serialize.loads(serialize.dumps(-math.inf)) == -math.inf, "serialize: -inf round-trips")

# containers
var containers = [[1, 2, 3], {"a": 1, "b": [2, 3]}, Set([1, 2, 3]), Bytes([0, 127, 128, 255]), [], {}, Set([])]
for c in containers:
    ok(roundtrip(dump.loads, dump.dumps, c) == c, "dump container round-trip")
    ok(roundtrip(serialize.loads, serialize.dumps, c) == c, "serialize container round-trip")

# Bytes preserves its type (not silently a String)
ok(type(dump.loads(dump.dumps(Bytes([1, 2])))) == "Bytes", "dump preserves Bytes type")
ok(type(serialize.loads(serialize.dumps(Bytes([1, 2])))) == "Bytes", "serialize preserves Bytes type")

# deeply mixed nested graph
var mixed = {"list": [1, [2, [3]]], "set": Set(["a", "b"]), "dict": {"x": Bytes([9])}, "scal": 2.5}
ok(roundtrip(dump.loads, dump.dumps, mixed) == mixed, "dump mixed nested graph round-trips")
ok(roundtrip(serialize.loads, serialize.dumps, mixed) == mixed, "serialize mixed nested graph round-trips")

# ============================================================ SHARED REFERENCES (stay one object)
var shared = [1, 2, 3]
var pair = [shared, shared]
var rd = dump.loads(dump.dumps(pair))
ok(id(rd[0]) == id(rd[1]), "dump: shared reference stays one object")
var rs = serialize.loads(serialize.dumps(pair))
ok(id(rs[0]) == id(rs[1]), "serialize: shared reference stays one object")
# a value reachable by two distinct paths
var inner = {"v": 7}
var outer = {"a": inner, "b": [inner]}
var od = dump.loads(dump.dumps(outer))
ok(id(od["a"]) == id(od["b"][0]), "dump: diamond reference stays one object")
var os = serialize.loads(serialize.dumps(outer))
ok(id(os["a"]) == id(os["b"][0]), "serialize: diamond reference stays one object")

# ============================================================ CYCLES
# A list containing itself: id reservation before recursion makes it terminate and preserves the cycle.
var cyc = [1]
cyc.append(cyc)
var cd = dump.loads(dump.dumps(cyc))
ok(cd[0] == 1 and id(cd[1]) == id(cd), "dump: self-referential list cycle preserved")
var cs = serialize.loads(serialize.dumps(cyc))
ok(cs[0] == 1 and id(cs[1]) == id(cs), "serialize: self-referential list cycle preserved")
# a Dict that contains itself as a value
var dcyc = {}
dcyc["self"] = dcyc
var dcd = dump.loads(dump.dumps(dcyc))
ok(id(dcd["self"]) == id(dcd), "dump: self-referential dict cycle preserved")

# Two mutually-referencing instances.
class Node:
    var _init_ = Function(self, label):
        self.label = label
        self.peer = None
var a = Node("a")
var b = Node("b")
a.peer = b
b.peer = a
var ad = dump.loads(dump.dumps(a))
ok(ad.label == "a" and ad.peer.label == "b" and id(ad.peer.peer) == id(ad), "dump: mutual instance cycle preserved")
var asr = serialize.loads(serialize.dumps(a))
ok(asr.label == "a" and asr.peer.label == "b" and id(asr.peer.peer) == id(asr), "serialize: mutual instance cycle preserved")

# ============================================================ USER CLASS by-attribute (default)
class Point:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
var p = Point(3, 4)
var pd = dump.loads(dump.dumps(p))
ok(pd.x == 3 and pd.y == 4, "dump: user class serialized by attributes")
var ps = serialize.loads(serialize.dumps(p))
ok(ps.x == 3 and ps.y == 4, "serialize: user class serialized by attributes")
# nested instances + container attributes
class Box:
    var _init_ = Function(self, items):
        self.items = items
        self.tag = "box"
var box = Box([Point(1, 1), Point(2, 2)])
var bx = dump.loads(dump.dumps(box))
ok(bx.tag == "box" and bx.items[1].y == 2, "dump: nested instances in a list attribute")

# ============================================================ _getstate_/_setstate_ PROTOCOL
# Drops a transient field and recomputes it on load (the documented use case).
class Temp:
    var _init_ = Function(self, c):
        self.celsius = c
        self.fahrenheit = c * 9.0 / 5.0 + 32.0   # transient
    var _getstate_ = Function(self):
        return self.celsius
    var _setstate_ = Function(self, s):
        self.celsius = s
        self.fahrenheit = s * 9.0 / 5.0 + 32.0
var t = Temp(100)
var td = dump.loads(dump.dumps(t))
ok(td.celsius == 100 and td.fahrenheit == 212.0, "dump: _getstate_/_setstate_ restores + recomputes")
var ts = serialize.loads(serialize.dumps(t))
ok(ts.celsius == 100 and ts.fahrenheit == 212.0, "serialize: _getstate_/_setstate_ restores + recomputes")

# ============================================================ NATIVE VALUE TYPES (opt-in)
# DateTime: value equality by instant; round-trips through both formats.
var dt = time.make(2026, 6, 28, 14, 5, 30)
ok(dump.loads(dump.dumps(dt)) == dt, "dump: DateTime round-trips by instant")
ok(serialize.loads(serialize.dumps(dt)) == dt, "serialize: DateTime round-trips by instant")
ok(type(dump.loads(dump.dumps(dt))) == "DateTime", "dump: DateTime keeps its type")

# Random: a serialized generator restores the EXACT stream (reproducible checkpoint).
var rng = random.Random(20260629)
discard rng.randint(0, 100)
discard rng.randint(0, 100)
var rngD = dump.loads(dump.dumps(rng))
ok(rng.randint(0, 1000000000) == rngD.randint(0, 1000000000), "dump: Random restores the exact stream")
var rng2 = random.Random(20260629)
discard rng2.randint(0, 100)
discard rng2.randint(0, 100)
var rngS = serialize.loads(serialize.dumps(rng2))
ok(rng2.randint(0, 1000000000) == rngS.randint(0, 1000000000), "serialize: Random restores the exact stream")

# native value nested inside a container, with shared references, through both formats
var natGraph = {"when": dt, "blob": Bytes([5, 6, 7]), "set": Set([1, 2])}
var ng_s = serialize.loads(serialize.dumps(natGraph))
var ng_d = dump.loads(dump.dumps(natGraph))
ok(ng_s["when"] == dt and ng_d["when"] == dt, "DateTime nested in a dict round-trips (both formats)")

# ============================================================ CROSS-FORMAT AGREEMENT
# serialize(text) and dump(binary) reconstruct the SAME value graph from the same input.
var ca = Node("ca")
var cb = Node("cb")
ca.peer = cb
cb.peer = ca
var graph = {"cycle": ca, "blob": Bytes([1, 2, 3]), "set": Set([4, 5]), "nums": [1, 2.5, None, True], "dt": dt}
var gx_s = serialize.loads(serialize.dumps(graph))
var gx_d = dump.loads(dump.dumps(graph))
ok(gx_s["blob"] == gx_d["blob"], "cross-format: Bytes agree")
ok(gx_s["set"] == gx_d["set"], "cross-format: Set agree")
ok(gx_s["nums"] == gx_d["nums"], "cross-format: mixed list agree")
ok(gx_s["dt"] == gx_d["dt"], "cross-format: DateTime agree")
ok(id(gx_s["cycle"].peer.peer) == id(gx_s["cycle"]), "cross-format: serialize cycle intact")
ok(id(gx_d["cycle"].peer.peer) == id(gx_d["cycle"]), "cross-format: dump cycle intact")

# ============================================================ RESOURCES MUST NOT SERIALIZE
var SCRATCH = import("path").gettempdir()   # portable temp dir (TMPDIR/TMP/TEMP, falls back to /tmp)
var fpath = path.join(SCRATCH, "r6_serde_resource.txt")
var f = io.open(fpath, "w")
ok(throws(Function(): return dump.dumps(f)), "dump: an open file throws (resource)")
ok(throws(Function(): return serialize.dumps(f)), "serialize: an open file throws (resource)")
discard f.close()
discard path.remove(fpath, missing_ok = True)
# a Function now serializes by default (its source + captured free variables travel)
var _sq6 = Function(x): return x * x
ok(dump.loads(dump.dumps(_sq6))(7) == 49, "dump: a Function round-trips")
ok(serialize.loads(serialize.dumps(_sq6))(6) == 36, "serialize: a Function round-trips")
# a BytesIO (a live stream) is not serializable
var bio = io.BytesIO()
ok(throws(Function(): return dump.dumps(bio)), "dump: a BytesIO throws (resource)")

# ============================================================ CORRUPT / TRUNCATED BLOBS THROW CLEANLY
# A malformed blob must produce a catchable diagnostic, never a crash.
ok(throws(Function(): return serialize.loads("not a blob")), "serialize: garbage text throws")
ok(throws(Function(): return serialize.loads("")), "serialize: empty text throws")
ok(throws(Function(): return serialize.loads("KSER2 0 0")), "serialize: bad header magic throws")
ok(throws(Function(): return serialize.loads("KSER1 99 0")), "serialize: object count > data throws")
ok(throws(Function(): return serialize.loads("KSER1 1 I notanumber 0")), "serialize: malformed int token throws")
ok(throws(Function(): return dump.loads(Bytes([1, 2, 3, 4, 5]))), "dump: garbage bytes throw")
ok(throws(Function(): return dump.loads(Bytes([]))), "dump: empty bytes throw")
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 99]))), "dump: unsupported version throws")
ok(throws(Function(): return dump.loads(42)), "dump.loads on a non-Bytes/non-String throws")
# truncated dump (valid header KDMP v1, count says 1, but no record bytes)
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0]))), "dump: truncated record throws")

# ============================================================ dump.loads ALSO accepts a String of bytes
# (documented: discouraged because String() wrapping corrupts the blob, but a byte-transparent String
# of the same bytes is accepted). latin-1 maps bytes<->code-points 1:1.
var blob = dump.dumps([1, 2, 3])
ok(dump.loads(blob.decode("latin-1")) == [1, 2, 3], "dump.loads accepts a byte-transparent String")

# ============================================================ KEYWORD ARGUMENTS (per inspect)
ok(serialize.dumps(value=[1, 2]) == serialize.dumps([1, 2]), "serialize.dumps accepts value= keyword")
ok(serialize.loads(text=serialize.dumps([5])) == [5], "serialize.loads accepts text= keyword")
ok(dump.loads(data=dump.dumps([6])) == [6], "dump.loads accepts data= keyword")

# ============================================================ FILE save/load ROUND-TRIP (scratch, cleaned)
# serialize.save/load (text)
var spath = path.join(SCRATCH, "r6_serde_text.kser")
serialize.save(graph, spath)
var sload = serialize.load(spath)
ok(id(sload["cycle"].peer.peer) == id(sload["cycle"]), "serialize.save/load preserves a cycle on disk")
ok(sload["blob"] == Bytes([1, 2, 3]), "serialize.save/load preserves Bytes on disk")
discard path.remove(spath, missing_ok = True)
ok(path.exists(spath) == False, "serialize scratch file cleaned up")
# dump.save/load (binary)
var dpath = path.join(SCRATCH, "r6_serde_bin.kdmp")
dump.save(graph, dpath)
var dload = dump.load(dpath)
ok(id(dload["cycle"].peer.peer) == id(dload["cycle"]), "dump.save/load preserves a cycle on disk")
ok(dload["dt"] == dt, "dump.save/load preserves a DateTime on disk")
discard path.remove(dpath, missing_ok = True)
ok(path.exists(dpath) == False, "dump scratch file cleaned up")
# save to an unwritable path throws cleanly
ok(throws(Function(): return dump.save([1], "/nonexistent_dir_r6/x.bin")), "dump.save to a bad path throws")
ok(throws(Function(): return serialize.load(path.join(SCRATCH, "r6_does_not_exist.kser"))), "serialize.load of a missing file throws")

# ============================================================ DEPTH GUARD (no native-stack overflow)
# A pathologically deep nested list must THROW (flatten depth guard) instead of overflowing.
var bad = []
var cur = bad
var depth = 0
while depth < 20000:
    var nxt = []
    cur.append(nxt)
    cur = nxt
    depth = depth + 1
ok(throws(Function(): return dump.dumps(bad)), "dump: 20000-deep list throws (depth guard)")
ok(throws(Function(): return serialize.dumps(bad)), "serialize: 20000-deep list throws (depth guard)")

io.print("r6_serde: " + String(n) + " checks passed")
