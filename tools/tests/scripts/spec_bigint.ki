# int module: arbitrary-precision BigInt, the integer math set, and primality. Kirito-level tests —
# known values, a differential fuzz against native Integer, floor-div/mod sign agreement, the
# reflected-operator invariant, cross-type equality/hashing, serialize/dump round-trips, and
# primality (deterministic trial division + Miller-Rabin agreeing on a range). Runs under every preset.
var int = import("int")
var random = import("random")
var math = import("math")
var serialize = import("serialize")
var dump = import("dump")
var io = import("io")

var raises = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch:
        return True

# --- known values ---
assert String(int.factorial(20)) == "2432902008176640000", "factorial 20"
assert String(int.factorial(50)) == "30414093201713378043612608166064768844377641568960512000000000000", "factorial 50"
assert String(int.pow(2, 128)) == "340282366920938463463374607431768211456", "2**128"
assert String(int.BigInt(4).modpow(13, 497)) == "445", "modpow"
assert String(int.from_string("354224848179261915075")) == "354224848179261915075", "fib100 parse"
assert String(int.isqrt(int.pow(2, 200))) == "1267650600228229401496703205376", "isqrt 2**200 = 2**100"

# --- true division is Float ---
assert int.BigInt(10) / int.BigInt(4) == 2.5, "big / -> Float"
assert type(int.BigInt(7) / int.BigInt(2)) == "Float", "big / type Float"

# --- reflected-operator invariant: dispatch on the LEFT operand ---
assert String(int.BigInt(2) + 3) == "5", "BigInt + Integer"
assert raises(Function(): return 3 + int.BigInt(2)), "Integer + BigInt throws"
assert raises(Function(): return 3 * int.BigInt(2)), "Integer * BigInt throws"
# == / != stay symmetric
assert int.BigInt(5) == 5 and 5 == int.BigInt(5), "== symmetric"
assert int.BigInt(5) != 6 and 6 != int.BigInt(5), "!= symmetric"
# hashing agrees with an equal Integer
var d = {}
d[int.BigInt(42)] = "x"
assert d[42] == "x", "BigInt/Integer share a Dict bucket"
assert len({int.BigInt(9), 9}) == 1, "BigInt/Integer share a Set bucket"

# --- differential fuzz vs native Integer (kept in a no-overflow range) ---
for i in range(400):
    var a = random.randbelow(2000000000) - 1000000000
    var b = random.randbelow(2000000000) - 1000000000
    assert String(int.BigInt(a) + b) == String(a + b), "fuzz +"
    assert String(int.BigInt(a) - b) == String(a - b), "fuzz -"
    assert String(int.BigInt(a) * b) == String(a * b), "fuzz *"
    assert (int.BigInt(a) < b) == (a < b), "fuzz <"
    assert (int.BigInt(a) == b) == (a == b), "fuzz =="
    if b != 0:
        assert String(int.BigInt(a) // b) == String(a // b), "fuzz // (floor)"
        assert String(int.BigInt(a) % b) == String(a % b), "fuzz % (floor sign)"

# floor-div/mod sign conventions (all four quadrants) match native
assert String(int.BigInt(-7) // 2) == "-4" and String(int.BigInt(-7) % 2) == "1", "neg dividend"
assert String(int.BigInt(7) // -2) == "-4" and String(int.BigInt(7) % -2) == "-1", "neg divisor"

# --- base round-trips ---
for base in range(2, 37):
    var n = int.pow(int.BigInt(base), 50) + 999
    assert int.from_string(String(n)) == n, "base10 round-trip"
assert String(int.BigInt("0xff")) == "255" and String(int.from_string("zz", 36)) == "1295", "prefixes/bases"
assert String(int.BigInt("-123456789012345678901234567890")) == "-123456789012345678901234567890", "big negative parse"

# --- int math set: exact analogues of math, and exact where math overflows ---
assert String(int.gcd(48, 60)) == String(math.gcd(48, 60)), "gcd == math.gcd"
assert String(int.lcm(12, 18)) == String(math.lcm(12, 18)), "lcm == math.lcm"
assert String(int.factorial(12)) == String(math.factorial(12)), "factorial == math"
assert String(int.comb(20, 7)) == String(math.comb(20, 7)), "comb == math"
assert String(int.perm(15, 4)) == String(math.perm(15, 4)), "perm == math"
assert String(int.comb(100, 50)) == "100891344545564193334812497256", "comb exact beyond int64"
# isqrt property
for i in range(200):
    var x = random.randbelow(1000000000000000000)
    var r = int.isqrt(x)
    assert r * r <= x and (r + 1) * (r + 1) > x, "isqrt floor property"
# modinv property
for i in range(200):
    var m = 2 + random.randbelow(100000)
    var a = 1 + random.randbelow(m - 1)
    if int.gcd(int.BigInt(a), m) == 1:
        assert (int.modinv(a, m) * a) % m == 1, "modinv property"

# --- primality: deterministic and probabilistic agree over a range ---
var refprime = Function(n) -> Bool:
    if n < 2:
        return False
    var i = 2
    while i * i <= n:
        if n % i == 0:
            return False
        i = i + 1
    return True
for n in range(0, 1000):
    assert int.is_prime(n) == refprime(n), "is_prime vs reference"
    assert int.is_probable_prime(n) == refprime(n), "is_probable_prime vs reference"
# Carmichael numbers must be rejected by Miller-Rabin
for c in [561, 1105, 1729, 2465, 2821, 6601, 8911]:
    assert int.is_probable_prime(c) == False, "Carmichael rejected"
# Mersenne / large primes recognised
assert int.is_probable_prime(int.pow(2, 61) - 1), "M61 prime"
assert int.is_probable_prime(int.pow(2, 127) - 1), "M127 prime"
# random_prime output is prime with the right bit length (verified with the fast test)
var p = int.random_prime(48)
assert int.is_probable_prime(p) and p.bit_length() == 48, "random_prime 48-bit"

# --- methods ---
assert int.pow(2, 100).bit_length() == 101, "bit_length"
assert int.BigInt(255).to_int() == 255 and type(int.BigInt(255).to_int()) == "Integer", "to_int"
assert raises(Function(): return int.pow(2, 100).to_int()), "to_int overflow throws"

# --- serialize / dump round-trips ---
var big = int.pow(7, 80) - int.pow(3, 50)
assert serialize.loads(serialize.dumps(big)) == big, "serialize round-trip"
assert dump.loads(dump.dumps(big)) == big, "dump round-trip"

# --- adversarial ---
assert raises(Function(): return int.BigInt(5) // 0), "div by zero"
assert raises(Function(): return int.BigInt(5) % 0), "mod by zero"
assert raises(Function(): return int.modinv(4, 8)), "modinv non-coprime"
assert raises(Function(): return int.from_string("12x")), "bad digit"
assert raises(Function(): return int.from_string("7", 40)), "bad base"
assert raises(Function(): return int.BigInt("hello")), "non-numeric string"
assert raises(Function(): return int.factorial(-1)), "factorial negative"
assert raises(Function(): return int.BigInt(3.14)), "Float rejected"
assert int.is_prime(-5) == False and int.is_prime(0) == False and int.is_prime(1) == False, "non-primes"

io.print("OK bigint")
