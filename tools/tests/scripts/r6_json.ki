# r6_json.ki — ROUND-6 audit of the `json` stdlib module (parse/loads, stringify/dumps).
# Verifies every documented behavior of docs/pages/10-stdlib.md "## json" against the implementation
# (src/kirito/stdlib_json.hpp). Non-overlapping companion to r5_serde.ki / deep_serialization.ki.
# Focus areas:
#   - round-trips of deeply nested mixed structures; exact float round-trip (Float == is exact)
#   - every escape (\" \\ \/ \n \t \r \b \f \xHH-equivalent), \u escapes, surrogate pairs, and the
#     WHATWG unpaired-surrogate -> U+FFFD substitution
#   - the non-finite tokens NaN / Infinity / -Infinity (parse + emit, both directions)
#   - indent pretty-printing (compact at indent<=0; nested padding at indent>0; empty containers)
#   - keyword-argument support (parse(text=...), stringify(value=..., indent=...)) per inspect
#   - malformed inputs that MUST throw (truncated/unterminated/bad-token/trailing-junk/bad-escape/
#     non-string-key/deep-nest)
#   - the INTENTIONALLY-LENIENT number forms (leading zeros, trailing dot, empty exponent) that PARSE
#     rather than throw — a pinned design decision (see the source comment + deep_serialization.ki)
#
# DETERMINISTIC: no RNG, clock, or network. Only CONFIRMED-correct behavior is asserted.

var io = import("io")
var json = import("json")

var n = 0
var ok = Function(cond, msg):
    n = n + 1
    assert cond, msg

# True iff fn() thrown a catchable error (a clean diagnostic, never a crash).
var throws = Function(fn) -> Bool:
    try:
        discard fn()
        return False
    catch as e:
        return True

# ============================================================ ALIASES
# loads == parse, dumps == stringify (documented aliases).
ok(json.loads("[1, 2, 3]") == [1, 2, 3], "loads is an alias of parse")
ok(json.dumps([1, 2, 3]) == "[1, 2, 3]", "dumps is an alias of stringify")
ok(json.parse("true") == True and json.parse("false") == False, "true/false literals")
ok(json.parse("null") == None, "null -> None")

# ============================================================ SCALAR ROUND-TRIPS
ok(json.parse("42") == 42 and type(json.parse("42")) == "Integer", "integer parses to Integer")
ok(json.parse("-7") == -7, "negative integer")
ok(json.parse("3.14") == 3.14 and type(json.parse("3.14")) == "Float", "float parses to Float")
ok(json.parse("1.5e3") == 1500.0, "scientific notation")
ok(json.parse("2e-3") == 0.002, "negative exponent")
ok(json.parse("\"hello\"") == "hello", "string parses")
ok(json.parse("\"\"") == "", "empty string parses")

# ============================================================ OBJECTS -> Dict, ARRAYS -> List
ok(json.parse("{\"a\": 1, \"b\": 2}") == {"a": 1, "b": 2}, "object parses to Dict")
ok(json.parse("[]") == [], "empty array -> empty List")
ok(json.parse("{}") == {}, "empty object -> empty Dict")
ok(type(json.parse("{\"k\": 1}")) == "Dict", "parsed object is a Dict")
ok(type(json.parse("[1]")) == "List", "parsed array is a List")

# ============================================================ NESTED ROUND-TRIP
var nested = {"name": "x", "nums": [1, 2, [3, 4]], "meta": {"ok": True, "n": None}, "f": 2.5}
ok(json.loads(json.dumps(nested)) == nested, "nested structure round-trips")
var deep = [1, [2, [3, [4, [5, [6]]]]]]
ok(json.loads(json.dumps(deep)) == deep, "deeply nested list round-trips")

# ============================================================ EXACT FLOAT ROUND-TRIP
# Float == is EXACT bit equality; dumps emits the shortest round-tripping form so loads recovers the
# identical double (documented).
ok(json.dumps(0.1 + 0.2) == "0.30000000000000004", "0.1+0.2 emits the full-precision form")
ok(json.loads(json.dumps(0.1 + 0.2)) == 0.1 + 0.2, "0.1+0.2 round-trips bit-exactly")
ok(json.loads(json.dumps(1.0 / 3.0)) == 1.0 / 3.0, "1/3 round-trips bit-exactly")
ok(json.loads(json.dumps(2.2250738585072014e-308)) == 2.2250738585072014e-308, "subnormal-ish double round-trips")

# ============================================================ ESCAPES (read side)
ok(json.parse("\"a\\nb\"") == "a\nb", "\\n escape")
ok(json.parse("\"a\\tb\"") == "a\tb", "\\t escape")
ok(json.parse("\"a\\rb\"") == "a\rb", "\\r escape")
ok(json.parse("\"a\\\\b\"") == "a\\b", "\\\\ escape (backslash)")
ok(json.parse("\"a\\\"b\"") == "a\"b", "\\\" escape (quote)")
ok(json.parse("\"a\\/b\"") == "a/b", "\\/ escape (solidus)")
var bf = json.parse("\"\\b\\f\"")
ok(bf == (chr(8) + chr(12)), "\\b and \\f escapes")
# all eight escapes in one string
var allesc = json.parse("\"\\\"\\\\\\/\\n\\t\\r\\b\\f\"")
ok(len(allesc) == 8, "all eight escapes decode to eight chars")

# ============================================================ \u ESCAPES + SURROGATE PAIRS
ok(json.parse("\"\\u0041\"") == "A", "\\u0041 -> A")
ok(json.parse("\"\\u00e9\"") == chr(233), "\\u00e9 -> e-acute (BMP)")
# surrogate pair: U+1F600 GRINNING FACE encoded as 😀 -> one code point
var emoji = json.parse("\"\\ud83d\\ude00\"")
ok(len(emoji) == 1, "surrogate pair decodes to one code point")
ok(emoji == chr(128512), "surrogate pair -> U+1F600")
# WHATWG: an UNPAIRED surrogate is substituted with U+FFFD (well-formed UTF-8), NOT an error
ok(json.parse("\"\\ud800\"") == chr(65533), "lone high surrogate -> U+FFFD")
ok(json.parse("\"\\udc00\"") == chr(65533), "lone low surrogate -> U+FFFD")
var hx = json.parse("\"\\ud83dX\"")
ok(hx[0] == chr(65533) and hx[1] == "X", "high surrogate not followed by \\u -> U+FFFD + rest")

# ============================================================ NON-FINITE TOKENS (both directions)
var nan = json.parse("NaN")
ok(nan != nan, "NaN token parses to NaN (NaN != NaN)")
ok(json.parse("Infinity") > 0.0, "Infinity token -> +inf")
ok(json.parse("-Infinity") < 0.0, "-Infinity token -> -inf")
ok(json.dumps(json.parse("Infinity")) == "Infinity", "dumps emits Infinity")
ok(json.dumps(json.parse("-Infinity")) == "-Infinity", "dumps emits -Infinity")
ok(json.dumps(nan) == "NaN", "dumps emits NaN")
ok(json.loads(json.dumps(json.parse("Infinity"))) == json.parse("Infinity"), "inf round-trips")

# ============================================================ INDENT PRETTY-PRINT
# indent <= 0 is compact; indent > 0 nests with `indent` spaces per level.
ok(json.dumps([1, 2]) == "[1, 2]", "default is compact")
ok(json.dumps([1, 2], 0) == "[1, 2]", "indent 0 is compact")
ok(json.dumps([1, 2], -1) == "[1, 2]", "negative indent is compact")
ok(json.dumps([1, 2], 2) == "[\n  1,\n  2\n]", "indent 2 nests a list")
ok(json.dumps({"a": 1}, 2) == "{\n  \"a\": 1\n}", "indent 2 nests an object")
# nested indent: two levels indent correctly
ok(json.dumps({"a": [1]}, 2) == "{\n  \"a\": [\n    1\n  ]\n}", "indent nests two levels")
# empty containers stay inline even with indent
ok(json.dumps([], 2) == "[]", "empty list stays [] under indent")
ok(json.dumps({}, 2) == "{}", "empty object stays {} under indent")
# pretty-printed output is still valid (round-trips)
ok(json.loads(json.dumps(nested, 4)) == nested, "pretty-printed output still round-trips")

# ============================================================ KEYWORD ARGUMENTS (per inspect)
ok(json.parse(text="[9, 8]") == [9, 8], "parse accepts text= keyword")
ok(json.loads(text="[7]") == [7], "loads accepts text= keyword")
ok(json.stringify(value=[1, 2]) == "[1, 2]", "stringify accepts value= keyword")
ok(json.stringify(value=[1], indent=2) == "[\n  1\n]", "stringify accepts value=+indent= keywords")
ok(json.dumps(value=[3], indent=0) == "[3]", "dumps accepts value=+indent= keywords")

# ============================================================ STRINGIFY: control chars + key tokens
# stringify always \u-escapes control chars U+0000..U+001F so the output is valid JSON, and a
# parse->dumps->parse round-trip is lossless.
var ctrl = "x" + chr(0) + chr(9) + chr(10) + chr(31) + "y"
ok(json.loads(json.dumps(ctrl)) == ctrl, "control chars re-escape and round-trip")
ok("\\u0000" in json.dumps(ctrl), "NUL emitted as \\u0000")
# Bool/None Dict keys serialize as the canonical JSON tokens (documented).
ok(json.dumps({True: 1}) == "{\"true\": 1}", "Bool key -> \"true\"")
ok(json.dumps({None: 1}) == "{\"null\": 1}", "None key -> \"null\"")

# ============================================================ NON-JSON VALUE TYPES throw on stringify
ok(throws(Function(): return json.dumps(Set([1, 2]))), "stringify a Set throws")
ok(throws(Function(): return json.dumps(Bytes([1, 2]))), "stringify a Bytes throws")
# a cyclic structure cannot be stringified (would not terminate)
var cyc = [1]
cyc.append(cyc)
ok(throws(Function(): return json.dumps(cyc)), "stringify a cyclic structure throws")

# ============================================================ MALFORMED INPUT MUST THROW
ok(throws(Function(): return json.parse("")), "empty input throws")
ok(throws(Function(): return json.parse("   ")), "whitespace-only input throws")
ok(throws(Function(): return json.parse("[1, 2")), "truncated array throws")
ok(throws(Function(): return json.parse("{\"a\": 1")), "truncated object throws")
ok(throws(Function(): return json.parse("\"abc")), "unterminated string throws")
ok(throws(Function(): return json.parse("[1, 2,]")), "trailing comma in array throws")
ok(throws(Function(): return json.parse("{\"a\": 1,}")), "trailing comma in object throws")
ok(throws(Function(): return json.parse("tru")), "bad literal 'tru' throws")
ok(throws(Function(): return json.parse("nul")), "bad literal 'nul' throws")
ok(throws(Function(): return json.parse(",")), "bare comma throws")
ok(throws(Function(): return json.parse("1 2")), "trailing junk after value throws")
ok(throws(Function(): return json.parse("[1] [2]")), "two top-level values throw")
ok(throws(Function(): return json.parse("{1: 2}")), "non-string object key throws")
ok(throws(Function(): return json.parse("{\"a\" 1}")), "missing ':' in object throws")
ok(throws(Function(): return json.parse("\"\\q\"")), "bad escape \\q throws")
ok(throws(Function(): return json.parse("\"\\uZZZZ\"")), "bad hex in \\u throws")
ok(throws(Function(): return json.parse("\"\\uF\"")), "truncated \\u escape throws")
ok(json.parse("\"\\ud83d\\u0041\"") == chr(65533) + "A", "high surrogate + non-low \\u -> U+FFFD then the char")
ok(throws(Function(): return json.parse("1..2")), "'1..2' throws")
ok(throws(Function(): return json.parse("1e1e1")), "'1e1e1' throws")
ok(throws(Function(): return json.parse("Inf")), "short 'Inf' throws")
ok(throws(Function(): return json.parse("NaNx")), "'NaNx' (trailing char) throws")
ok(throws(Function(): return json.parse("@")), "stray '@' throws")
# deeply nested input throws (the 1000-level parse depth guard) rather than overflowing
var manyOpen = ""
var di = 0
while di < 1100:
    manyOpen = manyOpen + "["
    di = di + 1
ok(throws(Function(): return json.parse(manyOpen)), "1100-deep nesting throws (depth guard)")

# ============================================================ INTENTIONALLY-LENIENT NUMBER FORMS
# These are a PINNED design decision (stdlib_json.hpp comment + deep_serialization.ki): leading zeros,
# a trailing dot, and an empty exponent PARSE rather than throw. Asserting the actual behavior.
ok(json.parse("00") == 0, "'00' (leading zeros) parses to 0 (lenient)")
ok(type(json.parse("00")) == "Integer", "'00' stays an Integer")
ok(json.parse("007") == 7, "'007' parses to 7 (lenient)")
ok(json.parse("5.") == 5.0, "'5.' (trailing dot) parses to 5.0 (lenient)")
ok(type(json.parse("5.")) == "Float", "'5.' becomes a Float")
ok(json.parse("1e") == 1.0, "'1e' (empty exponent) parses to 1.0 (lenient)")
ok(type(json.parse("1e")) == "Float", "'1e' becomes a Float")
ok(json.parse("-0") == 0, "'-0' parses to 0")

# ============================================================ HUGE INTEGER -> Float (documented widening)
ok(type(json.parse("99999999999999999999999999")) == "Float", "int beyond int64 widens to Float")

io.print("r6_json: " + String(n) + " checks passed")
