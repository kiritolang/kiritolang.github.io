# test_video.ki -- self-test for the video module (and the jpeg/gif codecs it builds on). Run:
#     ki examples/big_projects/imaging/test_video.ki        (from the repo root)
# or with the package dir as the working directory (how CTest's script_video runs it).
# Asserts against the committed testdata/ MJPEG+GIF assets and round-trips a PNG sequence and a Y4M
# it writes itself. The committed-asset pixel values are this decoder's own deterministic output.

var cv = import("video")
var path = import("path")
var Image = import("imaging")
var jpeg = import("jpeg")
var gif = import("gif")
var io = import("io")
var sys = import("sys")

# Locate testdata/ whether the working directory is the package dir (CTest) or the repo root (manual).
var _tdata = Function():
    for base in ["testdata", "examples/big_projects/imaging/testdata"]:
        if path.exists(path.join(base, "clip.mjpeg")):
            return base
    throw "cannot find testdata/ (run from the repo root or the package directory)"
var tdata = _tdata()
var tmp = path.gettempdir()

var _pad = Function(k):
    var s = String(k)
    while len(s) < 3:
        s = "0" + s
    return s

var checks = 0
var check = Function(cond, msg):
    assert cond, msg
    checks = checks + 1

# ----------------------------------------------------------------- MJPEG file (baseline JPEG decode)
var cap = cv.VideoCapture(path.join(tdata, "clip.mjpeg"))
check(cap.isopened(), "mjpeg opened")
check(cap.kind == "mjpeg", "mjpeg kind")
check(cap.count == 3, "mjpeg frame count")
check(cap.width == 16 and cap.height == 16, "mjpeg size")
check(cap.get(cv.CAP_PROP_FRAME_COUNT) == 3.0, "mjpeg CAP_PROP_FRAME_COUNT")
var p0 = cap.read()
check(p0[0] and p0[1].mode == "RGB", "mjpeg read frame 0")
check(p0[1].getpixel([0, 0]) == [0, 0, 0], "mjpeg f0 corner")
check(p0[1].getpixel([8, 8]) == [112, 120, 0], "mjpeg f0 mid")
discard cap.read()
var p2 = cap.read()
check(p2[1].getpixel([8, 8]) == [251, 122, 137], "mjpeg f2 mid")
check(not cap.read()[0], "mjpeg exhausted after 3")
check(cap.set(cv.CAP_PROP_POS_FRAMES, 0), "mjpeg seek")
check(cap.read()[1].getpixel([8, 8]) == [112, 120, 0], "mjpeg re-read after seek")
cap.release()
check(not cap.isopened(), "mjpeg released")

# Image.open / frombytes also handle a standalone JPEG (find the first EOI by hand).
var raw = io.open(path.join(tdata, "clip.mjpeg"), "rb").read()
var eoi = 0
var ei = 0
while ei + 1 < len(raw):
    if raw[ei] == 255 and raw[ei + 1] == 217:
        eoi = ei
        ei = len(raw)
    else:
        ei = ei + 1
var onejpg = Image.frombytes(raw[0:eoi + 2])
check(onejpg.mode == "RGB" and onejpg.size == [16, 16], "Image.frombytes(jpeg)")

# ----------------------------------------------------------------- animated GIF (LZW + compositing)
var g = cv.VideoCapture(path.join(tdata, "anim.gif"))
check(g.kind == "gif" and g.count == 4, "gif frame count")
check(g.width == 12 and g.height == 10, "gif size")
check(g.get(cv.CAP_PROP_FPS) > 0.0, "gif fps")
check(g.read()[1].getpixel([6, 5]) == [108, 110, 0], "gif f0 pixel")
var frames = 1
var pr = g.read()
while pr[0]:
    frames = frames + 1
    pr = g.read()
check(frames == 4, "gif read all 4")
g.release()
# for-loop iteration yields Images
var g2 = cv.VideoCapture(path.join(tdata, "anim.gif"))
var it = 0
for frame in g2:
    check(frame.mode == "RGB", "gif iter frame is RGB image")
    it = it + 1
check(it == 4, "gif for-loop count")
check(Image.open(path.join(tdata, "anim.gif")).size == [12, 10], "Image.open(gif) first frame")

# ----------------------------------------------------------------- image sequence (lossless round-trip)
var seqdir = path.join(tmp, "ki_vid_seq")
discard path.mkdir(seqdir, exist_ok = True)
var colors = [[200, 10, 20], [10, 200, 30], [40, 50, 200]]
var k = 0
while k < 3:
    var im = Image.new("RGB", [8, 6], colors[k])
    im.putpixel([1, 1], [k, k, k])
    im.save(path.join(seqdir, "f_" + _pad(k) + ".png"))
    k = k + 1
var sq = cv.VideoCapture(path.join(seqdir, "f_%03d.png"))
check(sq.kind == "seq" and sq.count == 3, "seq count")
check(sq.width == 8 and sq.height == 6, "seq size")
var si = 0
var sp = sq.read()
while sp[0]:
    check(sp[1].getpixel([0, 0]) == colors[si], "seq frame color")
    check(sp[1].getpixel([1, 1]) == [si, si, si], "seq frame marker")
    si = si + 1
    sp = sq.read()
check(si == 3, "seq read all")
sq.release()

# ----------------------------------------------------------------- Y4M round-trip (raw YUV, Kirito-written)
# A flat-grey frame (Y=v, Cb=Cr=128) decodes to RGB [v, v, v] exactly.
var w = 8
var h = 6
var body = "YUV4MPEG2 W8 H6 F25:1 Ip A1:1 C444\n".encode("ascii")
var greys = [60, 150]
var gi = 0
while gi < len(greys):
    var plane = []
    var chroma = []
    var z = 0
    while z < w * h:
        plane.append(greys[gi])
        chroma.append(128)
        z = z + 1
    body = body + "FRAME\n".encode("ascii") + Bytes(plane) + Bytes(chroma) + Bytes(chroma)
    gi = gi + 1
var y4mpath = path.join(tmp, "ki_vid.y4m")
var yf = io.open(y4mpath, "wb")
yf.write(body)
yf.close()
var yc = cv.VideoCapture(y4mpath)
check(yc.kind == "y4m" and yc.count == 2, "y4m count")
check(yc.width == 8 and yc.height == 6, "y4m size")
check(yc.read()[1].getpixel([3, 3]) == [60, 60, 60], "y4m frame 0 grey")
check(yc.read()[1].getpixel([3, 3]) == [150, 150, 150], "y4m frame 1 grey")
yc.release()

# ----------------------------------------------------------------- direct codec entry points
var jp = jpeg.decode(raw[0:eoi + 2])
check(jp[1] == "RGB" and jp[0].shape() == [16, 16, 3], "jpeg.decode direct")
var gframes = gif.frames(io.open(path.join(tdata, "anim.gif"), "rb").read())
check(len(gframes) == 4 and "delay" in gframes[0], "gif.frames direct")

io.print("video: " + String(checks) + " checks passed")
io.print("ALL TESTS PASSED")
