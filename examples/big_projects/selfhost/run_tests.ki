# Run the main project's .ki test suite (everything test_release.sh runs) through the self-hosted
# interpreter and check each program reproduces its recorded output. Auto-discovers every
# tools/tests/scripts/*.ki that has a matching .expected.
#
#   ki --lib examples/big_projects/selfhost/lib examples/big_projects/selfhost/run_tests.ki
#
# (run from the repository root). Prints PASS/FAIL per program and a final summary; exits non-zero
# unless every discovered program passes.

var io = import("io")
var path = import("path")
var kirito = import("kirito")

var SCRIPTS = "tools/tests/scripts"
var STDMODS = "examples/big_projects/selfhost/lib/stdmods"

var readFile = Function(path):
    var fh = io.open(path, "r")
    var data = fh.read()
    fh.close()
    return data

# Discover every <name>.ki that has a <name>.expected (skips library-only modules).
# By default the slow/blocked programs are excluded so this stays a fast, green CTest. Pass "full"
# as an argument to run every discovered program (incl. the slow hashing / fuzz ones).
#
# EXCLUSIONS. The self-host validates the CORE LANGUAGE (lexer/parser/evaluator: closures, classes,
# exceptions, dicts, recursion, strings, control flow) by running real programs through it. It is NOT
# a reimplementation of the C++ native stdlib, so programs that depend on native-only modules/types
# are out of scope and excluded. Grouped by reason (the real interpreter tests all of these under
# CTest/asan/tsan):
# NOW IMPLEMENTED in pure Kirito (so their programs run through the self-host): the `Bytes` type,
# container `apply`, `matrix.vector`/dot/cross/norm, the `complex` module (numbers + matrices/vectors),
# the `gzip`/`zlib`(LZ77)/`hash`(crc32/adler32/crc64) compression+checksum stack, `semver`, and the
# full `tensor` module (N-D arrays, broadcasting, linear algebra, einsum, reverse-mode autograd).
#
# REMAINING EXCLUSIONS, grouped by the genuine reason they can't (or shouldn't) match the native:
#   * parallel — true multiprocessing (a KiritoDispatcher + OS threads); no sequential equivalent:
#     parallel_basic, parallel_sync, probe_parallel, probe_parallel_adversarial, probe_parallel_fuzz,
#     r7_parallel, r8_parallel, r7_net_regex, r8_net_regex, r9_net_parallel (import "parallel")
#   * native-object introspection format — self-host values are ordinary Kirito classes, so `inspect`
#     reports "<Name> instance:" with Kirito-shaped signatures, not the native "<Name> object:" with
#     C++ signatures (and net.Socket / compiled-regex serde rejection): probe_inspect, spec_inspect,
#     probe_surface, probe_trio, probe_serde_matrix, probe_binary_adversarial; path_module asserts on
#     the native inspect(path) signatures (mkdir(path: String, exist_ok: Bool = False), ...) too
#     (instances as Dict/Set keys used to be excluded here too — the host Dict/Set couldn't key on a
#     boxed instance — but that is now supported: getMember/setItem/literals map an instance key
#     through its _hash_ (or identity), so spec_serialize_native's DateTime-keyed Dict/Set now works
#     and it is no longer excluded.)
#   * intentional pure-Kirito divergences the suite asserts on: spec_serde (native rejection wording),
#     spec_edges (empty-needle count)
#   * VM introspection the educational tree-walker doesn't model: spec_traceback needs sys.traceback()
#     — a per-frame call stack with source line numbers, which would mean threading a frame stack +
#     line tracking through the hot call path (with naming of anonymous functions). Out of scope, like
#     inspect's native-vs-Kirito format above.
#   * compile-time static resolution: r8_language asserts an undefined name is rejected even inside a
#     never-taken branch ("if False: return undefinedName"), i.e. BEFORE the function is ever called.
#     The real interpreter has a dedicated scope-aware resolver pass (resolver.hpp) that walks every
#     function body once at compile time; the self-host is a lazy tree-walker with no such pass — an
#     undefined name only surfaces when that line actually executes. A naive "scan the whole body for
#     free names" check can't be bolted on safely: legitimate recursion/mutual-recursion/forward
#     references (a function calling itself or a sibling defined later in the module) would falsely
#     trip it, since the resolver's actual algorithm is scope-MEMBERSHIP, not execution-order. Out of
#     scope, like the two VM-introspection cases above.
#   * other pre-existing exclusions: spec_modules, sample_pipeline, spec_fuzz, libraries, spec_net,
#     spec_pass_todo, spec_tee, spec_io_stream
#
# SLOW (below) PASS but their KB-scale sha256 + LZ77 over the doubly-interpreted runtime takes minutes,
# so they run only under `full`: spec_gzip, probe_compress_fuzz.
#   * class_hash: exhaustively exercises _hash_ / _eq_ with Point instances as Dict/Set keys AND
#     ITERATES those keys (`for k in pDict: k.x`). The self-host's guest Dict/Set is a HOST
#     Dict/Set keyed by the value's hash integer, so iteration yields Integers, not the original
#     instances. Fixing this would need an auxiliary hash→value map (or a compound bucket layout);
#     out of scope for the illustrative tree-walker.
#   * random_generators / random_prng_quality: the native dispatches between two real engines
#     (xoshiro256++ and std::mt19937_64) and asserts (a) their streams differ and (b) each passes
#     ~5σ statistical-quality tests. The self-host has a single LCG for both engine names, so
#     "different engine → different stream" and the byte-balance / chi-square / autocorrelation
#     tests can't be satisfied without reimplementing xoshiro AND MT19937_64 in pure Kirito. The
#     API-parity fix (accepting `generator=` and exposing `.generator`) lives in stdmods/random.ki;
#     the deep-statistical tests remain out of scope, like the audit_/deep_/r10_/r11_ families.
var EXCLUDE = Set(["spec_modules", "spec_serde", "sample_pipeline", "spec_fuzz", "libraries", "spec_net", "spec_pass_todo", "spec_tee", "spec_io_stream", "parallel_basic", "parallel_sync", "probe_parallel", "probe_parallel_adversarial", "probe_surface", "probe_parallel_fuzz", "probe_binary_adversarial", "probe_inspect", "probe_serde_matrix", "probe_trio", "spec_edges", "spec_inspect", "spec_traceback", "path_module", "r8_language", "r7_parallel", "r8_parallel", "r7_net_regex", "r8_net_regex", "r9_net_parallel", "parallel_forkbomb_guard", "probe_http_client_abuse", "class_hash", "random_generators", "random_prng_quality"])
# Belt-and-suspenders: any script importing the `parallel` module (true multiprocessing — no sequential
# equivalent in a tree-walker) is out of scope for the pure-Kirito self-host even if not named above, so
# a newly-added such script does not silently fail the run. Detected per-script by _usesNativeOnly.
var _usesNativeOnly = Function(base):
    return "import(\"parallel\")" in readFile(SCRIPTS + "/" + base + ".ki")
# The `audit_*`, `deep_*`, and `r4_`/`r5_`/`r6_`/`r10_`/`r11_` families are the NATIVE-interpreter
# audit suites — they deliberately probe native stdlib behaviour (Integer("0xFF"), Latin-1 case,
# sys.arch, RFC-4180 csv, Matrix.shape, Tensor // and cumprod, native serde round-trips, agent-gap
# regressions, doc invariants, ...) that the self-host's pure-Kirito stdmods don't replicate. They
# all pass on the native `ki` under CTest; the self-host validates the CORE LANGUAGE via the
# spec_*/probe_* corpus, so it skips the whole family by prefix (self-maintaining as more are
# added). The r7-r9 families still run because they were curated to focus on language surfaces the
# self-host does model; r10 and r11 were introduced later and drift into stdlib corners.
var nativeAuditPrefixes = ["audit_", "deep_", "r4_", "r5_", "r6_", "r10_", "r11_"]
var isNativeAudit = Function(base) -> Bool:
    for p in nativeAuditPrefixes:
        if base.startswith(p):
            return True
    return False
# SLOW: these PASS through the self-host but their crypto/compression over KB-scale data is too slow
# for the default fast CTest, so they are skipped unless `full` is given (the gzip/zlib/hash stack).
# r8_serde_data is validated-but-impractical: its assertions all pass (verified in slices — the time
# section 71/71, the fuzz section, and a scaled-down full run — after this round's fixes), but a full
# run does a 600KB sha256, an O(blob^2 * 256) single-byte-mutation sweep, and thousands of fuzz
# round-trips through the doubly-interpreted runtime, i.e. many minutes even under `full`.
var SLOW = Set(["spec_gzip", "probe_compress_fuzz", "r8_serde_data"])
var runAll = "full" in arglist

var cases = []
for entry in path.listdir(SCRIPTS):
    if entry.endswith(".ki"):
        var base = entry[0:len(entry) - 3]
        if path.exists(SCRIPTS + "/" + base + ".expected") and not isNativeAudit(base) and not _usesNativeOnly(base):
            if runAll or not (base in EXCLUDE or base in SLOW):
                cases.append(base)
cases.sort()

var passed = 0
var failed = 0
var failures = []

for name in cases:
    var src = readFile(SCRIPTS + "/" + name + ".ki")
    var expected = readFile(SCRIPTS + "/" + name + ".expected")
    var inputText = ""
    if path.exists(SCRIPTS + "/" + name + ".in"):
        inputText = readFile(SCRIPTS + "/" + name + ".in")
    # Optional `<name>.args` sidecar (one argv token per line) — the program's command-line
    # arguments, so an arglist/argmain test runs with the same argv as under the native `ki`.
    var scriptArgs = []
    if path.exists(SCRIPTS + "/" + name + ".args"):
        for tok in readFile(SCRIPTS + "/" + name + ".args").split("\n"):
            if len(tok) > 0:
                scriptArgs.append(tok)
    var ok = False
    var detail = ""
    try:
        # import dirs: the std modules first, then the script dir (for complex/linsolve)
        var got = kirito.run5(src, inputText, [STDMODS, SCRIPTS], scriptArgs)
        if got == expected:
            ok = True
        else:
            var gl = got.split("\n")
            var el = expected.split("\n")
            detail = "output mismatch (" + String(len(gl)) + " vs " + String(len(el)) + " lines)"
            var i = 0
            var lim = len(gl)
            if len(el) < lim:
                lim = len(el)
            while i < lim:
                if gl[i] != el[i]:
                    detail = "line " + String(i + 1) + ": got [" + gl[i] + "] want [" + el[i] + "]"
                    i = lim
                i = i + 1
    catch as e:
        if isinstance(e, "Dict") and ("selfhost_error" in e):
            detail = e["selfhost_error"]
        else:
            detail = String(e)
    if ok:
        passed = passed + 1
        io.print("  PASS  " + name)
    else:
        failed = failed + 1
        failures.append(name + ": " + detail)
        io.print("  FAIL  " + name + "  (" + detail + ")")

io.print("")
io.print("self-host: " + String(passed) + " passed, " + String(failed) + " failed, of " + String(len(cases)))
if failed == 0:
    io.print("ALL SELF-HOST TESTS PASSED")
else:
    io.print("SELF-HOST FAILURES:")
    for f in failures:
        io.print("  - " + f)
    assert False, "self-host suite had failures"
