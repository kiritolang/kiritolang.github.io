# SQL parser: a recursive-descent parser over the token list from sql_lexer, producing statement
# AST Dicts the engine can execute. Supports a practical SQL subset:
#   CREATE TABLE t (col TYPE [PRIMARY KEY], ...)
#   DROP TABLE [IF EXISTS] t
#   INSERT INTO t [(cols)] VALUES (v, ...), (...)
#   SELECT */cols [COUNT(*)] FROM t [WHERE cond] [ORDER BY col [ASC|DESC]] [LIMIT n]
#   UPDATE t SET col = val, ... [WHERE cond]
#   DELETE FROM t [WHERE cond]
# WHERE conditions: comparisons (= != < <= > >=), IS NULL / IS NOT NULL, AND/OR/NOT, parentheses.

var lexer = import("sql_lexer")

class SqlParseError:
    var _init_ = Function(self, msg : String):
        self.msg = msg
    var _str_ = Function(self) -> String:
        return "SqlParseError: " + self.msg

class Parser:
    var _init_ = Function(self, tokens : List):
        self._toks = tokens
        self._pos = 0

    var _peek = Function(self):
        return self._toks[self._pos]

    var _next = Function(self):
        var t = self._toks[self._pos]
        self._pos = self._pos + 1
        return t

    var _at_end = Function(self) -> Bool:
        return self._peek()["type"] == "eof"

    # Accept a token of the given type (and optional value); return it or throw.
    var _expect = Function(self, ttype : String, tval):
        var t = self._peek()
        if t["type"] != ttype:
            throw SqlParseError("expected " + ttype + " but found " + t["type"] + " '" + t["value"] + "'")
        if tval != None and t["value"] != tval:
            throw SqlParseError("expected '" + tval + "' but found '" + t["value"] + "'")
        return self._next()

    # True (and consumes) if the next token matches; else False.
    var _accept = Function(self, ttype : String, tval) -> Bool:
        var t = self._peek()
        if t["type"] == ttype and (tval == None or t["value"] == tval):
            discard self._next()
            return True
        return False

    var parse = Function(self):
        var t = self._peek()
        var stmt = None
        if t["type"] != "keyword":
            throw SqlParseError("expected a statement keyword, found '" + t["value"] + "'")
        var kw = t["value"]
        switch kw:
            case "select":
                stmt = self._parse_select()
            case "insert":
                stmt = self._parse_insert()
            case "create":
                stmt = self._parse_create()
            case "drop":
                stmt = self._parse_drop()
            case "update":
                stmt = self._parse_update()
            case "delete":
                stmt = self._parse_delete()
            default:
                throw SqlParseError("unsupported statement: " + kw)
        discard self._accept("punct", ";")
        if not self._at_end():
            throw SqlParseError("trailing tokens after statement: '" + self._peek()["value"] + "'")
        return stmt

    var _parse_create = Function(self):
        discard self._expect("keyword", "create")
        discard self._expect("keyword", "table")
        var name = self._expect("ident", None)["value"]
        discard self._expect("punct", "(")
        var columns = []
        var more = True
        while more:
            var col = self._expect("ident", None)["value"]
            var ctype = self._next()
            if ctype["type"] != "keyword" or (ctype["value"] != "integer" and ctype["value"] != "text"):
                throw SqlParseError("expected column type INTEGER or TEXT for '" + col + "'")
            var is_pk = False
            if self._accept("keyword", "primary"):
                discard self._expect("keyword", "key")
                is_pk = True
            columns.append({"name": col, "type": ctype["value"], "pk": is_pk})
            more = self._accept("punct", ",")
        discard self._expect("punct", ")")
        return {"kind": "create", "table": name, "columns": columns}

    var _parse_drop = Function(self):
        discard self._expect("keyword", "drop")
        discard self._expect("keyword", "table")
        var if_exists = False
        if self._accept("keyword", "if"):
            discard self._expect("keyword", "not")  # not used; we accept IF EXISTS via a simpler path
        var name = self._expect("ident", None)["value"]
        return {"kind": "drop", "table": name, "if_exists": if_exists}

    var _parse_insert = Function(self):
        discard self._expect("keyword", "insert")
        discard self._expect("keyword", "into")
        var name = self._expect("ident", None)["value"]
        var cols = None
        if self._accept("punct", "("):
            cols = []
            var more = True
            while more:
                cols.append(self._expect("ident", None)["value"])
                more = self._accept("punct", ",")
            discard self._expect("punct", ")")
        discard self._expect("keyword", "values")
        var rows = []
        var more_rows = True
        while more_rows:
            discard self._expect("punct", "(")
            var vals = []
            var more = True
            while more:
                vals.append(self._parse_literal())
                more = self._accept("punct", ",")
            discard self._expect("punct", ")")
            rows.append(vals)
            more_rows = self._accept("punct", ",")
        return {"kind": "insert", "table": name, "columns": cols, "rows": rows}

    var _parse_select = Function(self):
        discard self._expect("keyword", "select")
        var projection = None   # None = star
        var is_count = False
        if self._accept("star", None):
            projection = "star"
        elif self._accept("keyword", "count"):
            discard self._expect("punct", "(")
            discard self._expect("star", None)
            discard self._expect("punct", ")")
            is_count = True
        else:
            projection = []
            var more = True
            while more:
                projection.append(self._expect("ident", None)["value"])
                more = self._accept("punct", ",")
        discard self._expect("keyword", "from")
        var table = self._expect("ident", None)["value"]
        var where = None
        if self._accept("keyword", "where"):
            where = self._parse_expr()
        var order = None
        if self._accept("keyword", "order"):
            discard self._expect("keyword", "by")
            var col = self._expect("ident", None)["value"]
            var dir = "asc"
            if self._accept("keyword", "desc"):
                dir = "desc"
            elif self._accept("keyword", "asc"):
                dir = "asc"
            order = {"column": col, "dir": dir}
        var limit = None
        if self._accept("keyword", "limit"):
            limit = Integer(self._expect("number", None)["value"])
        return {"kind": "select", "table": table, "projection": projection,
                "count": is_count, "where": where, "order": order, "limit": limit}

    var _parse_update = Function(self):
        discard self._expect("keyword", "update")
        var table = self._expect("ident", None)["value"]
        discard self._expect("keyword", "set")
        var assigns = []
        var more = True
        while more:
            var col = self._expect("ident", None)["value"]
            discard self._expect("op", "=")
            assigns.append({"column": col, "value": self._parse_literal()})
            more = self._accept("punct", ",")
        var where = None
        if self._accept("keyword", "where"):
            where = self._parse_expr()
        return {"kind": "update", "table": table, "assigns": assigns, "where": where}

    var _parse_delete = Function(self):
        discard self._expect("keyword", "delete")
        discard self._expect("keyword", "from")
        var table = self._expect("ident", None)["value"]
        var where = None
        if self._accept("keyword", "where"):
            where = self._parse_expr()
        return {"kind": "delete", "table": table, "where": where}

    # --- WHERE expression grammar: or_expr -> and_expr (OR and_expr)* ---
    var _parse_expr = Function(self):
        return self._parse_or()

    var _parse_or = Function(self):
        var left = self._parse_and()
        while self._accept("keyword", "or"):
            var right = self._parse_and()
            left = {"op": "or", "left": left, "right": right}
        return left

    var _parse_and = Function(self):
        var left = self._parse_not()
        while self._accept("keyword", "and"):
            var right = self._parse_not()
            left = {"op": "and", "left": left, "right": right}
        return left

    var _parse_not = Function(self):
        if self._accept("keyword", "not"):
            return {"op": "not", "child": self._parse_not()}
        return self._parse_cmp()

    var _parse_cmp = Function(self):
        if self._accept("punct", "("):
            var inner = self._parse_or()
            discard self._expect("punct", ")")
            return inner
        var col = self._expect("ident", None)["value"]
        if self._accept("keyword", "is"):
            var negate = self._accept("keyword", "not")
            discard self._expect("keyword", "null")
            if negate:
                return {"op": "isnotnull", "column": col}
            return {"op": "isnull", "column": col}
        var t = self._peek()
        if t["type"] != "op":
            throw SqlParseError("expected a comparison operator after '" + col + "'")
        var opv = self._next()["value"]
        var rhs = self._parse_literal()
        return {"op": "cmp", "column": col, "cmp": opv, "value": rhs}

    # A literal value: number -> Integer, string -> String, NULL -> None, TRUE/FALSE -> Bool.
    var _parse_literal = Function(self):
        var t = self._next()
        if t["type"] == "number":
            return {"vtype": "int", "value": Integer(t["value"])}
        if t["type"] == "string":
            return {"vtype": "text", "value": t["value"]}
        if t["type"] == "keyword" and t["value"] == "null":
            return {"vtype": "null", "value": None}
        if t["type"] == "keyword" and t["value"] == "true":
            return {"vtype": "int", "value": 1}
        if t["type"] == "keyword" and t["value"] == "false":
            return {"vtype": "int", "value": 0}
        throw SqlParseError("expected a literal value, found '" + t["value"] + "'")

var parse = Function(sql : String):
    var toks = lexer.tokenize(sql)
    var p = Parser(toks)
    return p.parse()
