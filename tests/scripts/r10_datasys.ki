# r10_datasys.ki — docs-vs-impl audit of io/path/json/serialize/dump/zlib/gzip/hash/time/sys.
# Every assertion mirrors real native behavior; cross-checked against docs/pages/10-stdlib.md and
# src/kirito/stdlib_*.hpp. Deterministic (no wall-clock value assertions). One stdout line, no stray
# output: all scratch files live under path.gettempdir() and are removed at the end.
var io = import("io")
var path = import("path")
var json = import("json")
var serialize = import("serialize")
var dump = import("dump")
var zlib = import("zlib")
var gzip = import("gzip")
var hash = import("hash")
var time = import("time")
var sys = import("sys")
var math = import("math")
var matrix = import("matrix")
var complex = import("complex")
var random = import("random")
var tensor = import("tensor")
var net = import("net")
var regex = import("regex")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1
var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True
var srt = Function(v):
    return serialize.loads(serialize.dumps(v))
var drt = Function(v):
    return dump.loads(dump.dumps(v))

# Scratch workspace under the system temp dir (removed at the very end).
var work = path.join(path.gettempdir(), "r10_datasys_work")
discard path.rmtree(work, missing_ok = True)
discard path.mkdir(work, exist_ok = True)
var tmp = Function(name):
    return path.join(work, name)

# ============================== io =====================================================
# --- BytesIO ---
var b = io.BytesIO()
ok(b.write("hello") == 5, "BytesIO.write returns count")
ok(b.tell() == 5, "BytesIO.tell after write")
ok(b.seek(0) == 0, "BytesIO.seek to start")
ok(b.read(2) == "he", "BytesIO.read(n)")
ok(b.read() == "llo", "BytesIO.read() rest")
ok(b.getvalue() == "hello", "BytesIO.getvalue")
ok(b.size() == 5, "BytesIO.size")
ok(len(b) == 5, "len(BytesIO)")
ok(type(b.read()) == "String", "BytesIO.read yields String")
discard b.seek(0)
ok(b.read(None) == "hello", "BytesIO.read(None) reads rest")
discard b.seek(0)
ok(b.readline() == "hello", "BytesIO.readline strips newline")
ok(b.seek(-100, 1) == 0, "BytesIO.seek negative clamps to 0")
ok(b.flush() == None, "BytesIO.flush is a no-op None")
ok(b.close() == None, "BytesIO.close is a no-op None")
var b2 = io.BytesIO("abcdefg")
discard b2.seek(3)
ok(b2.truncate() == 3, "BytesIO.truncate at cursor")
ok(b2.getvalue() == "abc", "BytesIO.truncate drops tail")
ok(io.BytesIO("preset").getvalue() == "preset", "BytesIO initial content")
ok(io.BytesIO().seek(0, 2) == 0, "BytesIO empty seek end")
ok(io.BytesIO("abc").seek(0, 2) == 3, "BytesIO seek whence=end")
var b3 = io.BytesIO("abcdef")
discard b3.seek(0, 2)
ok(b3.seek(-2, 1) == 4, "BytesIO seek whence=cur")
ok(io.BytesIO("l1\nl2").readline() == "l1", "BytesIO readline first")
ok(io.BytesIO().write(Bytes([65, 66])) == 2, "BytesIO.write accepts Bytes")

# --- open / File (text) ---
var fp = tmp("io_text.txt")
var wf = io.open(fp, "w")
ok(wf.write("line1\nline2\nline3") == None, "File.write returns None")
ok(wf.tell() == 17, "File.tell after write")
ok(wf.flush() == None, "File.flush returns None")
discard wf.close()
ok(path.getsize(fp) == 17, "written file size")
ok(throws(Function(): return wf.read()), "read on closed file throws")
ok(throws(Function(): return wf.write("x")), "write on closed file throws")
ok(throws(Function(): return wf.seek(0)), "seek on closed file throws")
var rf = io.open(fp, "r")
ok(rf.readline() == "line1", "File.readline")
ok(rf.readlines() == ["line2", "line3"], "File.readlines rest")
ok(throws(Function(): return rf.write("x")), "write on read-only file throws")
discard rf.close()
var rf2 = io.open(fp, "r")
ok(rf2.seek(6) == 6, "File.seek set")
ok(rf2.seek(2, 1) == 8, "File.seek cur")
ok(rf2.seek(0, 2) == 17, "File.seek end")
ok(rf2.read() == "", "File.read at end is empty")
ok(throws(Function(): return rf2.seek(-3)), "File.seek negative throws")
ok(throws(Function(): return rf2.seek(0, 5)), "File.seek bad whence throws")
discard rf2.close()
var wo = io.open(fp, "w")
ok(throws(Function(): return wo.read()), "read on write-only file throws")
discard wo.close()
ok(throws(Function(): return io.open(fp, "q")), "unsupported open mode throws")
ok(throws(Function(): return io.open(tmp("no_such_dir/x"), "r")), "open missing file throws")
# iterate lines
var itf = io.open(fp, "w")
discard itf.write("a\nb\nc")
discard itf.close()
var collected = []
for ln in io.open(fp, "r"):
    discard collected.append(ln)
ok(collected == ["a", "b", "c"], "iterating a File yields lines")
# with context manager
with io.open(fp, "w") as cm:
    discard cm.write("ctx")
ok(path.getsize(fp) == 3, "File as with-context writes")
# r+ read/write
var rp = io.open(fp, "r+")
ok(rp.read(3) == "ctx", "r+ reads existing")
discard rp.seek(0)
discard rp.write("CTX")
discard rp.seek(0)
ok(rp.read() == "CTX", "r+ overwrites")
discard rp.close()

# --- File binary mode ---
var bp = tmp("io_bin.bin")
var bw = io.open(bp, "wb")
ok(bw.write(Bytes([104, 105, 0, 255])) == None, "binary write accepts Bytes")
discard bw.close()
var br = io.open(bp, "rb")
var bd = br.read()
ok(type(bd) == "Bytes", "binary read yields Bytes")
ok(bd == Bytes([104, 105, 0, 255]), "binary read exact bytes")
discard br.close()
# Bind the File to a local + close it explicitly before removing — otherwise Windows keeps the
# handle open (POSIX unlink-of-open-files is lenient; Win32 throws "sharing violation").
var wf2 = io.open(bp, "wb")
ok(throws(Function(): return wf2.write("text")) == False, "binary write also accepts String")
discard wf2.close()
discard path.remove(bp)

# --- streams: stream= kwarg, rebinding stdout ---
var cap = io.BytesIO()
discard io.print("hi", stream = cap)
ok(cap.getvalue() == "hi\n", "print stream= redirect + newline")
var cap2 = io.BytesIO()
discard io.write("a", "b", "c", stream = cap2)
ok(cap2.getvalue() == "abc", "write stream= no separator/newline")
var cap3 = io.BytesIO()
discard io.eprint("e", stream = cap3)
ok(cap3.getvalue() == "e\n", "eprint stream= redirect")
ok(throws(Function(): return io.print("x", bogus = 1)), "print unexpected kwarg throws")
var src = io.BytesIO("firstline\nsecondline\ntail")
ok(io.input(stream = src) == "firstline", "input stream= reads a line")
ok(io.read(6, stream = src) == "second", "read n stream=")
# rebind stdout to a buffer, restore
var savedOut = io.stdout
io.stdout = io.BytesIO()
discard io.print("redirected")
var captured = io.stdout.getvalue()
io.stdout = savedOut
ok(captured == "redirected\n", "rebound stdout captures print")
ok(io.stdout == io.__stdout__, "stdout restored equals __stdout__")
ok(io.stderr == io.__stderr__, "stderr equals __stderr__ originally")
ok(io.stdin == io.__stdin__, "stdin equals __stdin__ originally")
# a duck-typed object usable as a stream
class Sink:
    var _init_ = Function(self):
        self.data = ""
    var write = Function(self, s):
        self.data = self.data + s
var sink = Sink()
discard io.print("duck", stream = sink)
ok(sink.data == "duck\n", "duck-typed stream via write()")

# ============================== path ===================================================
# --- pure path strings ---
ok(path.join("a", "b", "c") == "a/b/c", "join basic")
ok(path.join("a/", "b") == "a/b", "join no double slash")
ok(path.join("/a", "b", "/c", "d") == "/c/d", "join absolute component resets")
ok(path.join("a", "", "b") == "a/b", "join empty parts contribute nothing")
ok(path.join("solo") == "solo", "join single component")
ok(throws(Function(): return path.join()), "join() with no args throws")
ok(path.dirname("/a/b/c") == "/a/b", "dirname")
ok(path.dirname("/a") == "/", "dirname keeps root")
ok(path.dirname("file.txt") == "", "dirname no separator")
ok(path.basename("/a/b/c") == "c", "basename")
ok(path.basename("/a/b/") == "", "basename trailing slash empty")
ok(path.splitext("a/b.txt") == ["a/b", ".txt"], "splitext")
ok(path.splitext("archive.tar.gz") == ["archive.tar", ".gz"], "splitext last ext only")
ok(path.splitext("/x/.bashrc") == ["/x/.bashrc", ""], "splitext leading dot protected")
ok(path.splitext("..") == ["..", ""], "splitext dotdot no ext")
ok(path.splitext("noext") == ["noext", ""], "splitext no dot")
ok(path.splitext("trailing.") == ["trailing", "."], "splitext trailing dot")
ok(throws(Function(): return path.dirname(5)), "dirname non-String throws")

# --- filesystem queries ---
ok(path.isdir(work) == True, "isdir on existing dir")
ok(path.exists(work) == True, "exists on existing dir")
ok(path.isfile(work) == False, "isfile on a dir is False")
var qf = tmp("query.txt")
with io.open(qf, "w") as f:
    discard f.write("12345")
ok(path.exists(qf) == True, "exists on file")
ok(path.isfile(qf) == True, "isfile on file")
ok(path.getsize(qf) == 5, "getsize returns byte length")
ok(path.exists(tmp("ghost")) == False, "exists tolerant on missing")
ok(path.isfile(tmp("ghost")) == False, "isfile tolerant on missing")
ok(path.isdir(tmp("ghost")) == False, "isdir tolerant on missing")
ok(path.listdir(tmp("ghost")) == [], "listdir tolerant on missing")
ok(throws(Function(): return path.getsize(tmp("ghost"))), "getsize missing throws")
ok(throws(Function(): return path.getsize(work)), "getsize on a dir throws")
ok(len(path.listdir(work)) >= 1, "listdir lists entries")
ok(type(path.getcwd()) == "String", "getcwd returns String")
ok(len(path.getcwd()) > 0, "getcwd non-empty")
ok(type(path.gettempdir()) == "String", "gettempdir returns String")
ok(len(path.gettempdir()) > 0, "gettempdir non-empty")
ok(type(path.executable) == "String", "path.executable is a String")
ok(len(path.executable) > 0, "path.executable non-empty here")
ok(path.isfile(path.executable) == True, "path.executable is a real file")
# gettempdir + executable moved out of sys
ok(hasattr(sys, "gettempdir") == False, "sys.gettempdir no longer exists")
ok(hasattr(sys, "executable") == False, "sys.executable no longer exists")
ok(hasattr(path, "gettempdir") == True, "path.gettempdir exists")
ok(hasattr(path, "executable") == True, "path.executable exists")
# walk
var wd = tmp("walkdir")
discard path.mkdir(wd)
var wsub = path.join(wd, "sub")
discard path.mkdir(wsub)
with io.open(path.join(wd, "top.txt"), "w") as f:
    discard f.write("x")
with io.open(path.join(wsub, "deep.txt"), "w") as f:
    discard f.write("y")
ok(len(path.walk(wd)) == 2, "walk finds all nested files")
ok(path.walk(tmp("ghost")) == [], "walk tolerant on missing")

# --- filesystem mutation (strict by default) ---
var md = tmp("mkdir_target")
ok(path.mkdir(md) == True, "mkdir creates -> True")
ok(path.isdir(md) == True, "mkdir made the dir")
ok(throws(Function(): return path.mkdir(md)), "mkdir on existing throws")
ok(path.mkdir(md, exist_ok = True) == False, "mkdir exist_ok -> False")
var nested = tmp("mkdir_parents/a/b/c")
ok(path.mkdir(nested) == True, "mkdir creates parents")
ok(path.isdir(nested) == True, "nested parents made")
var rmf = path.join(md, "victim.txt")
with io.open(rmf, "w") as f:
    discard f.write("bye")
ok(path.remove(rmf) == True, "remove file -> True")
ok(path.exists(rmf) == False, "removed file gone")
ok(throws(Function(): return path.remove(rmf)), "remove missing throws")
ok(path.remove(rmf, missing_ok = True) == False, "remove missing_ok -> False")
# non-empty dir: remove throws, rmtree works
var full = tmp("nonempty")
discard path.mkdir(full)
with io.open(path.join(full, "f.txt"), "w") as f:
    discard f.write("z")
ok(throws(Function(): return path.remove(full)), "remove non-empty dir throws")
ok(path.rmtree(full) == True, "rmtree recursive -> True")
ok(path.exists(full) == False, "rmtree removed the tree")
ok(throws(Function(): return path.rmtree(full)), "rmtree missing throws")
ok(path.rmtree(full, missing_ok = True) == False, "rmtree missing_ok -> False")
# rename
var ra = tmp("rename_a.txt")
var rb = tmp("rename_b.txt")
with io.open(ra, "w") as f:
    discard f.write("data")
ok(path.rename(ra, rb) == None, "rename returns None")
ok(path.isfile(rb) == True, "rename moved target")
ok(path.exists(ra) == False, "rename source gone")
ok(throws(Function(): return path.rename(tmp("ghost1"), tmp("ghost2"))), "rename missing throws")
discard path.remove(rb)
# chmod lenient
var cf = tmp("chmod.txt")
with io.open(cf, "w") as f:
    discard f.write("x")
ok(path.chmod(cf, 0o644) == True, "chmod existing -> True")
ok(path.chmod(tmp("ghost"), 0o644) == False, "chmod missing lenient -> False")
discard path.remove(cf)

# ============================== json ===================================================
ok(json.parse("5") == 5, "json parse Integer")
ok(type(json.parse("5")) == "Integer", "json 5 stays Integer")
ok(type(json.parse("5.0")) == "Float", "json 5.0 stays Float")
ok(type(json.parse("-7")) == "Integer", "json negative Integer")
ok(type(json.parse("1e3")) == "Float", "json exponent is Float")
ok(json.parse("9223372036854775807") == 9223372036854775807, "json int64 max stays Integer")
ok(type(json.parse("9223372036854775807")) == "Integer", "json int64 max type")
ok(type(json.parse("9223372036854775808")) == "Float", "json over-int64 widens to Float")
ok(type(json.parse("99999999999999999999999999")) == "Float", "json huge int widens to Float")
ok(json.parse("1e400") == math.inf, "json overflow float -> inf")
ok(json.parse("true") == True, "json true")
ok(json.parse("false") == False, "json false")
ok(json.parse("null") == None, "json null")
ok(json.parse("\"hi\"") == "hi", "json string")
ok(json.parse("[1, 2, 3]") == [1, 2, 3], "json array -> List")
ok(json.parse("{\"a\": 1, \"b\": 2}") == {"a": 1, "b": 2}, "json object -> Dict")
ok(json.parse("01") == 1, "json lenient leading zero (documented)")
ok(math.isnan(json.parse("NaN")), "json NaN literal")
ok(json.parse("Infinity") == math.inf, "json Infinity literal")
ok(json.parse("-Infinity") == 0.0 - math.inf, "json -Infinity literal")
# unicode + surrogates
ok(json.parse("\"\\u0041\"") == "A", "json \\u escape")
ok(len(json.parse("\"\\uD83D\\uDE00\"")) == 1, "json surrogate pair -> 1 code point")
ok(json.parse("\"\\uD800\"") == chr(65533), "json lone surrogate -> U+FFFD")
ok(json.loads("[1,2]") == [1, 2], "json.loads alias of parse")
# stringify
ok(json.dumps([1, 2, 3]) == "[1, 2, 3]", "json compact list")
ok(json.dumps({"a": 1}) == "{\"a\": 1}", "json compact object")
ok(json.dumps("A\tB") == "\"A\\tB\"", "json escapes tab")
ok(json.dumps(chr(1)) == "\"\\u0001\"", "json escapes control char")
ok(json.dumps(math.inf) == "Infinity", "json dumps inf")
ok(json.dumps(0.0 - math.inf) == "-Infinity", "json dumps -inf")
ok(json.dumps(math.nan) == "NaN", "json dumps nan")
ok(json.stringify([1]) == "[1]", "json.stringify alias")
ok(("\n" in json.dumps([1, 2], indent = 2)) == True, "json indent pretty-prints")
ok(("\n" in json.dumps([1, 2], indent = 0)) == False, "json indent=0 compact")
ok(json.dumps([], indent = 2) == "[]", "json empty list stays []")
ok(json.dumps({}, indent = 2) == "{}", "json empty object stays {}")
ok(json.loads(json.dumps(0.1 + 0.2)) == 0.1 + 0.2, "json float exact round-trip")
ok(json.loads(json.dumps("héllo ☃")) == "héllo ☃", "json unicode round-trip")
# malformed / unsupported
ok(throws(Function(): return json.parse("")), "json empty input throws")
ok(throws(Function(): return json.parse("{bad}")), "json bad object throws")
ok(throws(Function(): return json.parse("[1, 2")), "json unterminated array throws")
ok(throws(Function(): return json.parse("1 2")), "json trailing chars throw")
ok(throws(Function(): return json.parse("nul")), "json bad literal throws")
var jcyc = [1]
discard jcyc.append(jcyc)
ok(throws(Function(): return json.dumps(jcyc)), "json cyclic structure throws")
ok(throws(Function(): return json.dumps({1, 2})), "json Set is unsupported -> throws")
ok(throws(Function(): return json.dumps(io.BytesIO())), "json BytesIO unsupported -> throws")
var deepj = ""
for i in range(2000):
    deepj = deepj + "["
ok(throws(Function(): return json.parse(deepj)), "json too-deep nesting throws")

# ============================== serialize (text) + dump (binary) =======================
ok(type(serialize.dumps(1)) == "String", "serialize.dumps -> String")
ok(serialize.dumps(1)[0:5] == "KSER1", "serialize header tag")
ok(type(dump.dumps(1)) == "Bytes", "dump.dumps -> Bytes")
ok(dump.dumps(1)[0] == 75, "dump magic byte K")
ok(dump.dumps(1)[1] == 68, "dump magic byte D")
# built-in round-trips through both formats
ok(srt(None) == None, "serialize None")
ok(srt(True) == True, "serialize Bool")
ok(srt(42) == 42, "serialize Integer")
ok(srt(3.5) == 3.5, "serialize Float")
ok(srt("héllo") == "héllo", "serialize String unicode")
ok(srt([1, "two", 3.0]) == [1, "two", 3.0], "serialize List")
ok(srt({"a": 1, "b": [2, 3]}) == {"a": 1, "b": [2, 3]}, "serialize nested Dict")
ok(srt({1, 2, 3}) == {1, 2, 3}, "serialize Set")
ok(drt(None) == None, "dump None")
ok(drt(True) == True, "dump Bool")
ok(drt(-99) == -99, "dump Integer")
ok(drt(2.718281828) == 2.718281828, "dump Float")
ok(drt("world") == "world", "dump String")
ok(drt([1, [2, [3]]]) == [1, [2, [3]]], "dump nested List")
ok(drt({"k": {"j": 5}}) == {"k": {"j": 5}}, "dump nested Dict")
ok(drt({7, 8, 9}) == {7, 8, 9}, "dump Set")
# Bytes round-trip (a serializable value type)
var by = Bytes([0, 1, 2, 254, 255])
ok(srt(by) == by, "serialize Bytes")
ok(drt(by) == by, "dump Bytes")
# cycles
var cyc = [1, 2]
discard cyc.append(cyc)
var cycS = srt(cyc)
ok(cycS[2][2][0] == 1, "serialize preserves a self-cycle")
var cycD = drt(cyc)
ok(cycD[2][2][2][1] == 2, "dump preserves a self-cycle")
# shared references
var shared = [0]
var pairS = srt([shared, shared])
discard pairS[0].append(7)
ok(pairS[1] == [0, 7], "serialize preserves shared reference")
var pairD = drt([shared, shared])
discard pairD[0].append(9)
ok(pairD[1] == [0, 9], "dump preserves shared reference")
# user classes (by attributes)
class Point:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
var ptS = srt(Point(3, 4))
ok(ptS.x == 3 and ptS.y == 4, "serialize user class by attributes")
var ptD = drt(Point(5, 6))
ok(ptD.x == 5 and ptD.y == 6, "dump user class by attributes")
# _getstate_/_setstate_ protocol
class Boxed:
    var _init_ = Function(self, v):
        self.v = v
        self.cached = v * 10
    var _getstate_ = Function(self):
        return self.v
    var _setstate_ = Function(self, st):
        self.v = st
        self.cached = st * 10
var boxS = srt(Boxed(4))
ok(boxS.v == 4 and boxS.cached == 40, "serialize _getstate_/_setstate_")
var boxD = drt(Boxed(8))
ok(boxD.v == 8 and boxD.cached == 80, "dump _getstate_/_setstate_")
# native value types (need their module imported to register the deserializer)
var mx = matrix.identity(3)
ok(srt(mx)[1, 1] == 1.0, "serialize Matrix diagonal")
ok(drt(mx)[0, 1] == 0.0, "dump Matrix off-diagonal")
var cx = complex.of(3, 4)
ok(srt(cx).re == 3.0, "serialize Complex real part")
ok(drt(cx).modulus() == 5.0, "dump Complex modulus")
var when = time.make(2021, 7, 4, 15, 30, 45)
ok(srt(when).year == 2021, "serialize DateTime year")
ok(drt(when) == when, "dump DateTime equal by instant")
var rng = random.Random(12345)
discard rng.randint(0, 1000000)
var rngB = drt(rng)
ok(rng.randint(0, 1000000) == rngB.randint(0, 1000000), "dump Random restores exact stream")
var rngC = srt(rng)
ok(rng.randint(0, 1000000) == rngC.randint(0, 1000000), "serialize Random restores stream")
var tn = tensor.Tensor([[1.0, 2.0], [3.0, 4.0]])
ok(srt(tn).tolist() == [[1.0, 2.0], [3.0, 4.0]], "serialize Tensor")
ok(drt(tn).tolist() == tn.tolist(), "dump Tensor")
ok(throws(Function(): return dump.dumps(tensor.Tensor([1.0, 2.0], requiresgrad = True))), "grad Tensor rejects serialization")
ok(drt(tensor.Tensor([1.0, 2.0], requiresgrad = True).detach()).tolist() == [1.0, 2.0], "detached grad Tensor serializes")
# a container of native values round-trips (shared identity preserved by the graph walk)
var backM = drt([mx, mx])
ok(backM[0] == backM[1] and backM[0][2, 2] == 1.0, "dump round-trips a container of natives")
# a Kirito Function now serializes (source + captured free vars); native functions/resources do not
ok(dump.loads(dump.dumps(Function(x): return x * 3))(4) == 12, "dump round-trips a Kirito Function")
ok(throws(Function(): return serialize.dumps(len)), "serialize rejects a native Function")
ok(throws(Function(): return dump.dumps(io.BytesIO())), "reject BytesIO")
ok(throws(Function(): return dump.dumps(net.Socket())), "reject Socket")
ok(throws(Function(): return serialize.dumps(regex.compile("a+"))), "reject compiled regex")
var openf = io.open(tmp("res.txt"), "w")
ok(throws(Function(): return dump.dumps(openf)), "reject an open File")
discard openf.close()
discard path.remove(tmp("res.txt"))
# save / load to disk
var serPath = tmp("graph.kser")
discard serialize.save([1, 2, {"k": 3}], serPath)
ok(serialize.load(serPath) == [1, 2, {"k": 3}], "serialize save/load disk")
ok(path.exists(serPath) == True, "serialize.save wrote a file")
var dumpPath = tmp("graph.kdmp")
discard dump.save({"x": [1, 2]}, dumpPath)
ok(dump.load(dumpPath) == {"x": [1, 2]}, "dump save/load disk")
discard path.remove(serPath)
discard path.remove(dumpPath)
# kwargs
ok(serialize.loads(text = serialize.dumps(value = 11)) == 11, "serialize kwargs value=/text=")
ok(dump.loads(data = dump.dumps(value = 12)) == 12, "dump kwargs value=/data=")
# malformed input throws
ok(throws(Function(): return serialize.loads("not a blob")), "serialize malformed throws")
ok(throws(Function(): return serialize.loads("KSER1 999 N")), "serialize bad count throws")
ok(throws(Function(): return dump.loads(Bytes("garbage"))), "dump malformed throws")
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 9]))), "dump bad version throws")
ok(throws(Function(): return dump.loads(42)), "dump.loads rejects non-Bytes/String")

# ============================== zlib / gzip ============================================
var payload = "The quick brown fox jumps over the lazy dog. " * 8
ok(type(zlib.compress(payload)) == "String", "zlib.compress String -> String")
ok(zlib.decompress(zlib.compress(payload)) == payload, "zlib round-trip String")
ok(type(zlib.compress(Bytes(payload))) == "Bytes", "zlib.compress Bytes -> Bytes")
ok(zlib.decompress(zlib.compress(Bytes(payload))) == Bytes(payload), "zlib round-trip Bytes")
ok(zlib.inflate(zlib.deflate(payload)) == payload, "zlib deflate/inflate round-trip")
ok(type(zlib.deflate(Bytes(payload))) == "Bytes", "zlib.deflate Bytes -> Bytes")
ok(zlib.decompress(zlib.compress("")) == "", "zlib empty round-trip")
ok(len(zlib.compress(payload)) < len(payload), "zlib actually compresses")
ok(gzip.decompress(gzip.compress(payload)) == payload, "gzip round-trip String")
ok(gzip.decompress(gzip.compress(Bytes(payload))) == Bytes(payload), "gzip round-trip Bytes")
ok(gzip.gunzip(gzip.gzip(payload)) == payload, "gzip gzip/gunzip aliases")
ok(type(gzip.compress(payload)) == "String", "gzip type preservation")
# corrupt / truncated / cross-container
ok(throws(Function(): return zlib.decompress("not a zlib stream!!")), "zlib corrupt throws")
ok(throws(Function(): return gzip.decompress("not a gzip stream")), "gzip corrupt throws")
ok(throws(Function(): return zlib.inflate("\x00\x01\x02 garbage")), "zlib inflate garbage throws")
ok(throws(Function(): return zlib.decompress(zlib.compress(payload)[0:5])), "zlib truncated throws")
ok(throws(Function(): return gzip.decompress(gzip.compress(payload)[0:12])), "gzip truncated throws")
ok(throws(Function(): return gzip.decompress(zlib.compress(payload))), "gzip on zlib data throws")
ok(throws(Function(): return zlib.decompress(gzip.compress(payload))), "zlib on gzip data throws")
ok(throws(Function(): return zlib.compress(123)), "zlib rejects Integer")
ok(throws(Function(): return gzip.compress([1, 2])), "gzip rejects List")

# ============================== hash ===================================================
ok(hash.md5("") == "d41d8cd98f00b204e9800998ecf8427e", "md5 empty")
ok(hash.md5("abc") == "900150983cd24fb0d6963f7d28e17f72", "md5 abc")
ok(hash.sha1("") == "da39a3ee5e6b4b0d3255bfef95601890afd80709", "sha1 empty")
ok(hash.sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d", "sha1 abc")
ok(hash.sha256("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256 empty")
ok(hash.sha256("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad", "sha256 abc")
ok(hash.crc32("") == 0, "crc32 empty")
ok(hash.crc32("abc") == 891568578, "crc32 abc")
ok(hash.adler32("") == 1, "adler32 empty")
ok(hash.adler32("abc") == 38600999, "adler32 abc")
ok(hash.crc64("") == 0, "crc64 empty")
ok(hash.crc64("abc") == 3231342946509354535, "crc64 abc")
ok(type(hash.md5("x")) == "String", "md5 returns String")
ok(type(hash.crc32("x")) == "Integer", "crc32 returns Integer")
# String == Bytes equivalence
ok(hash.md5("abc") == hash.md5(Bytes("abc")), "md5 String==Bytes")
ok(hash.sha1("abc") == hash.sha1(Bytes("abc")), "sha1 String==Bytes")
ok(hash.sha256("abc") == hash.sha256(Bytes("abc")), "sha256 String==Bytes")
ok(hash.crc32("abc") == hash.crc32(Bytes("abc")), "crc32 String==Bytes")
ok(hash.adler32("abc") == hash.adler32(Bytes("abc")), "adler32 String==Bytes")
ok(hash.crc64("abc") == hash.crc64(Bytes("abc")), "crc64 String==Bytes")
# binary data (bytes a UTF-8 String can't represent)
ok(hash.md5(Bytes([0, 255, 128])) == "4fd64cb80c3f86e1e9d0f559af8b370f", "md5 raw bytes")
# checksum sanity + kwargs
ok(hash.crc32("hello") == hash.crc32("hello"), "crc32 deterministic")
ok(hash.sha256(data = "abc")[0:8] == "ba7816bf", "hash kwargs data=")
# reject non String/Bytes
ok(throws(Function(): return hash.md5(42)), "hash rejects Integer")
ok(throws(Function(): return hash.crc32([1, 2])), "hash rejects List")

# ============================== time ===================================================
ok(time.time() > 0.0, "time() positive")
ok(type(time.time()) == "Float", "time() is Float")
ok(time.timens() > 0, "timens() positive")
ok(type(time.timens()) == "Integer", "timens() is Integer")
ok(type(time.monotonic()) == "Float", "monotonic() is Float")
var mono1 = time.monotonic()
var mono2 = time.monotonic()
ok(mono2 >= mono1, "monotonic non-decreasing")
ok(type(time.perfcounterns()) == "Integer", "perfcounterns() is Integer")
var pc1 = time.perfcounterns()
var pc2 = time.perfcounterns()
ok(pc2 >= pc1, "perfcounterns non-decreasing")
ok(time.sleep(0.001) == None, "sleep returns None")
ok(type(time.now()) == "DateTime", "now() -> DateTime")
ok(type(time.datetime()) == "DateTime", "datetime() -> DateTime")
ok(type(time.datetime(0)) == "DateTime", "datetime(ts) -> DateTime")
# DateTime fields (2021-07-04 15:30:45 UTC, a Sunday)
var dt = time.make(2021, 7, 4, 15, 30, 45)
ok(dt.year == 2021, "DateTime.year")
ok(dt.month == 7, "DateTime.month")
ok(dt.day == 4, "DateTime.day")
ok(dt.hour == 15, "DateTime.hour")
ok(dt.minute == 30, "DateTime.minute")
ok(dt.second == 45, "DateTime.second")
ok(dt.weekday == 0, "DateTime.weekday 0=Sunday")
ok(dt.yearday == 185, "DateTime.yearday")
ok(type(dt.timestamp) == "Integer", "DateTime.timestamp is Integer")
ok(time.datetime(0).weekday == 4, "epoch 0 is Thursday (weekday 4)")
ok(time.datetime(0).year == 1970, "epoch 0 is 1970")
# iso / format
ok(dt.iso() == "2021-07-04T15:30:45", "DateTime.iso()")
ok(dt.isoformat() == dt.iso(), "isoformat is an alias")
ok(dt.format("%Y-%m-%d") == "2021-07-04", "DateTime.format date")
ok(dt.format("%H:%M:%S") == "15:30:45", "DateTime.format time")
# arithmetic
ok(dt.add(3600).hour == 16, "DateTime.add seconds")
ok(dt.sub(45).second == 0, "DateTime.sub seconds")
ok(dt.add(100).diff(dt) == 100, "DateTime.diff self-consistent")
ok(dt.diff(dt.sub(10)) == 10, "DateTime.diff positive")
ok(time.datetime(dt.timestamp).iso() == dt.iso(), "timestamp round-trips via datetime")
# equality + hashing
ok(time.datetime(500) == time.datetime(500), "DateTime equality by instant")
ok((time.datetime(500) == time.datetime(501)) == False, "distinct instants not equal")
var dtmap = {time.datetime(777): "hit"}
ok(dtmap[time.datetime(777)] == "hit", "DateTime usable as Dict key")
# make normalization (C mktime style)
ok(time.make(2024, 13, 1).iso() == "2025-01-01T00:00:00", "make month 13 rolls over")
ok(time.make(2024, 1, 32).iso() == "2024-02-01T00:00:00", "make day 32 rolls over")
ok(time.make(2024, 2, 29).month == 2, "make leap day valid")
# make with kwargs and defaults
ok(time.make(year = 2000, month = 1, day = 1).timestamp == 946684800, "make kwargs + epoch")
ok(time.make(2000, 1, 1).hour == 0, "make hour defaults to 0")
# make strictness: Integer components required
ok(throws(Function(): return time.make(2000.5, 1, 1)), "make rejects Float component")
ok(throws(Function(): return time.make("2000", 1, 1)), "make rejects String component")
# datetime rejects NaN / inf
ok(throws(Function(): return time.datetime(math.nan)), "datetime rejects NaN")
ok(throws(Function(): return time.datetime(math.inf)), "datetime rejects inf")
ok(throws(Function(): return time.datetime(1.0e19)), "datetime rejects out-of-range")
ok(throws(Function(): return time.datetime(99999999999999999)), "datetime rejects year > 9999")
# strptime strictness
ok(time.strptime("2021-07-04T15:30:45", "%Y-%m-%dT%H:%M:%S").timestamp == dt.timestamp, "strptime round-trips iso")
ok(time.strptime("2020-02-29", "%Y-%m-%d").day == 29, "strptime leap day ok")
ok(throws(Function(): return time.strptime("2024-99-99", "%Y-%m-%d")), "strptime out-of-range field throws")
ok(throws(Function(): return time.strptime("2024-01-01XYZ", "%Y-%m-%d")), "strptime trailing input throws")
ok(throws(Function(): return time.strptime("nope", "%Y-%m-%d")), "strptime mismatch throws")
ok(throws(Function(): return time.strptime("2024-13-01", "%Y-%m-%d")), "strptime bad month throws")

# ============================== sys ====================================================
ok(type(sys.platform) == "String", "sys.platform is a String")
ok(sys.platform == "linux" or sys.platform == "darwin" or sys.platform == "windows", "sys.platform known value")
ok(type(sys.arch) == "String", "sys.arch is a String")
ok(len(sys.arch) > 0, "sys.arch non-empty")
ok(type(sys.version) == "String", "sys.version is a String")
ok(len(sys.version) > 0, "sys.version non-empty")
# env
discard sys.setenv("R10_DATASYS_VAR", "vvv123")
ok(sys.getenv("R10_DATASYS_VAR") == "vvv123", "setenv/getenv round-trip")
ok(sys.environ()["R10_DATASYS_VAR"] == "vvv123", "environ contains the var")
ok(type(sys.environ()) == "Dict", "environ() is a Dict")
discard sys.unsetenv("R10_DATASYS_VAR")
ok(sys.getenv("R10_DATASYS_VAR") == None, "unsetenv removes the var")
ok(sys.getenv("R10_ABSENT_VAR") == None, "getenv missing -> None")
ok(sys.getenv("R10_ABSENT_VAR", "fallback") == "fallback", "getenv default")
# traceback
ok(sys.traceback() == "" or type(sys.traceback()) == "String", "traceback is a String")
try:
    throw "kaboom"
catch:
    ok(len(sys.traceback()) > 0, "traceback populated after a caught error")
if sys.platform != "windows":  # subprocess block: POSIX-only tools (cat/pwd) + POSIX 8-bit exit-code wrapping
    # external processes: createprocess (argv)
    var cpv = sys.createprocess([path.executable, "--version"])
    ok(cpv["code"] == 0, "createprocess ki --version exits 0")
    ok((sys.version in cpv["stdout"]) == True, "createprocess captures stdout")
    ok(type(cpv["stderr"]) == "String", "createprocess stderr is a String")
    ok(sys.createprocess(["cat"], input = "piped")["stdout"] == "piped", "createprocess feeds stdin")
    ok(sys.createprocess(["pwd"], cwd = work)["code"] == 0, "createprocess accepts cwd")
    ok(throws(Function(): return sys.createprocess(["/no/such/prog_xyz"])), "createprocess missing program throws")
    ok(throws(Function(): return sys.createprocess([])), "createprocess empty argv throws")
    # shell
    ok(sys.shell("echo hi_from_shell")["stdout"].strip() == "hi_from_shell", "shell captures stdout")
    ok(sys.shell("exit 0")["code"] == 0, "shell exit 0")
    ok(sys.shell("exit 7")["code"] == 7, "shell exit code passthrough")
    ok(sys.shell("cat", input = "shellpipe")["stdout"] == "shellpipe", "shell feeds stdin")
    ok(sys.shell("echo quick", timeout = 30)["stdout"].strip() == "quick", "shell accepts timeout")
    # sys.exit code semantics via a child ki process
    var runExit = Function(arg):
        var sp = tmp("exit_child.ki")
        with io.open(sp, "w") as f:
            discard f.write("import(\"sys\").exit(" + arg + ")")
        var r = sys.createprocess([path.executable, sp])
        discard path.remove(sp)
        return r
    ok(runExit("0")["code"] == 0, "sys.exit(0)")
    ok(runExit("7")["code"] == 7, "sys.exit(7)")
    ok(runExit("256")["code"] == 0, "sys.exit(256) wraps to 0")
    ok(runExit("-1")["code"] == 255, "sys.exit(-1) wraps to 255")
    var em = runExit("\"failmsg\"")
    ok(em["code"] == 1, "sys.exit(non-int) exits 1")
    ok(("failmsg" in em["stderr"]) == True, "sys.exit(message) prints to stderr")
else:
    n = n + 18  # keep the reported check count platform-stable (the 18-check POSIX subprocess block above)

# ============================== cleanup + report =======================================
# Best-effort: on Windows a scratch file that a `for line in io.open(...)` left open (its handle not
# yet GC'd) can't be deleted while still held ("Sharing violation") — correct Windows semantics, and
# a non-fatal cleanup concern since every assertion above already passed. The next run's start-of-run
# rmtree clears it (the process exit releases the handle).
try:
    discard path.rmtree(work, missing_ok = True)
catch:
    pass
io.print("r10_datasys: " + String(n) + " checks passed")
