# v1.16.1 audit — adversarial / edge coverage of String + Bytes (unicode indexing, slicing extremes,
# every method's optional args, format mini-spec, f-strings, encodings, repr-in-container). All must hold.
var io = import("io")

# --- unicode code-point (not byte) indexing/slicing ---
var s = "héllo"
assert len(s) == 5 and s[1] == "é" and s[1:3] == "él" and s[::-1] == "olléh", "unicode index/slice/reverse"
assert "a" * 0 == "" and "ab" * 3 == "ababab", "string repeat incl. zero"
assert "abc"[5:] == "" and "abc"[-100:] == "abc" and "abc"[:-100] == "", "slice out-of-bounds clamps"
assert "abcdef"[1:5:2] == "bd" and "abc"[::-1] == "cba", "slice with step / full reverse"

# --- methods + optional args ---
assert "a,b,,c".split(",") == ["a", "b", "", "c"], "split keeps empty fields"
assert "a b  c".split() == ["a", "b", "c"], "whitespace split collapses runs"
assert "aXbXcXd".split("X", 2) == ["a", "b", "cXd"], "split maxsplit"
assert "hello".find("l") == 2 and "hello".find("l", 3) == 3 and "hello".find("z") == -1, "find + start"
assert "hello".rfind("l") == 3, "rfind"
assert "aaa".count("a") == 3 and "aaa".count("a", 1) == 2, "count + start"
assert "abcabc".replace("bc", "X", 1) == "aXabc", "replace count"
assert "  hi  ".strip() == "hi" and "xxhixx".strip("x") == "hi", "strip default / chars"
assert "Hi".startswith("Hi") and "Hi".endswith("i"), "startswith / endswith"
assert "abc".removeprefix("ab") == "c" and "abc".removesuffix("bc") == "a", "remove prefix/suffix"
assert "5".zfill(3) == "005" and "-5".zfill(3) == "-05", "zfill keeps the sign"
assert "ab".center(6, "*") == "**ab**" and "ab".ljust(4) == "ab  " and "ab".rjust(4) == "  ab", "just / center"
assert "a-b-c".partition("-") == ["a", "-", "b-c"], "partition"
assert "HÉLLO".lower() == "héllo" and "héllo".upper() == "HÉLLO", "case is unicode-aware (Latin-1)"
assert "héllo".levenshtein("hello") == 1, "levenshtein edit distance"

# --- format mini-spec ---
assert format(255, "#x") == "0xff" and format(7, "08b") == "00000111", "format alternate form / zero-pad"
assert format(255, "#010b") == "0b11111111", "format alt + width"
assert format(3.14159, ".2f") == "3.14", "format float precision"
assert format(1000000, ",") == "1,000,000", "format thousands separator"
assert format(-5, "+") == "-5" and format(5, "+") == "+5", "format explicit sign"

# --- f-strings ---
var x = 42
var pi = 3.14159
assert f"{x:05d}" == "00042" and f"{pi:.2f}" == "3.14", "f-string format specs"
var dd = {"k": "v"}
assert f"{dd['k']}" == "v", "f-string with a single-quoted dict key"

# --- bytes ---
var b = "hi".encode()
assert len(b) == 2 and b[0] == 104 and b.hex() == "6869", "bytes encode / index int / hex"
assert "héllo".encode("utf-8").decode("utf-8") == "héllo", "utf-8 round-trip"
assert "héllo".encode("latin-1").decode("latin-1") == "héllo", "latin-1 round-trip"
assert Bytes([104, 105]).decode() == "hi", "Bytes from a List of Integers"
var encThrew = False
try:
    discard "€".encode("ascii")
catch:
    encThrew = True
assert encThrew, "ascii encode of a non-ascii code point throws"

# --- str vs repr in containers ---
assert String(["a", "b"]) == "['a', 'b']" and String("a") == "a" and String([""]) == "['']", "repr-quoting inside containers, bare outside"

io.print("v1.16.1 strings: all passed")
