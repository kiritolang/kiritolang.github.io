var io = import("io")
var hash = import("hash")

# --- Known-Answer Tests (independent reference vectors) ---
assert hash.md5("") == "d41d8cd98f00b204e9800998ecf8427e", "md5 empty"
assert hash.md5("abc") == "900150983cd24fb0d6963f7d28e17f72", "md5 abc"
assert hash.sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d", "sha1 abc"
assert hash.sha256("") == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256 empty"
assert hash.sha256("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad", "sha256 abc"
assert hash.sha512("abc") == "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f", "sha512 abc"
# HMAC-SHA256 RFC 4231 test case 2 (key="Jefe", msg="what do ya want for nothing?")
assert hash.hmac("Jefe", "what do ya want for nothing?", "sha256") == "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843", "hmac-sha256 RFC4231-2"
# crc32 of "123456789" is the standard 0xCBF43926
assert hash.crc32("123456789") == 3421780262, "crc32 check value"
assert hash.adler32("Wikipedia") == 300286872, "adler32 known"
# constant-time compare
assert hash.comparedigest("abc", "abc") and not hash.comparedigest("abc", "abd"), "comparedigest"
# hash accepts Bytes too
assert hash.sha256("abc".encode()) == hash.sha256("abc"), "hash accepts Bytes == String"

# --- path pure-string ops (os.path semantics) ---
var path = import("path")
assert path.join("a", "b", "c") == "a/b/c", "path join"
assert path.join("a", "/abs", "c") == "/abs/c", "path join absolute reset"
assert path.basename("/a/b/c.ki") == "c.ki" and path.dirname("/a/b/c.ki") == "/a/b", "path base/dirname"
assert path.splitext("f.tar.gz") == ["f.tar", ".gz"], "path splitext"
assert path.splitext("noext") == ["noext", ""], "path splitext no ext"
var pjthrew = False
try:
    discard path.join()
catch:
    pjthrew = True
assert pjthrew, "path.join() with zero args throws"

io.print("v1.16.1 hash/path: all passed")
