# r9_math_extra.ki — edge-case and error-hardening for math, complex, and random modules:
# math domain errors + NaN/inf pass-through + constants + every function;
# complex number arithmetic, domain errors, ordering restriction, .compare;
# random: reproducibility, range checking, error on bad inputs.

var io = import("io")
var math = import("math")
var cmod = import("complex")
var random = import("random")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1

var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# =========================================================== math constants
ok(math.pi > 3.14 and math.pi < 3.15, "math.pi is ~3.14159")
ok(math.e > 2.71 and math.e < 2.72, "math.e is ~2.71828")
ok(math.isinf(math.inf), "math.inf is infinite")
ok(math.isnan(math.nan), "math.nan is NaN")

# =========================================================== math domain errors (must throw)
ok(throws(Function(): return math.sqrt(-1)), "sqrt(-1) throws")
ok(throws(Function(): return math.log(0)), "log(0) throws")
ok(throws(Function(): return math.log(-1)), "log(-1) throws")
ok(throws(Function(): return math.log(0, 10)), "log(0, 10) throws")
ok(throws(Function(): return math.log(-5, 2)), "log(-5, 2) throws")
ok(throws(Function(): return math.asin(2)), "asin(2) throws")
ok(throws(Function(): return math.asin(-2)), "asin(-2) throws")
ok(throws(Function(): return math.acos(2)), "acos(2) throws")
ok(throws(Function(): return math.acos(-2)), "acos(-2) throws")
ok(throws(Function(): return math.acosh(0)), "acosh(0) throws")
ok(throws(Function(): return math.acosh(0.5)), "acosh(0.5) throws")
ok(throws(Function(): return math.atanh(1)), "atanh(1) throws")
ok(throws(Function(): return math.atanh(-1)), "atanh(-1) throws")
ok(throws(Function(): return math.atanh(2)), "atanh(2) throws")
ok(throws(Function(): return math.gamma(0)), "gamma(0) throws")
ok(throws(Function(): return math.gamma(-1)), "gamma(-1) throws")
ok(throws(Function(): return math.gamma(-5)), "gamma(-5) throws")
ok(throws(Function(): return math.factorial(-1)), "factorial(-1) throws")
ok(throws(Function(): return math.factorial(1.5)), "factorial(1.5) throws (non-integer)")

# =========================================================== math valid computations
ok(math.sqrt(0) == 0.0, "sqrt(0) = 0.0")
ok(math.sqrt(4) == 2.0, "sqrt(4) = 2.0")
ok(math.sqrt(2).compare(1.41421356, rel_tol=1e-7), "sqrt(2) is ~1.41421356")
ok(math.log(1) == 0.0, "log(1) = 0.0")
ok(math.log(math.e).compare(1.0, abs_tol=1e-10), "log(e) = 1.0")
ok(math.log(100, 10).compare(2.0, abs_tol=1e-10), "log(100, 10) = 2.0")
ok(math.exp(0) == 1.0, "exp(0) = 1.0")
ok(math.exp(1).compare(math.e, rel_tol=1e-10), "exp(1) = e")
ok(math.isinf(math.exp(1000.0)), "exp(1000) overflows to inf (not throw)")
ok(math.sin(0) == 0.0, "sin(0) = 0.0")
ok(math.cos(0) == 1.0, "cos(0) = 1.0")
ok(math.sin(math.pi).compare(0.0, abs_tol=1e-10), "sin(pi) ≈ 0")
ok(math.floor(3.7) == 3, "floor(3.7) = 3")
ok(math.ceil(3.2) == 4, "ceil(3.2) = 4")
ok(math.trunc(3.9) == 3, "trunc(3.9) = 3")
ok(math.trunc(-3.9) == -3, "trunc(-3.9) = -3")
ok(abs(-5) == 5, "builtin abs(-5) = 5")
ok(math.gcd(12, 8) == 4, "gcd(12, 8) = 4")
ok(math.lcm(4, 6) == 12, "lcm(4, 6) = 12")
ok(math.factorial(0) == 1, "factorial(0) = 1")
ok(math.factorial(5) == 120, "factorial(5) = 120")
ok(math.comb(5, 2) == 10, "comb(5, 2) = 10")
ok(math.perm(5, 2) == 20, "perm(5, 2) = 20")
ok(math.gamma(5).compare(24.0, abs_tol=1e-6), "gamma(5) = 4! = 24.0")
ok(math.isnan(math.sqrt(math.nan)), "sqrt(nan) → nan (pass-through)")
ok(math.isnan(math.log(math.nan)), "log(nan) → nan (pass-through)")
ok(math.prod([2, 3, 4]) == 24, "math.prod([2,3,4]) = 24")
ok(math.hypot(3, 4) == 5.0, "hypot(3, 4) = 5.0")
ok(math.degrees(math.pi).compare(180.0, abs_tol=1e-10), "degrees(pi) = 180.0")
ok(math.radians(180).compare(math.pi, abs_tol=1e-10), "radians(180) = pi")
ok(math.atan2(1, 1).compare(math.pi/4, abs_tol=1e-10), "atan2(1,1) = pi/4")
ok(math.erf(0) == 0.0, "erf(0) = 0.0")
ok(math.erfc(0) == 1.0, "erfc(0) = 1.0")
ok(math.isfinite(1.0), "isfinite(1.0) = True")
ok(not math.isfinite(math.inf), "isfinite(inf) = False")
ok(not math.isfinite(math.nan), "isfinite(nan) = False")

# =========================================================== complex module
var z = cmod.Complex(3, 4)
ok(z.re == 3.0, "complex re field")
ok(z.im == 4.0, "complex im field")
ok(z.modulus() == 5.0, "complex modulus (3-4-5 triangle)")
ok(z.norm2() == 25.0, "complex norm2 = modulus^2")

# Conjugate
var zc = z.conjugate()
ok(zc.re == 3.0 and zc.im == -4.0, "complex conjugate flips im sign")

# Arithmetic
var z2 = cmod.Complex(1, 2)
var zs = z + z2
ok(zs.re == 4.0 and zs.im == 6.0, "_add_ complex+complex")
var zd = z - z2
ok(zd.re == 2.0 and zd.im == 2.0, "_sub_ complex-complex")
var zm = z * z2
ok(zm.re == (3*1 - 4*2) and zm.im == (3*2 + 4*1), "_mul_ complex*complex")
var zdiv = cmod.Complex(1, 0) / cmod.Complex(1, 0)
ok(zdiv.re == 1.0 and zdiv.im == 0.0, "_div_ complex/complex identity")

# Real coercion: complex + Integer
var zri = z + 1
ok(zri.re == 4.0 and zri.im == 4.0, "complex + Integer coerces real")

# Constants
ok(cmod.zero.re == 0.0 and cmod.zero.im == 0.0, "complex.zero")
ok(cmod.one.re == 1.0 and cmod.one.im == 0.0, "complex.one")
ok(cmod.i.re == 0.0 and cmod.i.im == 1.0, "complex.i = sqrt(-1)")

# Factories
var zp = cmod.polar(5.0, 0.0)
ok(zp.re.compare(5.0, abs_tol=1e-10) and zp.im.compare(0.0, abs_tol=1e-10), "complex.polar(5, 0)")
var zreal = cmod.real(7.0)
ok(zreal.re == 7.0 and zreal.im == 0.0, "complex.real factory")

# Math functions
var ze = cmod.exp(cmod.Complex(0, math.pi))
ok(ze.re.compare(-1.0, abs_tol=1e-10), "exp(i*pi).re ≈ -1 (Euler)")
ok(ze.im.compare(0.0, abs_tol=1e-10), "exp(i*pi).im ≈ 0")
ok(cmod.sqrt(cmod.Complex(-1, 0)).im.compare(1.0, abs_tol=1e-10), "sqrt(-1) = i")

# is_zero (tolerant predicate on Complex)
ok(cmod.zero.is_zero(), "zero.is_zero() = True")
ok(not z.is_zero(), "non-zero.is_zero() = False")

# == is exact; .compare is tolerant
var z3 = cmod.Complex(1, 0)
var z4 = cmod.Complex(1.0000000001, 0)
ok(not (z3 == z4), "exact == detects small difference")
ok(z3.compare(z4, rel_tol=1e-8), "compare tolerant ignores small difference")

# Ordering not supported
ok(throws(Function(): return z < z2), "complex < throws (unordered)")
ok(throws(Function(): return z > z2), "complex > throws (unordered)")
ok(throws(Function(): return z <= z2), "complex <= throws (unordered)")
ok(throws(Function(): return z >= z2), "complex >= throws (unordered)")

# Domain errors
ok(throws(Function(): return cmod.log(cmod.zero)), "complex log(0) throws")
ok(throws(Function(): return cmod.log10(cmod.zero)), "complex log10(0) throws")
ok(throws(Function(): return cmod.atanh(cmod.Complex(1, 0))), "complex atanh(1) throws")
ok(throws(Function(): return cmod.atanh(cmod.Complex(-1, 0))), "complex atanh(-1) throws")
ok(throws(Function(): return cmod.pow(cmod.zero, cmod.Complex(-1, 0))), "complex pow(0, -1) throws")

# =========================================================== random module
var rng = random.Random(12345)

# basic range checks
var rv = rng.random()
ok(0.0 <= rv and rv < 1.0, "random() in [0, 1)")
var u = rng.uniform(2.0, 5.0)
ok(2.0 <= u and u <= 5.0, "uniform(2, 5) in range")
var ri = rng.randint(1, 100)
ok(1 <= ri and ri <= 100, "randint(1, 100) in range")
var rr = rng.randrange(0, 10, 2)
ok(rr >= 0 and rr < 10 and rr % 2 == 0, "randrange(0, 10, 2) is even in range")

# Reproducibility (same seed → same sequence)
var rng2 = random.Random(12345)
ok(rng2.random() == rv, "same seed → same first random()")

# choice / shuffle / sample
var choices = [10, 20, 30, 40]
var ch = rng.choice(choices)
ok(ch in choices, "choice() returns element from list")
var lst = [1, 2, 3, 4, 5]
rng.shuffle(lst)
ok(len(lst) == 5 and sorted(lst) == [1, 2, 3, 4, 5], "shuffle keeps all elements")
var samp = rng.sample([1, 2, 3, 4, 5], 3)
ok(len(samp) == 3, "sample(pop, 3) returns 3 elements")
ok(len(Set(samp)) == 3, "sample returns distinct elements")

# gauss / expovariate
var g = rng.gauss(0.0, 1.0)
ok(type(g) == "Float", "gauss returns Float")
var e = rng.expovariate(2.0)
ok(e > 0.0, "expovariate returns positive Float")

# Error cases
ok(throws(Function(): return rng.choice([])), "choice([]) throws")
ok(throws(Function(): return rng.sample([1, 2], 5)), "sample k > n throws")
ok(throws(Function(): return rng.randint(10, 5)), "randint(10, 5) inverted range throws")
ok(throws(Function(): return rng.expovariate(0.0)), "expovariate(0) throws (zero lambda)")

io.print("r9_math_extra: " + String(n) + " checks passed")
