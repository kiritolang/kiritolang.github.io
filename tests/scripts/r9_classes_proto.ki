# r9_classes_proto.ki — exhaustive tests for Kirito class features:
# special methods (_init_, _str_, _add_, etc.), type annotations, private members,
# _super_(), context manager protocol, iterator protocol, serialization protocol.
# Each ok() increments n; final line is the golden output.

var io = import("io")
var serialize = import("serialize")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1

var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# =========================================================== Basic class: _init_ and _str_
class Point:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
    var _str_ = Function(self):
        return "Point(" + String(self.x) + ", " + String(self.y) + ")"

var p = Point(3, 4)
ok(p.x == 3, "_init_ sets x")
ok(p.y == 4, "_init_ sets y")
ok(String(p) == "Point(3, 4)", "_str_ called by String()")
ok(type(p) == "Point", "type() of class instance")

# =========================================================== _str_ must return String
class NumStr:
    var _str_ = Function(self):
        return 42

ok(String(NumStr()) == "42", "_str_ returning Integer: result is String of that Integer")

# =========================================================== _len_ protocol
class Container:
    var _init_ = Function(self, items):
        self.items = items
    var _len_ = Function(self):
        return len(self.items)

var c = Container([1, 2, 3])
ok(len(c) == 3, "_len_ protocol: len() uses _len_")
var ce = Container([])
ok(len(ce) == 0, "_len_ empty container")

class BadLen:
    var _len_ = Function(self):
        return "not an int"

ok(throws(Function(): return len(BadLen())), "_len_ returning non-Integer throws")

# =========================================================== Arithmetic operators
class Vec:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
    var _add_ = Function(self, other):
        return Vec(self.x + other.x, self.y + other.y)
    var _sub_ = Function(self, other):
        return Vec(self.x - other.x, self.y - other.y)
    var _mul_ = Function(self, scalar):
        return Vec(self.x * scalar, self.y * scalar)
    var _neg_ = Function(self):
        return Vec(-self.x, -self.y)
    var _eq_ = Function(self, other):
        return self.x == other.x and self.y == other.y
    var _str_ = Function(self):
        return "Vec(" + String(self.x) + "," + String(self.y) + ")"

var v1 = Vec(1, 2)
var v2 = Vec(3, 4)
var vsum = v1 + v2
ok(vsum.x == 4 and vsum.y == 6, "_add_ works")
var vdiff = v2 - v1
ok(vdiff.x == 2 and vdiff.y == 2, "_sub_ works")
var vscale = v1 * 3
ok(vscale.x == 3 and vscale.y == 6, "_mul_ works")
var vneg = -v1
ok(vneg.x == -1 and vneg.y == -2, "_neg_ works")
ok(v1 == Vec(1, 2), "_eq_ works")
ok(v1 != Vec(1, 3), "!= works when _eq_ defined")

# =========================================================== Comparison operators
class Ordered:
    var _init_ = Function(self, v):
        self.v = v
    var _lt_ = Function(self, other):
        return self.v < other.v
    var _le_ = Function(self, other):
        return self.v <= other.v
    var _gt_ = Function(self, other):
        return self.v > other.v
    var _ge_ = Function(self, other):
        return self.v >= other.v
    var _eq_ = Function(self, other):
        return self.v == other.v

var o1 = Ordered(1)
var o2 = Ordered(2)
ok((o1 < o2) == True, "_lt_ works")
ok((o1 <= o2) == True, "_le_ works")
ok((o2 > o1) == True, "_gt_ works")
ok((o2 >= o1) == True, "_ge_ works")
ok(o1 == Ordered(1), "_eq_ works")
ok(sorted([o2, o1, Ordered(3)], key=Function(x): return x.v) == [o1, o2, Ordered(3)], "sorted with class key")

# =========================================================== _not_ operator
class Toggleable:
    var _init_ = Function(self, val):
        self.val = val
    var _not_ = Function(self):
        return not self.val

var t = Toggleable(True)
ok((not t) == False, "_not_ works")
var tf = Toggleable(False)
ok((not tf) == True, "_not_ on False")

# =========================================================== _call_ protocol
class Adder:
    var _init_ = Function(self, base):
        self.base = base
    var _call_ = Function(self, x):
        return self.base + x

var add5 = Adder(5)
ok(add5(3) == 8, "_call_ makes instance callable")
ok(add5(0) == 5, "_call_ with 0")
ok(isinstance(add5, Adder), "isinstance works on callable class")

# =========================================================== _getitem_ / _setitem_
class Matrix2x2:
    var _init_ = Function(self):
        self.data = [[0,0],[0,0]]
    var _getitem_ = Function(self, i, j):
        return self.data[i][j]
    var _setitem_ = Function(self, i, j, val):
        self.data[i][j] = val

var m = Matrix2x2()
m[0, 0] = 1
m[1, 1] = 2
ok(m[0, 0] == 1, "_setitem_ and _getitem_ with two keys")
ok(m[1, 1] == 2, "_setitem_ second element")
ok(m[0, 1] == 0, "_getitem_ unset element")

# =========================================================== _contains_ protocol
class Bag:
    var _init_ = Function(self, items):
        self.items = items
    var _contains_ = Function(self, x):
        return x in self.items

var bag = Bag([1, 2, 3])
ok((2 in bag) == True, "_contains_: 2 in bag")
ok((5 in bag) == False, "_contains_: 5 not in bag")

# =========================================================== _iter_ protocol
# _iter_ returns an iterable (e.g. a List); for-in then iterates that iterable.
class CountDown:
    var _init_ = Function(self, n):
        self.n = n
    var _iter_ = Function(self):
        var result = []
        var i = self.n
        while i > 0:
            result.append(i)
            i = i - 1
        return result

var cd = CountDown(3)
var items = []
for x in cd:
    items.append(x)
ok(items == [3, 2, 1], "_iter_ protocol: for-in uses _iter_ (returns List)")

var cd2 = CountDown(0)
var items2 = []
for x in cd2:
    items2.append(x)
ok(items2 == [], "_iter_: empty iteration")

# _iter_ returning a range
class RangeWrapper:
    var _init_ = Function(self, n):
        self.n = n
    var _iter_ = Function(self):
        return range(self.n)

var rw = RangeWrapper(4)
var rwItems = []
for x in rw:
    rwItems.append(x)
ok(rwItems == [0, 1, 2, 3], "_iter_ can return a range")

# =========================================================== _enter_ / _exit_ (context manager)
class ManagedResource:
    var _init_ = Function(self):
        self.entered = False
        self.exited = False
        self.val = 42
    var _enter_ = Function(self):
        self.entered = True
        return self
    var _exit_ = Function(self):
        self.exited = True

var resource = ManagedResource()
with resource as r:
    ok(resource.entered == True, "_enter_ called by with")
    ok(id(r) == id(resource), "with...as binds the _enter_ return value (same id)")
ok(resource.exited == True, "_exit_ called on with block exit")

# =========================================================== _exit_ called on exception
class TrackExit:
    var _init_ = Function(self):
        self.exited = False
    var _enter_ = Function(self):
        return self
    var _exit_ = Function(self):
        self.exited = True

var te = TrackExit()
var caughtErr = False
try:
    with te:
        throw "test error"
catch:
    caughtErr = True
ok(caughtErr and te.exited, "_exit_ called even when exception thrown in with block")

# =========================================================== Private members
class BankAccount:
    var _init_ = Function(self, balance):
        self._balance = balance
    var getBalance = Function(self):
        return self._balance
    var deposit = Function(self, amount):
        self._balance = self._balance + amount

var acc = BankAccount(100)
ok(acc.getBalance() == 100, "private _balance accessible from within class")
acc.deposit(50)
ok(acc.getBalance() == 150, "private _balance modified by method")
ok(throws(Function(): return acc._balance), "private _balance not accessible from outside")

# =========================================================== Inheritance and _super_()
class Animal:
    var _init_ = Function(self, name):
        self.name = name
    var speak = Function(self):
        return "..."
    var describe = Function(self):
        return "I am " + self.name

class Dog(Animal):
    var _init_ = Function(self, name, breed):
        discard self._super_()._init_(name)
        self.breed = breed
    var speak = Function(self):
        return "Woof!"
    var info = Function(self):
        return self.describe() + " (" + self.breed + ")"

var d = Dog("Rex", "Labrador")
ok(d.name == "Rex", "_super_()._init_ sets name on self")
ok(d.breed == "Labrador", "subclass _init_ sets breed")
ok(d.speak() == "Woof!", "overridden method used")
ok(d.describe() == "I am Rex", "inherited method works")
ok(d.info() == "I am Rex (Labrador)", "subclass method calling inherited")
ok(isinstance(d, Dog), "isinstance direct class")
ok(isinstance(d, Animal), "isinstance base class")

# Multi-level inheritance
class Poodle(Dog):
    var speak = Function(self):
        return "Yip!"
    var parentSpeak = Function(self):
        return self._super_().speak()

var poodle = Poodle("Fifi", "Poodle")
ok(poodle.speak() == "Yip!", "multi-level override")
ok(poodle.parentSpeak() == "Woof!", "_super_() climbs one level in multi-level chain")
ok(isinstance(poodle, Poodle), "isinstance Poodle")
ok(isinstance(poodle, Dog), "isinstance Dog (parent)")
ok(isinstance(poodle, Animal), "isinstance Animal (grandparent)")

# =========================================================== Class attributes (shared)
# Class-level vars act as default attribute values for instances.
# Assigning to instance.attr creates a per-instance shadow.
# Mutable class-level values (Lists) are shared by reference across instances.
class DefaultAttr:
    var x = 10
    var y = "hello"

var da1 = DefaultAttr()
var da2 = DefaultAttr()
ok(da1.x == 10, "class attr default read by instance")
ok(da2.y == "hello", "class attr string default")
da1.x = 99
ok(da1.x == 99, "instance assignment creates per-instance shadow")
ok(da2.x == 10, "other instance sees original default")

# Class-level mutable (List) IS shared (same reference, no copy-on-write until reassigned)
class SharedState:
    var shared = [0]
    var bump = Function(self):
        self.shared[0] = self.shared[0] + 1
    var getCount = Function(self):
        return self.shared[0]

var ss1 = SharedState()
var ss2 = SharedState()
ss1.bump()
ss2.bump()
ok(ss1.getCount() == 2, "mutable class attr shared via reference: ss1 sees ss2 bump")
ok(ss2.getCount() == 2, "mutable class attr shared: ss2 also sees 2")
ok(id(ss1.shared) == id(ss2.shared), "same list object (not copied)")

# Copy-on-write: assigning to instance attr shadows the class attr
class WithDefaults:
    var items = []

var wd1 = WithDefaults()
var wd2 = WithDefaults()
wd1.items = [1, 2, 3]
ok(wd1.items == [1, 2, 3], "instance now has its own items list")
ok(wd2.items == [], "wd2 still sees the original empty list class attr")

# =========================================================== Type annotations
class Typed:
    var compute = Function(self, x : Integer, y : Integer) -> Integer:
        return x + y
    var name = Function(self, s : String) -> String:
        return "Hello, " + s

var tyObj = Typed()
ok(tyObj.compute(3, 4) == 7, "annotated function works with correct types")
ok(tyObj.name("Alice") == "Hello, Alice", "annotated string function works")
ok(throws(Function(): return tyObj.compute("a", 4)), "annotation enforced: String where Integer expected")
ok(throws(Function(): return tyObj.compute(3, 4.0)), "annotation enforced: Float where Integer expected")

# Return type annotation
class Strict:
    var getStr = Function(self) -> String:
        return "ok"
    var getBadReturn = Function(self) -> String:
        return 42

ok(Strict().getStr() == "ok", "return annotation satisfied")
ok(throws(Function(): return Strict().getBadReturn()), "return annotation violation throws")

# =========================================================== Default parameter values
class HasDefault:
    var greet = Function(self, name, greeting = "Hello"):
        return greeting + ", " + name + "!"

var hd = HasDefault()
ok(hd.greet("Alice") == "Hello, Alice!", "default parameter used")
ok(hd.greet("Bob", "Hi") == "Hi, Bob!", "default overridden")

# Mutable default is fresh per call
class FreshDefault:
    var collect = Function(self, items = []):
        items.append(1)
        return items

var fd = FreshDefault()
var r1 = fd.collect()
var r2 = fd.collect()
ok(r1 == [1], "mutable default is fresh per call (first call)")
ok(r2 == [1], "mutable default is fresh per call (second call, not accumulated)")

# =========================================================== _getstate_ / _setstate_ serialization
class Serializable:
    var _init_ = Function(self, a, b):
        self.a = a
        self.b = b
        self._private = "hidden"
    var getPrivate = Function(self):
        return self._private
    var _getstate_ = Function(self):
        return {"a": self.a, "b": self.b}
    var _setstate_ = Function(self, state):
        self.a = state["a"]
        self.b = state["b"]
        self._private = "restored"

var orig = Serializable(10, 20)
var blob = serialize.dumps(orig)
var copy = serialize.loads(blob)
ok(copy.a == 10 and copy.b == 20, "_getstate_/_setstate_: values restored")
ok(copy.getPrivate() == "restored", "_setstate_ can set private member (verified via method)")
ok(id(copy) != id(orig), "copy is a new object (different id)")

# =========================================================== Keyword arguments to class constructor
class KwPoint:
    var _init_ = Function(self, x, y, z = 0):
        self.x = x
        self.y = y
        self.z = z

var kp1 = KwPoint(1, 2)
ok(kp1.x == 1 and kp1.y == 2 and kp1.z == 0, "constructor keyword defaults")
var kp2 = KwPoint(y=4, x=3)
ok(kp2.x == 3 and kp2.y == 4, "constructor kwargs in any order")
var kp3 = KwPoint(1, 2, z=3)
ok(kp3.z == 3, "constructor mixed positional + kwarg")

# =========================================================== Class as first-class value
var clsVar = Point
var p2 = clsVar(5, 6)
ok(p2.x == 5 and p2.y == 6, "class stored in variable and called")
ok(isinstance(p2, Point), "isinstance works with class-as-variable")

# =========================================================== Nested classes
class Outer:
    var _init_ = Function(self):
        self.inner = Inner(99)

class Inner:
    var _init_ = Function(self, v):
        self.v = v

var outer = Outer()
ok(outer.inner.v == 99, "class can hold instance of another class")
ok(isinstance(outer.inner, Inner), "isinstance for nested class instance")

io.print("r9_classes_proto: " + String(n) + " checks passed")
