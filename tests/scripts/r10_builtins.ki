# r10_builtins.ki — docs-vs-impl audit of Kirito builtins (typical, edge, hardening).
# Every ok(...) encodes REAL native behavior observed by running build-release/ki against
# docs/pages/08-builtins.md. Covers: type/Integer/Float/String/Bool/List/Set/Dict/Bytes/fromhex,
# isinstance/hasattr/id/len, range/enumerate/zip/map/filter/reversed/sorted/sum/min/max/all/any,
# abs/round/divmod/pow, bin/oct/hex, bitand/bitor/bitxor/bitnot, shl/shr, ord/chr, format, inspect,
# import, and keyword-argument hardening.
var io = import("io")
var math = import("math")
var NAN = math.nan
var INF = math.inf
var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1
var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True
var feq = Function(x, s):
    return String(x) == s
var dbl = Function(x): return x * 2
var isodd = Function(x): return x % 2 == 1
var gt2 = Function(x): return x > 2
class Animal:
    var _init_ = Function(self):
        self.legs = 4
class Dog(Animal):
    var bark = Function(self):
        return "woof"
var dog = Dog()

# ===== type(x) =====
ok(type(1) == "Integer", "type int")
ok(type(1.0) == "Float", "type float")
ok(type("x") == "String", "type str")
ok(type(True) == "Bool", "type bool")
ok(type(None) == "None", "type none")
ok(type([]) == "List", "type list")
ok(type({}) == "Dict", "type dict")
ok(type({1, 2}) == "Set", "type set")
ok(type(Bytes()) == "Bytes", "type bytes")
ok(type(len) == "Function", "type builtin fn")
ok(type(Integer) == "Function", "type ctor fn")
ok(type(dog) == "Dog", "type instance")
ok(type(Dog) == "Dog", "type class value -> own name")
ok(type(x = 42) == "Integer", "type keyword")

# ===== Integer(x) =====
ok(Integer(3.9) == 3, "Integer trunc pos")
ok(Integer(-3.9) == -3, "Integer trunc neg toward zero")
ok(Integer(True) == 1, "Integer True")
ok(Integer(False) == 0, "Integer False")
ok(Integer(42) == 42, "Integer passthrough")
ok(Integer("42") == 42, "Integer dec str")
ok(Integer("0xFF") == 255, "Integer hex")
ok(Integer("0X1A") == 26, "Integer uppercase hex prefix")
ok(Integer("0o17") == 15, "Integer octal")
ok(Integer("0b1010") == 10, "Integer binary")
ok(Integer("  -5 ") == -5, "Integer whitespace+sign")
ok(Integer("+5") == 5, "Integer plus sign")
ok(Integer("  0b11  ") == 3, "Integer ws around binary")
ok(Integer("0") == 0, "Integer zero str")
ok(Integer(x = "42") == 42, "Integer keyword")
ok(throws(Function(): return Integer("--5")), "Integer doubled sign")
ok(throws(Function(): return Integer("+ 5")), "Integer space after sign")
ok(throws(Function(): return Integer("0x-5")), "Integer sign after prefix")
ok(throws(Function(): return Integer("42abc")), "Integer trailing garbage")
ok(throws(Function(): return Integer("")), "Integer empty str")
ok(throws(Function(): return Integer("  ")), "Integer blank str")
ok(throws(Function(): return Integer("0x")), "Integer bare prefix")
ok(throws(Function(): return Integer("12.5")), "Integer float str")
ok(throws(Function(): return Integer(NAN)), "Integer NaN")
ok(throws(Function(): return Integer(INF)), "Integer infinity")
ok(throws(Function(): return Integer(1e19)), "Integer out of range")
ok(throws(Function(): return Integer(None)), "Integer None")
ok(throws(Function(): return Integer([])), "Integer list")
ok(throws(Function(): return Integer()), "Integer no args")
ok(throws(Function(): return Integer(1, 2)), "Integer too many pos")

# ===== Float(x) =====
ok(Float(5) == 5.0, "Float int")
ok(Float(True) == 1.0, "Float bool")
ok(feq(Float("3.14"), "3.14"), "Float dec str")
ok(Float("1e10") == 1e10, "Float scientific")
ok(Float("inf") == INF, "Float inf")
ok(Float("-INFINITY") == -INF, "Float -INFINITY case-insensitive")
ok(Float("nan") != Float("nan"), "Float nan is not equal to itself")
ok(feq(Float(2), "2.0"), "Float int repr")
ok(throws(Function(): return Float("0x1p4")), "Float rejects C99 hex-float")
ok(throws(Function(): return Float("abc")), "Float garbage str")
ok(throws(Function(): return Float("")), "Float empty str")
ok(throws(Function(): return Float(None)), "Float None")

# ===== String(x) =====
ok(String(42) == "42", "String int")
ok(String(2.0) == "2.0", "String float keeps .0")
ok(String(True) == "True", "String bool")
ok(String(None) == "None", "String none")
ok(String("hi") == "hi", "String raw text")
ok(String([1, 2]) == "[1, 2]", "String list")
ok(String(["a"]) == "['a']", "String nested str is repr")
ok(String({"k": "v"}) == "{'k': 'v'}", "String dict repr")
ok(String([""]) == "['']", "String empty-str element distinguishable")

# ===== Bool(x) =====
ok(Bool(0) == False, "Bool 0")
ok(Bool(1) == True, "Bool 1")
ok(Bool(0.0) == False, "Bool 0.0")
ok(Bool("") == False, "Bool empty str")
ok(Bool("x") == True, "Bool nonempty str")
ok(Bool([]) == False, "Bool empty list")
ok(Bool([0]) == True, "Bool nonempty list")
ok(Bool(None) == False, "Bool none")
ok(Bool(Bytes()) == False, "Bool empty bytes")
ok(Bool(Bytes([1])) == True, "Bool nonempty bytes")

# ===== List / Set / Dict =====
ok(List() == [], "List empty")
ok(List([1, 2]) == [1, 2], "List from list")
ok(List("abc") == ["a", "b", "c"], "List from string")
ok(sorted(List({3, 1, 2})) == [1, 2, 3], "List from set")
ok(List(Bytes([1, 2, 3])) == [1, 2, 3], "List from bytes -> ints")
ok(List(iterable = [1, 2]) == [1, 2], "List keyword")
ok(throws(Function(): return List(5)), "List non-iterable")
ok(len(Set([1, 1, 2, 3])) == 3, "Set dedup len")
ok(Set([1, 1, 2, 3]) == {1, 2, 3}, "Set dedup")
ok(Set("aab") == Set(["a", "b"]), "Set from string")
ok(Set() == Set([]), "Set empty")
ok(Dict() == {}, "Dict empty")
ok(Dict([["a", 1], ["b", 2]]) == {"a": 1, "b": 2}, "Dict from pairs")
ok(throws(Function(): return Dict([[1, 2, 3]])), "Dict non-pair item")
ok(throws(Function(): return Dict(5)), "Dict non-iterable")

# ===== Bytes / fromhex =====
ok(len(Bytes()) == 0, "Bytes empty")
ok(len(Bytes(None)) == 0, "Bytes None -> empty")
ok(len(Bytes(3)) == 3, "Bytes n zero bytes")
ok(Bytes([72, 105]).decode() == "Hi", "Bytes from int list")
ok(Bytes("Hi").hex() == "4869", "Bytes from string utf-8")
ok(Bytes("café").hex() == "636166c3a9", "Bytes utf-8 multibyte")
ok(Bytes("café", "latin-1").hex() == "636166e9", "Bytes latin-1")
ok(Bytes("A", encoding = "ascii").decode() == "A", "Bytes ascii keyword")
ok(Bytes(x = [65]).decode() == "A", "Bytes x keyword")
ok(Bytes([72, 105]) == Bytes("Hi"), "Bytes equality")
ok(throws(Function(): return Bytes([256])), "Bytes element > 255")
ok(throws(Function(): return Bytes([-1])), "Bytes element < 0")
ok(throws(Function(): return Bytes(1.0)), "Bytes from Float rejected")
ok(throws(Function(): return Bytes("x", "bogus")), "Bytes bad encoding")
ok(fromhex("4869").decode() == "Hi", "fromhex")
ok(fromhex("48 69").decode() == "Hi", "fromhex spaces allowed")
ok(len(fromhex("")) == 0, "fromhex empty")
ok(throws(Function(): return fromhex("zz")), "fromhex non-hex digit")
ok(throws(Function(): return fromhex("4")), "fromhex odd length")
ok(throws(Function(): return fromhex(72)), "fromhex non-string")

# ===== isinstance =====
ok(isinstance(1, Integer) == True, "isinstance Integer ctor")
ok(isinstance(True, Integer) == False, "isinstance Bool is not Integer")
ok(isinstance(1, Bool) == False, "isinstance Integer is not Bool")
ok(isinstance(True, Bool) == True, "isinstance Bool")
ok(isinstance("x", String) == True, "isinstance String")
ok(isinstance(1.5, Float) == True, "isinstance Float")
ok(isinstance([], List) == True, "isinstance List")
ok(isinstance({1}, Set) == True, "isinstance Set")
ok(isinstance({}, Dict) == True, "isinstance Dict")
ok(isinstance(Bytes(), Bytes) == True, "isinstance Bytes ctor")
ok(isinstance(1, "Integer") == True, "isinstance type-name string")
ok(isinstance(1, "Number") == True, "isinstance pseudo Number int")
ok(isinstance(1.0, "Number") == True, "isinstance pseudo Number float")
ok(isinstance("x", "Number") == False, "isinstance Number rejects str")
ok(isinstance(1, "Any") == True, "isinstance pseudo Any")
ok(isinstance(None, "None") == True, "isinstance pseudo None")
ok(isinstance(io, "Module") == True, "isinstance pseudo Module")
ok(isinstance(dbl, "Function") == True, "isinstance pseudo Function")
ok(isinstance(dog, Dog) == True, "isinstance own class")
ok(isinstance(dog, Animal) == True, "isinstance base class inheritance")
ok(isinstance(dog, "Animal") == True, "isinstance base by name")
ok(isinstance(Bytes(), "Bytes") == True, "isinstance native type name")
ok(isinstance(Dog, "Class") == True, "isinstance class value is Class")
ok(isinstance(1, "Bogus") == False, "isinstance unknown name -> False")
ok(isinstance(value = 1, type = Integer) == True, "isinstance keywords")
ok(throws(Function(): return isinstance(1, 42)), "isinstance non-type 2nd arg")
ok(throws(Function(): return isinstance(1, [])), "isinstance list as type")
ok(throws(Function(): return isinstance(1)), "isinstance missing type")

# ===== hasattr =====
ok(hasattr("x", "upper") == True, "hasattr string method")
ok(hasattr([1], "append") == True, "hasattr list method")
ok(hasattr(5, "compare") == True, "hasattr int compare")
ok(hasattr(math, "sqrt") == True, "hasattr module member")
ok(hasattr(math, "nope") == False, "hasattr module missing")
ok(hasattr(dog, "legs") == True, "hasattr instance attr")
ok(hasattr(dog, "bark") == True, "hasattr instance method")
ok(hasattr(dog, "nope") == False, "hasattr instance missing")
ok(hasattr(Dog, "bark") == False, "hasattr class value -> False")
ok(hasattr(dbl, "x") == False, "hasattr plain function -> False")
ok(throws(Function(): return hasattr(5, 42)), "hasattr non-string name")

# ===== id =====
var la = [1, 2]
var lb = la
var lc = [1, 2]
ok(id(la) == id(lb), "id equal for aliases")
ok(id(la) != id(lc), "id distinct for equal-but-separate")
ok(id(1) == id(1), "id interned small int")
ok(type(id(la)) == "Integer", "id returns Integer")

# ===== len =====
ok(len([1, 2, 3]) == 3, "len list")
ok(len("abc") == 3, "len string")
ok(len("héllo") == 5, "len unicode code points")
ok(len("") == 0, "len empty string")
ok(len([]) == 0, "len empty list")
ok(len({}) == 0, "len empty dict")
ok(len({1, 2, 3}) == 3, "len set")
ok(len({"a": 1}) == 1, "len dict")
ok(len(Bytes([1, 2])) == 2, "len bytes")
ok(len(range(10)) == 10, "len range")
ok(throws(Function(): return len(5)), "len int throws")
ok(throws(Function(): return len(None)), "len none throws")
ok(throws(Function(): return len(True)), "len bool throws")

# ===== range =====
ok(range(5) == [0, 1, 2, 3, 4], "range stop")
ok(range(2, 5) == [2, 3, 4], "range start stop")
ok(range(2, 10, 3) == [2, 5, 8], "range step")
ok(range(5, 0, -1) == [5, 4, 3, 2, 1], "range negative step")
ok(range(0) == [], "range 0 empty")
ok(range(5, 2) == [], "range empty forward")
ok(range(end = 3) == [0, 1, 2], "range end keyword")
ok(range(1, 10, step = 2) == [1, 3, 5, 7, 9], "range step keyword")
ok(len(range(1000)) == 1000, "range length")
ok(throws(Function(): return range(2, 5, 0)), "range step zero")
ok(throws(Function(): return range(1.5)), "range float rejected")
ok(throws(Function(): return range()), "range missing stop")
ok(throws(Function(): return range(2, 5, start = 1)), "range duplicate start")
ok(throws(Function(): return range(0, 10000000000)), "range too large guard")

# ===== enumerate =====
ok(List(enumerate(["a", "b"])) == [[0, "a"], [1, "b"]], "enumerate")
ok(List(enumerate(["a", "b"], 1)) == [[1, "a"], [2, "b"]], "enumerate start")
ok(List(enumerate("ab", start = 5)) == [[5, "a"], [6, "b"]], "enumerate start keyword")
ok(List(enumerate([], 1)) == [], "enumerate empty")
ok(type(List(enumerate(["x"]))[0]) == "List", "enumerate pair is a List")
ok(throws(Function(): return List(enumerate(5))), "enumerate non-iterable")
ok(throws(Function(): return enumerate([1], 1.5)), "enumerate float start rejected")

# ===== zip =====
ok(List(zip([1, 2], [3, 4])) == [[1, 3], [2, 4]], "zip")
ok(List(zip([1, 2, 3], [4, 5])) == [[1, 4], [2, 5]], "zip truncates to shortest")
ok(List(zip([1], [2], [3])) == [[1, 2, 3]], "zip three")
ok(List(zip()) == [], "zip no args")
ok(List(zip([1, 2])) == [[1], [2]], "zip one")
ok(List(zip([], [1, 2])) == [], "zip with empty")
ok(List(zip("ab", "cd")) == [["a", "c"], ["b", "d"]], "zip strings")
ok(throws(Function(): return List(zip([1, 2], 5))), "zip non-iterable arg")

# ===== map / filter =====
ok(List(map(dbl, [1, 2, 3])) == [2, 4, 6], "map")
ok(List(map(dbl, [])) == [], "map empty")
ok(List(map(String, [1, 2, 3])) == ["1", "2", "3"], "map builtin")
ok(List(map(function = dbl, iterable = [1])) == [2], "map keywords")
ok(throws(Function(): return List(map(dbl, 5))), "map non-iterable")
ok(List(filter(isodd, [1, 2, 3, 4, 5])) == [1, 3, 5], "filter")
ok(List(filter(isodd, [])) == [], "filter empty")
ok(List(filter(gt2, [1, 2, 3, 4])) == [3, 4], "filter inline")

# ===== reversed =====
ok(reversed([1, 2, 3]) == [3, 2, 1], "reversed list")
ok(reversed("abc") == ["c", "b", "a"], "reversed string -> list")
ok(reversed([]) == [], "reversed empty")
ok(len(reversed({1, 2, 3})) == 3, "reversed set")
ok(throws(Function(): return reversed(5)), "reversed non-iterable")

# ===== sorted =====
ok(sorted([3, 1, 2]) == [1, 2, 3], "sorted")
ok(sorted([3, 1, 2], reverse = True) == [3, 2, 1], "sorted reverse")
ok(sorted(["bb", "a", "ccc"], key = len) == ["a", "bb", "ccc"], "sorted key")
ok(sorted("cba") == ["a", "b", "c"], "sorted string -> list")
ok(sorted([]) == [], "sorted empty")
ok(sorted({3, 1, 2}) == [1, 2, 3], "sorted set")
ok(sorted([3, 1, 2], key = None) == [1, 2, 3], "sorted key None identity")
ok(sorted([3, 1, 2], None, True) == [3, 2, 1], "sorted positional key/reverse")
ok(sorted(["a", "bb", "c", "dd"], key = len) == ["a", "c", "bb", "dd"], "sorted stable")
ok(sorted(iterable = [3, 1, 2]) == [1, 2, 3], "sorted keyword")
ok(throws(Function(): return sorted(5)), "sorted non-iterable")
ok(throws(Function(): return sorted([1, "a"])), "sorted unorderable mix")

# ===== sum =====
ok(sum([1, 2, 3]) == 6, "sum")
ok(type(sum([1, 2, 3])) == "Integer", "sum stays Integer")
ok(sum([1, 2, 3], 10) == 16, "sum start")
ok(sum([1.0, 2]) == 3.0, "sum with float")
ok(type(sum([1.0, 2])) == "Float", "sum float element -> Float")
ok(type(sum([1, 2], 0.0)) == "Float", "sum float start -> Float")
ok(sum([]) == 0, "sum empty -> 0 default")
ok(sum([], 5) == 5, "sum empty -> start")
ok(sum([1, 2], start = 100) == 103, "sum start keyword")
ok(throws(Function(): return sum(["a", "b"])), "sum non-number element")
ok(throws(Function(): return sum([True, True])), "sum bool not a number")
ok(throws(Function(): return sum(5)), "sum non-iterable")
ok(throws(Function(): return sum([1, 2], "x")), "sum start non-number")

# ===== min / max =====
ok(min([3, 1, 2]) == 1, "min iterable")
ok(min(3, 1, 2) == 1, "min varargs")
ok(max([3, 1, 2]) == 3, "max iterable")
ok(max(3, 1, 2) == 3, "max varargs")
ok(min("bca") == "a", "min string")
ok(max("bca") == "c", "max string")
ok(min(["bb", "a", "ccc"], key = len) == "a", "min key")
ok(max(["bb", "a", "ccc"], key = len) == "ccc", "max key")
ok(min([], default = 99) == 99, "min default on empty")
ok(max([], default = None) == None, "max default None")
ok(min(2, 3, 1, default = 0) == 1, "min default ignored when nonempty")
ok(max([5, 2], default = 99) == 5, "max default ignored when nonempty")
ok(throws(Function(): return min([])), "min empty throws")
ok(throws(Function(): return max([])), "max empty throws")
ok(throws(Function(): return min(5)), "min single non-iterable")
ok(throws(Function(): return min([1, "a"])), "min unorderable mix")

# ===== all / any =====
ok(all([True, 1, "x"]) == True, "all truthy")
ok(all([1, 0, 1]) == False, "all with falsy")
ok(all([]) == True, "all empty vacuously True")
ok(any([0, 0, 1]) == True, "any")
ok(any([0, 0, 0]) == False, "any all falsy")
ok(any([]) == False, "any empty False")
ok(throws(Function(): return all(5)), "all non-iterable")
ok(throws(Function(): return any(5)), "any non-iterable")

# ===== abs =====
ok(abs(-5) == 5, "abs negative int")
ok(abs(5) == 5, "abs positive int")
ok(abs(-5.5) == 5.5, "abs float")
ok(type(abs(-5)) == "Integer", "abs int stays Integer")
ok(abs(-9223372036854775808) == -9223372036854775808, "abs INT64_MIN wraps to itself")
ok(abs(x = -9) == 9, "abs keyword")
ok(throws(Function(): return abs(True)), "abs Bool rejected")
ok(throws(Function(): return abs("x")), "abs string rejected")
ok(throws(Function(): return abs()), "abs no args")

# ===== round =====
ok(round(0.5) == 1, "round 0.5 half away from zero")
ok(round(1.5) == 2, "round 1.5")
ok(round(2.5) == 3, "round 2.5 not banker's")
ok(round(-0.5) == -1, "round -0.5")
ok(round(-1.5) == -2, "round -1.5")
ok(round(-2.7) == -3, "round -2.7")
ok(round(2.0) == 2, "round 2.0")
ok(type(round(2.0)) == "Integer", "round -> Integer")
ok(round(5) == 5, "round Integer")
ok(type(round(5)) == "Integer", "round Integer stays Integer")
ok(feq(round(2.675, 2), "2.67"), "round no double-rounding (2.675)")
ok(feq(round(3.14159, 2), "3.14"), "round ndigits")
ok(feq(round(2.5, 0), "3.0"), "round ndigits 0 -> Float")
ok(feq(round(123.456, -1), "120.0"), "round negative ndigits")
ok(type(round(2.0, 2)) == "Float", "round ndigits -> Float")
ok(round(3.14159, ndigits = 2) == round(3.14159, 2), "round ndigits keyword")
ok(feq(round(3.14159, 100), "3.14159"), "round huge ndigits no-op")
ok(feq(round(3.14159, -400), "0.0"), "round very negative ndigits -> 0.0")
ok(round(NAN, 2) != round(NAN, 2), "round(nan, 2) passes through as nan")
ok(feq(round(INF, 2), "inf"), "round(inf, 2) passes through")
ok(throws(Function(): return round(NAN)), "round NaN -> Integer throws")
ok(throws(Function(): return round(INF)), "round inf -> Integer throws")
ok(throws(Function(): return round(True)), "round Bool rejected")
ok(throws(Function(): return round("x")), "round string rejected")
ok(throws(Function(): return round(3.14, 1.5)), "round non-int ndigits rejected")

# ===== divmod =====
ok(divmod(7, 3) == [2, 1], "divmod")
ok(divmod(-7, 3) == [-3, 2], "divmod floor semantics")
ok(divmod(7, -3) == [-3, -2], "divmod negative divisor")
ok(divmod(7.5, 2) == [3.0, 1.5], "divmod float")
ok(divmod(a = 17, b = 5) == [3, 2], "divmod keywords")
ok(throws(Function(): return divmod(7, 0)), "divmod by zero")
ok(throws(Function(): return divmod(7.0, 0)), "divmod float by zero")
ok(throws(Function(): return divmod("a", "b")), "divmod non-number")

# ===== pow =====
ok(pow(2, 10) == 1024, "pow")
ok(type(pow(2, 10)) == "Integer", "pow int base/exp -> Integer")
ok(pow(2, -1) == 0.5, "pow negative exp -> Float")
ok(type(pow(2, -1)) == "Float", "pow negative exp type")
ok(pow(2, 0) == 1, "pow zero exp")
ok(pow(0, 0) == 1, "pow 0**0 == 1")
ok(pow(2.0, 3) == 8.0, "pow float base")
ok(pow(0.0, 0) == 1.0, "pow 0.0**0 == 1.0")
ok(pow(2, 10, 1000) == 24, "pow modular")
ok(pow(2, 3, mod = 5) == 3, "pow mod keyword")
ok(pow(3, 0, 7) == 1, "pow mod with zero exp")
ok(pow(2, 10, 1) == 0, "pow mod 1 == 0")
ok(throws(Function(): return pow(2, -1, 5)), "pow negative exp with mod")
ok(throws(Function(): return pow(2, 3, 0)), "pow mod zero")
ok(throws(Function(): return pow(2, 3, -5)), "pow negative mod")
ok(throws(Function(): return pow(2.0, 3, 5)), "pow non-int base with mod")
ok(throws(Function(): return pow("a", 2)), "pow non-number")

# ===== bin / oct / hex =====
ok(bin(10) == "0b1010", "bin")
ok(oct(64) == "0o100", "oct")
ok(hex(255) == "0xff", "hex")
ok(bin(-10) == "-0b1010", "bin negative sign-aware")
ok(hex(-255) == "-0xff", "hex negative")
ok(hex(0) == "0x0", "hex zero")
ok(bin(0) == "0b0", "bin zero")
ok(hex(-9223372036854775808) == "-0x8000000000000000", "hex INT64_MIN")
ok(hex(n = 255) == "0xff", "hex keyword")
ok(throws(Function(): return hex(1.0)), "hex float rejected")
ok(throws(Function(): return bin(True)), "bin Bool rejected")
ok(throws(Function(): return oct("x")), "oct string rejected")

# ===== bitand / bitor / bitxor / bitnot =====
ok(bitand(12, 10) == 8, "bitand")
ok(bitor(12, 10) == 14, "bitor")
ok(bitxor(12, 10) == 6, "bitxor")
ok(bitnot(0) == -1, "bitnot 0 == -1")
ok(bitnot(5) == -6, "bitnot 5 == -6")
ok(bitnot(-1) == 0, "bitnot -1 == 0")
ok(bitand(a = 6, b = 3) == 2, "bitand keywords")
ok(throws(Function(): return bitand(1, True)), "bitand Bool rejected")
ok(throws(Function(): return bitor(1.0, 2)), "bitor float rejected")

# ===== shl / shr =====
ok(shl(1, 4) == 16, "shl")
ok(shr(256, 4) == 16, "shr")
ok(shr(-8, 1) == -4, "shr arithmetic sign-preserving")
ok(shl(1, 63) == -9223372036854775808, "shl into sign bit")
ok(shl(1, 64) == 0, "shl >= 64 clears")
ok(shr(-1, 64) == -1, "shr negative >= 64 == -1")
ok(shr(5, 64) == 0, "shr positive >= 64 == 0")
ok(shl(a = 1, n = 3) == 8, "shl keywords")
ok(throws(Function(): return shl(1, -1)), "shl negative count")
ok(throws(Function(): return shr(1, -1)), "shr negative count")
ok(throws(Function(): return shl(True, 1)), "shl Bool rejected")

# ===== ord / chr =====
ok(ord("A") == 65, "ord ascii")
ok(ord("é") == 233, "ord latin1")
ok(ord("€") == 8364, "ord euro")
ok(chr(65) == "A", "chr ascii")
ok(chr(233) == "é", "chr latin1")
ok(chr(8364) == "€", "chr euro")
ok(ord(chr(127488)) == 127488, "ord/chr roundtrip high")
ok(ord(chr(0)) == 0, "ord chr(0) == 0")
ok(len(chr(0)) == 1, "chr(0) length 1")
ok(len(chr(1114111)) == 1, "chr max code point")
ok(ord(char = "Z") == 90, "ord keyword")
ok(chr(codepoint = 65) == "A", "chr keyword")
ok(throws(Function(): return ord("ab")), "ord multi-char")
ok(throws(Function(): return ord("")), "ord empty")
ok(throws(Function(): return ord(65)), "ord non-string")
ok(throws(Function(): return chr(-1)), "chr negative")
ok(throws(Function(): return chr(1114112)), "chr above max")
ok(throws(Function(): return chr(55296)), "chr surrogate rejected")
ok(throws(Function(): return chr(1.0)), "chr float rejected")

# ===== format =====
ok(format(42, "05d") == "00042", "format zero-pad d")
ok(format(255, "x") == "ff", "format hex")
ok(format(255, "X") == "FF", "format HEX upper")
ok(format(255, "#x") == "0xff", "format alt hex prefix")
ok(format(255, "#X") == "0XFF", "format alt HEX prefix")
ok(format(10, "b") == "1010", "format binary")
ok(format(10, "#b") == "0b1010", "format alt binary")
ok(format(64, "o") == "100", "format octal")
ok(format(64, "#o") == "0o100", "format alt octal")
ok(format(255, "#08x") == "0x0000ff", "format alt+zeropad hex")
ok(format(255, "#010x") == "0x000000ff", "format alt+width hex")
ok(format(3.14159, ".2f") == "3.14", "format fixed")
ok(format(1234567, ",") == "1,234,567", "format thousands")
ok(format(1000000, ",.2f") == "1,000,000.00", "format thousands + fixed")
ok(format(0.25, ".1%") == "25.0%", "format percent")
ok(format(1, "%") == "100.000000%", "format percent default precision")
ok(format(1.5, ".3e") == "1.500e+00", "format exponent")
ok(format(123456789, ".3g") == "1.23e+08", "format general")
ok(format("hi", "^6") == "  hi  ", "format center")
ok(format("x", "*^7") == "***x***", "format custom fill center")
ok(format(42, "*>6") == "****42", "format fill right")
ok(format(-42, "+06d") == "-00042", "format sign + zero-pad")
ok(format(42, "+d") == "+42", "format explicit plus")
ok(format(42, " d") == " 42", "format space sign")
ok(format(-5, " d") == "-5", "format space sign negative")
ok(format(7, ">06d") == "000007", "format zero-flag with align")
ok(format(255, "+x") == "+ff", "format sign with hex allowed")
ok(format(5, ".2f") == "5.00", "format Integer as float")
ok(format(True, "d") == "1", "format Bool as d")
ok(format(3.14159) == "3.14159", "format no spec float")
ok(format(True) == "True", "format no spec bool")
ok(format(42) == "42", "format no spec int")
ok(format("hi") == "hi", "format no spec string")
ok(format(None) == "None", "format None")
ok(format("café", ".2s") == "ca", "format string precision truncates code points")
ok(format("ab", ".0s") == "", "format string precision 0")
ok(format(42, spec = "05d") == "00042", "format spec keyword")
ok(throws(Function(): return format(3.7, "d")), "format Float with d throws")
ok(throws(Function(): return format(42, ".2d")), "format precision on integer throws")
ok(throws(Function(): return format(42, ",x")), "format comma with hex throws")
ok(throws(Function(): return format("hi", "d")), "format string with d throws")
ok(throws(Function(): return format(42, "q")), "format unknown type throws")
ok(throws(Function(): return format(1e10, "E")), "format E unsupported (only lowercase e)")
ok(throws(Function(): return format(1e10, "G")), "format G unsupported (only lowercase g)")
ok(throws(Function(): return format(42, 5)), "format non-string spec throws")
# String presentation THROWS on numeric-only flags rather than silently ignoring them.
ok(throws(Function(): return format("hi", "+5")), "format string with + sign throws")
ok(throws(Function(): return format("hi", "-5")), "format string with - sign throws")
ok(throws(Function(): return format("hi", " 5")), "format string with space sign throws")
ok(throws(Function(): return format("hi", "#6")), "format string with # alt-form throws")
ok(throws(Function(): return format("hi", "=6")), "format string with = align throws")
ok(throws(Function(): return format("hi", "05")), "format string with 0 (implies = align) throws")
ok(throws(Function(): return format("hi", ",")), "format string with , grouping throws")
ok(throws(Function(): return format(None, "+5")), "format non-string value keeps string rules")
# ...but the valid string specs (fill/align/width/precision) still work.
ok(format("hi", "6") == "hi    ", "format string plain width left-aligns")
ok(format("hi", ">5") == "   hi", "format string right align")
ok(format("hi", "<05") == "hi000", "format string explicit align + zero fill allowed")
ok(format("hi", "^6") == "  hi  ", "format string center")

# ===== inspect =====
ok(type(inspect(5)) == "String", "inspect returns String")
ok(type(inspect(io)) == "String", "inspect module -> String")
ok(len(inspect(dog)) > 0, "inspect instance non-empty")

# ===== import =====
ok(type(import("io")) == "Module", "import io")
ok(import("math").pi > 3.14, "import math pi")
ok(type(import(name = "io")) == "Module", "import keyword")
ok(throws(Function(): return import("nonexistent_xyz_module")), "import missing module")
ok(throws(Function(): return import(5)), "import non-string name")

# ===== keyword-argument hardening (uniform across builtins) =====
ok(abs(x = -5) == 5, "kw abs")
ok(len(x = [1, 2]) == 2, "kw len")
ok(throws(Function(): return abs(nope = 5)), "kw unknown keyword")
ok(throws(Function(): return abs(-5, extra = 1)), "kw unexpected keyword")
ok(throws(Function(): return Integer(42, x = 43)), "kw duplicate positional+keyword")

io.print("r10_builtins: " + String(n) + " checks passed")
