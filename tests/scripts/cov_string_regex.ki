# Exhaustive coverage for the `string`, `textwrap`, and `regex` stdlib MODULES.
# (Not the String type methods — those live in a separate coverage script.)
# Every assertion below was confirmed against ./build-release/ki actual behavior.

var io = import("io")
var string = import("string")
var tw = import("textwrap")
var re = import("regex")

var threw = Function(f):
    try:
        discard f()
        return False
    catch as e:
        return True
var emsg = Function(f):
    try:
        discard f()
        return ""
    catch as e:
        return e
var approx = Function(a, b):
    var d = a - b
    return (d if d >= 0 else -d) < 0.000000001

# =====================================================================================
# string module — constants
# =====================================================================================
assert string.ascii_lowercase == "abcdefghijklmnopqrstuvwxyz"
assert string.ascii_uppercase == "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
assert string.ascii_letters == string.ascii_lowercase + string.ascii_uppercase
assert len(string.ascii_letters) == 52
assert string.digits == "0123456789"
assert string.hexdigits == "0123456789abcdefABCDEF"
assert string.octdigits == "01234567"
assert string.punctuation == "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
assert len(string.punctuation) == 32
assert string.whitespace == " \t\n\r"
assert len(string.whitespace) == 4
# every char is a String constant (type sanity)
assert type(string.digits) == "String"

# =====================================================================================
# string.capwords — capitalize each SPACE-separated word (single-space split only)
# =====================================================================================
assert string.capwords("hello world") == "Hello World"
assert string.capwords("HELLO WoRLD") == "Hello World"            # lowercases the tail
assert string.capwords("") == ""                                  # empty
assert string.capwords("a") == "A"                                # single char
assert string.capwords("word") == "Word"                          # single word
# does NOT collapse whitespace runs; empty segments between spaces are preserved verbatim
assert string.capwords("  hello   world  ") == "  Hello   World  "
# tabs/newlines are NOT separators — the whole run is one "word"
assert string.capwords("a\tb") == "A\tb"
assert string.capwords("a\nb") == "A\nb"
# unicode first letter is uppercased (code-point aware)
assert string.capwords("élan vital") == "Élan Vital"
# digits/punctuation lead: word[0:1].upper() is a no-op, rest lowercased
assert string.capwords("1st place") == "1st Place"

# =====================================================================================
# string.similarity — 1 - editdistance/longerlength; String or List second arg
# =====================================================================================
assert string.similarity("", "") == 1.0                           # two empties identical
assert string.similarity("abc", "abc") == 1.0                     # identical
assert string.similarity("abc", "") == 0.0                        # one empty
assert string.similarity("", "abc") == 0.0
assert approx(string.similarity("kitten", "sitting"), 1.0 - 3.0/7.0)
assert approx(string.similarity("abc", "abd"), 1.0 - 1.0/3.0)     # one substitution
assert type(string.similarity("a", "b")) == "Float"
# List form: one score per candidate, order preserved
var sl = string.similarity("abc", ["abc", "abd", "xyz"])
assert type(sl) == "List"
assert len(sl) == 3
assert sl[0] == 1.0
assert approx(sl[1], 1.0 - 1.0/3.0)
assert sl[2] == 0.0
# List form with an empty candidate and an empty query element
assert string.similarity("cat", ["cat", "bat", "xyz", "dog"])[3] == 0.0
assert string.similarity("", [""])[0] == 1.0
assert string.similarity("", ["abc"])[0] == 0.0
# empty candidate list -> empty score list
assert string.similarity("x", []) == []

# =====================================================================================
# string.closest — smallest edit distance, ties to earliest, None on empty
# =====================================================================================
assert string.closest("aple", ["apple", "grape", "mango"]) == "apple"
assert string.closest("x", []) == None
assert string.closest("cat", ["cat"]) == "cat"                    # single candidate
# tie -> earliest candidate wins ("ab" is distance 1 from both "ac" and "xb")
assert string.closest("ab", ["ac", "xb"]) == "ac"
assert string.closest("aaa", ["xxx", "aax", "zzz"]) == "aax"     # nearest by distance

# =====================================================================================
# string.fuzzymatch — [candidate, score] pairs >= cutoff, sorted by score desc
# =====================================================================================
var fm = string.fuzzymatch("aple", ["apple", "grape", "mango"])   # default cutoff 0.6
assert len(fm) == 1
assert fm[0][0] == "apple"
assert fm[0][1] == 0.8
assert string.fuzzymatch("aple", []) == []                        # empty candidates
# cutoff filters
assert string.fuzzymatch("cat", ["cat", "cot", "dog"], 0.9) == [["cat", 1.0]]
# a low cutoff keeps everything, sorted by score descending
var fm2 = string.fuzzymatch("cat", ["cat", "cot", "xyz"], 0.0)
assert fm2[0][0] == "cat"
assert fm2[0][1] == 1.0
assert fm2[len(fm2) - 1][0] == "xyz"                              # worst last
# ties keep input order (stable), both scores 0.5
var ft = string.fuzzymatch("ab", ["ac", "xb"], 0.0)
assert ft[0][0] == "ac"
assert ft[1][0] == "xb"

# =====================================================================================
# textwrap.wrap — greedy word wrap on single spaces; never breaks a long word
# =====================================================================================
assert tw.wrap("the quick brown fox jumps", 10) == ["the quick", "brown fox", "jumps"]
assert tw.wrap("", 10) == []                                      # empty -> no lines
assert tw.wrap("hello", 10) == ["hello"]                          # fits
assert len(tw.wrap("a b c d e", 70)) == 1                         # default width 70
assert tw.wrap("a b c d e") == ["a b c d e"]                      # default width omitted
# a word longer than width is placed on its own line, NOT broken (delta: no error/break)
assert tw.wrap("supercalifragilistic word", 5) == ["supercalifragilistic", "word"]
# width 0 / negative: each word becomes its own line (no error raised — see findings)
assert tw.wrap("a b c", 0) == ["a", "b", "c"]
assert tw.wrap("a b c", -5) == ["a", "b", "c"]
assert not threw(Function(): return tw.wrap("a b c", 0))
# exact-fit boundary: "aa bb" width 5 fits on one line
assert tw.wrap("aa bb", 5) == ["aa bb"]
assert tw.wrap("aa bb", 4) == ["aa", "bb"]

# =====================================================================================
# textwrap.fill — newline-joined wrap
# =====================================================================================
assert tw.fill("the quick brown fox", 10) == "the quick\nbrown fox"
assert tw.fill("", 10) == ""
assert tw.fill("hello", 10) == "hello"
assert tw.fill("a b c d e") == "a b c d e"                        # default width

# =====================================================================================
# textwrap.indent — prefix each non-empty line
# =====================================================================================
assert tw.indent("a\nb\nc", "> ") == "> a\n> b\n> c"
assert tw.indent("a\n\nb", "> ") == "> a\n\n> b"                  # blank line NOT prefixed
assert tw.indent("", "> ") == ""                                 # empty line NOT prefixed
assert tw.indent("solo", "# ") == "# solo"
assert tw.indent("x", "") == "x"                                 # empty prefix

# =====================================================================================
# textwrap.dedent — remove the common leading whitespace
# =====================================================================================
assert tw.dedent("    a\n    b") == "a\nb"
assert tw.dedent("    a\n      b") == "a\n  b"                    # keeps extra indent
assert tw.dedent("no indent") == "no indent"                     # nothing common
assert tw.dedent("") == ""
# a blank line does not count toward the common prefix
assert tw.dedent("  a\n\n  b") == "a\n\nb"
assert tw.dedent("\ta\n\tb") == "a\nb"                           # tab-based indent
# mixed: only lines with content set the minimum
assert tw.dedent("        deep\n    shallow") == "    deep\nshallow"

# =====================================================================================
# regex — module functions: match / search / fullmatch
# =====================================================================================
assert re.search("z", "abc") == None                             # no match anywhere
assert re.search("b", "abc").group() == "b"                      # match anywhere
assert re.match("bc", "abc") == None                             # match is anchored at start
assert re.match("ab", "abc").group() == "ab"
assert re.fullmatch("a.c", "abc").group() == "abc"               # whole string
assert re.fullmatch("ab", "abc") == None                         # must cover all
assert re.fullmatch("abc", "abc").group() == "abc"

# =====================================================================================
# regex — Match object: group / groups / groupdict / start / end / span / string
# =====================================================================================
var m = re.search("(?P<user>\\w+)@(?P<host>[\\w.]+)", "contact ada@kirito.dev now")
assert m.group() == "ada@kirito.dev"                             # whole match
assert m.group(0) == "ada@kirito.dev"
assert m.group("user") == "ada"                                  # by name
assert m.group(1) == "ada"                                       # by number
assert m.group(2) == "kirito.dev"
assert m.group("user", "host") == ["ada", "kirito.dev"]          # several keys -> List
assert m.group(1, 2) == ["ada", "kirito.dev"]
assert m.groups() == ["ada", "kirito.dev"]
assert m.groupdict() == {"user": "ada", "host": "kirito.dev"}
assert m.start() == 8
assert m.end() == 22
assert m.span() == [8, 22]
assert m.string == "contact ada@kirito.dev now"
# group start/end/span for a specific group
var m2 = re.search("(b)(c)", "abc")
assert m2.span(1) == [1, 2]
assert m2.span(2) == [2, 3]
assert m2.start(1) == 1
assert m2.end(2) == 3
# Match str repr shows the span
assert "span=(1, 3)" in String(re.search("bc", "abc"))

# non-participating group -> None (group/groups) but -1 spans
var mp = re.search("(a)|(b)", "b")
assert mp.group(1) == None
assert mp.group(2) == "b"
assert mp.groups() == [None, "b"]
assert mp.groups("X") == ["X", "b"]                              # groups() default
assert mp.start(1) == -1
assert mp.end(1) == -1
assert mp.span(1) == [-1, -1]
# groupdict default for an absent named group
assert re.search("(?P<x>a)?b", "b").groupdict("Z") == {"x": "Z"}
# groupdict is empty when there are no named groups
assert re.search("(a)", "a").groupdict() == {}

# =====================================================================================
# regex — findall (0 / 1 / 2+ group shapes; absent group renders "")
# =====================================================================================
assert re.findall("\\d+", "12 and 345") == ["12", "345"]         # 0 groups: matched strings
assert re.findall("(\\w)", "abc") == ["a", "b", "c"]             # 1 group: that group
assert re.findall("(\\w)(\\d)", "a1 b2") == [["a", "1"], ["b", "2"]]  # 2+: per-match Lists
# an absent group renders as "" in findall (unlike group() which gives None)
assert re.findall("(a)|(b)", "ab") == [["a", ""], ["", "b"]]
assert re.findall("z", "abc") == []                              # no match -> empty List

# =====================================================================================
# regex — finditer (List of Match objects)
# =====================================================================================
var it = re.finditer("\\d", "1a2b3")
assert len(it) == 3
assert it[0].group() == "1"
assert it[0].start() == 0
assert it[2].start() == 4
assert re.finditer("z", "abc") == []

# =====================================================================================
# regex — sub (template refs, function repl, count)
# =====================================================================================
assert re.sub("\\s+", "_", "a   b  c") == "a_b_c"
assert re.sub("(\\w+)@(\\w+)", "\\2.\\1", "ada@dev") == "dev.ada"     # \1 \2 refs
assert re.sub("\\w+", "<\\g<0>>", "ab cd") == "<ab> <cd>"            # \g<0> whole match
assert re.compile("(?P<y>\\w+)").sub("[\\g<y>]", "hi there") == "[hi] [there]"  # \g<name>
assert re.sub("a", "X", "aaa", 2) == "XXa"                          # count limits
assert re.sub("a", "X", "aaa") == "XXX"                             # count 0 -> all
assert re.sub("a", "X", "aaa", -1) == "XXX"                         # negative count -> all (see findings)
assert re.sub("z", "X", "abc") == "abc"                             # no match -> unchanged
# function replacement receives a Match, must return a String
assert re.compile("\\d+").sub(Function(mm): return "N", "a1b22") == "aNbN"
assert re.compile("\\d+").sub(Function(mm): return "[" + mm.group() + "]", "a1b22") == "a[1]b[22]"
# escape sequences in a template
assert re.sub("X", "\\n", "aXb") == "a\nb"
assert re.sub("X", "\\t", "aXb") == "a\tb"
assert re.sub("X", "\\\\", "aXb") == "a\\b"

# =====================================================================================
# regex — split (with/without groups, maxsplit)
# =====================================================================================
assert re.split(",", "a,b,c") == ["a", "b", "c"]
assert re.split("(,)", "a,b,c") == ["a", ",", "b", ",", "c"]        # captured groups interleaved
assert re.split(",", "a,b,c,d", 2) == ["a", "b", "c,d"]            # maxsplit
assert re.split(",", "a,b,c", -1) == ["a", "b", "c"]              # negative maxsplit -> all
assert re.split(",", "abc") == ["abc"]                            # no match -> whole string
# an absent optional group in a split contributes None
assert re.split("(x)?,", "a,b") == ["a", None, "b"]

# =====================================================================================
# regex — escape
# =====================================================================================
assert re.escape("a.b*c") == "a\\.b\\*c"
assert re.escape("a+b") == "a\\+b"
assert re.escape("plain") == "plain"                             # word chars untouched
assert re.escape("") == ""
# non-ASCII (cp > 127) is treated as word-ish and left literal; ASCII punct escaped
assert re.escape("café!") == "café\\!"
# an escaped literal actually matches literally
assert re.search(re.escape("a.b"), "xa.by").group() == "a.b"
assert re.search(re.escape("a.b"), "aXb") == None

# =====================================================================================
# regex — compile object attributes
# =====================================================================================
var rx = re.compile("cat|dog", re.IGNORECASE)
assert rx.pattern == "cat|dog"
assert rx.groups == 0
assert rx.findall("Cat dog CAT") == ["Cat", "dog", "CAT"]
var rg = re.compile("(?P<a>x)(?P<b>y)(z)")
assert rg.groups == 3
assert rg.groupindex == {"a": 1, "b": 2}                         # only NAMED groups
assert re.compile("abc").groupindex == {}

# =====================================================================================
# regex — flags: IGNORECASE / MULTILINE / DOTALL and aliases, combining
# =====================================================================================
assert re.I == re.IGNORECASE
assert re.M == re.MULTILINE
assert re.S == re.DOTALL
assert re.findall("cat", "Cat CAT cat", re.IGNORECASE) == ["Cat", "CAT", "cat"]
assert re.findall("^\\w+", "a\nb\nc", re.MULTILINE) == ["a", "b", "c"]
assert re.search("a.b", "a\nb", re.DOTALL).group() == "a\nb"     # . matches newline
assert re.search("a.b", "a\nb") == None                          # ...but not by default
assert re.findall("^cat", "CAT\ncat", re.I + re.M) == ["CAT", "cat"]  # combine with +
# inline flags
assert re.findall("(?i)cat", "CAT cat") == ["CAT", "cat"]

# =====================================================================================
# regex — pos / endpos on compiled methods
# =====================================================================================
var w = re.compile("\\w+")
assert w.search("abc def", 4).group() == "def"                   # start at pos
assert w.search("abcdef", 0, 3).group() == "abc"                 # endpos truncates subject
assert re.compile("\\w+$").search("abcdef", 0, 3).group() == "abc"  # $ anchors at endpos
assert w.match("xabc", 1).group() == "abc"                       # anchored match at pos

# =====================================================================================
# regex — quantifiers, classes, anchors, alternation
# =====================================================================================
assert re.findall("a{2,3}", "a aa aaa aaaa") == ["aa", "aaa", "aaa"]
assert re.fullmatch("a{3}", "aaa").group() == "aaa"
assert re.search("a{2,}", "aaaa").group() == "aaaa"
assert re.search("a.*b", "axbxb").group() == "axbxb"             # greedy
assert re.search("a.*?b", "axbxb").group() == "axb"              # lazy
assert re.findall("[^0-9]+", "ab12cd") == ["ab", "cd"]           # negated class
assert re.findall("\\bcat\\b", "cat category cat") == ["cat", "cat"]  # word boundary
assert re.search("\\Aab", "abc").group() == "ab"                 # \A start anchor
assert re.search("c\\Z", "abc").group() == "c"                   # \Z end anchor
assert re.findall("a|", "aba") == ["a", "", "a", ""]             # alternation w/ empty branch
# nested groups
assert re.search("((a)(b))", "ab").groups() == ["ab", "a", "b"]

# =====================================================================================
# regex — empty pattern and empty-match handling
# =====================================================================================
assert re.findall("", "ab") == ["", "", ""]                      # match at each position + end
assert re.split("", "ab") == ["", "a", "b", ""]
assert re.search("", "abc").group() == ""

# =====================================================================================
# regex — code-point (not byte) positions on multibyte input
# =====================================================================================
var mu = re.search("é", "aébc")
assert mu.span() == [1, 2]                                       # code-point index, not byte
assert re.search("c", "aébc").start() == 3
# ASCII shorthands do NOT match non-ASCII letters (é is not \w)
assert re.findall("\\w", "héllo") == ["h", "l", "l", "o"]

# =====================================================================================
# regex — escapes: octal \0NN, \xHH, \uHHHH
# =====================================================================================
assert re.search("\\052", "*").group() == "*"                    # octal 052 = '*'
assert re.search("\\x41", "A").group() == "A"                    # hex
assert re.search("\\u00e9", "é").group() == "é"                  # 4-hex code point

# =====================================================================================
# regex — the documented divergence: a repeated nullable capturing group
# =====================================================================================
assert re.search("(a*)*", "").group(1) == None                   # Kirito gives None (Python: '')
assert re.fullmatch("(a*)*", "aaa").group(1) == "aaa"            # the consuming iteration
assert re.fullmatch("(a*)*", "aaa").group(0) == "aaa"           # match itself always correct

# =====================================================================================
# regex — HARDENING: invalid patterns and misuse must raise the RIGHT error
# =====================================================================================
# backreferences unsupported
assert "backreferences" in emsg(Function(): return re.compile("(a)\\1"))
assert "backreferences" in emsg(Function(): return re.compile("\\1"))   # bare \1 rejected too
# lookaround unsupported
assert "lookahead" in emsg(Function(): return re.compile("(?=a)"))
assert "lookahead" in emsg(Function(): return re.compile("(?!a)"))
assert threw(Function(): return re.compile("(?<=a)"))
assert threw(Function(): return re.compile("(?<!a)"))
# structural errors
assert "invalid regex" in emsg(Function(): return re.compile("("))
assert "missing )" in emsg(Function(): return re.compile("(abc"))
assert "nothing to repeat" in emsg(Function(): return re.compile("*abc"))
assert "character class" in emsg(Function(): return re.compile("[abc"))
assert "bad repetition bounds" in emsg(Function(): return re.compile("a{3,2}"))
assert "duplicate group name" in emsg(Function(): return re.compile("(?P<x>a)(?P<x>b)"))
assert "empty group name" in emsg(Function(): return re.compile("(?P<>a)"))
# bad group key on a Match
assert "no such group" in emsg(Function(): return re.search("(a)", "a").group("nope"))
assert "no such group" in emsg(Function(): return re.search("(a)", "a").group(5))
assert "no such group" in emsg(Function(): return re.search("(a)", "a").group(-1))
# template / replacement errors in sub
assert "invalid group reference" in emsg(Function(): return re.sub("(a)", "\\5", "a"))
assert "trailing backslash" in emsg(Function(): return re.sub("a", "\\", "a"))
assert "no group named" in emsg(Function(): return re.sub("(a)", "\\g<nope>", "a"))
assert "no group named" in emsg(Function(): return re.sub("(a)", "\\g<>", "a"))
assert "must be a String or a function" in emsg(Function(): return re.compile("a").sub(5, "a"))
assert "must return a String" in emsg(Function(): return re.compile("a").sub(Function(mm): return 7, "a"))
# these SHOULD error (guard against silent success)
assert threw(Function(): return re.sub("(a)", "\\5", "a"))
assert threw(Function(): return re.search("(a)", "a").group(9))

io.print("cov string/regex: all passed")
