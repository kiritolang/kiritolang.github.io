# =============================================================================================
# r8_kimods_a.ki — round-8 exhaustive re-audit of the Kirito-authored frozen-source stdlib
# modules (src/kirito/stdlib_kimodules.hpp), GROUP A:
#   itertools, functools, collections, statistics, heapq, bisect, copy, enum.
#
# This suite COMPLEMENTS the r4/r6/r7/deep_kimods/audit_{heapq,bisect,statistics} suites — it
# deliberately picks FRESH inputs, seeds and angles those leave thin, with no duplication:
#   - cache key identity under Kirito's numeric == (1 and 1.0 collapse to ONE key; 0/False/None
#     stay distinct — but via a math-oracle count, the inverse of r7's distinctness check);
#   - copy/deepcopy of a collections INSTANCE (deque/Counter/defaultdict) — independent via serde,
#     where the prior suites only copied a hand-rolled `class Box`;
#   - deque has no _contains_ (`x in dq` throws) — distinct from r7's "deque slicing throws";
#   - chain/islice/accumulate iterating a DICT (yields its keys) — r7 used String/Bytes;
#   - accumulate with a NON-COMMUTATIVE binop (subtraction) where left/right order is observable;
#   - the partial R8 snapshot probed by INDEX mutation (b[0]=…) and by full reassignment, not append;
#   - reduce with a non-commutative func and a falsy non-None seed; explicit None seed == no seed;
#   - nsmallest == sorted(x)[:n] and nlargest == sorted(x, reverse)[:n] cross-checked under a fresh
#     fixed-seed (424242) duplicate-heavy fuzz (a different RNG/range than audit_heapq's);
#   - enum DUPLICATE-name values() returns the shadowed [1,1,2] (deep_kimods only probed get/nameof);
#   - quantiles interior linear-interpolation against a hand oracle on fresh data + both clamp arms;
#   - mode tie-break DIRECTION sensitivity ([4,4,5,5]->4 vs reversed [5,5,4,4]->5);
#   - combinatorics counts checked against a factorial/binomial math oracle over a fixed-seed sweep;
#   - kwargs into class instantiation (_init_) for deque/Counter/defaultdict/Enum;
#   - malformed inputs (wrong types / non-iterables / non-callable preds) throw cleanly everywhere.
#
# Every assertion bumps `n`; the final line reports the count. Deterministic, exit 0, zero stderr.
# =============================================================================================
var io = import("io")
var math = import("math")
var random = import("random")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1

# True iff calling `f` throws.
var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True

# Float closeness (computed floats are never compared with ==).
var close = Function(a, b):
    return a.compare(b, 1e-9, 1e-12)

var it = import("itertools")
var ft = import("functools")
var co = import("collections")
var st = import("statistics")
var hq = import("heapq")
var bi = import("bisect")
var cp = import("copy")
var en = import("enum")

# ===================================================================== itertools: fresh edges
# Iterating a DICT as the source yields its KEYS (a Dict is iterable). Fresh vs r7's String/Bytes.
var dkeys = it.chain([{"a": 1, "b": 2}])
ok(sorted(dkeys) == ["a", "b"], "chain over a Dict iterates its keys")
ok(sorted(it.islice({"x": 1, "y": 2, "z": 3}, 0, 3)) == ["x", "y", "z"], "islice over a Dict iterates keys")
# accumulate with a NON-COMMUTATIVE binop: ((10-1)-2)-3 == 4, proving left-fold (a is the accumulator).
ok(it.accumulate([10, 1, 2, 3], Function(a, b): return a - b) == [10, 9, 7, 4], "accumulate folds left (a-b, non-commutative)")
# accumulate single element never calls the func (would error on a 1-arg-needing body if it did).
ok(it.accumulate([42], Function(a, b): return a + b + 999) == [42], "accumulate single never calls func")
# islice start==stop is an empty window; start>stop empty; step that overshoots in one stride.
ok(it.islice([1, 2, 3, 4], 2, 2) == [], "islice start==stop empty")
ok(it.islice([0, 1, 2, 3, 4], 4, 1) == [], "islice start>stop empty")
ok(it.islice([0, 1, 2, 3, 4, 5, 6], 0, 7, 5) == [0, 5], "islice big step lands at 0 and 5")
# count where the step does not divide the span exactly: stops strictly before stop.
ok(it.count(0, 3, 10) == [0, 3, 6, 9], "count step 3 stops before 10")
ok(it.count(0, 3, 9) == [0, 3, 6], "count step 3, stop exactly on a step is exclusive")
# count with a Float step, asserted element-by-element via close (never == on computed floats).
var cf = it.count(0.0, 0.25, 1.0)
ok(len(cf) == 4, "count Float step length")
ok(close(cf[0], 0.0) and close(cf[1], 0.25) and close(cf[2], 0.5) and close(cf[3], 0.75), "count Float step values")
# product over duplicate factors and a singleton factor.
ok(it.product([[1, 1], [2]]) == [[1, 2], [1, 2]], "product preserves duplicate factor entries by position")
# groupby where the key COLLAPSES then RE-SPLITS a non-consecutive run (parity over a fresh sequence).
ok(it.groupby([1, 3, 5, 2, 4, 7], Function(x): return x % 2) == [[1, [1, 3, 5]], [0, [2, 4]], [1, [7]]], "groupby parity splits non-consecutive runs")
# ziplongest with a single list -> each element wrapped; empty list-of-lists -> [].
ok(it.ziplongest([[1, 2, 3]]) == [[1], [2], [3]], "ziplongest of one list wraps each element")
ok(it.ziplongest([]) == [], "ziplongest of no lists is empty")
# combinations/permutations of the empty domain.
ok(it.permutations([]) == [[]], "permutations of [] is one empty arrangement")
ok(it.combinations([], 0) == [[]], "combinations of [] choose 0 is one empty set")
ok(it.combinations([1, 2], 3) == [], "combinations r>n is empty")
ok(it.permutations([1, 2], -1) == [], "permutations negative r is empty")

# itertools combinatorics COUNTS against a factorial/binomial oracle (fixed-seed sweep, fresh).
var nck = Function(nn, kk):
    if kk < 0 or kk > nn:
        return 0
    return math.factorial(nn) // (math.factorial(kk) * math.factorial(nn - kk))
var npk = Function(nn, kk):
    if kk < 0 or kk > nn:
        return 0
    return math.factorial(nn) // math.factorial(nn - kk)
var rngc = random.Random(20240808)
var ti = 0
while ti < 40:
    var sz = rngc.randint(0, 6)
    var dom = []
    var j = 0
    while j < sz:
        dom.append(j)
        j = j + 1
    var r = rngc.randint(0, sz + 1)
    ok(len(it.combinations(dom, r)) == nck(sz, r), "combinations count == C(n,r)")
    ok(len(it.permutations(dom, r)) == npk(sz, r), "permutations count == P(n,r)")
    ti = ti + 1

# ===================================================================== functools: fresh edges
# reduce with a NON-COMMUTATIVE func: subtraction left-folds, ((((100-1)-2)-3)-4) == 90.
ok(ft.reduce(Function(a, b): return a - b, [1, 2, 3, 4], 100) == 90, "reduce subtraction left-folds with seed")
ok(ft.reduce(Function(a, b): return a - b, [10, 1, 2, 3]) == 4, "reduce subtraction left-folds without seed")
# A falsy non-None seed (empty String) actually seeds (have = initial != None is True for "").
ok(ft.reduce(Function(a, b): return a + b, ["x", "y"], "") == "xy", "reduce with an empty-String seed seeds")
ok(ft.reduce(Function(a, b): return a + b, [], "") == "", "reduce empty list with empty-String seed returns the seed")
# Explicit initial=None is a REAL seed (identity sentinel, Python parity): it folds None with the first
# element (None + 1 -> error), and seeds an empty fold to None instead of throwing.
ok(throws(Function(): return ft.reduce(Function(a, b): return a + b, [1, 2, 3], None)), "reduce explicit initial=None seeds the fold (None + 1 raises)")
ok(ft.reduce(Function(a, b): return a + b, [], None) == None, "reduce empty list with None seed returns the None seed")
# partial R8 snapshot — probed by INDEX mutation and by full REASSIGNMENT of the caller's binding.
var snap = [1, 2]
var pIdx = ft.partial(Function(args): return args, snap)
ok(pIdx([9]) == [1, 2, 9], "partial uses the bound list")
snap[0] = 777
ok(pIdx([9]) == [1, 2, 9], "partial froze the bound list: an index mutation does not leak in")
snap = [99, 99, 99]
ok(pIdx([9]) == [1, 2, 9], "partial holds its own copy: rebinding the caller var does not leak in")
# A partial wrapping another partial composes.
var inner = ft.partial(Function(args): return args[0] + args[1] + args[2], [1])
var outer = ft.partial(Function(args): return inner(args), [2])
ok(outer([3]) == 6, "nested partials compose (inner([2,3]) -> 1+2+3)")
# cache key identity: 1 and 1.0 are the SAME key (1 == 1.0 exactly), so the body runs ONCE.
var oneCalls = [0]
var oneBody = Function(x):
    oneCalls[0] = oneCalls[0] + 1
    return x
var oneCached = ft.cache(oneBody)
discard oneCached(1)
discard oneCached(1.0)
discard oneCached(1)
discard oneCached(1.0)
ok(oneCalls[0] == 1, "cache: 1 and 1.0 collapse to ONE key (numeric == is exact-equal)")
# Mirror check: 0, False, None remain THREE distinct keys.
var distCalls = [0]
var distBody = Function(x):
    distCalls[0] = distCalls[0] + 1
    return x
var distCached = ft.cache(distBody)
discard distCached(0)
discard distCached(False)
discard distCached(None)
discard distCached(0)
discard distCached(False)
discard distCached(None)
ok(distCalls[0] == 3, "cache: 0, False, None remain three distinct keys")
# cache caches a None RESULT too (a body that returns None still memoizes).
var noneResultCalls = [0]
var noneResultBody = Function(x):
    noneResultCalls[0] = noneResultCalls[0] + 1
    return None
var noneResultCached = ft.cache(noneResultBody)
discard noneResultCached(5)
discard noneResultCached(5)
ok(noneResultCalls[0] == 1, "cache memoizes a None result (computed once)")
# cache of an unhashable (List) argument throws (Dict-key requirement).
ok(throws(Function(): return ft.cache(Function(x): return x)([1, 2])), "cache of a List argument throws (unhashable key)")

# ===================================================================== collections: fresh edges
# copy/deepcopy of a deque INSTANCE -> an independent deque (via serde). Fresh vs class-Box copies.
var dqOrig = co.deque([1, 2, 3])
var dqShallow = cp.copy(dqOrig)
dqShallow.append(99)
ok(String(dqOrig) == "deque([1, 2, 3])", "copy of a deque instance is independent (append doesn't leak back)")
ok(String(dqShallow) == "deque([1, 2, 3, 99])", "the copied deque carries its elements")
var dqDeep = cp.deepcopy(co.deque([4, 5]))
dqDeep.append(6)
ok(String(dqDeep) == "deque([4, 5, 6])", "deepcopy of a deque instance works")
# deepcopy of a Counter instance is independent.
var ctOrig = co.Counter([1, 1, 2])
var ctCopy = cp.deepcopy(ctOrig)
ctCopy.add(1)
ok(ctOrig.get(1) == 2 and ctCopy.get(1) == 3, "deepcopy of a Counter is independent")
# deque has NO _contains_, so `x in dq` throws (distinct from r7's slice-throws).
ok(throws(Function(): return 2 in co.deque([1, 2, 3])), "deque has no _contains_ ('in' throws)")
# deque pop / popleft on an empty deque throw cleanly.
ok(throws(Function(): return co.deque().pop()), "deque.pop on empty throws")
ok(throws(Function(): return co.deque().popleft()), "deque.popleft on empty throws")
# deque appendleft/append ordering, then drain from both ends.
var dq = co.deque([5])
dq.appendleft(3)
dq.append(7)
ok(dq[0] == 3 and dq[1] == 5 and dq[2] == 7, "deque appendleft/append place at the right ends")
ok(dq.pop() == 7 and dq.popleft() == 3 and len(dq) == 1, "deque drains from both ends")
# Counter over INTEGER keys: mostcommon ordering and a negative-n end-slice that drops everything.
var cInt = co.Counter([1, 1, 2, 3, 3, 3])
ok(cInt.mostcommon(2) == [[3, 3], [1, 2]], "Counter(Integer keys) mostcommon top-2 by count")
ok(cInt.mostcommon(-1) == [], "Counter mostcommon(negative n) is [] (CPython)")
ok(cInt.mostcommon(-10) == [], "Counter mostcommon with a hugely negative n drops everything -> []")
# Counter.get of an unseen key is 0; the documented-absent surface throws.
ok(co.Counter([1]).get(99) == 0, "Counter.get of an unseen key is 0")
ok(throws(Function(): return co.Counter([1]).pop(1)), "Counter has no pop")
ok(throws(Function(): return co.Counter([1]).keys()), "Counter has no keys")
ok(throws(Function(): return co.Counter([1]).values()), "Counter has no values")
# defaultdict: a list factory yields a FRESH list per missing key (distinct identities).
var ddList = co.defaultdict(Function(): return [])
ddList["a"].append(1)
ddList["b"].append(2)
ok(ddList["a"] == [1] and ddList["b"] == [2], "defaultdict list factory accumulates per key")
ok(id(ddList["a"]) != id(ddList["b"]), "defaultdict makes a fresh value per missing key")
# defaultdict nested-dict factory builds nested structure on access.
var ddNest = co.defaultdict(Function(): return {})
ddNest["outer"]["inner"] = 7
ok(ddNest["outer"]["inner"] == 7, "defaultdict dict factory builds nested dicts")
# kwargs into class instantiation (_init_ keyword binding) for every collections constructor.
ok(String(co.deque(items = [1, 2])) == "deque([1, 2])", "deque(items=) kwarg")
ok(co.Counter(items = ["a", "a"]).get("a") == 2, "Counter(items=) kwarg")
ok(co.defaultdict(factory = Function(): return 9)["k"] == 9, "defaultdict(factory=) kwarg")

# ===================================================================== statistics: fresh edges
# quantiles INTERIOR linear interpolation on fresh non-uniform data, against a hand oracle.
# data = [1, 2, 4, 8], n=4, ld=4: pos_i = i*(ld+1)/n = i*5/4 -> 1.25, 2.5, 3.75.
#   i=1: pos 1.25, lo=1, frac .25 -> s[0] + .25*(s[1]-s[0]) = 1 + .25*1   = 1.25
#   i=2: pos 2.5 , lo=2, frac .5  -> s[1] + .5 *(s[2]-s[1]) = 2 + .5*2    = 3.0
#   i=3: pos 3.75, lo=3, frac .75 -> s[2] + .75*(s[3]-s[2]) = 4 + .75*4   = 7.0
var q1 = st.quantiles([1, 2, 4, 8])
ok(len(q1) == 3, "quantiles default n=4 -> 3 cuts")
ok(close(q1[0], 1.25) and close(q1[1], 3.0) and close(q1[2], 7.0), "quantiles interior interpolation matches the oracle")
# Tail cuts on tiny data: n large vs 2 points EXTRAPOLATES past the range (CPython exclusive method).
var q2 = st.quantiles([1, 2], 4)
ok(close(q2[0], 0.75) and close(q2[1], 1.5) and close(q2[2], 2.25), "quantiles n=4 on 2 points extrapolates the tail cuts")
ok(len(st.quantiles([1, 2, 3], 5)) == 4, "quantiles n=5 -> 4 cuts")
# quantiles sorts internally; n=2 single cut equals the median.
ok(st.quantiles([8, 2, 4, 1]) == st.quantiles([1, 2, 4, 8]), "quantiles sorts internally")
ok(close(st.quantiles([1, 2, 3, 4, 5], 2)[0], st.median([1, 2, 3, 4, 5])), "quantiles n=2 cut equals the median")
# mode tie-break is DIRECTION sensitive: first value to REACH the max count wins.
ok(st.mode([4, 4, 5, 5]) == 4, "mode tie: 4 reaches max first in [4,4,5,5]")
ok(st.mode([5, 5, 4, 4]) == 5, "mode tie: 5 reaches max first in the reversed list")
# multimode keeps BOTH tied values in first-seen order (independent of mode's tie-break).
ok(st.multimode([4, 4, 5, 5]) == [4, 5], "multimode keeps both tied modes, first-seen order")
ok(st.multimode([5, 5, 4, 4]) == [5, 4], "multimode first-seen order follows the reversed input")
# variance/stdev relationships on a fresh dataset.
var sv = [3, 6, 9, 12, 15]
ok(close(st.stdev(sv) * st.stdev(sv), st.variance(sv)), "stdev^2 == variance (fresh data)")
ok(close(st.pstdev(sv) * st.pstdev(sv), st.pvariance(sv)), "pstdev^2 == pvariance (fresh data)")
ok(close(st.variance(sv), st.pvariance(sv) * 5.0 / 4.0), "sample == population * n/(n-1)")
# Return-type contracts.
ok(type(st.mean([1, 2, 3])) == "Float" and type(st.median([1, 2, 3])) == "Float", "mean/median return Float")
ok(type(st.pvariance([1, 2, 3])) == "Float" and type(st.pstdev([1, 2, 3])) == "Float", "pvariance/pstdev return Float")
# Documented throws + Python-only names that Kirito does NOT provide.
ok(throws(Function(): return st.mean([])), "mean of empty throws")
ok(throws(Function(): return st.variance([5])), "variance needs >= 2 samples")
ok(throws(Function(): return st.quantiles([5])), "quantiles needs >= 2 samples")
ok(throws(Function(): return st.quantiles([1, 2, 3], 0)), "quantiles n<1 throws")
ok(st.mode([1, 1, 2]) == 1 and st.mode(["a", "a", "b"]) == "a", "statistics.mode returns the most common value")
ok(throws(Function(): return st.fmean([1, 2, 3])), "no fmean")
ok(throws(Function(): return st.geometric_mean([1, 2, 4])), "no geometric_mean")
ok(throws(Function(): return st.median_grouped([1, 2, 3])), "no median_grouped")
# A non-numeric input to mean fails at sum (the choke point).
ok(throws(Function(): return st.mean(["a", "b"])), "mean of Strings throws (sum chokes)")

# ===================================================================== heapq: fresh edges
# nsmallest == sorted(x)[:n] and nlargest == sorted(x, reverse)[:n] under a fresh fixed-seed,
# duplicate-heavy fuzz (range 0..7 maximizes ties; seed 424242 differs from audit_heapq).
var rngh = random.Random(424242)
var th = 0
while th < 120:
    var sz = rngh.randint(0, 18)
    var xs = []
    var k = 0
    while k < sz:
        xs.append(rngh.randint(0, 7))
        k = k + 1
    var want = rngh.randint(0, sz + 3)
    var asc = sorted(xs)
    var desc = sorted(xs, None, True)
    var cap = want if want < sz else sz
    ok(hq.nsmallest(want, xs) == asc[0:cap], "fuzz: nsmallest == sorted asc prefix")
    ok(hq.nlargest(want, xs) == desc[0:cap], "fuzz: nlargest == sorted desc prefix")
    th = th + 1
# heapify returns a NEW list; mutating the heap leaves the source intact.
var hsrc = [3, 1, 2]
var hnew = hq.heapify(hsrc)
hnew[0] = 999
ok(hsrc == [3, 1, 2], "heapify returns a new list (source untouched after mutation)")
# heappush returns None; nsmallest does not consume its argument.
ok(hq.heappush([], 5) == None, "heappush returns None")
var nssrc = [4, 2, 6, 1]
discard hq.nsmallest(2, nssrc)
ok(nssrc == [4, 2, 6, 1], "nsmallest does not mutate its input")
# heapreplace on a heap where the new item exceeds the whole heap: old min out, new item sinks.
var hr = hq.heapify([1, 2, 3])
ok(hq.heapreplace(hr, 100) == 1, "heapreplace returns the old min even for a large new item")
ok(hr[0] == 2 and sorted(hr) == [2, 3, 100], "heapreplace re-establishes the min and keeps the new item")
# merge over Strings; merge tolerates an unsorted input (full re-heap); merge of an empty sublist.
ok(hq.merge([["b", "d"], ["a", "c"]]) == ["a", "b", "c", "d"], "merge over Strings")
ok(hq.merge([[3, 1], [2, 0]]) == [0, 1, 2, 3], "merge re-sorts even unsorted inputs")
ok(hq.merge([[5], [], [1, 3]]) == [1, 3, 5], "merge with an empty sublist")
# nlargest/nsmallest keyword args (signature is (n, items)).
ok(hq.nlargest(n = 2, items = [5, 1, 9, 3]) == [9, 5], "nlargest n=/items= kwargs")
ok(hq.nsmallest(n = 2, items = [5, 1, 9, 3]) == [1, 3], "nsmallest n=/items= kwargs")
# nlargest does NOT accept a Python-style key kwarg; a mixed non-comparable heap throws.
ok(throws(Function(): return hq.nlargest(2, [[1, 5]], key = Function(p): return p[1])), "nlargest rejects a key kwarg")
ok(throws(Function(): return hq.heapify([1, "a"])), "heapify of mixed non-comparable types throws")

# ===================================================================== bisect: fresh edges
# Float lists: interior position and a key equal to an existing element.
var fa = [1.0, 2.0, 3.0, 4.0]
ok(bi.bisectleft(fa, 2.5) == 2, "bisectleft Float interior")
ok(bi.bisectleft(fa, 2.0) == 1 and bi.bisectright(fa, 2.0) == 2, "bisectleft/right around an existing Float")
# bisectright - bisectleft == multiplicity over a duplicate run.
var dups = [1, 5, 5, 5, 9]
ok(bi.bisectright(dups, 5) - bi.bisectleft(dups, 5) == 3, "right - left == multiplicity of the key")
# bisect* do not mutate; insort returns None and keeps the list sorted; left vs right on a run.
var bImm = [10, 20, 30]
discard bi.bisectleft(bImm, 25)
ok(bImm == [10, 20, 30], "bisect* does not mutate its argument")
var insA = [1, 3, 5]
ok(bi.insort(insA, 4) == None and insA == [1, 3, 4, 5], "insort returns None and keeps sorted")
var insL = [1, 2, 2, 3]
bi.insortleft(insL, 2)
ok(insL == [1, 2, 2, 2, 3], "insortleft inserts before the equal run")
var insR = [1, 2, 2, 3]
bi.insortright(insR, 2)
ok(insR == [1, 2, 2, 2, 3], "insortright inserts after the equal run")
# The bare aliases ARE the *right variants (same function object).
ok(id(bi.bisect) == id(bi.bisectright) and id(bi.insort) == id(bi.insortright), "bisect/insort are the *right aliases")
# Returns are Integers; empty list -> 0.
ok(type(bi.bisectleft([1, 2], 1)) == "Integer", "bisect returns Integer")
ok(bi.bisectleft([], 5) == 0 and bi.bisectright([], 5) == 0, "bisect of empty -> 0")
# kwargs.
ok(bi.bisectleft(a = [1, 3, 3, 5], x = 3) == 1 and bi.bisectright(a = [1, 3, 3, 5], x = 3) == 3, "bisect a=/x= kwargs")
# Python-only spellings / lo-hi bounds are absent -> throw.
ok(throws(Function(): return bi.bisect_left([1, 2, 3], 2)), "no bisect_left underscore name")
ok(throws(Function(): return bi.bisectleft([1, 2, 3, 4, 5], 3, 1, 4)), "bisectleft takes no lo/hi bounds")
# insort fuzz: a fixed-seed sweep stays sorted and grows by exactly one (fresh seed 909090).
var rngb = random.Random(909090)
var big = []
var bi2 = 0
while bi2 < 300:
    big.append(bi2)
    bi2 = bi2 + 1
var inserts = 0
while inserts < 250:
    bi.insort(big, rngb.randint(-50, 350))
    inserts = inserts + 1
var stillSorted = True
var si = 1
while si < len(big):
    if big[si - 1] > big[si]:
        stillSorted = False
    si = si + 1
ok(stillSorted, "insort fuzz keeps the list sorted")
ok(len(big) == 550, "insort fuzz: every call appended exactly one element")

# ===================================================================== copy: fresh edges
# Empty containers: copy and deepcopy produce equal-but-distinct empties.
var eL = []
ok(cp.copy(eL) == [] and id(cp.copy(eL)) != id(eL), "copy of [] is a fresh empty list")
ok(cp.deepcopy({}) == {} and cp.deepcopy(Set()) == Set(), "deepcopy of empty Dict/Set")
# deepcopy with Integer Dict keys preserved + deep independence.
var di = {1: [1], 2: [2]}
var dic = cp.deepcopy(di)
dic[1].append(9)
ok(di[1] == [1] and dic[1] == [1, 9], "deepcopy with Integer keys is deeply independent")
# deepcopy preserves a shared INNER-DICT reference (mapped once).
var innerD = {"x": 1}
var holderD = {"a": innerD, "b": innerD}
var holderDc = cp.deepcopy(holderD)
ok(id(holderDc["a"]) == id(holderDc["b"]), "deepcopy maps a shared inner dict to one copy")
ok(id(holderDc["a"]) != id(innerD), "the deepcopied inner dict is fresh")
# Shallow copy of a list shares the nested lists.
var shOrig = [[1], [2]]
var shCopy = cp.copy(shOrig)
shCopy[0].append(99)
ok(shOrig[0] == [1, 99], "shallow copy shares the nested lists")
# deepcopy of a Set of immutables is equal and independent.
var setO = Set([10, 20, 30])
var setC = cp.deepcopy(setO)
ok(setC == Set([10, 20, 30]) and id(setC) != id(setO), "deepcopy of a Set is equal but independent")
# Scalars (incl. Bytes) round-trip through copy and deepcopy unchanged.
ok(cp.copy(Bytes([1, 2, 3])) == Bytes([1, 2, 3]), "copy of Bytes")
ok(cp.deepcopy(Bytes([1, 2, 3])) == Bytes([1, 2, 3]), "deepcopy of Bytes")
ok(cp.copy(7) == 7 and cp.deepcopy(3.5) == 3.5 and cp.copy(None) == None, "copy/deepcopy of scalars")
# deepcopy of a deeply nested Dict-in-List-in-Dict is independent at the floor.
var deepNest = {"a": [{"b": [1]}]}
var deepNestC = cp.deepcopy(deepNest)
deepNestC["a"][0]["b"].append(2)
ok(deepNest["a"][0]["b"] == [1] and deepNestC["a"][0]["b"] == [1, 2], "deepcopy is independent at the deepest level")
# deepcopy is cycle-safe (a self-referential list).
var cyc = [1]
cyc.append(cyc)
var cycC = cp.deepcopy(cyc)
ok(len(cycC) == 2 and id(cycC[1]) == id(cycC) and id(cycC) != id(cyc), "deepcopy reconstructs a self-cycle")
# copy kwargs.
ok(cp.copy(obj = [1, 2]) == [1, 2] and cp.deepcopy(obj = {"k": [1]})["k"] == [1], "copy/deepcopy obj= kwarg")

# ===================================================================== enum: fresh edges
# DUPLICATE names are now REJECTED at construction (previously they silently overwrote the earlier
# ordinal, leaving get/nameof disagreeing and values() no longer 0..n-1 — a silent-corruption bug).
var dupThrew = False
try:
    discard en.Enum(["A", "A", "B"])
catch String as de:
    dupThrew = "duplicate enum member: A" in de
ok(dupThrew, "enum duplicate name is rejected with a clear error")
# Integer member names work (any hashable name).
var IntE = en.Enum([10, 20, 30])
ok(IntE.get(20) == 1 and IntE.nameof(2) == 30, "enum with Integer member names")
ok((10 in IntE) == True and (99 in IntE) == False, "enum membership with Integer names")
# Empty enum.
var Empty = en.Enum([])
ok(Empty.names() == [] and Empty.values() == [] and ("X" in Empty) == False, "empty enum has no members")
# Unknown name via get and via [] both throw; the [] path carries the documented message.
ok(throws(Function(): return en.Enum(["A"]).get("ZZ")), "enum get of an unknown name throws")
var enumMsg = ""
try:
    discard en.Enum(["A"])["ZZ"]
catch as e:
    enumMsg = e
ok("no such enum member" in enumMsg, "enum [] of an unknown name carries the documented message")
# nameof of an unknown value throws (a Dict key-miss).
ok(throws(Function(): return en.Enum(["A", "B"]).nameof(99)), "enum nameof of an unknown value throws")
# names() returns a DEFENSIVE copy; values() rebuilds each call.
var KwE = en.Enum(names = ["P", "Q", "R"])
ok(KwE.get("R") == 2, "enum names= kwarg")
var nm = KwE.names()
nm.append("HACK")
ok(KwE.names() == ["P", "Q", "R"], "enum names() returns a defensive copy")

# ===================================================================== inspect of each module
ok(len(inspect(it)) > 0 and "chain" in inspect(it), "inspect itertools non-empty + mentions chain")
ok(len(inspect(ft)) > 0 and "reduce" in inspect(ft), "inspect functools non-empty + mentions reduce")
ok(len(inspect(co)) > 0 and "deque" in inspect(co), "inspect collections non-empty + mentions deque")
ok(len(inspect(st)) > 0 and "quantiles" in inspect(st), "inspect statistics non-empty + mentions quantiles")
ok(len(inspect(hq)) > 0 and "heapify" in inspect(hq), "inspect heapq non-empty + mentions heapify")
ok(len(inspect(bi)) > 0 and "bisect" in inspect(bi), "inspect bisect non-empty + mentions bisect")
ok(len(inspect(cp)) > 0 and "deepcopy" in inspect(cp), "inspect copy non-empty + mentions deepcopy")
ok(len(inspect(en)) > 0 and "Enum" in inspect(en), "inspect enum non-empty + mentions Enum")
# inspect of an instance lists its methods (Counter shows mostcommon; Enum shows nameof).
ok("mostcommon" in inspect(co.Counter([1])), "inspect Counter instance lists mostcommon")
ok("nameof" in inspect(en.Enum(["A"])), "inspect Enum instance lists nameof")

io.print("r8_kimods_a: " + String(n) + " checks passed")
