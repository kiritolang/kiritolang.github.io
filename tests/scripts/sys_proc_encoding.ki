# sys_proc_encoding.ki — argv encoding + binary stdin/stdout/stderr fidelity through sys.createprocess.
# CROSS-PLATFORM by construction: every assertion is an exact round-trip that must hold identically on
# Linux AND Windows (run under wine in CI). It is the regression net for the two Windows fixes:
#   * the std streams are opened in BINARY mode (no '\n'<->"\r\n" translation, no Ctrl-Z/0x1A EOF), so
#     io.read()/io.write() of control/NUL bytes round-trip exactly;
#   * argv is rebuilt as UTF-8 from the wide command line, so non-ASCII / astral arguments survive the
#     UTF-8 <-> UTF-16 trip instead of being mangled by the ANSI codepage.
# The child is always `ki` itself (path.executable) running a generated helper, so this is portable.
# Args are returned NUL-joined (a NUL can never appear inside an OS argv element) so an argument may
# contain ANY other byte — spaces, newlines, quotes, Unicode — without ambiguity.
var io = import("io")
var path = import("path")
var sys = import("sys")
var random = import("random")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1

var KI = path.executable
var DIR = path.gettempdir()
var helper = path.join(DIR, "sysproc_enc_helper.ki")
var src = r"""var io = import("io")
var m = arglist[0] if len(arglist) >= 1 else ""
if m == "echo":
    io.write(io.read())
elif m == "echoerr":
    io.write(io.read(), stream = io.stderr)
elif m == "argsraw":
    var parts = []
    var i = 1
    while i < len(arglist):
        parts.append(arglist[i])
        i = i + 1
    io.write(chr(0).join(parts))
elif m == "argcount":
    io.write(String(len(arglist) - 1))
"""
var fh = io.open(helper, "w")
discard fh.write(src)
fh.close()

# round-trip a List of String args through the child's argv; returns the List the child actually saw
var argvRoundtrip = Function(testargs):
    if len(testargs) == 0:
        return []
    return sys.createprocess([KI, helper, "argsraw"] + testargs)["stdout"].split(chr(0))
var argCount = Function(testargs):
    return Integer(sys.createprocess([KI, helper, "argcount"] + testargs)["stdout"])
# echo a payload through stdin -> stdout (and a stderr variant)
var echo = Function(payload):
    return sys.createprocess([KI, helper, "echo"], input = payload)["stdout"]
var echoErr = Function(payload):
    return sys.createprocess([KI, helper, "echoerr"], input = payload)["stderr"]

# ============================================================ ARGV: fixed encoding cases
ok(argvRoundtrip(["hello", "world"]) == ["hello", "world"], "ascii args round-trip")
ok(argvRoundtrip(["über", "café", "ñ", "ÿ"]) == ["über", "café", "ñ", "ÿ"], "latin-1 args round-trip")
ok(argvRoundtrip(["Ł", "œ", "ß", "Ǝ"]) == ["Ł", "œ", "ß", "Ǝ"], "latin-extended args round-trip")
ok(argvRoundtrip(["你好", "こんにちは", "한국어", "Привет"]) == ["你好", "こんにちは", "한국어", "Привет"], "cjk/cyrillic args round-trip")
ok(argvRoundtrip([chr(128512), chr(128169), chr(127464) + chr(127465)]) == [chr(128512), chr(128169), chr(127464) + chr(127465)], "astral/emoji args round-trip (UTF-16 surrogate pairs)")
ok(argvRoundtrip(["a你b" + chr(128512) + "cüd"]) == ["a你b" + chr(128512) + "cüd"], "mixed-script single arg round-trips")
ok(argvRoundtrip(["", "x", ""]) == ["", "x", ""], "empty args preserved in position")
ok(argvRoundtrip(["  ", "\t", " a b "]) == ["  ", "\t", " a b "], "whitespace-only / spaced args verbatim")
ok(argvRoundtrip(["a b c", "with\"quote", "back\\slash", "$HOME", "*", "a;b|c&d"]) == ["a b c", "with\"quote", "back\\slash", "$HOME", "*", "a;b|c&d"], "shell metacharacters are literal (no shell)")
# a single argument may even contain a newline (a NUL cannot, which is why NUL is the separator)
ok(argvRoundtrip(["line1\nline2", "tab\there"]) == ["line1\nline2", "tab\there"], "arg with an embedded newline round-trips")
# a long Unicode argument
var longArg = "ü" * 5000
ok(argvRoundtrip([longArg]) == [longArg], "5000-codepoint Unicode arg round-trips")
# many arguments, none dropped or split
var many = []
var mi = 0
while mi < 60:
    many.append("arg" + String(mi) + "_你" + chr(128512))
    mi = mi + 1
ok(argvRoundtrip(many) == many, "60 Unicode args all round-trip")
ok(argCount(many) == 60, "60 args arrive as exactly 60 (none split/merged)")
ok(argCount(["a b c", "d  e"]) == 2, "spaced args are not split into more arguments")

# ============================================================ ARGV: fuzz (random Unicode strings)
# code-point ranges spanning ASCII, Latin-1, Latin-Extended, Cyrillic, CJK and astral emoji; NUL and
# the surrogate range are excluded (NUL can't live in argv; surrogates aren't scalar values).
var ranges = [[32, 126], [160, 255], [256, 383], [0x400, 0x44F], [0x4E00, 0x4E80], [0x1F600, 0x1F640]]
var rng = random.Random(20260629)
var pickCp = Function():
    var r = ranges[rng.randint(0, len(ranges) - 1)]
    return chr(rng.randint(r[0], r[1]))
var fa = 0
while fa < 50:
    var k = rng.randint(1, 5)
    var fuzzargs = []
    var j = 0
    while j < k:
        var s = ""
        var t = 0
        var lenA = rng.randint(0, 10)
        while t < lenA:
            s = s + pickCp()
            t = t + 1
        fuzzargs.append(s)
        j = j + 1
    ok(argvRoundtrip(fuzzargs) == fuzzargs, "fuzz argv round-trip #" + String(fa))
    fa = fa + 1

# ============================================================ STDIN/STDOUT: control-byte fidelity
ok(echo("a" + chr(0) + "b") == "a" + chr(0) + "b", "embedded NUL round-trips")
ok(echo(chr(0) + chr(0) + chr(0)) == chr(0) + chr(0) + chr(0), "leading/only NUL bytes round-trip")
ok(echo("a" + chr(26) + "b") == "a" + chr(26) + "b", "Ctrl-Z (0x1A) is data, NOT a stdin EOF (binary mode)")
ok(echo("x" + chr(26)) == "x" + chr(26), "trailing Ctrl-Z preserved (no truncation)")
ok(echo("a" + chr(13) + "b") == "a" + chr(13) + "b", "lone CR (0x0D) is not translated")
ok(echo("a" + chr(10) + "b") == "a" + chr(10) + "b", "lone LF (0x0A) is not expanded to CRLF")
ok(echo("a" + chr(13) + chr(10) + "b") == "a" + chr(13) + chr(10) + "b", "CRLF passes through unchanged")
ok(echo("a" + chr(10) + chr(13) + "b") == "a" + chr(10) + chr(13) + "b", "LF-CR (reversed) passes through unchanged")
# every C0 control byte 0..31 plus DEL and a few high code points
var ctrl = ""
var ci = 0
while ci < 32:
    ctrl = ctrl + chr(ci)
    ci = ci + 1
ctrl = ctrl + chr(127) + chr(128) + chr(255)
ok(echo(ctrl) == ctrl, "all C0 control bytes (0..31) + DEL + high round-trip")
ok(len(echo(ctrl)) == len(ctrl), "control-byte payload length is preserved exactly")
# a large payload sprinkled with the dangerous bytes
var big = ("x" + chr(0) + chr(26) + chr(10) + chr(13) + "你") * 20000
var bigOut = echo(big)
ok(len(bigOut) == len(big), "120k-codepoint control-laden payload: exact length")
ok(bigOut == big, "120k-codepoint control-laden payload: exact bytes")

# ============================================================ STDIN: fuzz (random control + Unicode)
var fp = 0
while fp < 30:
    var plen = rng.randint(0, 600)
    var data = ""
    var q = 0
    while q < plen:
        var pick = rng.randint(0, 4)
        if pick == 0:
            data = data + chr(rng.randint(0, 31))      # a C0 control byte (incl. NUL/CR/LF/Ctrl-Z)
        elif pick == 1:
            data = data + pickCp()                      # any Unicode code point from the pool
        else:
            data = data + chr(rng.randint(32, 126))     # printable ASCII
        q = q + 1
    ok(echo(data) == data, "fuzz stdin control/Unicode round-trip #" + String(fp))
    fp = fp + 1

# ============================================================ STDERR fidelity + edges
ok(echoErr("e" + chr(0) + chr(10) + "你" + chr(26)) == "e" + chr(0) + chr(10) + "你" + chr(26), "stderr carries control/Unicode bytes exactly")
ok(echo("") == "", "empty stdin -> empty stdout")
# binary output and a nonzero exit code coexist (the capture is independent of the exit status)
var both = sys.createprocess([KI, helper, "echo"], input = "p" + chr(0) + "q")
ok(both["stdout"] == "p" + chr(0) + "q" and both["code"] == 0, "binary stdout captured alongside the exit code")

# ============================================================ RAW BYTES: Bytes input + binary=True output
# A `Bytes` input is fed to stdin VERBATIM (not UTF-8-re-encoded the way a String is), and
# `binary=True` returns stdout/stderr as raw `Bytes`. This is the ONLY faithful path for arbitrary
# binary through a NON-Kirito tool: a String built from `Bytes.decode()` would balloon every byte
# >= 0x80 into a multi-byte UTF-8 sequence and corrupt a binary consumer. The `ki` echo helper is
# byte-transparent, so a Bytes -> Bytes round-trip is exact even here.
var rawEcho = Function(b):
    return sys.createprocess([KI, helper, "echo"], input = b, binary = True)["stdout"]
var rawEchoErr = Function(b):
    return sys.createprocess([KI, helper, "echoerr"], input = b, binary = True)["stderr"]
# high bytes (0x80-0xFF) + control bytes + invalid-UTF-8 sequences that String mode would mangle
var binpayload = Bytes([255, 128, 195, 40, 0, 65, 10, 13, 26, 254, 192, 191])
ok(type(rawEcho(binpayload)) == "Bytes", "binary=True returns Bytes")
ok(rawEcho(binpayload) == binpayload, "Bytes input + binary output round-trips byte-exact")
ok(rawEcho(Bytes([])) == Bytes([]), "empty Bytes round-trips")
ok(rawEchoErr(binpayload) == binpayload, "binary stderr is byte-exact too")
# a String input with binary output comes back as its UTF-8 storage bytes (pure ASCII: same bytes)
ok(sys.createprocess([KI, helper, "echo"], input = "AB", binary = True)["stdout"] == Bytes([65, 66]), "String input + binary output = its UTF-8 bytes")
# a large binary payload (a PNG signature, repeated) survives exactly
var bigbin = Bytes([137, 80, 78, 71, 13, 10, 26, 10]) * 10000
ok(rawEcho(bigbin) == bigbin, "80k-byte binary payload round-trips exactly")
# default (no binary=) still returns a String — back-compat
ok(type(sys.createprocess([KI, helper, "echo"], input = "z")["stdout"]) == "String", "default output stays a String")

discard path.remove(helper, missing_ok = True)
io.print("sys_proc_encoding: " + String(n) + " checks passed")
