# Arithmetic, precedence, and numeric semantics.
var io = import("io")

io.print(1 + 2 * 3)          # 7
io.print((1 + 2) * 3)        # 9
io.print(2 ** 3 ** 2)        # 512 (right-assoc)
io.print(-2 ** 2)            # -4
io.print(7 // 2)             # 3
io.print(-7 // 2)            # -4
io.print(7 % 3)              # 1
io.print(-7 % 3)             # 2
io.print(7 / 2)              # 3.5 (always Float)
io.print(2 * 1.5)            # 3.0
io.print(10 == 10.0)         # True
io.print(3 < 4 and 4 < 5)    # True
