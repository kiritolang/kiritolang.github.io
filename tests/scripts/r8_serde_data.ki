# r8_serde_data.ki — ROUND-8 exhaustive re-audit of Kirito's data-serialization & compression stdlib:
#   time / json / serialize / dump / zlib / gzip / hash
# against docs/pages/10-stdlib.md and the implementations
#   (stdlib_time.hpp, stdlib_json.hpp, stdlib_serde.hpp [shared flatten/rebuild],
#    stdlib_serialize.hpp [text codec], stdlib_dump.hpp [binary codec], stdlib_zlib.hpp,
#    stdlib_gzip.hpp, stdlib_hash.hpp, deflate.hpp).
#
# Deliberately NON-OVERLAPPING with r7_serde_data / r6_serde / r6_json / r6_hash / r6_compress /
# r6_time / r5_serde / deep_serialization / probe_serde_fuzz. Fresh angles this round:
#   - hash: FRESH known-answer vectors ("kirito", "Hello, World!") cross-checked against a reference
#     implementation (not the "abc"/"123456789"/"fox" vectors the earlier rounds pin).
#   - json: deeply-nested OBJECT depth guard (earlier rounds used arrays); duplicate-key last-wins;
#     Integer/Float Dict keys emit their str() token; nested-list-in-object pretty structure; a Float
#     with an integral value stays a Float across a round-trip.
#   - serialize/dump: SYSTEMATIC byte-mutation fuzz of a rich blob — every single-byte position swept,
#     plus multi-byte random flips, truncations and random-extension — each decode must throw OR
#     succeed, never crash (the headline ask; no prior test does per-position sweep). Hand-crafted
#     hostile blobs that exercise the count*2 / name-length / child-id / root-id bounds paths.
#   - gzip: CRAFTED streams that exercise the FEXTRA / FNAME / FCOMMENT / FHCRC optional-field skipping
#     in the decoder (every prior gzip test uses FLG=0, so that path was untested); truncated-FEXTRA.
#   - time: FRESH fixed instant; make() Float-component rejection; the exact representable-epoch
#     boundary (9999-12-31T23:59:59 ok, +1s throws); format("") / literal %% / unknown directive;
#     single-digit strptime field tolerance; fractional-Float add truncation; negative (proleptic) year.
#
# HARD: exit 0, exactly one stdout line, ZERO stderr (every dropped value is `discard`-ed; no unused
# locals; no warnings), DETERMINISTIC (the only RNG is a fixed seed; no clock/network value is asserted
# — only invariants; scratch files removed). Self-checking: each ok(cond,msg) increments a counter.

var io = import("io")
var path = import("path")
var json = import("json")
var serialize = import("serialize")
var dump = import("dump")
var zlib = import("zlib")
var gzip = import("gzip")
var hash = import("hash")
var time = import("time")
var math = import("math")
var sys = import("sys")
var random = import("random")
var matrix = import("matrix")
var complex = import("complex")
var tensor = import("tensor")
var net = import("net")
var regex = import("regex")

var n = 0
var ok = Function(c, m):
    assert c, m
    n = n + 1
# True iff f() thrown a catchable error (a clean diagnostic, never a crash).
var throws = Function(f):
    try:
        discard f()
        return False
    catch:
        return True
# Bytes -> List of Integers (for byte-level mutation).
var bytesToList = Function(b):
    var l = []
    var i = 0
    while i < len(b):
        discard l.append(b[i])
        i = i + 1
    return l

# =====================================================================================  hash
# FRESH known-answer digests/checksums (cross-checked against a reference implementation), distinct
# from the "abc"/"fox"/"123456789"/"Wikipedia"/"message digest" vectors pinned by r5/r6/r7.
ok(hash.md5("kirito") == "4e3a77ce388ff804ba20ab589fc6069d", "md5 kirito KAT")
ok(hash.sha1("kirito") == "e92f236741dc5e9a0d3501b09086c8aa4ad05534", "sha1 kirito KAT")
ok(hash.sha256("kirito") == "9c69a0b72b442ccac3e6aaaa7630d12f2b351fe395e9fe667efa0907cde90da5", "sha256 kirito KAT")
ok(hash.adler32("kirito") == 149881491, "adler32 kirito KAT")
ok(hash.crc32("kirito") == 1472009093, "crc32 kirito KAT")
ok(hash.crc64("kirito") == 4628181147489648822, "crc64 kirito KAT (positive)")
ok(hash.md5("Hello, World!") == "65a8e27d8879283831b664bd8b7f0ad4", "md5 Hello World KAT")
ok(hash.sha256("Hello, World!") == "dffd6021bb2bd5b0af676290809ec3a53191dd81c7f70a4b28688a362182986f", "sha256 Hello World KAT")
ok(hash.crc32("Hello, World!") == 3964322768, "crc32 Hello World KAT")
ok(hash.crc64("Hello, World!") == 2884049718812637996, "crc64 Hello World KAT")
# crc64 negative-on-top-bit vector (documented signed Integer) — the standard XZ check value.
ok(hash.crc64("123456789") == -7395533204333446662, "crc64 123456789 negative signed")
ok(hash.crc64("123456789") < 0, "crc64 top-bit -> negative")
# String == latin-1 Bytes digest for these fresh inputs.
ok(hash.sha256("kirito") == hash.sha256("kirito".encode("latin-1")), "sha256 kirito str==bytes")
ok(hash.crc64("Hello, World!") == hash.crc64("Hello, World!".encode("latin-1")), "crc64 Hello World str==bytes")
# A long repeated input still digests to a fixed-width digest (no overflow on a large message).
var bigMsg = "kirito" * 100000
ok(len(hash.sha256(bigMsg)) == 64, "sha256 of 600KB message is 64 hex")
ok(len(hash.md5(bigMsg)) == 32, "md5 of 600KB message is 32 hex")
ok(hash.sha256(bigMsg) == hash.sha256(bigMsg), "sha256 deterministic on large input")
# Flipping one byte changes the digest (avalanche sanity).
ok(hash.sha256("kirito") != hash.sha256("kiritp"), "sha256 one-char change differs")
ok(hash.crc32("kirito") != hash.crc32("kiritp"), "crc32 one-char change differs")
# kwargs.
ok(hash.sha1(data = "kirito") == hash.sha1("kirito"), "hash sha1 kwarg data")
ok(hash.adler32(data = "kirito") == hash.adler32("kirito"), "hash adler32 kwarg data")
# Non-String/Bytes throws.
ok(throws(Function(): return hash.sha256([1, 2])), "hash rejects a List")
ok(throws(Function(): return hash.crc64(None)), "hash rejects None")

# =====================================================================================  json
# Deeply-nested OBJECT depth guard (earlier rounds exercised arrays; this drives the object() path).
var deepObj = ""
var dj = 0
while dj < 1100:
    deepObj = deepObj + "{\"k\":"
    dj = dj + 1
ok(throws(Function(): return json.parse(deepObj)), "json deep object nesting throws (depth guard)")
# A balanced deep object also throws (open + close, still over the limit).
ok(throws(Function(): return json.parse("{\"a\":" * 1100 + "1" + "}" * 1100)), "json deep balanced object throws")
# Duplicate keys: the last value wins (documented Dict semantics).
ok(json.parse("{\"a\":1,\"a\":2,\"a\":3}")["a"] == 3, "json duplicate key -> last wins")
ok(len(json.parse("{\"a\":1,\"a\":2}")) == 1, "json duplicate key collapses to one entry")
# Integer / Float / Bool / None Dict keys emit a canonical token (outside strict JSON but valid).
ok(json.dumps({5: "v"}) == "{\"5\": \"v\"}", "json Integer key -> str token")
ok(json.dumps({True: 1}) == "{\"true\": 1}", "json Bool key -> true token")
ok(json.dumps({None: 1}) == "{\"null\": 1}", "json None key -> null token")
# A Float with an integral value stays a Float across a round-trip (Integer/Float distinction kept).
ok(type(json.loads(json.dumps(5.0))) == "Float", "json 5.0 stays Float on round-trip")
ok(json.loads(json.dumps(5.0)) == 5.0, "json 5.0 value preserved")
ok(type(json.loads(json.dumps(5))) == "Integer", "json 5 stays Integer")
# Nested list inside an object pretty-prints with correct two-level padding.
ok(json.dumps({"a": [1]}, indent = 2) == "{\n  \"a\": [\n    1\n  ]\n}", "json pretty nested list in object")
# Nested object inside a list pretty-prints correctly.
ok(json.dumps([{"x": 1}], indent = 2) == "[\n  {\n    \"x\": 1\n  }\n]", "json pretty object in list")
# A big nested mixed structure round-trips through pretty-print unchanged.
var jbig = {"a": [1, 2, {"b": [3, [4, 5]], "c": None}], "d": True, "e": "text", "f": 1.25}
ok(json.loads(json.dumps(jbig, indent = 3)) == jbig, "json big nested pretty round-trip")
# Leading whitespace (tab/newline) before a scalar is tolerated.
ok(json.parse("\t\n  -7") == -7, "json leading whitespace before scalar")
# INT64 boundaries: exactly max stays Integer; one past max widens to Float (documented).
ok(json.parse("9223372036854775807") == 9223372036854775807, "json INT64_MAX exact")
ok(type(json.parse("9223372036854775807")) == "Integer", "json INT64_MAX is Integer")
ok(type(json.parse("9223372036854775808")) == "Float", "json INT64_MAX+1 widens to Float")
# Malformed forms not exhaustively covered earlier this way.
ok(throws(Function(): return json.parse("-")), "json bare minus throws")
ok(throws(Function(): return json.parse("+5")), "json leading plus throws")
ok(throws(Function(): return json.parse("[1] [2]")), "json two top-level values throw")
ok(throws(Function(): return json.parse("{\"a\":1 \"b\":2}")), "json missing comma in object throws")
ok(throws(Function(): return json.parse("[1 2]")), "json missing comma in array throws")
ok(throws(Function(): return json.parse("nan")), "json lowercase nan throws (only NaN token)")
ok(json.parse("\"\\ud800\\u0041\"") == chr(65533) + "A", "json high surrogate + BMP \\u -> U+FFFD + char")
# A raw control char inside a string is accepted (lenient); the writer re-escapes it (lossless).
ok(json.parse("\"x\ty\"") == "x\ty", "json raw tab in string accepted (lenient)")
var ctrlRt = "a" + chr(1) + chr(2) + chr(30) + "z"
ok(json.loads(json.dumps(ctrlRt)) == ctrlRt, "json control chars re-escape + round-trip")
ok("\\u0001" in json.dumps(ctrlRt), "json U+0001 emitted escaped")
# kwargs.
ok(json.stringify(value = [1, 2], indent = 2) == "[\n  1,\n  2\n]", "json stringify value+indent kwargs")
ok(json.parse(text = "{\"z\":9}")["z"] == 9, "json parse text kwarg")

# =====================================================================================  serialize + dump
# Helper: round-trips identically through BOTH the text and binary codecs (Kirito == is deep).
var bothEq = Function(v):
    return serialize.loads(serialize.dumps(v)) == v and dump.loads(dump.dumps(v)) == v
# A fresh nontrivial graph (distinct from earlier rounds' inputs).
ok(bothEq({"alpha": [1, -2, 3.5], "beta": Set(["x", "y", "z"]), "gamma": None, "delta": False}), "serde fresh nested graph")
ok(bothEq(Bytes([7, 0, 255, 13, 10, 32, 9])), "serde Bytes with separator-ish bytes")
# A String whose CONTENT looks like a serialize header must round-trip verbatim (length-prefix guards it).
var headerLike = "KSER1 42 X I 99 garbage payload"
ok(serialize.loads(serialize.dumps(headerLike)) == headerLike, "serialize String content mimicking header round-trips")
ok(serialize.loads(serialize.dumps("L 3 0 1 2")) == "L 3 0 1 2", "serialize String mimicking a list record round-trips")
# A String with embedded newlines + double spaces (text codec uses a length prefix, not whitespace split).
ok(serialize.loads(serialize.dumps("a\n\nb  c\td")) == "a\n\nb  c\td", "serialize String w/ newlines+spaces+tab")
# dump.loads accepts the Bytes blob directly; a latin-1 byte-transparent String of it also works.
var blob42 = dump.dumps({"v": [1, 2, 3]})
ok(dump.loads(blob42)["v"][2] == 3, "dump.loads on Bytes blob")
ok(dump.loads(blob42.decode("latin-1"))["v"][2] == 3, "dump.loads on byte-transparent String")
# Wrapping a binary blob in String() (UTF-8) corrupts it -> throws (documented warning).
var binBlob = dump.dumps(Bytes([200, 201, 202]))
ok(throws(Function(): return dump.loads(String(binBlob))), "dump.loads(String(blob)) corrupts -> throws")

# A class whose attribute VALUES are themselves containers + shared references.
class Graph:
    var _init_ = Function(self, nodes, edges):
        self.nodes = nodes
        self.edges = edges
var shared = {"id": 1}
var gobj = Graph([shared, shared], {"e": shared})
var dg = dump.loads(dump.dumps(gobj))
ok(dg.nodes[0]["id"] == 1 and id(dg.nodes[0]) == id(dg.nodes[1]), "dump class w/ shared container attrs")
ok(id(dg.nodes[0]) == id(dg.edges["e"]), "dump shared ref across distinct attributes")
var sg = serialize.loads(serialize.dumps(gobj))
ok(id(sg.nodes[0]) == id(sg.edges["e"]), "serialize shared ref across attributes")

# Native value types nested + shared (fresh shapes; distinct from r6/r7 instances).
var m3 = matrix.identity(3)
var c2 = complex.of(2.0, -3.0)
var t2 = tensor.Tensor([[5.0, 6.0], [7.0, 8.0]])
var dt2 = time.make(2030, 12, 31, 23, 59, 58)
var natGraph = {"m": m3, "c": c2, "t": t2, "when": [dt2, dt2]}
var dn = dump.loads(dump.dumps(natGraph))
ok(dn["m"] == m3 and dn["c"] == c2 and dn["t"] == t2, "dump native values in a dict")
ok(dn["when"][0] == dt2 and id(dn["when"][0]) == id(dn["when"][1]), "dump shared DateTime in a list")
var snat = serialize.loads(serialize.dumps(natGraph))
ok(snat["m"] == m3 and snat["c"] == c2 and snat["t"] == t2 and snat["when"][1] == dt2, "serialize native values agree")

# Random restores the EXACT stream after several draws (fresh seed; checkpoint test).
var rsrc = random.Random(0xBEEF)
discard rsrc.randint(0, 9)
discard rsrc.gauss(0.0, 1.0)
discard rsrc.random()
var rcopy = dump.loads(dump.dumps(rsrc))
ok(rsrc.random() == rcopy.random(), "dump Random continues identical stream")
ok(rsrc.randint(0, 1000000) == rcopy.randint(0, 1000000), "dump Random next draw also identical")

# Resource-like natives throw on BOTH codecs (never crash).
ok(throws(Function(): return dump.dumps(net.Socket())), "dump Socket throws")
ok(throws(Function(): return serialize.dumps(regex.compile("x*"))), "serialize regex Pattern throws")
ok(throws(Function(): return dump.dumps(io.BytesIO())), "dump BytesIO throws")
var rxm = regex.match("a", "a")
ok(throws(Function(): return dump.dumps(rxm)), "dump regex Match throws")
# A grad-tracking Tensor must not serialize; detach() makes it serializable.
var tg = tensor.ones([2, 3], requiresgrad = True)
ok(throws(Function(): return serialize.dumps(tg)), "serialize grad Tensor throws")
ok(dump.loads(dump.dumps(tg.detach())) == tg.detach(), "dump detached Tensor round-trips")

# ---- Hand-crafted HOSTILE binary blobs: every bounds path throws cleanly (no crash/OOB/over-alloc) ----
# (KDMP magic = 75 68 77 80, version = 1, then u32 objectCount little-endian, then records.)
# Dict (tag 6) with count 0x7FFFFFFF: the decoder's `count*2` must not overflow into a wild loop.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 6, 255, 255, 255, 127]))), "dump Dict count*2 overflow rejected")
# Dict with count 0xFFFFFFFF (count*2 wraps to 0xFFFFFFFE).
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 6, 255, 255, 255, 255]))), "dump Dict max count rejected")
# Object (tag 8) with a 0xFFFFFFFF name length (would over-allocate a string).
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 8, 255, 255, 255, 255]))), "dump Object huge name length rejected")
# String (tag 4) with a 0xFFFFFFFF byte length.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 4, 255, 255, 255, 255]))), "dump String huge length rejected")
# objectCount 0xFFFFFFFF far exceeds the data size -> rejected before allocating the node vector.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 255, 255, 255, 255]))), "dump objectCount > data rejected")
# rootId out of range: one None object (id 0), rootId = 5.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 0, 5, 0, 0, 0]))), "dump rootId out of range rejected")
# A List (tag 5) whose single child id (99) points past the table.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 5, 1, 0, 0, 0, 99, 0, 0, 0, 0, 0, 0, 0]))), "dump child id out of range rejected")
# A Stateful (tag 9) naming a class with no registered deserializer.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 9, 3, 0, 0, 0, 88, 89, 90, 0, 0, 0, 0]))), "dump Stateful unknown class rejected")
# An unknown tag byte (200) is rejected.
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 1, 1, 0, 0, 0, 200]))), "dump unknown tag rejected")
# Bad magic, empty, header-only, bad version.
ok(throws(Function(): return dump.loads(Bytes([1, 2, 3, 4]))), "dump bad magic rejected")
ok(throws(Function(): return dump.loads(Bytes([]))), "dump empty rejected")
ok(throws(Function(): return dump.loads(Bytes([75, 68, 77, 80, 99]))), "dump bad version rejected")
# Text codec hostile inputs: bad header, huge/negative counts, malformed numbers, truncated string len.
ok(throws(Function(): return serialize.loads("KSER1 -1 0")), "serialize negative count rejected")
ok(throws(Function(): return serialize.loads("KSER1 5000000000 0")), "serialize huge count rejected")
ok(throws(Function(): return serialize.loads("KSER1 1 S 999 x 0")), "serialize String len > data rejected")
ok(throws(Function(): return serialize.loads("KSER1 1 Z 0")), "serialize unknown tag rejected")
ok(throws(Function(): return serialize.loads("KSER1 1 I notanint 0")), "serialize malformed int rejected")
ok(throws(Function(): return serialize.loads("KSER1 1")), "serialize truncated (no records) rejected")

# ---- SYSTEMATIC byte-mutation FUZZ of a rich valid blob: never crash (throw or succeed) ----
class Pt2:
    var _init_ = Function(self, x, y):
        self.x = x
        self.y = y
var fuzzSample = {"i": -12345, "f": 2.71828, "s": "fuzz\nme", "n": None, "b": True,
                  "li": [1, [2, [3]]], "se": Set([9, 8]), "by": Bytes([0, 127, 255]),
                  "in": Pt2(4, 5), "mx": matrix.identity(2)}
var fuzzBlob = dump.dumps(fuzzSample)
var fuzzBase = bytesToList(fuzzBlob)
# Sweep every byte position with a spread of replacement values (every 37th value), then decode.
var sweepCount = 0
var pos = 0
while pos < len(fuzzBase):
    var v = 0
    while v < 256:
        var mut = []
        var k = 0
        while k < len(fuzzBase):
            discard mut.append(fuzzBase[k])
            k = k + 1
        mut[pos] = v
        discard throws(Function(): return dump.loads(Bytes(mut)))   # throw-or-succeed; must not crash
        sweepCount = sweepCount + 1
        v = v + 37
    pos = pos + 1
ok(sweepCount > 0, "dump single-byte sweep ran (no crash)")
# Every truncation of the valid blob: decode must not crash.
var trunc = 0
while trunc <= len(fuzzBase):
    discard throws(Function(): return dump.loads(fuzzBlob[0:trunc]))
    trunc = trunc + 1
ok(trunc == len(fuzzBase) + 1, "dump truncation sweep ran (no crash)")
# Random multi-byte flips + random extensions (fixed seed).
var frng = random.Random(8675309)
var fz = 0
while fz < 2500:
    var m2 = []
    var kk = 0
    while kk < len(fuzzBase):
        discard m2.append(fuzzBase[kk])
        kk = kk + 1
    var flips = frng.randint(1, 6)
    var ff = 0
    while ff < flips:
        m2[frng.randint(0, len(m2) - 1)] = frng.randint(0, 255)
        ff = ff + 1
    if frng.random() < 0.5:
        var ext = frng.randint(0, 24)
        var ee = 0
        while ee < ext:
            discard m2.append(frng.randint(0, 255))
            ee = ee + 1
    discard throws(Function(): return dump.loads(Bytes(m2)))
    fz = fz + 1
ok(fz == 2500, "dump random multi-flip+extend fuzz ran (no crash)")
# Random blobs, half prefixed with the valid magic to drive the record loop.
var rb = 0
while rb < 2500:
    var rl = frng.randint(0, 50)
    var bb = []
    if frng.random() < 0.5:
        bb = [75, 68, 77, 80, 1]
    var rr = 0
    while rr < rl:
        discard bb.append(frng.randint(0, 255))
        rr = rr + 1
    discard throws(Function(): return dump.loads(Bytes(bb)))
    rb = rb + 1
ok(rb == 2500, "dump random/magic-prefixed blob fuzz ran (no crash)")
# Text codec: random KSER1-prefixed token streams.
var ts = 0
while ts < 2000:
    var parts = ["KSER1"]
    var np = frng.randint(0, 14)
    var pp = 0
    while pp < np:
        var ch = frng.randint(0, 4)
        if ch == 0:
            discard parts.append(String(frng.randint(-50, 5000000000)))
        elif ch == 1:
            discard parts.append(chr(frng.randint(78, 90)))
        elif ch == 2:
            discard parts.append("I")
        elif ch == 3:
            discard parts.append("S")
        else:
            discard parts.append(String(frng.randint(0, 200)))
        pp = pp + 1
    var text = ""
    var jj = 0
    while jj < len(parts):
        if jj > 0:
            text = text + " "
        text = text + parts[jj]
        jj = jj + 1
    discard throws(Function(): return serialize.loads(text))
    ts = ts + 1
ok(ts == 2000, "serialize random token-stream fuzz ran (no crash)")
# After all that abuse the codecs still work correctly.
ok(dump.loads(dump.dumps(fuzzSample))["in"].x == 4, "dump healthy after fuzz")
ok(serialize.loads(serialize.dumps([1, 2, 3])) == [1, 2, 3], "serialize healthy after fuzz")

# File save/load round-trip on a fresh graph (scratch dir; cleaned up).
var sPath = path.join(path.gettempdir(), "r8_serde_text.kser")
var dPath = path.join(path.gettempdir(), "r8_serde_bin.kdmp")
discard serialize.save({"x": [None, True], "dt": dt2}, sPath)
ok(serialize.load(sPath)["dt"] == dt2, "serialize.save/load DateTime on disk")
discard dump.save({"y": Set([1, 2, 3]), "m": m3}, dPath)
ok(dump.load(dPath)["m"] == m3, "dump.save/load Matrix on disk")
ok(2 in dump.load(dPath)["y"], "dump.save/load Set member")
discard path.remove(sPath, missing_ok = True)
discard path.remove(dPath, missing_ok = True)
ok(throws(Function(): return dump.load(path.join(path.gettempdir(), "r8_no_such.kdmp"))), "dump.load missing file throws")
# Cross-format agreement on the fresh graph.
var ca = dump.loads(dump.dumps(natGraph))
var cs = serialize.loads(serialize.dumps(natGraph))
ok(ca["m"] == cs["m"] and ca["c"] == cs["c"] and ca["when"][0] == cs["when"][0], "serialize/dump agree on native graph")
# kwargs across the serde signatured functions.
ok(serialize.loads(text = serialize.dumps(value = [4, 5]))[1] == 5, "serialize kwargs value/text")
ok(dump.loads(data = dump.dumps(value = [6, 7]))[0] == 6, "dump kwargs value/data")

# =====================================================================================  zlib
# Round-trip String AND Bytes (fresh payloads), same TYPE out.
var zmsg = "kirito-rocks-" * 500
ok(zlib.decompress(zlib.compress(zmsg)) == zmsg, "zlib String round-trip")
ok(type(zlib.compress(zmsg)) == "String", "zlib String -> String")
var zby = zmsg.encode()
ok(zlib.decompress(zlib.compress(zby)) == zby, "zlib Bytes round-trip")
ok(type(zlib.compress(zby)) == "Bytes", "zlib Bytes -> Bytes")
ok(type(zlib.decompress(zlib.compress(zby))) == "Bytes", "zlib Bytes decompress -> Bytes")
# Empty.
ok(zlib.decompress(zlib.compress("")) == "", "zlib empty String round-trip")
ok(zlib.decompress(zlib.compress(Bytes([]))) == Bytes([]), "zlib empty Bytes round-trip")
# Raw deflate/inflate round-trip + type.
ok(zlib.inflate(zlib.deflate(zby)) == zby, "zlib raw deflate/inflate round-trip")
ok(type(zlib.deflate(zby)) == "Bytes", "zlib deflate Bytes -> Bytes")
# zlib stream and raw deflate are distinct, and neither decodes the other.
ok(zlib.compress(zmsg) != zlib.deflate(zmsg), "zlib stream != raw deflate")
ok(throws(Function(): return zlib.inflate(zlib.compress(zmsg))), "zlib inflate on a zlib stream throws")
ok(throws(Function(): return zlib.decompress(zlib.deflate(zmsg))), "zlib decompress on raw deflate throws")
# Corrupt data throws.
ok(throws(Function(): return zlib.decompress("garbage not a zlib stream")), "zlib decompress garbage throws")
ok(throws(Function(): return zlib.decompress(Bytes([]))), "zlib decompress empty throws")
ok(throws(Function(): return zlib.inflate(Bytes([254, 254, 254, 254]))), "zlib inflate garbage throws")
# Corrupted Adler-32 trailer throws.
var zc = zlib.compress(zby)
var zct = zc[0:len(zc) - 1] + Bytes([(zc[len(zc) - 1] + 1) % 256])
ok(throws(Function(): return zlib.decompress(zct)), "zlib corrupted trailer throws")
# Non-bytes argument throws.
ok(throws(Function(): return zlib.compress({})), "zlib rejects a Dict")
# kwargs.
ok(zlib.decompress(data = zlib.compress(data = "kw")) == "kw", "zlib kwargs data")

# =====================================================================================  gzip
# Round-trip String AND Bytes, same TYPE out (fresh payload).
ok(gzip.decompress(gzip.compress(zmsg)) == zmsg, "gzip String round-trip")
ok(type(gzip.compress(zmsg)) == "String", "gzip String -> String")
ok(gzip.decompress(gzip.compress(zby)) == zby, "gzip Bytes round-trip")
ok(type(gzip.compress(zby)) == "Bytes", "gzip Bytes -> Bytes")
# Aliases.
ok(gzip.gunzip(gzip.gzip(zby)) == zby, "gzip/gunzip aliases round-trip")
ok(gzip.gzip(zby) == gzip.compress(zby), "gzip alias == compress")
# Empty.
ok(gzip.decompress(gzip.compress("")) == "", "gzip empty round-trip")
# Header magic + CM.
var gz = gzip.compress(zby)
ok(gz[0] == 31 and gz[1] == 139 and gz[2] == 8, "gzip header magic + CM")
ok(gz[3] == 0, "gzip FLG = 0 from compress")
# ---- CRAFTED streams exercising the optional-field skipping (FEXTRA/FNAME/FCOMMENT/FHCRC) ----
# (No prior test drives these flags — compress() always emits FLG=0.) Build a valid body+trailer from
# compress(), then prepend a header with optional fields per RFC 1952 order: FEXTRA, FNAME, FCOMMENT, FHCRC.
var payload = "gzip-optional-fields"
var gbase = gzip.compress(payload.encode())   # Bytes: 10-byte header + deflate body + 8-byte trailer
var bodyTrailer = gbase[10:len(gbase)]
# FEXTRA (0x04) + FNAME (0x08): FLG = 0x0C.
var hdrEN = Bytes([31, 139, 8, 12, 0, 0, 0, 0, 0, 255])
var fextra = Bytes([2, 0, 65, 66])              # XLEN=2 (LE), then 2 bytes
var fname = "f.txt".encode() + Bytes([0])       # NUL-terminated
ok(gzip.decompress(hdrEN + fextra + fname + bodyTrailer).decode() == payload, "gzip decodes FEXTRA+FNAME stream")
# FCOMMENT (0x10) + FHCRC (0x02): FLG = 0x12, fields in RFC order (comment then 2-byte header CRC).
var hdrCH = Bytes([31, 139, 8, 18, 0, 0, 0, 0, 0, 255])
var fcomment = "c".encode() + Bytes([0])
var fhcrc = Bytes([1, 2])
ok(gzip.decompress(hdrCH + fcomment + fhcrc + bodyTrailer).decode() == payload, "gzip decodes FCOMMENT+FHCRC stream")
# All four optional fields at once: FLG = 0x1E.
var hdrAll = Bytes([31, 139, 8, 30, 0, 0, 0, 0, 0, 255])
var allFields = Bytes([1, 0, 77]) + ("nm".encode() + Bytes([0])) + ("cm".encode() + Bytes([0])) + Bytes([9, 9])
ok(gzip.decompress(hdrAll + allFields + bodyTrailer).decode() == payload, "gzip decodes all-optional-fields stream")
# A truncated FEXTRA (XLEN claims more bytes than present) throws (not a crash).
ok(throws(Function(): return gzip.decompress(hdrEN + Bytes([200, 0]) + bodyTrailer)), "gzip truncated FEXTRA throws")
# Multi-member: concatenated members decompress to the concatenation (gunzip semantics).
ok(gzip.decompress(gzip.compress("AA".encode()) + gzip.compress("BB".encode())).decode() == "AABB", "gzip multi-member concat")
# Trailing junk after a complete member is rejected (not silently ignored).
ok(throws(Function(): return gzip.decompress(gz + Bytes([1, 2, 3]))), "gzip trailing junk throws")
# Truncated / corrupt streams throw.
ok(throws(Function(): return gzip.decompress("not gzip at all")), "gzip garbage throws")
ok(throws(Function(): return gzip.decompress(gz[0:12])), "gzip truncated throws")
ok(throws(Function(): return gzip.decompress(Bytes([31, 139, 8]))), "gzip header-only throws")
# A flipped trailer byte (CRC/ISIZE) throws.
var gzt = gz[0:len(gz) - 1] + Bytes([(gz[len(gz) - 1] + 1) % 256])
ok(throws(Function(): return gzip.decompress(gzt)), "gzip corrupted trailer throws")
# Cross-container: neither decodes the other.
ok(throws(Function(): return gzip.decompress(zlib.compress(zby))), "gzip on zlib stream throws")
ok(throws(Function(): return zlib.decompress(gzip.compress(zby))), "zlib on gzip stream throws")
# kwargs.
ok(gzip.decompress(data = gzip.compress(data = "kw")) == "kw", "gzip kwargs data")

# =====================================================================================  time (determinism-safe)
# A FRESH fixed instant: 2030-12-31 23:59:58 UTC.
var dt = time.make(2030, 12, 31, 23, 59, 58)
ok(dt.iso() == "2030-12-31T23:59:58", "DateTime iso fresh instant")
ok(dt.isoformat() == dt.iso(), "isoformat alias")
ok(dt.year == 2030 and dt.month == 12 and dt.day == 31, "DateTime y/m/d")
ok(dt.hour == 23 and dt.minute == 59 and dt.second == 58, "DateTime h/m/s")
# 2030-12-31 is a Tuesday -> tm_wday = 2 (0=Sunday).
ok(dt.weekday == 2, "DateTime weekday (Tue=2)")
ok(dt.yearday == 365, "DateTime yearday (2030 not a leap year)")
ok(dt.format("%Y-%m-%dT%H:%M:%S") == dt.iso(), "DateTime format reproduces iso")
ok(dt.format("%j") == "365", "DateTime format day-of-year")
# datetime(epoch) reconstructs the same instant.
ok(time.datetime(dt.timestamp) == dt, "datetime(epoch) == make")
# make() with a Float component is rejected (params are Integer-typed).
ok(throws(Function(): return time.make(2024.5, 1, 1)), "make Float year throws")
ok(throws(Function(): return time.make(2024, 1, 1, 12.0)), "make Float hour throws")
# make() requires year/month/day; hour/minute/second default to 0.
ok(throws(Function(): return time.make(2024, 1)), "make missing day throws")
ok(time.make(2024, 7, 4).iso() == "2024-07-04T00:00:00", "make defaults hour/min/sec to 0")
# make() normalizes out-of-range components (mktime-style), does not throw.
ok(time.make(2024, 13, 1).iso() == "2025-01-01T00:00:00", "make month 13 rolls to next year")
ok(time.make(2024, 2, 30).month == 3, "make Feb 30 rolls into March")
# Negative (proleptic Gregorian) year is representable down to -9999.
var ancient = time.make(-44, 3, 15, 12, 0, 0)
ok(ancient.year == -44, "make negative year (proleptic)")
ok(ancient.timestamp < 0, "negative year has negative epoch")
ok(time.datetime(ancient.timestamp) == ancient, "negative-year epoch round-trips")
# The exact representable-epoch boundary: 9999-12-31T23:59:59 ok, one second past throws.
ok(time.datetime(253402300799).iso() == "9999-12-31T23:59:59", "epoch boundary 9999-12-31 ok")
ok(throws(Function(): return time.datetime(253402300800)), "epoch one past 9999 throws")
ok(time.datetime(-377705116800).year == -9999, "epoch lower bound -9999 ok")
# strptime round-trips make; single-digit fields are tolerated (num() reads up to width digits).
ok(time.strptime("2030-12-31 23:59:58", "%Y-%m-%d %H:%M:%S") == dt, "strptime round-trips make")
ok(time.strptime("2024-1-5", "%Y-%m-%d").month == 1, "strptime tolerates single-digit month")
ok(time.strptime("2024-1-5", "%Y-%m-%d").day == 5, "strptime tolerates single-digit day")
# strptime literal %% matches a literal percent in the text.
ok(time.strptime("12%", "%H%%").hour == 12, "strptime literal %% matches percent")
# strptime is strict on out-of-range / mismatch / trailing.
ok(throws(Function(): return time.strptime("2024-13-01", "%Y-%m-%d")), "strptime month 13 throws")
ok(throws(Function(): return time.strptime("2024-02-30", "%Y-%m-%d")), "strptime Feb 30 throws")
ok(throws(Function(): return time.strptime("2024-01-01 24:00:00", "%Y-%m-%d %H:%M:%S")), "strptime hour 24 throws")
ok(throws(Function(): return time.strptime("2024-01-01extra", "%Y-%m-%d")), "strptime trailing input throws")
ok(throws(Function(): return time.strptime("2024/01/01", "%Y-%m-%d")), "strptime separator mismatch throws")
ok(throws(Function(): return time.strptime("2024-01-01", "%Q")), "strptime unsupported directive throws")
# DateTime.format: empty fmt -> "", literal %% -> "%", unknown directive passes through (no crash).
ok(dt.format("") == "", "DateTime format empty string")
ok(dt.format("100%%") == "100%", "DateTime format literal %%")
ok(len(dt.format("%Q")) >= 0, "DateTime format unknown directive does not crash")
# Arithmetic: add/sub/diff.
ok(dt.add(1).second == 59, "DateTime add 1s")
ok(dt.add(2).iso() == "2031-01-01T00:00:00", "DateTime add 2s crosses year boundary")
ok(dt.sub(58).minute == 59 and dt.sub(58).second == 0, "DateTime sub 58s")
ok(dt.add(100).diff(dt) == 100, "DateTime diff forward")
ok(dt.diff(dt.add(100)) == -100, "DateTime diff backward signed")
# add() accepts a Float and truncates toward zero (1.9 -> 1, -1.9 -> -1).
ok(dt.add(1.9).second == 59, "DateTime add Float truncates (1.9 -> 1s)")
ok(dt.add(-1.9).second == 57, "DateTime add negative Float truncates (-1.9 -> -1s)")
# add/sub overflow and non-finite throw.
ok(throws(Function(): return dt.add(9223372036854775807)), "DateTime add overflow throws")
ok(throws(Function(): return dt.add(1e30)), "DateTime add huge Float throws")
ok(throws(Function(): return dt.add(math.inf)), "DateTime add inf throws")
ok(throws(Function(): return dt.add(math.nan)), "DateTime add NaN throws")
# diff requires a DateTime; add/sub require a number.
ok(throws(Function(): return dt.diff(5)), "DateTime diff non-DateTime throws")
ok(throws(Function(): return dt.add("x")), "DateTime add non-number throws")
# Value equality + hashing by instant.
var dA = time.make(2010, 5, 5, 5, 5, 5)
var dB = time.datetime(dA.timestamp)
ok(dA == dB, "DateTime equality by instant")
ok((dA == dt) == False, "DateTime inequality different instant")
var dmap = {}
dmap[dA] = "first"
dmap[dB] = "second"
ok(len(dmap) == 1 and dmap[dA] == "second", "DateTime equal instants are one Dict key (last wins)")
ok(len(Set([dA, dB, dt])) == 2, "DateTime equal instants collapse in a Set")
# DateTime serializes through both formats (by epoch) — fresh instant.
ok(dump.loads(dump.dumps(dt)) == dt, "DateTime dump round-trip")
ok(serialize.loads(serialize.dumps(dt)) == dt, "DateTime serialize round-trip")
ok(type(dump.loads(dump.dumps(dt))) == "DateTime", "DateTime keeps its type through dump")
# Clock invariants (NO exact wall-clock assertions).
ok(type(time.time()) == "Float", "time() -> Float")
ok(time.time() > 0.0, "time() positive")
ok(type(time.timens()) == "Integer", "timens() -> Integer")
ok(time.timens() > 0, "timens() positive")
ok(type(time.monotonic()) == "Float", "monotonic() -> Float")
var mo1 = time.monotonic()
var mo2 = time.monotonic()
ok(mo2 >= mo1, "monotonic non-decreasing")
ok(type(time.perfcounterns()) == "Integer", "perfcounterns() -> Integer")
var pn1 = time.perfcounterns()
var pn2 = time.perfcounterns()
ok(pn2 >= pn1, "perfcounterns non-decreasing")
# sleep(0) / sleep(negative) are no-ops returning None (do not sleep a real interval).
ok(time.sleep(0) == None, "sleep(0) returns None")
ok(time.sleep(-5) == None, "sleep negative no-op")
# now() / datetime() / datetime(None) yield a DateTime.
ok(type(time.now()) == "DateTime", "now() -> DateTime")
ok(type(time.datetime()) == "DateTime", "datetime() -> DateTime")
ok(type(time.datetime(None)) == "DateTime", "datetime(None) -> DateTime")
# datetime rejects NaN / infinity.
ok(throws(Function(): return time.datetime(math.nan)), "datetime(NaN) throws")
ok(throws(Function(): return time.datetime(-math.inf)), "datetime(-inf) throws")
# time.make / strptime kwargs (any order).
ok(time.make(second = 58, minute = 59, hour = 23, day = 31, month = 12, year = 2030) == dt, "time.make kwargs out of order")
ok(time.strptime(format = "%Y-%m-%d", text = "2010-05-05").iso() == "2010-05-05T00:00:00", "strptime kwargs")

# =====================================================================================  fuzz round-trips (deterministic)
# Random byte payloads through zlib / gzip / raw-deflate / dump round-trips — fixed seed, no clock.
var rrng = random.Random(31337)
var okZlib = True
var okGzip = True
var okRaw = True
var okDump = True
var fi = 0
while fi < 50:
    var sz = rrng.randint(0, 400)
    var arr = []
    var fj = 0
    while fj < sz:
        discard arr.append(rrng.randint(0, 255))
        fj = fj + 1
    var payld = Bytes(arr)
    if zlib.decompress(zlib.compress(payld)) != payld:
        okZlib = False
    if gzip.decompress(gzip.compress(payld)) != payld:
        okGzip = False
    if zlib.inflate(zlib.deflate(payld)) != payld:
        okRaw = False
    if dump.loads(dump.dumps(payld)) != payld:
        okDump = False
    fi = fi + 1
ok(okZlib, "fuzz: zlib round-trip on 50 random payloads")
ok(okGzip, "fuzz: gzip round-trip on 50 random payloads")
ok(okRaw, "fuzz: raw deflate/inflate on 50 random payloads")
ok(okDump, "fuzz: dump round-trip on 50 random payloads")
# Fuzz a nested struct of random scalars through BOTH serde formats AND json (json-safe scalars only).
var okStruct = True
var okJson = True
var si = 0
while si < 25:
    var d = {}
    var sj = 0
    var lim = rrng.randint(1, 7)
    while sj < lim:
        d[String(sj)] = [rrng.randint(-1000000, 1000000), rrng.random(), sj % 2 == 0, None]
        sj = sj + 1
    if serialize.loads(serialize.dumps(d)) != d or dump.loads(dump.dumps(d)) != d:
        okStruct = False
    if json.loads(json.dumps(d)) != d:
        okJson = False
    si = si + 1
ok(okStruct, "fuzz: nested struct round-trip (both serde formats)")
ok(okJson, "fuzz: nested struct round-trip (json)")

io.print("r8_serde_data: " + String(n) + " checks passed")
