# math module: numerical results against known baselines.
var io = import("io")
var math = import("math")

io.print(math.sqrt(144))         # 12.0
io.print(math.floor(3.99))       # 3
io.print(math.ceil(3.01))        # 4
io.print(math.factorial(6))      # 720
io.print(math.gcd(48, 36))       # 12
io.print(math.pow(2, 16))        # 65536.0
io.print(math.log2(1024))        # 10.0
io.print(math.gcd(17, 5))        # 1

var area = Function(r):
    return math.pi * r * r
io.print(area(1) > 3.14 and area(1) < 3.15)  # True
