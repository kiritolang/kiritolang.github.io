<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Kirito syntax highlighting for Notepad++ (User Defined Language) — DARK theme.

  Install:  Notepad++ -> Language -> User Defined Language -> Define your language... -> Import...
            -> pick this file -> restart Notepad++.  Then pick "Kirito (Dark)" from the Language menu.

  Use this file when Notepad++ is on a DARK theme; use kirito-light.xml on a LIGHT theme. Notepad++'s
  UDL cannot render a transparent background for the base text/operator styles (an unset background
  becomes a solid white box), so each file instead paints EVERY style's background to match its
  theme — seamless, with no coloured boxes behind the text. The foreground palette here is tuned for
  a dark (~#1E1E1E) editor background.

  Coverage: keywords + logical operators, True/False/None/self, the built-in types, the builtin
  functions, the dunder/special methods, the standard-library module names, # line comments, decimal/
  hex/octal/binary/float numbers, and string literals in single- and double-quote forms incl. the
  f"" / f'' f-string and r"" raw flavours. (Notepad++'s UDL has no concept of triple-quoted strings;
  those are highlighted only line-by-line here — the VS Code grammar handles them fully.)
-->
<NotepadPlus>
    <UserLang name="Kirito (Dark)" ext="ki" udlVersion="2.1">
        <Settings>
            <Global caseIgnored="no" allowFoldOfComments="no" foldCompact="no" forcePureLC="0" decimalSeparator="0" />
            <Prefix Keywords1="no" Keywords2="no" Keywords3="no" Keywords4="no" Keywords5="no" Keywords6="no" Keywords7="no" Keywords8="no" />
        </Settings>
        <KeywordLists>
            <Keywords name="Comments">00# 01 02 03 04</Keywords>
            <Keywords name="Numbers, prefix1">0x 0X 0o 0O 0b 0B</Keywords>
            <Keywords name="Numbers, prefix2"></Keywords>
            <Keywords name="Numbers, extras1">.</Keywords>
            <Keywords name="Numbers, extras2">e E _ a b c d f A B C D F</Keywords>
            <Keywords name="Numbers, suffix1"></Keywords>
            <Keywords name="Numbers, suffix2"></Keywords>
            <Keywords name="Numbers, range">+ -</Keywords>
            <Keywords name="Operators1">+ - * / % = &lt; &gt; ! : ( ) [ ] { } , . | &amp;</Keywords>
            <Keywords name="Operators2"></Keywords>
            <Keywords name="Folders in code1, open"></Keywords>
            <Keywords name="Folders in code1, middle"></Keywords>
            <Keywords name="Folders in code1, close"></Keywords>
            <Keywords name="Folders in code2, open"></Keywords>
            <Keywords name="Folders in code2, middle"></Keywords>
            <Keywords name="Folders in code2, close"></Keywords>
            <Keywords name="Folders in comment, open"></Keywords>
            <Keywords name="Folders in comment, middle"></Keywords>
            <Keywords name="Folders in comment, close"></Keywords>
            <Keywords name="Keywords1">and as assert break case catch class continue default discard elif else finally for if in not or pass return switch throw todo try var while with Function</Keywords>
            <Keywords name="Keywords2">True False None self</Keywords>
            <Keywords name="Keywords3">Any Array Bool Bytes Dict Float Integer List Set String</Keywords>
            <Keywords name="Keywords4">abs all any bin bitand bitnot bitor bitxor chr divmod enumerate filter format fromhex hasattr hex id import inspect isinstance len map max min oct ord pow range reversed round shl shr sorted sum type zip</Keywords>
            <Keywords name="Keywords5">_init_ _str_ _add_ _sub_ _mul_ _div_ _floordiv_ _mod_ _pow_ _eq_ _ne_ _lt_ _le_ _gt_ _ge_ _neg_ _not_ _bool_ _call_ _getitem_ _setitem_ _len_ _contains_ _iter_ _enter_ _exit_ _hash_ _super_ _getstate_ _setstate_</Keywords>
            <Keywords name="Keywords6">io math random tensor matrix complex json serialize dump net sys time zlib gzip hash regex parallel itertools functools collections statistics string textwrap base64 csv tabular xml heapq bisect copy enum tee arg semver</Keywords>
            <Keywords name="Keywords7"></Keywords>
            <Keywords name="Keywords8"></Keywords>
            <Keywords name="Delimiters">00&quot; 01\ 02&quot; 03f&quot; 04\ 05&quot; 06&apos; 07\ 08&apos; 09f&apos; 10\ 11&apos; 12r&quot; 13 14&quot; 15r&apos; 16 17&apos; 18 19 20 21 22 23</Keywords>
        </KeywordLists>
        <Styles>
            <!-- Every style shares the dark background (1E1E1E) so nothing draws a box. -->
            <WordsStyle name="DEFAULT" fgColor="D4D4D4" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="OPERATORS" fgColor="D4D4D4" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="COMMENTS" fgColor="6A9955" bgColor="1E1E1E" fontStyle="2" nesting="0" />
            <WordsStyle name="LINE COMMENTS" fgColor="6A9955" bgColor="1E1E1E" fontStyle="2" nesting="0" />
            <WordsStyle name="NUMBERS" fgColor="B5CEA8" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS1" fgColor="C586C0" bgColor="1E1E1E" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS2" fgColor="569CD6" bgColor="1E1E1E" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS3" fgColor="4EC9B0" bgColor="1E1E1E" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS4" fgColor="DCDCAA" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS5" fgColor="4FC1FF" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS6" fgColor="4EC9B0" bgColor="1E1E1E" fontStyle="2" nesting="0" />
            <WordsStyle name="DELIMITERS1" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS2" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS3" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS4" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS5" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS6" fgColor="CE9178" bgColor="1E1E1E" fontStyle="0" nesting="0" />
        </Styles>
    </UserLang>
</NotepadPlus>
